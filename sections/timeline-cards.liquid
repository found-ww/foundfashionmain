{%- assign total = section.blocks.size -%}

<div id="section-{{ section.id }}" class="Section TimelineCards" data-section-id="{{ section.id }}" data-section-type="timeline-cards">

  {%- if section.settings.heading != blank -%}
    <div class="TimelineCards__Header">
      <p class="TimelineCards__Label">{{ section.settings.heading }}</p>
    </div>
  {%- endif -%}

  <div class="TimelineCards__Block">

    <div class="tc-prog"><div class="tc-prog-fill" id="tc-pf-{{ section.id }}"></div></div>

    <div class="tc-track-wrap" id="tc-tw-{{ section.id }}">
      <div class="tc-track" id="tc-track-{{ section.id }}">

        {%- for block in section.blocks -%}
          {%- assign card_num = forloop.index | prepend: '0' | slice: -2, 2 -%}
          {%- assign total_num = total | prepend: '0' | slice: -2, 2 -%}
          <div class="tc-card" {{ block.shopify_attributes }}>
            <span class="tc-card-num">{{ card_num }} / {{ total_num }}</span>
            {%- if block.settings.date != blank -%}
              <div class="tc-card-date">{{ block.settings.date }}</div>
            {%- endif -%}
            <div class="tc-card-rule"></div>
            {%- if block.settings.tag != blank -%}
              <span class="tc-card-tag">{{ block.settings.tag }}</span>
            {%- endif -%}
            {%- if block.settings.headline != blank -%}
              <h3 class="tc-card-h">{{ block.settings.headline }}</h3>
            {%- endif -%}
            {%- if block.settings.body != blank -%}
              <p class="tc-card-p">{{ block.settings.body }}</p>
            {%- endif -%}
          </div>
        {%- else -%}
          <div class="tc-card">
            <span class="tc-card-num">01 / 01</span>
            <div class="tc-card-date">2024</div>
            <div class="tc-card-rule"></div>
            <span class="tc-card-tag">Add cards</span>
            <h3 class="tc-card-h">Add cards in the theme editor</h3>
            <p class="tc-card-p">Use the "Add card" button in the theme editor to populate this timeline.</p>
          </div>
        {%- endfor -%}

      </div>
    </div>

    <div class="tc-foot" id="tc-foot-{{ section.id }}">
      {%- for block in section.blocks -%}
        <div class="tc-foot-dot{% if forloop.first %} active{% endif %}" data-i="{{ forloop.index0 }}"></div>
      {%- else -%}
        <div class="tc-foot-dot active" data-i="0"></div>
      {%- endfor -%}
      <span class="tc-foot-hint">Drag to explore</span>
    </div>

  </div>

</div>

<style>
  /* ── Header ── */
  .TimelineCards__Header {
    text-align: center;
    padding: 48px 24px 0;
  }
  .TimelineCards__Label {
    font-size: 10px;
    letter-spacing: .22em;
    text-transform: uppercase;
    color: rgb(128,111,100);
    opacity: .6;
  }

  /* ── Block ── */
  .TimelineCards__Block {
    display: flex;
    flex-direction: column;
    height: 460px;
    overflow: hidden;
    margin: 32px 0 0;
    border-top: .5px solid rgba(128,111,100,.15);
    border-bottom: .5px solid rgba(128,111,100,.15);
  }

  /* ── Progress bar ── */
  .tc-prog {
    height: 1px;
    background: rgba(128,111,100,.12);
    flex-shrink: 0;
    position: relative;
  }
  .tc-prog-fill {
    position: absolute;
    top: 0; left: 0;
    height: 100%; width: 0;
    background: rgb(128,111,100);
    transition: width .05s linear;
  }

  /* ── Draggable track ── */
  .tc-track-wrap {
    flex: 1;
    overflow: hidden;
    cursor: grab;
    position: relative;
  }
  .tc-track-wrap:active { cursor: grabbing; }
  .tc-track {
    display: flex;
    height: 100%;
    width: max-content;
    user-select: none;
  }

  /* ── Card ── */
  .tc-card {
    flex-shrink: 0;
    width: clamp(280px, 32vw, 420px);
    height: 100%;
    border-right: .5px solid rgba(128,111,100,.15);
    padding: 3rem;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 1rem;
    background: #fff;
    transition: background .35s;
    position: relative;
    overflow: hidden;
  }
  .tc-card:hover { background: rgb(245,243,239); }

  /* card number */
  .tc-card-num {
    position: absolute;
    top: 2.5rem; right: 2.5rem;
    font-size: 9px;
    letter-spacing: .22em;
    text-transform: uppercase;
    color: rgb(128,111,100);
    opacity: .35;
  }

  /* date */
  .tc-card-date {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 300;
    font-style: italic;
    color: rgb(128,111,100);
    line-height: 1;
    transition: letter-spacing .4s cubic-bezier(.16,1,.3,1);
  }
  .tc-card:hover .tc-card-date { letter-spacing: .03em; }

  /* rule */
  .tc-card-rule {
    width: 28px;
    height: .5px;
    background: rgba(128,111,100,.2);
    transition: width .4s cubic-bezier(.16,1,.3,1), background .3s;
  }
  .tc-card:hover .tc-card-rule { width: 50px; background: rgb(128,111,100); }

  /* tag */
  .tc-card-tag {
    font-size: 9px;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: rgb(128,111,100);
    opacity: .5;
    transition: opacity .3s;
  }
  .tc-card:hover .tc-card-tag { opacity: 1; }

  /* headline */
  .tc-card-h {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(18px, 2.2vw, 24px);
    font-weight: 300;
    font-style: italic;
    color: rgb(18,16,14);
    line-height: 1.15;
    transition: transform .45s cubic-bezier(.16,1,.3,1), color .3s;
  }
  .tc-card:hover .tc-card-h { transform: translateX(7px); color: rgb(128,111,100); }

  /* body */
  .tc-card-p {
    font-size: 12px;
    line-height: 1.78;
    color: rgb(148,123,105);
  }

  /* bottom sweep */
  .tc-card::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 1px;
    background: rgb(128,111,100);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform .5s cubic-bezier(.16,1,.3,1);
  }
  .tc-card:hover::after { transform: scaleX(1); }

  /* ── Footer ── */
  .tc-foot {
    height: 38px;
    border-top: .5px solid rgba(128,111,100,.15);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 0 2.5rem;
  }
  .tc-foot-dot {
    width: 5px; height: 5px;
    border-radius: 50%;
    background: rgba(128,111,100,.2);
    cursor: pointer;
    transition: background .2s, transform .2s;
    flex-shrink: 0;
  }
  .tc-foot-dot.active,
  .tc-foot-dot:hover { background: rgb(128,111,100); transform: scale(1.5); }
  .tc-foot-hint {
    margin-left: auto;
    font-size: 9px;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: rgb(128,111,100);
    opacity: .3;
  }

  /* ── Mobile ── */
  @media screen and (max-width: 640px) {
    .TimelineCards__Block { height: auto; }
    .tc-track-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; height: 380px; }
    .tc-card { width: 84vw; padding: 2.5rem 2rem; }
  }
</style>

<script>
(function(){
  var sid   = '{{ section.id }}';
  var tw    = document.getElementById('tc-tw-'    + sid);
  var track = document.getElementById('tc-track-' + sid);
  var pf    = document.getElementById('tc-pf-'   + sid);
  if (!tw || !track) return;

  var dots  = tw.closest('.TimelineCards__Block').querySelectorAll('.tc-foot-dot');
  var cards = track.querySelectorAll('.tc-card');
  var isDragging = false, startX = 0, tx = 0, animTx = 0, raf;

  function lerp(a, b, n) { return a + (b - a) * n; }
  function maxTx() { return -(track.scrollWidth - tw.clientWidth); }
  function clamp(v) { return Math.max(maxTx(), Math.min(0, v)); }

  function render() {
    track.style.transform = 'translateX(' + animTx + 'px)';
    var max = -maxTx();
    pf.style.width = (max > 0 ? Math.min(100, (-animTx / max) * 100) : 0) + '%';
    var cw  = cards[0] ? cards[0].offsetWidth : 1;
    var idx = Math.round(-animTx / cw);
    dots.forEach(function(d, i) { d.classList.toggle('active', i === idx); });
  }

  function loop() {
    animTx = lerp(animTx, tx, .1);
    if (Math.abs(animTx - tx) > 0.1) { render(); raf = requestAnimationFrame(loop); }
    else { animTx = tx; render(); }
  }

  /* Mouse drag */
  tw.addEventListener('mousedown', function(e) {
    isDragging = true; startX = e.pageX;
    cancelAnimationFrame(raf);
  });
  window.addEventListener('mousemove', function(e) {
    if (!isDragging) return;
    tx = clamp(tx + (e.pageX - startX)); startX = e.pageX; render();
  });
  window.addEventListener('mouseup', function() { isDragging = false; });

  /* Touch */
  tw.addEventListener('touchstart', function(e) {
    startX = e.touches[0].pageX; cancelAnimationFrame(raf);
  }, { passive: true });
  tw.addEventListener('touchmove', function(e) {
    tx = clamp(tx + (e.touches[0].pageX - startX)); startX = e.touches[0].pageX; render();
  }, { passive: true });

  /* Dot navigation */
  dots.forEach(function(d) {
    d.addEventListener('click', function() {
      tx = clamp(-(cards[0] ? cards[0].offsetWidth * parseInt(d.dataset.i) : 0));
      cancelAnimationFrame(raf);
      raf = requestAnimationFrame(loop);
    });
  });

  window.addEventListener('resize', function() { tx = clamp(tx); render(); });
  render();
})();
</script>

{% schema %}
{
  "name": "Timeline Cards",
  "tag": "section",
  "class": "section",
  "max_blocks": 12,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section label",
      "default": "Timeline"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "text",
          "id": "date",
          "label": "Year / Date",
          "default": "2024"
        },
        {
          "type": "text",
          "id": "tag",
          "label": "Tag",
          "default": "Milestone"
        },
        {
          "type": "text",
          "id": "headline",
          "label": "Headline"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Body"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Timeline Cards",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "date": "2020",
            "tag": "Origin",
            "headline": "The beginning",
            "body": "Describe this milestone here."
          }
        },
        {
          "type": "card",
          "settings": {
            "date": "2022",
            "tag": "Growth",
            "headline": "Expanding the range",
            "body": "Describe this milestone here."
          }
        },
        {
          "type": "card",
          "settings": {
            "date": "2024",
            "tag": "Present",
            "headline": "Where we are today",
            "body": "Describe this milestone here."
          }
        }
      ]
    }
  ]
}
{% endschema %}
