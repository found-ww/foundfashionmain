{%- assign sid = section.id -%}

<style>
  /* ── Hero ── */
  .ps-hero {
    position: relative;
    width: 100%;
    height: 60vh;
    min-height: 400px;
    overflow: hidden;
  }
  .ps-hero__img {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
  }
  .ps-hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.32);
  }
  .ps-hero__content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    padding: 0 24px 72px;
    text-align: center;
    color: #fff;
  }
  .ps-hero__eyebrow {
    font-size: 10px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    opacity: 0.7;
    margin-bottom: 20px;
  }
  .ps-hero__title {
    font-size: clamp(2.2rem, 5vw, 4rem);
    font-weight: 400;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    line-height: 1.1;
    margin: 0 0 20px;
    max-width: 700px;
  }
  /* Hero word-by-word reveal */
  .ps-hero__word {
    display: inline-block;
    opacity: 0;
    transform: translateY(18px);
    transition: opacity 0.6s cubic-bezier(0.16,1,0.3,1), transform 0.6s cubic-bezier(0.16,1,0.3,1);
  }
  .ps-hero__word.ps--in {
    opacity: 1;
    transform: translateY(0);
  }
  .ps-hero__sub {
    font-size: clamp(13px, 1.2vw, 15px);
    font-weight: 300;
    letter-spacing: 0.04em;
    opacity: 0;
    max-width: 480px;
    line-height: 1.7;
    margin: 0;
    transform: translateY(12px);
    transition: opacity 0.7s 0.5s cubic-bezier(0.16,1,0.3,1), transform 0.7s 0.5s cubic-bezier(0.16,1,0.3,1);
  }
  .ps-hero__sub.ps--in {
    opacity: 0.85;
    transform: translateY(0);
  }

  /* ── Intro ── */
  .ps-intro {
    padding: 80px 24px;
    text-align: center;
    background: #faf9f7;
  }
  .ps-intro__text {
    max-width: 620px;
    margin: 0 auto;
    font-size: clamp(15px, 1.4vw, 18px);
    font-weight: 300;
    line-height: 1.75;
    color: #2a2420;
    letter-spacing: 0.01em;
  }

  /* ── Process ── */
  .ps-process {
    padding: 80px 24px;
    background: #faf9f7;
  }
  .ps-process__label {
    text-align: center;
    font-size: 16px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #9a8f86;
    margin-bottom: 56px;
  }
  .ps-process__steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    column-gap: 1px;
    background: #e5e0da;
    max-width: 960px;
    margin: 0 auto;
  }
  .ps-step {
    background: #fff;
    padding: 40px;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s cubic-bezier(0.16,1,0.3,1), transform 0.4s cubic-bezier(0.16,1,0.3,1), box-shadow 0.4s cubic-bezier(0.16,1,0.3,1);
    cursor: default;
  }
  .ps-step.ps--in {
    opacity: 1;
    transform: translateY(0);
  }
  .ps-step.ps--in:hover {
    transform: translateY(-8px) scale(1.03);
    box-shadow: 0 16px 40px rgba(0,0,0,0.07);
    position: relative;
    z-index: 1;
  }
  .ps-step.ps--in:hover .ps-step__num {
    color: #8a7268;
  }
  .ps-step__num {
    font-size: 12px;
    letter-spacing: 0.2em;
    color: #b5ada5;
    margin-bottom: 20px;
    display: block;
    transition: color 0.3s;
  }
  .ps-step__title {
    font-size: 13px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #1c1c1c;
    font-weight: 400;
    margin-bottom: 14px;
  }
  .ps-step__body {
    font-size: 14px;
    font-weight: 300;
    line-height: 1.75;
    color: #6b6259;
  }

  /* ── Trust bar ── */
  .ps-trust {
    padding: 48px 24px;
    background: #1c1c1c;
  }
  .ps-trust__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    max-width: 900px;
    margin: 0 auto;
  }
  .ps-trust__item {
    flex: 1;
    text-align: center;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.75);
    padding: 0 32px;
    border-right: 0.5px solid rgba(255,255,255,0.15);
  }
  .ps-trust__item:last-child {
    border-right: none;
  }

  /* ── Sourcing split layout ── */
  .ps-sourcing {
    display: flex;
    position: relative;
  }
  .ps-sourcing::after {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 40%;
    bottom: 0;
    background: #fff;
    z-index: 0;
  }
  .ps-sourcing__grid {
    flex: 0 0 60%;
    padding: 40px;
    background: #fff;
    position: relative;
    z-index: 1;
  }
  .ps-sourcing__form {
    flex: 0 0 40%;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 56px 36px;
    background: transparent;
    position: relative;
    z-index: 1;
  }
  .ps-sourcing__form-inner {
    width: 100%;
    max-width: 400px;
    position: sticky;
    top: 32px;
  }

  /* Grid tiles */
  .ps-sourcing__tiles {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
  }
  .ps-stile {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: #f0ece7;
    display: block;
    text-decoration: none;
    cursor: pointer;
  }
  .ps-stile__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s cubic-bezier(0.16,1,0.3,1);
  }
  .ps-stile:hover .ps-stile__img { transform: scale(1.05); }
  .ps-stile__hover {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    padding: 0 14px 18px;
    background: linear-gradient(to top, rgba(0,0,0,0.55) 0%, transparent 60%);
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.3s ease, transform 0.3s ease;
    pointer-events: none;
  }
  .ps-stile:hover .ps-stile__hover {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  .ps-stile__name {
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #fff;
    text-align: center;
    margin-bottom: 10px;
    line-height: 1.4;
  }
  .ps-stile__btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(255,255,255,0.92);
    border: none;
    padding: 8px 14px;
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #1c1c1c;
    font-family: inherit;
    cursor: pointer;
    font-weight: 500;
    transition: background 0.2s;
    white-space: nowrap;
  }
  .ps-stile__btn:hover { background: #fff; }
  .ps-stile__btn.is-added {
    background: rgba(28,28,28,0.88);
    color: #fff;
  }
  .ps-stile--empty { cursor: default; }
  .ps-stile--empty::after {
    content: '';
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%,-50%);
    width: 20px; height: 20px;
    border: 1px solid #c8c0b8;
    border-radius: 50%;
  }

  /* Form elements */
  .ps-form-wrap {
    padding: 80px 24px 100px;
    background: #faf9f7;
  }
  .ps-form-inner {
    max-width: 560px;
    margin: 0 auto;
  }
  .ps-form__eyebrow {
    font-size: 10px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: #9a8f86;
    text-align: center;
    margin-bottom: 12px;
  }
  .ps-form__title {
    font-size: 22px;
    letter-spacing: 0.06em;
    font-weight: 400;
    text-transform: uppercase;
    color: #1c1c1c;
    margin-bottom: 8px;
  }
  .ps-form__subtitle {
    font-size: 13px;
    color: #6b6259;
    line-height: 1.65;
    margin-bottom: 28px;
  }
  .ps-field {
    position: relative;
    margin-bottom: 16px;
  }
  .ps-field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-bottom: 16px;
  }
  .ps-field-row .ps-field { margin-bottom: 0; }
  .ps-input,
  .ps-textarea {
    width: 100%;
    border: 1px solid #e0dbd5;
    background: #fff;
    padding: 20px 16px 8px;
    font-size: 14px;
    color: #3d3530;
    font-family: inherit;
    outline: none;
    transition: border-color 0.2s;
    display: block;
    box-sizing: border-box;
    border-radius: 0;
    appearance: none;
  }
  .ps-textarea {
    resize: vertical;
    min-height: 100px;
  }
  .ps-input:focus,
  .ps-textarea:focus { border-color: #9a8f86; }
  .ps-label {
    position: absolute;
    left: 16px;
    top: 14px;
    font-size: 14px;
    color: #b5ada5;
    pointer-events: none;
    transition: top 0.15s, font-size 0.15s, color 0.15s, letter-spacing 0.15s;
    font-family: inherit;
  }
  .ps-input:focus ~ .ps-label,
  .ps-input:not(:placeholder-shown) ~ .ps-label,
  .ps-textarea:focus ~ .ps-label,
  .ps-textarea:not(:placeholder-shown) ~ .ps-label {
    top: 6px;
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #9a8f86;
  }
  .ps-select-wrap {
    position: relative;
  }
  .ps-select-chevron {
    position: absolute;
    right: 14px;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
    color: #9a8f86;
  }
  .ps-submit {
    width: 100%;
    background: #1c1c1c;
    color: #fff;
    border: none;
    padding: 16px 24px;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 500;
    font-family: inherit;
    cursor: pointer;
    margin-top: 8px;
    transition: background 0.2s;
  }
  .ps-submit:hover { background: #3d3530; }
  .ps-form__note {
    font-size: 11px;
    letter-spacing: 0.06em;
    color: #9a8f86;
    text-align: center;
    margin-top: 16px;
  }
  .ps-form__success {
    padding: 48px 0;
    text-align: center;
  }
  .ps-form__success-mark {
    width: 40px;
    height: 40px;
    border: 1px solid #c8c0b8;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
    color: #9a8f86;
  }
  .ps-form__success-title {
    font-size: 16px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 400;
    color: #1c1c1c;
    margin-bottom: 10px;
  }
  .ps-form__success-note {
    font-size: 13px;
    color: #9a8f86;
    line-height: 1.6;
  }

  /* ── FAQ ── */
  .ps-faq {
    padding: 100px 24px;
    background: #fff;
  }
  .ps-faq__head {
    text-align: center;
    margin-bottom: 72px;
  }
  .ps-faq__eyebrow {
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #9a8f86;
    margin-bottom: 18px;
  }
  .ps-faq__title {
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 400;
    color: #1c1c1c;
    margin: 0;
  }
  .ps-faq__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: 64px;
    row-gap: 48px;
    max-width: 1100px;
    margin: 0 auto;
  }
  .ps-faq__item {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.5s cubic-bezier(0.16,1,0.3,1), transform 0.5s cubic-bezier(0.16,1,0.3,1);
  }
  .ps-faq__item.ps--in {
    opacity: 1;
    transform: translateY(0);
  }
  .ps-faq__num {
    font-size: 11px;
    letter-spacing: 0.18em;
    color: #b5ada5;
    margin-bottom: 10px;
    display: block;
  }
  .ps-faq__q {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 500;
    color: #1c1c1c;
    margin-bottom: 14px;
  }
  .ps-faq__divider {
    width: 100%;
    height: 0.5px;
    background: #e0dbd5;
    margin-bottom: 18px;
  }
  .ps-faq__a {
    font-size: 14px;
    font-weight: 300;
    line-height: 1.8;
    color: #6b6259;
  }

  /* ── Mobile ── */
  @media screen and (max-width: 767px) {
    .ps-hero { height: 50vh; min-height: 320px; }
    .ps-hero__content { padding-bottom: 48px; }
    .ps-intro { padding: 60px 24px; }
    .ps-process { padding: 60px 24px; }
    .ps-process__steps { grid-template-columns: 1fr; column-gap: 0; row-gap: 1px; }
    .ps-step { padding: 36px 24px; }
    .ps-trust__inner { flex-direction: column; gap: 24px; }
    .ps-trust__item { border-right: none; padding: 0; }
    .ps-faq { padding: 72px 24px; }
    .ps-faq__grid { grid-template-columns: 1fr; gap: 36px; }
  }
  @media screen and (max-width: 989px) {
    .ps-sourcing { flex-direction: column; }
    .ps-sourcing::after { width: 100%; top: auto; height: 50%; }
    .ps-sourcing__grid,
    .ps-sourcing__form { padding: 40px 24px; }
    .ps-sourcing__form-inner { position: static; }
    .ps-sourcing__tiles { gap: 6px; }
    .ps-field-row { grid-template-columns: 1fr; }
  }

  /* WhatsApp row */
  .ps-sourcing__wa-row {
    display: flex;
    margin-bottom: 16px;
  }
  .ps-sourcing__cc {
    flex: 0 0 auto;
    border: 1px solid #e0dbd5;
    border-right: none;
    background: #fff;
    padding: 14px 28px 14px 12px;
    font-size: 14px;
    color: #3d3530;
    font-family: inherit;
    outline: none;
    appearance: none;
    cursor: pointer;
    background-image: url("data:image/svg+xml,%3Csvg width='10' height='6' viewBox='0 0 10 6' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1L5 5L9 1' stroke='%239a8f86' stroke-width='1.2' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 8px center;
    transition: border-color 0.2s;
    min-width: 90px;
    border-radius: 0;
  }
  .ps-sourcing__cc:focus { border-color: #9a8f86; outline: none; }
  .ps-sourcing__wa-num {
    flex: 1;
    border: 1px solid #e0dbd5;
    background: #fff;
    padding: 14px 16px;
    font-size: 14px;
    color: #3d3530;
    font-family: inherit;
    outline: none;
    transition: border-color 0.2s;
    border-radius: 0;
  }
  .ps-sourcing__wa-num:focus { border-color: #9a8f86; }
  .ps-sourcing__wa-num::placeholder { color: #b5ada5; }

  /* Country select */
  .ps-sourcing__select-wrap {
    position: relative;
    margin-bottom: 16px;
  }
  .ps-sourcing__select {
    width: 100%;
    border: 1px solid #e0dbd5;
    background: #fff;
    padding: 14px 40px 14px 16px;
    font-size: 14px;
    color: #3d3530;
    font-family: inherit;
    outline: none;
    transition: border-color 0.2s;
    display: block;
    box-sizing: border-box;
    appearance: none;
    cursor: pointer;
    border-radius: 0;
  }
  .ps-sourcing__select:focus { border-color: #9a8f86; }
  .ps-sourcing__select option[value=""] { color: #b5ada5; }

  /* File upload */
  .ps-field--file {
    border: 1px dashed #d4cdc6;
    background: #fff;
    padding: 14px 16px;
    cursor: pointer;
    transition: border-color 0.2s;
  }
  .ps-field--file:hover { border-color: #9a8f86; }
  .ps-file-label {
    display: flex;
    align-items: center;
    justify-content: space-between;
    cursor: pointer;
  }
  .ps-file-label__text { font-size: 14px; color: #b5ada5; }
  .ps-file-label__hint { font-size: 10px; letter-spacing: 0.08em; color: #c8c0b8; text-transform: uppercase; }
  .ps-file-input {
    position: absolute;
    inset: 0;
    opacity: 0;
    width: 100%;
    height: 100%;
    cursor: pointer;
  }
  .ps-field--file.has-file .ps-file-label__text { color: #3d3530; }

  /* Validation */
  .ps-input.ps-error,
  .ps-textarea.ps-error,
  .ps-sourcing__select.ps-error { border-color: #c0392b; }
  .ps-field__error {
    font-size: 11px;
    color: #c0392b;
    margin-top: 4px;
    letter-spacing: 0.04em;
    display: block;
  }

  /* Image previews */
  .ps-image-previews {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 10px;
  }
  .ps-image-preview {
    position: relative;
    width: 64px;
    height: 64px;
    border: 1px solid #e0dbd5;
  }
  .ps-image-preview img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .ps-image-preview__remove {
    position: absolute;
    top: -6px;
    right: -6px;
    width: 18px;
    height: 18px;
    background: #1c1c1c;
    color: #fff;
    border: none;
    border-radius: 50%;
    font-size: 11px;
    line-height: 18px;
    text-align: center;
    cursor: pointer;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
</style>

{%- comment -%} ── Hero ── {%- endcomment -%}
<div class="ps-hero">
  {%- if section.settings.hero_image -%}
    <div class="ps-hero__img Image--lazyLoad Image--zoomOut"
         data-optimumx="1.4"
         data-expand="-150"
         style="background-image: url({{ section.settings.hero_image | img_url: '1x1' }})"
         data-bgset="{{ section.settings.hero_image | img_url: '750x' }} 750w, {{ section.settings.hero_image | img_url: '1200x' }} 1200w, {{ section.settings.hero_image | img_url: '1800x' }} 1800w">
    </div>
    <noscript>
      <div class="ps-hero__img" style="background-image: url({{ section.settings.hero_image | img_url: '1200x' }})"></div>
    </noscript>
  {%- else -%}
    <div class="ps-hero__img" style="background: #2a2420;"></div>
  {%- endif -%}
  <div class="ps-hero__overlay"></div>
  <div class="ps-hero__content">
    {%- if section.settings.hero_eyebrow != blank -%}
      <p class="ps-hero__eyebrow">{{ section.settings.hero_eyebrow }}</p>
    {%- endif -%}
    <h1 class="ps-hero__title" data-ps-title>{{ section.settings.hero_title | default: 'Personal Shopping' }}</h1>
    {%- if section.settings.hero_sub != blank -%}
      <p class="ps-hero__sub" data-ps-sub>{{ section.settings.hero_sub }}</p>
    {%- endif -%}
  </div>
</div>

{%- comment -%} ── Intro ── {%- endcomment -%}
{%- if section.settings.intro_text != blank -%}
  <div class="ps-intro">
    <p class="ps-intro__text">{{ section.settings.intro_text }}</p>
  </div>
{%- endif -%}

{%- comment -%} ── Sourcing split: grid + form ── {%- endcomment -%}
<div class="ps-sourcing" id="submit-request">

  {%- comment -%} LEFT: product grid {%- endcomment -%}
  <div class="ps-sourcing__grid">
    {%- if collections['sourcing'] != blank -%}
      {%- assign sourcing_pool = collections['sourcing'].products -%}
    {%- elsif collections['Sourcing'] != blank -%}
      {%- assign sourcing_pool = collections['Sourcing'].products -%}
    {%- else -%}
      {%- assign sourcing_pool = collections.all.products -%}
    {%- endif -%}
    <div class="ps-sourcing__tiles" id="ps-sourcing-grid">
      {%- assign rendered = 0 -%}
      {%- for product in sourcing_pool -%}
        {%- assign product_tags_down = product.tags | join: ',' | downcase -%}
        {%- unless product_tags_down contains 'sourcing' -%}{%- continue -%}{%- endunless -%}
        {%- if rendered >= 12 -%}{%- break -%}{%- endif -%}
        {%- assign rendered = rendered | plus: 1 -%}
        <div class="ps-stile"
          data-product-title="{{ product.title | escape }}"
          data-product-handle="{{ product.handle }}"
          data-product-type="{{ product.type | escape }}"
          data-product-brand="{{ product.metafields.custom.brand_name.value | first | default: product.metafields.custom.brand_name.value | escape }}">
          {%- if product.featured_image -%}
            <img class="ps-stile__img"
              src="{{ product.featured_image | img_url: '600x600', crop: 'center' }}"
              srcset="{{ product.featured_image | img_url: '300x300', crop: 'center' }} 300w,
                      {{ product.featured_image | img_url: '600x600', crop: 'center' }} 600w"
              sizes="(max-width: 989px) 33vw, 20vw"
              alt="{{ product.title | escape }}" loading="lazy">
