      {%- assign step_body  = section.settings[step_body_key] -%}
      {%- if step_title != blank or step_body != blank -%}
        <div class="ps-step">
          <span class="ps-step__num">0{{ i }}</span>
          {%- if step_title != blank -%}<p class="ps-step__title">{{ step_title }}</p>{%- endif -%}
          {%- if step_body != blank -%}<p class="ps-step__body">{{ step_body }}</p>{%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

{%- comment -%} ── FAQ ── {%- endcomment -%}
