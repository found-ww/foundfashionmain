    {%- for i in (1..6) -%}
      {%- assign faq_q_key = 'faq_' | append: i | append: '_q' -%}
      {%- assign faq_a_key = 'faq_' | append: i | append: '_a' -%}
      {%- assign faq_q = section.settings[faq_q_key] -%}
      {%- assign faq_a = section.settings[faq_a_key] -%}
      {%- if faq_q != blank or faq_a != blank -%}
        <div class="ps-faq__item">
          <span class="ps-faq__num">0{{ i }}</span>
          {%- if faq_q != blank -%}<p class="ps-faq__q">{{ faq_q }}</p>{%- endif -%}
          <div class="ps-faq__divider"></div>
          {%- if faq_a != blank -%}<p class="ps-faq__a">{{ faq_a }}</p>{%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

<script>
(function () {
  /* ── 1. Hero word reveal + cursor scale ── */
  var titleEl = document.querySelector('[data-ps-title]');
  var subEl   = document.querySelector('[data-ps-sub]');
  var heroEl  = document.querySelector('.ps-hero');

  if (titleEl) {
    var raw = titleEl.textContent.trim();
    titleEl.innerHTML = raw.split(' ').map(function (w, i) {
      return '<span class="ps-hero__word" style="transition-delay:' + (0.08 * i) + 's">' + w + '</span>';
    }).join(' ');
    requestAnimationFrame(function () {
      requestAnimationFrame(function () {
        titleEl.querySelectorAll('.ps-hero__word').forEach(function (w) {
          w.classList.add('ps--in');
        });
        if (subEl) subEl.classList.add('ps--in');
      });
    });

    /* Cursor: one word at a time, slow scale to 1.1 */
    if (heroEl && window.matchMedia('(hover: hover)').matches) {
      setTimeout(function () {
        var words = titleEl.querySelectorAll('.ps-hero__word');
        var activeWord = null;
        heroEl.addEventListener('mousemove', function (e) {
          var mx = e.clientX, my = e.clientY;
          var closest = null, closestDist = Infinity;
          words.forEach(function (w) {
            var r = w.getBoundingClientRect();
            var cx = r.left + r.width / 2;
            var cy = r.top  + r.height / 2;
            var dist = Math.sqrt(Math.pow(mx - cx, 2) + Math.pow(my - cy, 2));
            if (dist < closestDist) { closestDist = dist; closest = w; }
          });
          if (closest !== activeWord) {
            if (activeWord) {
              activeWord.style.transition = 'transform 0.7s cubic-bezier(0.16,1,0.3,1)';
              activeWord.style.transform = 'scale(1)';
            }
            activeWord = closest;
          }
          if (closest) {
            closest.style.transition = 'transform 0.7s cubic-bezier(0.16,1,0.3,1)';
            closest.style.transform = 'scale(1.1)';
          }
        });
        heroEl.addEventListener('mouseleave', function () {
          words.forEach(function (w) {
            w.style.transition = 'transform 0.7s cubic-bezier(0.16,1,0.3,1)';
            w.style.transform = 'scale(1)';
          });
          activeWord = null;
        });
      }, 1000);
    }
  }

  /* ── 2. Process step stagger reveal ── */
  var steps = document.querySelectorAll('.ps-step');
  if (steps.length) {
    var stepObs = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('ps--in');
          stepObs.unobserve(entry.target);
        }
      });
    }, { threshold: 0.2 });
    steps.forEach(function (s, i) {
      s.style.transitionDelay = (0.1 * i) + 's';
      stepObs.observe(s);
    });
  }

  /* ── 3. FAQ stagger reveal ── */
  var faqItems = document.querySelectorAll('.ps-faq__item');
  if (faqItems.length) {
    var faqObs = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('ps--in');
          faqObs.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });
    faqItems.forEach(function (item, i) {
      item.style.transitionDelay = (0.07 * i) + 's';
      faqObs.observe(item);
    });
  }
})();

/* ── Sourcing grid interaction ── */
(function () {
  var activeTile = null;
  var fieldItem  = document.getElementById('ps-item');
  var fieldBrand = document.getElementById('ps-brand');

  var PLUS_ICON  = '<svg class="ps-stile__icon" width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true"><path d="M5 1V9M1 5H9" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>';
  var MINUS_ICON = '<svg class="ps-stile__icon" width="10" height="2" viewBox="0 0 10 2" fill="none" aria-hidden="true"><path d="M1 1H9" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>';

  function clearFields() {
    if (fieldItem)  { fieldItem.value = '';  fieldItem.dispatchEvent(new Event('input')); }
    if (fieldBrand) { fieldBrand.value = ''; fieldBrand.dispatchEvent(new Event('input')); }
  }

  function fillFields(title, brand) {
    if (fieldItem)  { fieldItem.value = title;  fieldItem.dispatchEvent(new Event('input')); }
    if (fieldBrand) { fieldBrand.value = brand; fieldBrand.dispatchEvent(new Event('input')); }
  }

  var fileInput = document.getElementById('ps-image');
  var selectedFiles = [];

  function renderPreviews() {
    var container = document.getElementById('ps-image-previews');
    if (!container) return;
    container.innerHTML = '';
    selectedFiles.forEach(function(file, index) {
      var url = URL.createObjectURL(file);
      var wrap = document.createElement('div');
      wrap.className = 'ps-image-preview';
      var img = document.createElement('img');
      img.src = url;
      img.alt = file.name;
      var btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'ps-image-preview__remove';
      btn.innerHTML = '&times;';
      btn.addEventListener('click', function() {
        selectedFiles.splice(index, 1);
        renderPreviews();
        updateHint();
      });
      wrap.appendChild(img);
      wrap.appendChild(btn);
      container.appendChild(wrap);
    });
  }

  function updateHint() {
    var hint = document.getElementById('ps-image-hint');
    var field = fileInput ? fileInput.closest('.ps-field--file') : null;
    if (selectedFiles.length > 0) {
      if (field) field.classList.add('has-file');
      hint.textContent = selectedFiles.length === 1 ? selectedFiles[0].name : selectedFiles.length + ' images selected';
    } else {
      if (field) field.classList.remove('has-file');
      hint.textContent = 'Optional — up to 5 images';
    }
  }

  if (fileInput) {
    fileInput.addEventListener('change', function() {
      var newFiles = Array.from(fileInput.files);
      newFiles.forEach(function(file) {
        if (selectedFiles.length < 5) selectedFiles.push(file);
      });
      fileInput.value = '';
      renderPreviews();
      updateHint();
    });
  }

  document.querySelectorAll('.ps-stile[data-product-title]').forEach(function(tile) {
    var btn = tile.querySelector('.ps-stile__btn');
    if (!btn) return;
    btn.addEventListener('click', function(e) {
      e.preventDefault();
      if (activeTile === tile) {
        btn.classList.remove('is-added');
        btn.innerHTML = PLUS_ICON + '<span class="ps-stile__label">Add to request</span>';
        clearFields();
        activeTile = null;
        return;
      }
      if (activeTile) {
        var prev = activeTile.querySelector('.ps-stile__btn');
        if (prev) { prev.classList.remove('is-added'); prev.innerHTML = PLUS_ICON + '<span class="ps-stile__label">Add to request</span>'; }
      }
      activeTile = tile;
      btn.classList.add('is-added');
      btn.innerHTML = MINUS_ICON + '<span class="ps-stile__label">Remove item</span>';
      fillFields(tile.dataset.productTitle || '', tile.dataset.productBrand || '');
      if (window.innerWidth < 990) {
        var form = document.getElementById('ps-sourcing-form');
        if (form) form.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });

  /* ── Clear errors on input ── */
  ['ps-firstname','ps-lastname','ps-email','ps-item'].forEach(function(id) {
    var el = document.getElementById(id);
    if (el) el.addEventListener('input', function() {
      el.classList.remove('ps-error');
      var err = el.parentNode.querySelector('.ps-field__error');
      if (err) err.remove();
    });
  });

  /* ── Form validation ── */
  function showError(input, message) {
    input.classList.add('ps-error');
    var existing = input.parentNode.querySelector('.ps-field__error');
    if (!existing) {
      var err = document.createElement('span');
      err.className = 'ps-field__error';
      err.textContent = message;
      input.parentNode.appendChild(err);
    }
  }

  function clearErrors() {
    form.querySelectorAll('.ps-error').forEach(function(el) { el.classList.remove('ps-error'); });
    form.querySelectorAll('.ps-field__error').forEach(function(el) { el.remove(); });
  }

  function validateForm() {
    clearErrors();
    var valid = true;
    var fields = [
      { id: 'ps-firstname', msg: 'First name is required' },
      { id: 'ps-lastname',  msg: 'Last name is required' },
      { id: 'ps-email',     msg: 'Email is required' },
      { id: 'ps-item',      msg: 'Item name is required' }
    ];
    fields.forEach(function(f) {
      var el = document.getElementById(f.id);
      if (el && !el.value.trim()) { showError(el, f.msg); valid = false; }
    });
    var email = document.getElementById('ps-email');
    if (email && email.value && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.value)) {
      showError(email, 'Please enter a valid email');
      valid = false;
    }
    return valid;
  }

  /* ── Form submission to AWS Lambda ── */
  var form = document.getElementById('ps-sourcing-form');
  if (form) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();

      if (!validateForm()) return;

      var submitBtn = form.querySelector('.ps-submit');
      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending...';

      var imageFiles = selectedFiles.slice(0, 5);

      function sendData(images) {
        var payload = {
          firstName:    document.getElementById('ps-firstname').value,
          lastName:     document.getElementById('ps-lastname').value,
          email:        document.getElementById('ps-email').value,
          whatsappCode: document.querySelector('.ps-sourcing__cc').value,
          whatsapp:     document.getElementById('ps-whatsapp').value,
          country:      document.getElementById('ps-country').value,
          brand:        document.getElementById('ps-brand').value,
          itemName:     document.getElementById('ps-item').value,
          notes:        document.getElementById('ps-notes').value,
          images:       images
        };

        fetch('https://prh8oillgk.execute-api.eu-north-1.amazonaws.com/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        })
        .then(function(res) { return res.json(); })
        .then(function(data) {
          if (data.success) {
            form.innerHTML = '<div class="ps-form__success">' +
              '<div class="ps-form__success-mark" aria-hidden="true">' +
              '<svg width="16" height="12" viewBox="0 0 16 12" fill="none"><path d="M1 6L5.5 10.5L15 1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>' +
              '</div>' +
              '<p class="ps-form__success-title">Request received</p>' +
              '<p class="ps-form__success-note">We will be in touch within 48 hours.</p>' +
              '<button type="button" class="ps-submit" style="margin-top:24px;" onclick="window.location.reload()">Submit another request</button>' +
              '</div>';
          } else {
            submitBtn.disabled = false;
            submitBtn.textContent = 'Submit sourcing request';
            alert('Something went wrong. Please try again.');
          }
        })
        .catch(function() {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Submit sourcing request';
          alert('Something went wrong. Please try again.');
        });
      }

      if (imageFiles.length > 0) {
        var images = [];
        var loaded = 0;
        imageFiles.forEach(function(file) {
          var reader = new FileReader();
          reader.onload = function(ev) {
            images.push({ base64: ev.target.result.split(',')[1], type: file.type });
            loaded++;
            if (loaded === imageFiles.length) sendData(images);
          };
          reader.readAsDataURL(file);
        });
      } else {
        sendData([]);
      }
    });
  }
})();
</script>

