          {%- assign _content = _content | replace: '<p> [dual_image_1] </p>', '' -%}
          {%- assign _content = _content | replace: '<p>[dual_image_1] </p>', '' -%}
          {%- assign _content = _content | replace: '<p> [dual_image_1]</p>', '' -%}
        {%- endif -%}

        {%- comment -%}--- Info box block (At a Glance) ---{%- endcomment -%}
        {%- assign _ib_val = article.metafields.custom.info_box_1.value -%}
        {%- if _ib_val != blank -%}
          {%- assign _ib_lines = _ib_val | newline_to_br | split: '<br />' -%}
          {%- capture _ib_html -%}
            <div class="art-info-box">
              <p class="art-info-box__label">At a Glance</p>
