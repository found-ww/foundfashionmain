
{%- assign share_url = shop.url | append: article.url -%}
{%- assign twitter_text = article.title -%}
{%- assign pinterest_description = article.description | strip_html | truncatewords: 15 | url_param_escape -%}
{%- assign pinterest_image = article.image | img_url: '750x' | prepend: 'https:' -%}
{%- assign word_count = article.content | strip_html | split: ' ' | size -%}
{%- assign read_minutes = word_count | divided_by: 200 | at_least: 1 -%}
{%- assign par_word = article.metafields.custom.article_type.value -%}
{%- assign par_brand = article.metafields.custom.brand.value -%}
{%- assign par_sub = article.metafields.custom.hero_subtitle.value -%}
{%- assign pub_year = article.published_at | date: '%Y' -%}

<style>
  .ppv1-breadcrumb {
    padding: 14px 24px;
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #9a8f86;
    border-bottom: 1px solid #ede8e2;
  }
  .ppv1-breadcrumb__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px;
  }
  .ppv1-breadcrumb__item {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .ppv1-breadcrumb__item + .ppv1-breadcrumb__item::before {
    content: '/';
    color: #c8c0b8;
  }
  .ppv1-breadcrumb__link {
    color: #9a8f86;
    text-decoration: none;
    transition: color 0.15s;
  }
  .ppv1-breadcrumb__link:hover { color: #1c1c1c; }
  .ppv1-breadcrumb__current { color: #1c1c1c; }
</style>

<nav class="ppv1-breadcrumb" aria-label="Breadcrumb">
  <ol class="ppv1-breadcrumb__list" itemscope itemtype="https://schema.org/BreadcrumbList">
    <li class="ppv1-breadcrumb__item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
      <a class="ppv1-breadcrumb__link" href="{{ routes.root_url }}" itemprop="item">
        <span itemprop="name">{{ 'general.breadcrumb.home' | t }}</span>
      </a>
      <meta itemprop="position" content="1">
    </li>
    <li class="ppv1-breadcrumb__item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
      <a class="ppv1-breadcrumb__link" href="{{ blog.url }}" itemprop="item">
        <span itemprop="name">{{ blog.title }}</span>
      </a>
      <meta itemprop="position" content="2">
    </li>
    <li class="ppv1-breadcrumb__item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
      <span class="ppv1-breadcrumb__current" itemprop="name">{{ article.title }}</span>
      <meta itemprop="item" content="{{ shop.url }}{{ article.url }}">
      <meta itemprop="position" content="3">
    </li>
  </ol>
</nav>

<article class="Article" data-section-id="{{ section.id }}" data-section-type="article">
  <div class="Article__ProgressBar" id="article-progress-bar"></div>

  <aside class="ArticleToolbar hidden-phone">
    <div class="ArticleToolbar__Left">
      <span class="Heading Text--subdued u-h8 hidden-tablet">{{ 'blog.article.now_reading' | t }}</span>
      <span class="ArticleToolbar__ArticleTitle Heading u-h7">{{ article.title }}</span>
    </div>

    <div class="ArticleToolbar__Right">
      {%- if section.settings.show_share_buttons -%}
        <div class="ArticleToolbar__ShareList">
          <span class="ArticleToolbar__ShareLabel Heading Text--subdued u-h8">{{ 'blog.article.share' | t }}</span>

          <div class="HorizontalList">
            {%- if settings.social_instagram_link != blank -%}
              <a class="HorizontalList__Item Text--subdued Link" href="{{ settings.social_instagram_link }}" target="_blank" rel="noopener">{%- render 'icon' with 'instagram' -%}</a>
            {%- endif -%}
            <a class="HorizontalList__Item Text--subdued Link" href="https://wa.me/?text={{ article.title | url_encode }}%20{{ share_url | url_encode }}" target="_blank" rel="noopener">{%- render 'icon' with 'whatsapp' -%}</a>
            <a class="HorizontalList__Item Text--subdued Link" href="https://www.facebook.com/sharer.php?u={{ share_url }}" target="_blank" rel="noopener">{%- render 'icon' with 'facebook' -%}</a>
            <a class="HorizontalList__Item Text--subdued Link" href="https://twitter.com/share?{% if twitter_text != blank %}text={{ twitter_text }}&{% endif %}url={{ share_url }}" target="_blank" rel="noopener">{%- render 'icon' with 'x' -%}</a>
          </div>
        </div>
      {%- endif -%}

      {%- if blog.next_article or blog.previous_article -%}
        <div class="ArticleToolbar__Nav">
          {%- if blog.next_article -%}
            <a href="{{ blog.next_article }}" class="ArticleToolbar__NavItem ArticleToolbar__NavItem--next Heading Text--subdued Link u-h8">{% render 'icon' with 'select-arrow-left' %} {{ 'blog.article.previous' | t }}</a>
          {%- endif -%}

          {%- if blog.previous_article and blog.next_article -%}
            <span class="ArticleToolbar__NavItemSeparator"></span>
          {%- endif -%}

          {%- if blog.previous_article -%}
            <a href="{{ blog.previous_article }}" class="ArticleToolbar__NavItem ArticleToolbar__NavItem--prev Heading Text--subdued Link u-h8">{{ 'blog.article.next' | t }} {% render 'icon' with 'select-arrow-right' %}</a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </aside>

  {%- if article.image and section.settings.show_article_image -%}

    <div class="art-editorial-header">
      <div class="art-editorial-header__grid">

        <div class="art-editorial-header__left">
          {%- if par_brand != blank -%}
            <span class="art-meta-label">{{ par_brand }}</span>
          {%- elsif article.tags != empty -%}
            <span class="art-meta-label">{{ article.tags.first }}</span>
          {%- endif -%}
          <span class="art-meta-date">{{ article.published_at | date: '%B %-d, %Y' }}</span>
          <span class="art-meta-read">{{ read_minutes }} min read</span>
        </div>

        <div class="art-editorial-header__right">
          <h1 class="art-headline">{{ article.title }}</h1>
        </div>

      </div>
    </div>

    <div class="par-hero" id="par-hero">
      <div class="par-img-wrap" id="par-img">
        <img src="{{ article.image | img_url: '1600x' }}"
             srcset="{{ article.image | img_url: '800x' }} 800w, {{ article.image | img_url: '1200x' }} 1200w, {{ article.image | img_url: '1600x' }} 1600w"
             sizes="100vw"
             width="{{ article.image.width }}"
             height="{{ article.image.height }}"
             loading="eager"
             fetchpriority="high"
             alt="{{ article.image.alt | default: article.title | escape }}">
      </div>
    </div>

  {%- endif -%}

  <div id="article-body" class="Article__Wrapper">
    <div class="Article__Content">
      {%- unless article.image and section.settings.show_article_image -%}
      <header class="Article__Header">
        {%- capture article_meta -%}
          {%- if section.settings.show_date -%}
            <span class="Article__MetaItem">{{ article.published_at | date: format: 'month_day_year' }}</span>
          {%- endif -%}
          {%- if section.settings.show_category and article.tags != empty -%}
            <span class="Article__MetaItem">{{ article.tags.first }}</span>
          {%- endif -%}
        {%- endcapture -%}
        {%- if article_meta != blank -%}
          <div class="Article__Meta Heading Text--subdued u-h6">{{- article_meta -}}</div>
        {%- endif -%}
        <h1 class="Article__Title Heading u-h1">{{ article.title }}</h1>
      </header>
      {%- endunless -%}

      <div class="Article__Body Rte">
        {%- comment -%} ── Embed marker replacement ── {%- endcomment -%}
        {%- assign _quote = article.metafields.custom.large_quote.value -%}
        {%- assign _timeline = article.metafields.custom.timeline.value -%}
        {%- assign _quote2 = article.metafields.custom.large_quote_2.value -%}
        {%- assign _largetext = article.metafields.custom.large_text.value -%}
        {%- assign _largetext2 = article.metafields.custom.large_text_2.value -%}

        {%- assign _content = article.content -%}

        {%- assign _content = _content | replace: '<p>[parallax]</p>', '' -%}

        {%- if _quote != blank -%}
          {%- capture _pq_html -%}{%- render 'embed-pull-quote', quote: _quote -%}{%- endcapture -%}
          {%- assign _content = _content | replace: '<p>[quote]</p>', _pq_html -%}
        {%- else -%}
          {%- assign _content = _content | replace: '<p>[quote]</p>', '' -%}
        {%- endif -%}

        {%- if _largetext != blank -%}
          {%- capture _lt_html -%}{%- render 'embed-large-text', text: _largetext -%}{%- endcapture -%}
          {%- assign _content = _content | replace: '<p>[largeword]</p>', _lt_html -%}
        {%- else -%}
          {%- assign _content = _content | replace: '<p>[largeword]</p>', '' -%}
        {%- endif -%}

        {%- if _quote2 != blank -%}
          {%- capture _pq2_html -%}{%- render 'embed-pull-quote', quote: _quote2 -%}{%- endcapture -%}
          {%- assign _content = _content | replace: '<p>[quote_2]</p>', _pq2_html -%}
        {%- else -%}
          {%- assign _content = _content | replace: '<p>[quote_2]</p>', '' -%}
        {%- endif -%}

        {%- if _largetext2 != blank -%}
          {%- capture _lt2_html -%}{%- render 'embed-large-text', text: _largetext2 -%}{%- endcapture -%}
          {%- assign _content = _content | replace: '<p>[largeword_2]</p>', _lt2_html -%}
        {%- else -%}
          {%- assign _content = _content | replace: '<p>[largeword_2]</p>', '' -%}
        {%- endif -%}

        {%- if _timeline != blank -%}
          {%- capture _tc_html -%}{%- render 'embed-timeline-cards', content: _timeline, id: article.id -%}{%- endcapture -%}
          {%- assign _content = _content | replace: '<p>[timeline]</p>', _tc_html -%}
        {%- else -%}
          {%- assign _content = _content | replace: '<p>[timeline]</p>', '' -%}
        {%- endif -%}

        {%- comment -%} ── Product margin annotations ── {%- endcomment -%}
        {%- for _pi in (1..4) -%}
          {%- assign _p_key = 'product_' | append: _pi -%}
          {%- assign _p_val = article.metafields.custom[_p_key].value -%}
          {%- assign _p_marker = '[product_' | append: _pi | append: ']' -%}
          {%- assign _p_marker_tag = '<p>' | append: _p_marker | append: '</p>' -%}
          {%- if _p_val != blank -%}
            {%- assign _p_clean = _p_val | strip_html | strip -%}
            {%- assign _p_lines = _p_clean | newline_to_br | split: '<br />' -%}
            {%- assign _p_img = _p_lines[0] | strip -%}
            {%- assign _p_caption = _p_lines[1] | strip -%}
            {%- assign _p_sub = _p_lines[2] | strip -%}
            {%- capture _p_anchor -%}<span class="art-product-anchor" data-p-img="{{ _p_img | escape }}" data-p-caption="{{ _p_caption | escape }}" data-p-sub="{{ _p_sub | escape }}"></span>{%- endcapture -%}
            {%- assign _content = _content | replace: _p_marker_tag, _p_anchor -%}
          {%- else -%}
            {%- assign _content = _content | replace: _p_marker_tag, '' -%}
          {%- endif -%}
        {%- endfor -%}

        {%- comment -%} ── Card block embed ── {%- endcomment -%}
        {%- assign _cb_val = article.metafields.custom.card_block_1.value -%}
        {%- if _cb_val != blank -%}
          {%- assign _cb_clean = _cb_val | strip_html | strip -%}
          {%- assign _cb_lines = _cb_clean | newline_to_br | split: '<br />' -%}
          {%- capture _cb_html -%}
            <div class="art-card-block">
              {%- assign _cb_i = 0 -%}
              {%- for _line in _cb_lines -%}
                {%- assign _line_stripped = _line | strip -%}
                {%- if _line_stripped == blank -%}{%- continue -%}{%- endif -%}
                {%- assign _cb_mod = _cb_i | modulo: 2 -%}
                {%- if _cb_mod == 0 -%}
                  <div class="art-card-block__card">
                    <p class="art-card-block__title">{{ _line_stripped }}</p>
                {%- else -%}
                    <p class="art-card-block__body">{{ _line_stripped }}</p>
                  </div>
                {%- endif -%}
                {%- assign _cb_i = _cb_i | plus: 1 -%}
              {%- endfor -%}
              {%- assign _cb_mod_end = _cb_i | modulo: 2 -%}
              {%- if _cb_mod_end == 1 -%}</div>{%- endif -%}
            </div>
          {%- endcapture -%}
          {%- assign _content = _content | replace: '<p>[card_block_1]</p>', _cb_html -%}
        {%- else -%}
          {%- assign _content = _content | replace: '<p>[card_block_1]</p>', '' -%}
        {%- endif -%}

        {%- assign _cb2_val = article.metafields.custom.card_block_2.value -%}
        {%- if _cb2_val != blank -%}
          {%- assign _cb2_clean = _cb2_val | strip_html | strip -%}
          {%- assign _cb2_lines = _cb2_clean | newline_to_br | split: '<br />' -%}
          {%- capture _cb2_html -%}
            <div class="art-card-block">
              {%- assign _cb2_i = 0 -%}
              {%- for _line in _cb2_lines -%}
                {%- assign _line_stripped = _line | strip -%}
                {%- if _line_stripped == blank -%}{%- continue -%}{%- endif -%}
                {%- assign _cb2_mod = _cb2_i | modulo: 2 -%}
                {%- if _cb2_mod == 0 -%}
                  <div class="art-card-block__card">
                    <p class="art-card-block__title">{{ _line_stripped }}</p>
                {%- else -%}
                    <p class="art-card-block__body">{{ _line_stripped }}</p>
                  </div>
                {%- endif -%}
                {%- assign _cb2_i = _cb2_i | plus: 1 -%}
              {%- endfor -%}
              {%- assign _cb2_mod_end = _cb2_i | modulo: 2 -%}
              {%- if _cb2_mod_end == 1 -%}</div>{%- endif -%}
            </div>
          {%- endcapture -%}
          {%- assign _content = _content | replace: '<p>[card_block_2]</p>', _cb2_html -%}
        {%- else -%}
          {%- assign _content = _content | replace: '<p>[card_block_2]</p>', '' -%}
        {%- endif -%}

        {%- comment -%} ── Product block embed ── {%- endcomment -%}
        {%- assign _pb_val = article.metafields.custom.product_block_1.value -%}
        {%- if _pb_val != blank -%}
          {%- assign _pb_clean = _pb_val | strip_html | strip -%}
          {%- assign _pb_lines = _pb_clean | newline_to_br | split: '<br />' -%}
          {%- capture _pb_html -%}
            <div class="art-product-block">
              {%- assign _pb_i = 0 -%}
              {%- assign _pb_card_i = 0 -%}
              {%- for _line in _pb_lines -%}
                {%- assign _line_stripped = _line | strip -%}
                {%- if _line_stripped == blank -%}{%- continue -%}{%- endif -%}
                {%- assign _pb_field = _pb_i | modulo: 6 -%}
                {%- if _pb_field == 0 -%}
                  <div class="art-product-block__card">
                    <p class="art-product-block__title">{{ _line_stripped }}</p>
                    <div class="art-product-block__grid">
                {%- elsif _pb_field == 1 -%}
                      <div class="art-product-block__cell">
                        <span class="art-product-block__label">Year</span>
                        <span class="art-product-block__value">{{ _line_stripped }}</span>
                      </div>
                {%- elsif _pb_field == 2 -%}
                      <div class="art-product-block__cell">
                        <span class="art-product-block__label">Leather</span>
                        <span class="art-product-block__value">{{ _line_stripped }}</span>
                      </div>
                {%- elsif _pb_field == 3 -%}
                      <div class="art-product-block__cell">
                        <span class="art-product-block__label">Construction</span>
                        <span class="art-product-block__value">{{ _line_stripped }}</span>
                      </div>
                {%- elsif _pb_field == 4 -%}
                      <div class="art-product-block__cell">
                        <span class="art-product-block__label">Features</span>
                        <span class="art-product-block__value">{{ _line_stripped }}</span>
                      </div>
                    </div>
                {%- elsif _pb_field == 5 -%}
                    <div class="art-product-block__footer">
                      <span class="art-product-block__label">Best for</span>
                      <span class="art-product-block__value">{{ _line_stripped }}</span>
                    </div>
                  </div>
                {%- endif -%}
                {%- assign _pb_i = _pb_i | plus: 1 -%}
              {%- endfor -%}
            </div>
          {%- endcapture -%}
          {%- assign _content = _content | replace: '<p>[product_block_1]</p>', _pb_html -%}
        {%- else -%}
          {%- assign _content = _content | replace: '<p>[product_block_1]</p>', '' -%}
        {%- endif -%}

        {%- comment -%} ── Hotspot image embed ── {%- endcomment -%}
        {%- assign _hs_val = article.metafields.custom.hotspot_1.value -%}
        {%- if _hs_val != blank -%}
          {%- assign _hs_clean = _hs_val | strip_html | strip -%}
          {%- assign _hs_lines = _hs_clean | newline_to_br | split: '<br />' -%}
          {%- assign _hs_img = _hs_lines[0] | strip -%}
          {%- capture _hs_html -%}
            <div class="art-hotspot">
              <div class="art-hotspot__img-wrap">
                <img class="art-hotspot__img" src="{{ _hs_img }}" alt="" loading="lazy">
                {%- assign _hs_i = 0 -%}
                {%- for _line in _hs_lines -%}
                  {%- if forloop.index0 == 0 -%}{%- continue -%}{%- endif -%}
                  {%- assign _line_stripped = _line | strip -%}
                  {%- if _line_stripped == blank -%}{%- continue -%}{%- endif -%}
                  {%- assign _hs_mod = _hs_i | modulo: 2 -%}
                  {%- if _hs_mod == 0 -%}
                    {%- assign _hs_coords = _line_stripped | split: ',' -%}
                    {%- assign _hs_x = _hs_coords[0] | strip -%}
                    {%- assign _hs_y = _hs_coords[1] | strip -%}
                  {%- else -%}
                    <button class="art-hotspot__dot" style="left:{{ _hs_x }}%;top:{{ _hs_y }}%" data-hs-label="{{ _line_stripped | escape }}" type="button" aria-label="{{ _line_stripped | escape }}">
                      <span class="art-hotspot__pulse"></span>
                    </button>
                  {%- endif -%}
                  {%- assign _hs_i = _hs_i | plus: 1 -%}
                {%- endfor -%}
              </div>
            </div>
          {%- endcapture -%}
          {%- assign _content = _content | replace: '<p>[hotspot_1]</p>', _hs_html -%}
        {%- else -%}
          {%- assign _content = _content | replace: '<p>[hotspot_1]</p>', '' -%}
        {%- endif -%}

        {{ _content }}
      </div>

      {%- capture article_footer -%}
        {%- if section.settings.show_author -%}
          <span class="Article__Author Heading Text--subdued u-h6">{{ 'blog.article.written_by' | t: author: article.author }}</span>
        {%- endif -%}

        {%- if section.settings.show_share_buttons -%}
          <div class="Article__ShareSection">
            <div class="Article__ShareHeader">
              <span class="Article__ShareCaption">Share this story</span>
              <span class="Article__ShareCount"><span id="article-share-count">0</span> shares</span>
            </div>
            <div class="Article__ShareRow">
              <a class="ShareButtons__Item ShareButtons__Item--instagram" href="{{ settings.social_instagram_link | default: 'https://www.instagram.com/' }}" target="_blank" rel="noopener" data-share-btn aria-label="Share on Instagram">{%- render 'icon' with 'instagram' -%}</a>
              <a class="ShareButtons__Item ShareButtons__Item--whatsapp" href="https://wa.me/?text={{ article.title | url_encode }}%20{{ share_url | url_encode }}" target="_blank" rel="noopener" data-share-btn aria-label="Share on WhatsApp">{%- render 'icon' with 'whatsapp' -%}</a>
              <a class="ShareButtons__Item ShareButtons__Item--facebook" href="https://www.facebook.com/sharer.php?u={{ share_url }}" target="_blank" rel="noopener" data-share-btn aria-label="Share on Facebook">{%- render 'icon' with 'facebook' -%}</a>
              <a class="ShareButtons__Item ShareButtons__Item--x" href="https://twitter.com/share?{% if twitter_text != blank %}text={{ twitter_text }}&{% endif %}url={{ share_url }}" target="_blank" rel="noopener" data-share-btn aria-label="Share on X">{%- render 'icon' with 'x' -%}</a>
              <button class="Article__CopyLinkBtn" id="article-copy-link" type="button" data-url="{{ share_url | escape }}">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>
                <span id="article-copy-label">Copy link</span>
              </button>
            </div>
          </div>
        {%- endif -%}
      {%- endcapture -%}

      {%- if article_footer != blank -%}
        <footer class="Article__Footer">
          {{ article_footer }}
        </footer>
      {%- endif -%}

    </div>

  </div>

  {%- if section.settings.show_prev_next and blog.next_article or blog.previous_article -%}
    <aside class="ArticleNav">
      <div class="Container Container--narrow">
        <div class="Grid Grid--m Grid--center">
          {%- if blog.next_article -%}
            <div class="Grid__Cell 1/2--tablet-and-up">
              {%- render 'article-item', article: blog.next_article -%}
            </div>
          {%- elsif blog.articles_count > 3 -%}
            <div class="Grid__Cell 1/2--tablet-and-up">
              {%- render 'article-item', article: blog.articles.last -%}
            </div>
          {%- endif -%}

          {%- if blog.previous_article -%}
            <div class="Grid__Cell 1/2--tablet-and-up">
              {%- render 'article-item', article: blog.previous_article -%}
            </div>
          {%- elsif blog.articles_count > 3 -%}
            <div class="Grid__Cell 1/2--tablet-and-up">
              {%- render 'article-item', article: blog.articles.first -%}
            </div>
          {%- endif -%}
        </div>
      </div>
    </aside>
  {%- endif -%}
</article>

<style>
  /* ---- Pin ArticleToolbar to the true left viewport edge ---- */
  .ArticleToolbar { left: 0; right: 0; z-index: 10; background: #806f64; }
  .ArticleToolbar.hero-locked { visibility: hidden !important; }
  @media screen and (min-width: 1008px) {
    header.Header { transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1); }
    header.Header.art-header-hidden { transform: translateY(-100%); }
    .ArticleToolbar { transition: opacity 0.2s ease-in-out, transform 0.2s ease-in-out, top 0.35s cubic-bezier(0.4, 0, 0.2, 1) !important; }
    .ArticleToolbar.art-toolbar-top { top: 0 !important; }
  }
  .ArticleToolbar,
  .ArticleToolbar .Link,
  .ArticleToolbar__ArticleTitle { color: #fff; }
  .ArticleToolbar .Text--subdued { color: rgba(255,255,255,0.7); }
  .ArticleToolbar__ArticleTitle { max-width: none; width: auto; flex: 1; min-width: 0; }

  /* ---- Reading progress bar ---- */
  .Article__ProgressBar {
    position: fixed;
    top: 0;
    left: 0;
    width: 0%;
    height: 2px;
