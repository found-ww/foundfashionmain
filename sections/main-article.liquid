  /* ── Hotspot image embed ── */
  .art-hotspot {
    margin: 2em 0;
    width: 100%;
  }
  .art-hotspot__img-wrap {
    position: relative;
    display: block;
    line-height: 0;
  }
  .art-hotspot__img {
    width: 100%;
    display: block;
  }
  .art-hotspot__dot {
    position: absolute;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: #fff;
    border: 1.5px solid rgba(255,255,255,0.9);
    box-shadow: 0 2px 8px rgba(0,0,0,0.18);
    cursor: pointer;
    z-index: 2;
    transform: translate(-50%, -50%);
    transition: transform 0.2s ease;
    padding: 0;
    outline: none;
    -webkit-tap-highlight-color: transparent;
  }
  .art-hotspot__dot:hover { transform: translate(-50%, -50%) scale(1.3); }
  .art-hotspot__pulse {
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    border: 1.5px solid rgba(255,255,255,0.7);
    animation: art-hs-pulse 2s cubic-bezier(0.4,0,0.2,1) infinite;
    pointer-events: none;
  }
  @keyframes art-hs-pulse {
    0% { transform: scale(1); opacity: 0.7; }
    100% { transform: scale(2.2); opacity: 0; }
  }
  .art-hotspot__tooltip {
    position: absolute;
    z-index: 3;
    background: #fff;
    color: #1a1a1a;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    line-height: 1.4;
    padding: 10px 16px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.12);
    white-space: nowrap;
    pointer-events: none;
    opacity: 0;
    transform: translate(-50%, -100%) translateY(-14px);
    transition: opacity 0.25s ease, transform 0.25s ease;
  }
  .art-hotspot__tooltip--visible {
    opacity: 1;
    transform: translate(-50%, -100%) translateY(-18px);
  }
  .art-hotspot__tooltip::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 5px solid transparent;
    border-top-color: #fff;
  }
  /* Tooltip below dot (when near top) */
  .art-hotspot__tooltip--below {
    transform: translate(-50%, 0%) translateY(14px);
  }
  .art-hotspot__tooltip--below.art-hotspot__tooltip--visible {
    transform: translate(-50%, 0%) translateY(18px);
  }
  .art-hotspot__tooltip--below::after {
    top: auto;
    bottom: 100%;
    border-top-color: transparent;
    border-bottom-color: #fff;
  }
  /* Dot entrance animation */
  .art-hotspot__dot {
    opacity: 0;
    transform: translate(-50%, -50%) scale(0);
  }
  .art-hotspot__dot.art-hs--in {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
    transition: opacity 0.4s cubic-bezier(0.16,1,0.3,1), transform 0.4s cubic-bezier(0.16,1,0.3,1);
  }
  .art-hotspot__dot.art-hs--in:hover {
    transform: translate(-50%, -50%) scale(1.3);
  }
  @media screen and (max-width: 768px) {
    .art-hotspot__dot { width: 18px; height: 18px; }
    .art-hotspot__tooltip { font-size: 10px; padding: 8px 12px; }
  }

  /* Image column */
  .art-body-img-col { min-width: 0; }
  .art-body-img-col .Article__ParallaxWrap { margin-top: 0; }


  /* Full-width embeds break out of centered column */
  .Article__Body > .tl-h-outer {
    position: relative;
    left: 50%;
    transform: translateX(-50%);
    width: calc(100vw - 40px);
    max-width: none;
  }

  /* Pull quotes / large text within body column */
  .art-body-right .epq,
  .Article__Body > .epq {
    max-width: 100%;
  }

  /* Fade-in */
  .art-fade-in {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .art-fade-in.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  /* Fade-in for full-width embeds (preserve translateX breakout) */
  .Article__Body > .art-fade-in.tl-h-outer {
    transform: translateX(-50%) translateY(16px);
  }
  .Article__Body > .art-fade-in.tl-h-outer.is-visible {
    transform: translateX(-50%) translateY(0);
  }

  /* Mid-range screens — shrink margin annotations */
  @media screen and (max-width: 1200px) and (min-width: 769px) {
    .Article__Body { max-width: 600px; }
    .art-body-left {
