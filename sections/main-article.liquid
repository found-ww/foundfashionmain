  /* ---- Article width + body font size ---- */
  .Article__Wrapper { max-width: none; width: 100%; padding-left: 20px; padding-right: 20px; margin-bottom: 0 !important; padding-bottom: 0 !important; font-size: 17px; }
  article.Article { margin-bottom: 0; padding-bottom: 0; }
  @media screen and (min-width: 641px) { .Article__Wrapper { margin-bottom: 0; } }
  @media screen and (min-width: 1008px) { .Article__Wrapper { max-width: none; margin-bottom: 0; } }
  .Article__Body, .Article__Body.Rte { font-size: 1em !important; line-height: 1.65; }

  /* ── Centered article body with margin annotations ── */
  .Article__Body { max-width: 850px; margin-left: auto; margin-right: auto; position: relative; }

  .art-body-section-text,
  .art-body-section-img {
    position: relative;
    margin-bottom: 60px;
