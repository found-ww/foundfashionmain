    color: #fff !important;
    padding: 13px 24px;
    font-size: 13px;
    font-weight: 600;
    text-decoration: none !important;
    letter-spacing: 0.04em;
    margin: 0 0 12px;
    transition: background 0.2s ease;
  }
  .art-gate__btn:hover {
    background: #947b69;
  }
  .art-gate__link {
    font-size: 12px;
    color: #947b69 !important;
    text-decoration: underline !important;
  }
  @media screen and (max-width: 600px) {
    .art-gate__box { padding: 24px 20px; }
    .art-gate__title { font-size: 17px; }
  }

  /* Steps block */
  .art-steps {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin: 2em 0 0.5em;
  }
  .art-step {
    display: flex;
    align-items: stretch;
    border: 1px solid #e8e3de;
    background: #fff;
  }
  .art-step__num {
    width: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: #b8aea8;
    border-right: 1px solid #e8e3de;
    flex-shrink: 0;
  }
  .art-step__content {
    padding: 14px 18px;
    flex: 1;
  }
  .art-step__title {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.01em;
    color: #1b1b1c;
    margin: 0 0 4px !important;
  }
  .art-step__body {
    font-size: 13px;
    line-height: 1.6;
    color: rgba(27, 27, 28, 0.65);
    margin: 0 !important;
  }
  .art-step__body a { color: #947b69; text-decoration: underline; }
  .art-step--accent {
    border-color: #e8c97a;
    border-left: 3px solid #c9961a;
    background: #fdf9ee;
  }
  .art-step--accent .art-step__num {
    color: #c9961a;
    border-right-color: #e8c97a;
  }
  .art-step__num--icon {
    font-size: 0;
  }
  @media screen and (max-width: 768px) {
    .art-step__num { width: 40px; }
    .art-step__content { padding: 12px 14px; }
  }

  /* Info box (At a Glance) */
  .art-info-box {
    margin: 0 0 1em;
    border: 1px solid #e8e3de;
    border-left: 3px solid #947b69;
    border-radius: 0;
    background: #faf7f4;
    padding: 24px 28px;
  }
  .art-info-box__label {
    font-size: 9px !important;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #947b69;
    margin: 0 0 16px !important;
    padding: 0 !important;
  }
  .art-info-box__list {
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .art-info-box__row {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 12px;
    align-items: baseline;
  }
  .art-info-box__row--full {
    grid-template-columns: 1fr;
  }
  .art-info-box__key {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #1b1b1c;
    margin: 0;
  }
  .art-info-box__val {
    font-size: 14px;
    line-height: 1.5;
    color: rgba(27, 27, 28, 0.75);
    margin: 0;
  }
  @media screen and (max-width: 768px) {
    .art-info-box { padding: 20px; }
    .art-info-box__row { grid-template-columns: 1fr; gap: 2px; }
    .art-info-box__key { font-size: 10px; }
    .art-info-box__val { font-size: 13px; }
  }

  /* Warning callout */
  .art-callout {
    margin: 2.5em 0;
    border: 1px solid #e8c97a;
    border-left: 3px solid #c9961a;
    border-radius: 0;
    background: #fdf9ee;
    padding: 20px 24px;
    display: flex;
    gap: 14px;
    align-items: flex-start;
  }
  .art-callout__icon {
    flex-shrink: 0;
    color: #c9961a;
    margin-top: 2px;
  }
  .art-callout__body {
    font-size: 15px;
    line-height: 1.7;
    color: rgba(27, 27, 28, 0.8);
  }
  .art-callout__body strong { color: #1b1b1c; }
  @media screen and (max-width: 768px) {
    .art-callout { padding: 16px 18px; gap: 12px; }
    .art-callout__body { font-size: 14px; }
  }

  /* Large word */
  .art-large-word {
    margin: 1.8em 0;
    font-size: clamp(48px, 10vw, 96px);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.03em;
    color: #e0d9d2;
    text-align: center;
    user-select: none;
  }

  /* Store cards */
  .art-store-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin: 2em 0 0.5em;
  }
  .art-store-card {
    background: #fff;
    border: 1px solid #e8e3de;
    border-radius: 0;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .art-store-card__header {
    padding: 14px 16px 12px;
    border-bottom: 1px solid #e8e3de;
  }
  .art-store-card__badge {
    display: inline-block;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 3px 8px;
    margin-bottom: 8px;
    background: #f2ede8;
    color: #6b5c52;
    border: 0.5px solid #d4c9bf;
  }
  .art-store-card__badge--featured {
    background: #947b69;
    color: #fff;
    border-color: #947b69;
  }
  .art-store-card__name {
    font-size: 14px;
    font-weight: 600;
    color: #1b1b1c;
    margin: 0;
    letter-spacing: 0.01em;
  }
  .art-store-card__body {
    padding: 14px 16px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .art-store-card__meta {
    font-size: 11px;
    color: #7a7069;
    line-height: 1.7;
    margin: 0 0 10px;
  }
  .art-store-card__meta span { display: block; }
  .art-store-card__desc {
    font-size: 13px;
    color: #1b1b1c;
    line-height: 1.65;
    margin: 0;
    flex: 1;
  }
  .art-store-card__divider {
    height: 1px;
    background: #e8e3de;
    margin: 12px 0;
  }
  .art-store-card__best-label {
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #9a8f86;
    margin: 0 0 3px;
  }
  .art-store-card__best-val {
    font-size: 12px;
    color: #1b1b1c;
    margin: 0;
    line-height: 1.4;
  }
  .art-store-tip {
    font-size: 12px;
    color: #9a8f86;
    margin: 6px 0 2em !important;
    padding: 0 2px;
  }
  @media screen and (max-width: 900px) {
    .art-store-grid { grid-template-columns: 1fr; gap: 8px; }
  }

  /* Image column */
  .art-body-img-col { min-width: 0; }
  .art-body-img-col .Article__ParallaxWrap { margin-top: 0; }


  /* Pull quotes / large text within body column */
  .art-body-right .epq,
  .Article__Body > .epq {
    max-width: 100%;
  }

  /* Fade-in */
  .art-fade-in {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .art-fade-in.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Mid-range screens — shrink margin annotations */
  @media screen and (max-width: 1200px) and (min-width: 769px) {
    .Article__Body { max-width: 600px; }
    .art-body-left {
      width: 140px;
      margin-left: calc(-140px - 32px);
    }
    .art-body-caption-wrap {
      width: 120px;
      margin-right: calc(-120px - 32px);
    }
  }

  /* Mobile — stack everything */
  @media screen and (max-width: 768px) {
    .Article__Wrapper { padding-left: 20px; padding-right: 20px; }
    .Article__Body { max-width: none; }
    .art-body-section-text,
    .art-body-section-img { margin-bottom: 10px; }
    .art-body-section-text:has(.art-body-right > .art-card-block:only-child),
    .art-body-section-text:has(.art-body-right > .art-info-box:only-child),
    .art-body-section-text:has(.art-body-right > .art-callout:only-child),
    .art-body-section-text:has(.art-body-right > .art-stats:only-child) { margin-bottom: 20px; }
    .art-card-block + * { margin-top: 5px !important; }
    .art-body-left {
      float: none;
      width: auto;
      margin-left: 0;
      position: static;
      text-align: left;
      margin-bottom: 28px;
      padding: 0 0 20px;
      border-top: 0.5px solid rgba(0,0,0,0.12);
      border-bottom: 0.5px solid rgba(0,0,0,0.12);
      padding-top: 20px;
      margin-top: 10px;
    }
    .art-body-section-h { font-size: 17px !important; font-weight: 600 !important; color: #0a0a0a !important; }
    .art-body-left--empty { display: none; }

    /* Progress bar thicker on mobile */
    .Article__ProgressBar { height: 3px; }

    /* Pull quotes — full-width tinted band on mobile */
    .epq {
      background: #f5f1ed;
      margin-left: -20px;
      margin-right: -20px;
      padding: 32px 20px 32px !important;
    }
    .epq + * { margin-top: 50px !important; }

    /* Image captions as overlay on mobile */
    .art-body-img-col {
      position: relative;
      order: 1;
    }
    .art-body-caption-wrap {
      position: absolute !important;
      bottom: 0;
      left: 0;
      right: 0;
      margin-top: 0 !important;
      padding: 24px 16px 10px;
      background: linear-gradient(to top, rgba(0,0,0,0.45) 0%, transparent 100%);
      order: 1;
      z-index: 2;
    }
    .art-body-caption {
      color: rgba(255,255,255,0.85) !important;
    }

    /* Back to top button — sits above Tidio widget */
    .art-back-top {
      position: fixed;
      bottom: 90px;
      right: 20px;
      width: 44px;
      height: 44px;
      border-radius: 50%;
      background: #1c1c1c;
      color: #fff;
      border: none;
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 150;
      opacity: 0;
      pointer-events: none;
      transform: translateY(10px);
      transition: opacity 0.3s ease, transform 0.3s ease;
      cursor: pointer;
      box-shadow: 0 2px 8px rgba(0,0,0,0.2);
    }
    .art-back-top--visible {
      opacity: 1;
      pointer-events: auto;
      transform: translateY(0);
    }

    /* Mobile share section */
    .Article__Footer { padding: 36px 20px; }
    .Article__ShareRow {
      flex-wrap: wrap;
      gap: 10px;
      row-gap: 25px;
    }
    .Article__ShareSection .ShareButtons__Item {
      height: 48px !important;
      min-height: 48px;
      flex: 1;
    }
    .Article__ShareRow .Article__CopyLinkBtn {
      height: 48px !important;
      min-height: 48px;
      padding: 0 24px;
      width: 100%;
      margin-top: 8px !important;
    }
    .art-body-section-img {
      display: flex;
      flex-direction: column;
    }
    .art-body-caption-wrap {
      float: none;
      width: auto;
      margin-right: 0;
      text-align: left;
      margin-bottom: 0;
      margin-top: 8px;
      order: 2;
      position: static;
    }
    .art-body-caption { color: rgba(0,0,0,0.38); }
    .art-body-img-col { order: 1; }
    .art-body-right h3 { margin-top: 2em !important; margin-bottom: 1em !important; }
    .epq__text { font-size: 24px !important; }
    .art-card-block__card { padding: 24px 20px; }
  }

  /* ---- New badge ---- */
  .ArticleItem__ImageWrapper { position: relative; }
  .ArticleItem__NewBadge {
    position: absolute; top: 12px; left: 12px;
    background: #1c1c1c; color: #fff;
    font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase;
    padding: 5px 10px; z-index: 1; pointer-events: none;
  }

  /* ---- Share This Story section ---- */
  .Article__Footer {
    max-width: none;
    margin-top: 0;
    padding: 48px 20px;
    border-top: none;
    background: #f5f1ed;
    position: relative;
    left: 50%;
    transform: translateX(-50%);
    width: 100vw;
  }
  .Article__ShareSection {
    flex: 1;
    width: 100%;
    max-width: 1075px;
    min-width: 0;
    margin-left: auto;
    margin-right: auto;
    padding-left: 10px;
    padding-right: 10px;
    box-sizing: border-box;
  }
  .Article__ShareHeader {
    display: flex !important;
    flex-direction: row !important;
    align-items: center !important;
    justify-content: space-between !important;
    width: 100%;
    margin-bottom: 14px;
  }
  .Article__ShareCaption {
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #1c1c1c;
    white-space: nowrap;
  }
  .Article__ShareCount {
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #b5ada5;
    white-space: nowrap;
  }
  .Article__ShareRow {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  /* Equal height for all share buttons */
  .Article__ShareSection .ShareButtons__Item,
  .Article__CopyLinkBtn {
    height: 40px !important;
    min-height: 40px;
    box-sizing: border-box;
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
  }
  .Article__CopyLinkBtn {
    padding: 0 40px;
    gap: 8px;
    border: 1px solid #d4cec8;
    background: transparent;
    color: #1c1c1c;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
    font-family: inherit;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .Article__CopyLinkBtn:hover,
  .Article__CopyLinkBtn--copied { background: #1c1c1c; color: #fff; }

  /* ---- Blockquote ---- */
  .Article__Body blockquote {
    margin: 56px auto;
    max-width: none;
    padding: 0;
    text-align: left;
  }
  .Article__Body blockquote::before { display: none; }
  .Article__Body blockquote,
  .Article__Body blockquote p {
    font-family: inherit;
    font-size: clamp(18px, 1.8vw, 26px);
    font-weight: 500;
    font-style: normal;
    line-height: 1.4;
    color: #0f0f0f;
    letter-spacing: 0.02em;
    text-transform: none;
  }

  /* ---- Parallax image wrapper ---- */
  .Article__ParallaxWrap {
    overflow: hidden;
    display: block;
    line-height: 0;
    margin-top: 0;
    margin-bottom: 0;
  }
  .Article__ParallaxWrap img {
    width: 100%;
    display: block;
    margin: 0 !important;
    will-change: transform;
    transform: scale(1.12);
    transform-origin: center center;
  }
  @media screen and (max-width: 640px) {
    .Article__ParallaxWrap img { min-height: 72vw; object-fit: cover; }
  }

  /* ── Editorial header — full-width two-column ── */
  .art-editorial-header {
    width: 100vw;
    margin-left: calc(50% - 50vw);
    padding: calc(3.5rem + 50px) 0 0;
    border-bottom: none;
  }
  .art-editorial-header__grid {
    display: grid;
    grid-template-columns: 2.3fr 3fr;
    gap: 2rem;
    align-items: start;
    max-width: 80vw;
    margin-left: auto;
    margin-right: auto;
    padding: 0 20px 2rem;
  }
  .art-editorial-header__left {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    line-height: 1.2;
  }
  .art-meta-label {
    font-size: clamp(13px, 1vw, 17px);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #190d04;
  }
  .art-meta-date {
    font-size: clamp(13px, 1vw, 17px);
    font-weight: 500;
    letter-spacing: 0.04em;
    color: #555;
  }
  .art-meta-read {
    font-size: clamp(12px, 0.9vw, 16px);
    font-weight: 400;
    letter-spacing: 0.04em;
    color: #999;
  }
  .art-headline {
    font-family: inherit;
    font-size: 3.2rem;
    font-weight: 500;
    font-style: normal;
    line-height: 1.08;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #190d04;
    margin: 0;
    padding: 0;
    align-self: start;
  }
  .art-editorial-header__right { align-self: start; padding-top: 0; text-align: right; }
  @media screen and (max-width: 767px) {
    .art-editorial-header {
      padding-top: 35px;
    }
    .art-editorial-header__grid {
      grid-template-columns: 1fr;
      gap: 25px;
      padding: 0 5vw 35px;
      max-width: 100vw;
    }
    .art-editorial-header__left { flex-direction: row; flex-wrap: wrap; gap: 0.4rem 1.2rem; padding-left: 0; }
    .art-editorial-header__right { padding-top: 20px; text-align: left; }
    .art-headline { font-size: 2.5rem; }
  }

  /* ── Parallax hero — clean image, no overlay ── */
  .par-hero {
    position: relative;
    width: calc(100vw - 40px);
    margin-left: calc(50% - 50vw + 20px);
    height: clamp(400px, 36vw, 65vh);
    overflow: hidden;
    background: #12100e;
    margin-top: 24px;
    margin-bottom: 1.2rem;
  }
  .par-img-wrap {
    position: absolute;
    inset: -30px;
    z-index: 0;
  }
  .par-img-wrap img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center 30%;
    display: block;
  }
  @media screen and (max-width: 640px) {
    .par-hero { height: 30vh; min-height: 270px; margin-top: 10px; margin-bottom: 1.5rem; }
    .par-fg { padding: 0 24px 40px; }
    .par-title { font-size: clamp(1.6rem, 6vw, 2.4rem); padding-right: 3.5rem; line-height: 1.22; }
    .par-sub { padding-right: 3.5rem; }
    .par-scroll-hint { right: 1.5rem; bottom: 2rem; }
    .ppv1-breadcrumb { display: none; }
  }

  /* ── Horizontal timeline ── */
  .art-tl {
    position: relative;
    margin: 3em 0;
    padding: 60px 0 0;
    width: 100%;
  }
  .art-tl__line {
    position: absolute;
    top: 60px;
    left: 0;
    right: 0;
    height: 0.5px;
    background: #e5e0da;
  }
  .art-tl__line-fill {
    height: 100%;
    width: 0%;
    background: #1a1a1a;
    transition: width 2s cubic-bezier(0.16,1,0.3,1);
  }
  .art-tl__entries {
    display: flex;
    justify-content: space-between;
    position: relative;
  }
  .art-tl__entry {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    position: relative;
    padding: 0 8px;
  }
  .art-tl__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #1a1a1a;
    margin-top: -4px;
    margin-bottom: 16px;
    opacity: 0;
    transform: scale(0);
    transition: opacity 0.4s cubic-bezier(0.16,1,0.3,1), transform 0.4s cubic-bezier(0.16,1,0.3,1);
  }
  .art-tl__dot.art-tl--in {
    opacity: 1;
    transform: scale(1);
  }
  .art-tl__year {
    font-size: clamp(22px, 2vw, 32px);
    font-weight: 500;
    color: #0f0f0f;
    line-height: 1;
    letter-spacing: -0.02em;
    margin-bottom: 6px;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.5s ease, transform 0.5s ease;
    font-variant-numeric: tabular-nums;
  }
  .art-tl__year.art-tl--in {
    opacity: 1;
    transform: translateY(0);
  }
  .art-tl__label {
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: rgba(0,0,0,0.38);
    line-height: 1.3;
    max-width: 140px;
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  .art-tl__label.art-tl--in {
    opacity: 1;
    transform: translateY(0);
  }
  /* Tooltip on hover */
  .art-tl__tip {
    position: absolute;
    bottom: calc(100% + 24px);
    left: 50%;
    transform: translateX(-50%) translateY(4px);
    background: #fff;
    color: #1a1a1a;
    font-size: 13px;
    font-weight: 400;
    line-height: 1.5;
    padding: 14px 18px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.12);
    white-space: nowrap;
    max-width: 260px;
    white-space: normal;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.25s ease, transform 0.25s ease;
    z-index: 5;
  }
  .art-tl__tip::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 5px solid transparent;
    border-top-color: #fff;
  }
  .art-tl__entry:hover .art-tl__tip {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
  @media screen and (max-width: 768px) {
    .art-tl { padding: 50px 0 0; }
    .art-tl__line { top: 50px; }
    .art-tl__year { font-size: 18px; }
    .art-tl__label { font-size: 9px; letter-spacing: 0.1em; max-width: 80px; }
    .art-tl__dot { width: 6px; height: 6px; margin-top: -3px; margin-bottom: 12px; }
    .art-tl__entry { padding: 0 4px; }
    .art-tl__tip { display: none; }
  }

  /* ── Embed: Pull Quote / Large Text ── */
  .epq {
    margin: 0;
    padding: 16px 0 20px;
  }
  .epq__text {
    font-family: inherit;
    font-size: clamp(18px, 1.8vw, 26px);
    font-weight: 500;
    font-style: normal;
    line-height: 1.4;
    color: #0f0f0f;
    letter-spacing: 0.02em;
    text-transform: none;
    margin: 0;
  }
  .epq__word {
    display: inline-block;
    cursor: default;
    /* scroll-in start state */
    opacity: 0;
    filter: blur(14px);
    transform: translateY(10px);
    transition:
      opacity   .75s cubic-bezier(.16,1,.3,1),
      filter    .75s cubic-bezier(.16,1,.3,1),
      transform .75s cubic-bezier(.16,1,.3,1),
      color     .3s  ease;
  }
  .epq__word.epq--in {
    opacity: 1;
    filter: blur(0);
    transform: translateY(0);
  }
  .epq__word.epq--in:hover {
    transform: translateY(-5px);
    color: #947b69;
    filter: blur(0);
  }
</style>

<script>
  /* ── Centered article body restructure ── */
  (function() {
    var body = document.querySelector('.Article__Body');
    if (!body) return;

    /* Unwrap editor wrappers (ppv1-story__text etc.) so embeds become direct children */
    Array.from(body.querySelectorAll('.ppv1-story__text')).forEach(function(wrapper) {
      while (wrapper.firstChild) wrapper.parentNode.insertBefore(wrapper.firstChild, wrapper);
      wrapper.remove();
    });

    var nodes = Array.from(body.childNodes);
    var sections = [];
    var cur = null; // { type:'text', heading:el|null, right:[] } | { type:'img', el, alt } | { type:'rule' }

    function flush() { if (cur) { sections.push(cur); cur = null; } }

    function isImgNode(n) {
      if (n.nodeType !== 1) return false;
      var t = n.tagName.toLowerCase();
      if (t === 'img') return true;
      if (t === 'figure') return true;
      /* div/p wrapping only an img (editor sometimes does this) */
      if ((t === 'div' || t === 'p') && n.children.length === 1 && n.querySelector('img') &&
          !n.classList.contains('epq') &&
          !n.classList.contains('tl-outer') && !n.querySelector('.tl-outer')) return true;
      return false;
    }

    nodes.forEach(function(n) {
      /* Skip pure whitespace text nodes */
      if (n.nodeType === 3 && !n.textContent.trim()) return;

      /* Elements */
      if (n.nodeType === 1) {
        var tag = n.tagName.toLowerCase();

        if (tag === 'h2') {
          flush();
          cur = { type: 'text', heading: n, right: [] };
          return;
        }
        if (tag === 'hr') { return; /* skip dividers */ }
        if (isImgNode(n)) {
          flush();
          var img = n.tagName.toLowerCase() === 'img' ? n : n.querySelector('img');
          sections.push({ type: 'img', el: n, alt: img ? (img.getAttribute('alt') || '') : '' });
          return;
        }
      }

      /* Everything else → right column of current text section */
      if (!cur || cur.type !== 'text') cur = { type: 'text', heading: null, right: [] };
      cur.right.push(n);
    });
    flush();

    if (!sections.length) return;

    var frag = document.createDocumentFragment();
    sections.forEach(function(sec, i) {
      if (sec.type === 'img') {
        var row = document.createElement('div');
        row.className = 'art-body-section-img art-fade-in';
        if (sec.alt) {
          var capWrap = document.createElement('div');
          capWrap.className = 'art-body-caption-wrap';
          var cp = document.createElement('p');
          cp.className = 'art-body-caption';
          cp.textContent = sec.alt;
          capWrap.appendChild(cp);
          row.appendChild(capWrap);
        }
        var imgCol = document.createElement('div');
        imgCol.className = 'art-body-img-col';
        imgCol.appendChild(sec.el);
        /* On mobile, put caption inside imgCol so overlay positioning works */
        if (capWrap && window.innerWidth <= 768) {
          imgCol.appendChild(capWrap);
        }
        row.appendChild(imgCol);
        frag.appendChild(row);
        return;
      }
      if (sec.type === 'text') {
        if (!sec.heading && !sec.right.length) return;
        var row = document.createElement('div');
        row.className = 'art-body-section-text art-fade-in';
        var left = document.createElement('div');
        left.className = 'art-body-left';
        if (sec.heading) {
          sec.heading.className = 'art-body-section-h';
          left.appendChild(sec.heading);
        } else {
          left.classList.add('art-body-left--empty');
        }
        var right = document.createElement('div');
        right.className = 'art-body-right';
        sec.right.forEach(function(n) { right.appendChild(n); });
        row.appendChild(left);
        row.appendChild(right);
        frag.appendChild(row);
      }
    });

    body.innerHTML = '';
    body.appendChild(frag);

    /* Scroll fade-in */
    var io = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); }
      });
    }, { threshold: 0.06, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.art-fade-in').forEach(function(el, i) {
      el.style.transitionDelay = (i * 0.05) + 's';
      io.observe(el);
    });

    /* ---- Product margin annotations ---- */
    document.querySelectorAll('.art-product-anchor').forEach(function(anchor) {
      var img = anchor.getAttribute('data-p-img');
      var caption = anchor.getAttribute('data-p-caption');
      var sub = anchor.getAttribute('data-p-sub');
      if (!img && !caption) return;
      var card = document.createElement('div');
      card.className = 'art-product-card';
      var html = '';
      if (img) html += '<img class="art-product-card__img" src="' + img + '" alt="' + (caption || '').replace(/"/g, '&quot;') + '" loading="lazy">';
      if (caption) html += '<span class="art-product-card__caption">' + caption + '</span>';
      if (sub) html += '<span class="art-product-card__sub">' + sub + '</span>';
      card.innerHTML = html;
      anchor.appendChild(card);
    });

    /* ---- Card block scroll-in ---- */
    var cbCards = document.querySelectorAll('.art-card-block__card');
    if (cbCards.length) {
      var cbIo = new IntersectionObserver(function(entries) {
        entries.forEach(function(e) {
          if (e.isIntersecting) { e.target.classList.add('art-cb--in'); cbIo.unobserve(e.target); }
        });
      }, { threshold: 0.2 });
      cbCards.forEach(function(card, i) {
        card.style.transitionDelay = (0.1 * i) + 's';
        cbIo.observe(card);
      });
    }

    /* ---- Product block scroll-in ---- */
    var pbCards = document.querySelectorAll('.art-product-block__card');
    if (pbCards.length) {
      var pbIo = new IntersectionObserver(function(entries) {
        entries.forEach(function(e) {
          if (e.isIntersecting) { e.target.classList.add('art-pb--in'); pbIo.unobserve(e.target); }
        });
      }, { threshold: 0.2 });
      pbCards.forEach(function(card, i) {
        card.style.transitionDelay = (0.1 * i) + 's';
        pbIo.observe(card);
      });
    }

    /* ---- Product block tab switcher (mobile) ---- */
    document.querySelectorAll('.art-pb-tabs').forEach(function(tabBar) {
      var block = tabBar.closest('.art-product-block');
      if (!block) return;
      var cards = block.querySelectorAll('.art-product-block__card[data-pb-card]');
      var btns = tabBar.querySelectorAll('.art-pb-tabs__btn');
      /* Activate first card on load */
      if (cards.length) cards[0].classList.add('art-pb-card--active', 'art-pb--in');
      btns.forEach(function(btn) {
        btn.addEventListener('click', function() {
          var idx = btn.getAttribute('data-pb-tab');
          btns.forEach(function(b) { b.classList.remove('art-pb-tabs__btn--active'); });
          btn.classList.add('art-pb-tabs__btn--active');
          trackEvent('product_block_tab', {
            article_title: document.title,
            tab_label: btn.textContent.trim(),
            tab_index: idx
          });
          cards.forEach(function(c) { c.classList.remove('art-pb-card--active'); });
          var target = block.querySelector('.art-product-block__card[data-pb-card="' + idx + '"]');
          if (target) { target.classList.add('art-pb-card--active', 'art-pb--in'); }
        });
      });
    });

    /* ---- Hotspot image ---- */
    document.querySelectorAll('.art-hotspot').forEach(function(hotspot) {
      var wrap = hotspot.querySelector('.art-hotspot__img-wrap');
      if (!wrap) return;
      var dots = wrap.querySelectorAll('.art-hotspot__dot');
      var isMobile = !window.matchMedia('(hover: hover)').matches;
      var activeTooltip = null;

      function showTooltip(dot) {
        hideTooltip();
        var label = dot.getAttribute('data-hs-label');
        if (!label) return;
        trackEvent('hotspot_interact', { article_title: document.title, hotspot_label: label });
        var tip = document.createElement('div');
        tip.className = 'art-hotspot__tooltip';
        tip.textContent = label;
        tip.style.left = dot.style.left;
        tip.style.top = dot.style.top;
        /* Position below if dot is near top */
        var yPct = parseFloat(dot.style.top);
        if (yPct < 25) tip.classList.add('art-hotspot__tooltip--below');
        wrap.appendChild(tip);
        activeTooltip = tip;
        requestAnimationFrame(function() {
          requestAnimationFrame(function() {
            tip.classList.add('art-hotspot__tooltip--visible');
          });
        });
      }

      function hideTooltip() {
        if (activeTooltip) { activeTooltip.remove(); activeTooltip = null; }
      }

      dots.forEach(function(dot) {
        if (isMobile) {
          dot.addEventListener('click', function(e) {
            e.stopPropagation();
            if (activeTooltip && activeTooltip._dot === dot) { hideTooltip(); return; }
            showTooltip(dot);
            if (activeTooltip) activeTooltip._dot = dot;
          });
        } else {
          dot.addEventListener('mouseenter', function() { showTooltip(dot); });
          dot.addEventListener('mouseleave', function() { hideTooltip(); });
        }
      });

      if (isMobile) {
        document.addEventListener('click', function() { hideTooltip(); });
      }

      /* Scroll-in: staggered dot appearance */
      var hsIo = new IntersectionObserver(function(entries) {
        entries.forEach(function(e) {
          if (!e.isIntersecting) return;
          hsIo.disconnect();
          dots.forEach(function(dot, i) {
            setTimeout(function() { dot.classList.add('art-hs--in'); }, 300 + i * 150);
          });
        });
      }, { threshold: 0.3 });
      hsIo.observe(wrap);
    });

    /* ---- Stat counter ---- */
    document.querySelectorAll('.art-stats').forEach(function(block) {
      var items = block.querySelectorAll('.art-stats__number');
      if (!items.length) return;
      var fired = false;

      function animateNumber(el, delay) {
        var raw = el.getAttribute('data-stat-target');
        var match = raw.match(/^([\d,]+)(.*)/);
        if (!match) { el.textContent = raw; return; }
        var target = parseInt(match[1].replace(/,/g, ''), 10);
        var suffix = match[2] || '';
        var duration = 1800;

        setTimeout(function() {
          var start = performance.now();
          function tick(now) {
            var t = Math.min((now - start) / duration, 1);
            /* ease-out cubic */
            var ease = 1 - Math.pow(1 - t, 3);
            var current = Math.round(target * ease);
            el.textContent = current.toLocaleString() + suffix;
            if (t < 1) requestAnimationFrame(tick);
          }
          requestAnimationFrame(tick);
        }, delay);
      }

      var stIo = new IntersectionObserver(function(entries) {
        entries.forEach(function(e) {
          if (!e.isIntersecting || fired) return;
          fired = true;
          stIo.disconnect();
          items.forEach(function(el, i) {
            animateNumber(el, i * 150);
          });
        });
      }, { threshold: 0.4 });
      stIo.observe(block);
    });

    /* ---- FAQ accordion ---- */
    document.querySelectorAll('.art-faq__question').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var item = btn.closest('.art-faq__item');
        var answer = item.querySelector('.art-faq__answer');
        var isOpen = item.classList.contains('art-faq__item--open');

        /* Close all others in same FAQ block */
        var faq = item.closest('.art-faq');
        faq.querySelectorAll('.art-faq__item--open').forEach(function(openItem) {
          if (openItem !== item) {
            openItem.classList.remove('art-faq__item--open');
            openItem.querySelector('.art-faq__question').setAttribute('aria-expanded', 'false');
            openItem.querySelector('.art-faq__answer').style.maxHeight = '0';
          }
        });

        if (isOpen) {
          item.classList.remove('art-faq__item--open');
          btn.setAttribute('aria-expanded', 'false');
          answer.style.maxHeight = '0';
        } else {
          item.classList.add('art-faq__item--open');
          btn.setAttribute('aria-expanded', 'true');
          answer.style.maxHeight = '2000px';
        }
      });
    });

    /* ---- Horizontal timeline animation ---- */
    document.querySelectorAll('.art-tl').forEach(function(tl) {
      var fill = tl.querySelector('.art-tl__line-fill');
      var entries = tl.querySelectorAll('.art-tl__entry');
      var count = entries.length;
      if (!count) return;
      var fired = false;

      function animateYear(el, delay) {
        var raw = el.getAttribute('data-tl-year');
        var match = raw.match(/^(\d+)(.*)/);
        if (!match) { el.textContent = raw; return; }
        var target = parseInt(match[1], 10);
        var suffix = match[2] || '';
        var duration = 1200;
        setTimeout(function() {
          var start = performance.now();
          function tick(now) {
            var t = Math.min((now - start) / duration, 1);
            var ease = 1 - Math.pow(1 - t, 3);
            el.textContent = Math.round(target * ease) + suffix;
            if (t < 1) requestAnimationFrame(tick);
          }
          requestAnimationFrame(tick);
        }, delay);
      }

      var tlIo = new IntersectionObserver(function(es) {
        es.forEach(function(e) {
          if (!e.isIntersecting || fired) return;
          fired = true;
          tlIo.disconnect();
          /* 1. Draw the line */
          if (fill) fill.style.width = '100%';
          /* 2. Stagger dots, years, labels */
          entries.forEach(function(entry, i) {
            var dot = entry.querySelector('.art-tl__dot');
            var year = entry.querySelector('.art-tl__year');
            var label = entry.querySelector('.art-tl__label');
            var baseDelay = 400 + i * (1600 / count);
            if (dot) setTimeout(function() { dot.classList.add('art-tl--in'); }, baseDelay);
            if (year) {
              setTimeout(function() { year.classList.add('art-tl--in'); }, baseDelay + 150);
              animateYear(year, baseDelay + 150);
            }
            if (label) setTimeout(function() { label.classList.add('art-tl--in'); }, baseDelay + 350);
          });
        });
      }, { threshold: 0.3 });
      tlIo.observe(tl);
    });
  })();

  (function() {

    /* ---- Analytics helper: fires both dataLayer (GTM) and gtag (GA4) ---- */
    function trackEvent(eventName, params) {
      params = params || {};
      window.dataLayer = window.dataLayer || [];
      var dlObj = { event: eventName };
      for (var k in params) { if (params.hasOwnProperty(k)) dlObj[k] = params[k]; }
      window.dataLayer.push(dlObj);
      if (typeof gtag === 'function') {
        gtag('event', eventName, params);
      }
    }

    /* ---- Progress bar: tracks article content, not full page ---- */
    var bar     = document.getElementById('article-progress-bar');
    var content = document.querySelector('.Article__Content');
    if (bar && content) {
      var barPct = 0;
      var barTarget = 0;
      function updateBarTarget() {
        var scrollTop = window.pageYOffset || document.documentElement.scrollTop;
        var contentTop = content.getBoundingClientRect().top + scrollTop;
        var contentBottom = contentTop + content.offsetHeight;
        var scrollEnd = contentBottom - window.innerHeight;
        if (scrollEnd > 0) {
          barTarget = Math.min(100, Math.max(0, (scrollTop / scrollEnd) * 100));
        }
      }
      function barRAF() {
        barPct += (barTarget - barPct) * 0.12;
        if (Math.abs(barPct - barTarget) < 0.1) barPct = barTarget;
        bar.style.width = barPct + '%';
        requestAnimationFrame(barRAF);
      }
      /* ---- Scroll depth tracking ---- */
      var depthMilestones = { 25: false, 50: false, 75: false, 100: false };
      var readCompleteFired = false;
      function checkScrollDepth() {
        var pct = Math.round(barTarget);
        [25, 50, 75, 100].forEach(function(m) {
          if (pct >= m && !depthMilestones[m]) {
            depthMilestones[m] = true;
            trackEvent('article_scroll_depth', { article_title: document.title, scroll_depth: m });
          }
        });
        if (pct >= 98 && !readCompleteFired) {
          readCompleteFired = true;
          trackEvent('article_read_complete', { article_title: document.title });
        }
      }

      window.addEventListener('scroll', function() { updateBarTarget(); checkScrollDepth(); }, { passive: true });
      updateBarTarget();
      barRAF();
    }

    /* ---- Share count (localStorage per article URL) ---- */
    var SHARE_KEY  = 'ff_shares';
    var articleUrl = window.location.pathname;
    function getCount() {
      try { return (JSON.parse(localStorage.getItem(SHARE_KEY) || '{}')[articleUrl]) || 0; } catch(e) { return 0; }
    }
    function incrementCount() {
      try {
        var data = JSON.parse(localStorage.getItem(SHARE_KEY) || '{}');
        data[articleUrl] = (data[articleUrl] || 0) + 1;
        localStorage.setItem(SHARE_KEY, JSON.stringify(data));
        return data[articleUrl];
      } catch(e) { return 0; }
    }
    function updateCountEl(n) {
      var el = document.getElementById('article-share-count');
      if (el) el.textContent = n;
    }
    updateCountEl(getCount());
    document.querySelectorAll('[data-share-btn]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        updateCountEl(incrementCount());
        trackEvent('share_article', {
          article_title: document.title,
          share_method: btn.getAttribute('data-share-btn') || 'unknown',
          share_location: 'footer'
        });
      });
    });

    /* ---- Focus mode toggle ---- */
    var focusBtn = document.getElementById('art-focus-toggle');
    var articleEl = document.querySelector('article.Article');
    if (focusBtn && articleEl) {
      focusBtn.addEventListener('click', function() {
        var entering = !articleEl.classList.contains('art-focus-mode');
        articleEl.classList.toggle('art-focus-mode');
        focusBtn.classList.toggle('ArticleToolbar__FocusBtn--active');
        trackEvent('toggle_focus_mode', {
          article_title: document.title,
          focus_state: entering ? 'on' : 'off'
        });

        /* Move H2s into/out of the right column */
        articleEl.querySelectorAll('.art-body-section-text').forEach(function(section) {
          var left = section.querySelector('.art-body-left');
          var right = section.querySelector('.art-body-right');
          if (!left || !right) return;
          var heading = section.querySelector('.art-body-section-h');
          if (!heading) return;
          if (entering) {
            right.insertBefore(heading, right.firstChild);
          } else {
            left.appendChild(heading);
          }
        });
      });
    }

    /* ---- Toolbar share link tracking ---- */
    document.querySelectorAll('[data-toolbar-share]').forEach(function(link) {
      link.addEventListener('click', function() {
        trackEvent('share_article', {
          article_title: document.title,
          share_method: link.getAttribute('data-toolbar-share'),
          share_location: 'toolbar'
        });
      });
    });

    /* ---- Copy link button ---- */
    var copyBtn   = document.getElementById('article-copy-link');
    var copyLabel = document.getElementById('article-copy-label');
    if (copyBtn) {
      copyBtn.addEventListener('click', function() {
        var url = copyBtn.getAttribute('data-url') || window.location.href;
        function onCopied() {
          copyLabel.textContent = 'Copied!';
          copyBtn.classList.add('Article__CopyLinkBtn--copied');
          updateCountEl(incrementCount());
          trackEvent('copy_article_link', { article_title: document.title });
          setTimeout(function() {
            copyLabel.textContent = 'Copy link';
            copyBtn.classList.remove('Article__CopyLinkBtn--copied');
          }, 2000);
        }
        if (navigator.clipboard) {
          navigator.clipboard.writeText(url).then(onCopied);
        } else {
          var ta = document.createElement('textarea');
          ta.value = url; ta.style.cssText = 'position:fixed;opacity:0';
          document.body.appendChild(ta); ta.select(); document.execCommand('copy');
          document.body.removeChild(ta); onCopied();
        }
      });
    }

    /* ---- Show toolbar only after hero scrolls fully past viewport top ---- */
    var toolbar  = document.querySelector('.ArticleToolbar');
    var heroTrigger = document.getElementById('par-hero') || document.querySelector('.art-editorial-header');
    if (toolbar && heroTrigger) {
      toolbar.classList.add('hero-locked');
      function checkToolbarVisibility() {
        var top = heroTrigger.getBoundingClientRect().top;
        toolbar.classList.toggle('hero-locked', top > 0);
      }
      window.addEventListener('scroll', checkToolbarVisibility, { passive: true });
      checkToolbarVisibility();
    }

    /* ---- Hide header on scroll down, reveal on scroll up (desktop only) ---- */
    if (window.innerWidth >= 1008) {
      var siteHeader = document.querySelector('header.Header');
      if (siteHeader) {
        var lastScrollY = window.scrollY;
        var scrollThreshold = 80;
        var scrollUpAccum = 0;
        var scrollUpRequired = 120;
        window.addEventListener('scroll', function() {
          var currentY = window.scrollY;
          var artToolbar = document.querySelector('.ArticleToolbar');
          if (currentY < scrollThreshold) {
            siteHeader.classList.remove('art-header-hidden');
            if (artToolbar) artToolbar.classList.remove('art-toolbar-top');
            scrollUpAccum = 0;
          } else if (currentY > lastScrollY) {
            siteHeader.classList.add('art-header-hidden');
            if (artToolbar) artToolbar.classList.add('art-toolbar-top');
            scrollUpAccum = 0;
          } else {
            scrollUpAccum += lastScrollY - currentY;
            if (scrollUpAccum >= scrollUpRequired) {
              siteHeader.classList.remove('art-header-hidden');
              if (artToolbar) artToolbar.classList.remove('art-toolbar-top');
            }
          }
          lastScrollY = currentY;
        }, { passive: true });
      }
    }

    /* ---- Parallax hero ---- */
    var parHero  = document.getElementById('par-hero');
    var parImg   = document.getElementById('par-img');
    var parCtaEl = document.getElementById('par-cta');

    if (parHero && parImg && !window.matchMedia('(hover: hover)').matches) {
      /* Mobile: scroll-driven vertical parallax */
      function mobileParallax() {
        var rect  = parHero.getBoundingClientRect();
        var drift = Math.min(55, Math.max(0, (window.innerHeight - rect.top) * 0.06));
        parImg.style.transform = 'translateY(' + drift + 'px) scale(1.12)';
      }
      window.addEventListener('scroll', mobileParallax, { passive: true });
      mobileParallax();
    }

    if (parHero && parImg && window.matchMedia('(hover: hover)').matches) {
      var pMouse  = { x: 0, y: 0 };
      var imgT    = { x: 0, y: 0 };
      var imgC    = { x: 0, y: 0 };
      var pInside = false;

      function plerp(a, b, n) { return a + (b - a) * n; }

      parHero.addEventListener('mousemove', function(e) {
        var r  = parHero.getBoundingClientRect();
        pMouse.x = (e.clientX - r.left) / r.width  - 0.5;
        pMouse.y = (e.clientY - r.top)  / r.height - 0.5;
      });
      parHero.addEventListener('mouseenter', function() { pInside = true; });
      parHero.addEventListener('mouseleave', function() { pInside = false; imgT.x = 0; imgT.y = 0; });

      (function ptick() {
        if (pInside) { imgT.x = pMouse.x * -24; imgT.y = pMouse.y * -16; }
        imgC.x = plerp(imgC.x, imgT.x, 0.06);
        imgC.y = plerp(imgC.y, imgT.y, 0.06);
        parImg.style.transform = 'translate(' + imgC.x + 'px,' + imgC.y + 'px) scale(1.08)';
        requestAnimationFrame(ptick);
      })();
    }

    if (parCtaEl) {
      parCtaEl.addEventListener('click', function(e) {
        var target = document.getElementById('article-body');
        if (!target) return;
        e.preventDefault();
        var start      = window.pageYOffset;
        var toolbar    = document.querySelector('.ArticleToolbar');
        var headerH    = parseInt(getComputedStyle(document.documentElement).getPropertyValue('--header-height')) || 0;
        var toolbarH   = toolbar ? toolbar.offsetHeight : 0;
        var end        = parHero.getBoundingClientRect().bottom + start - headerH - toolbarH;
        var duration = 1400;
        var t0       = performance.now();
        function ease(t) { return t < 0.5 ? 4*t*t*t : 1 - Math.pow(-2*t+2, 3)/2; }
        (function step(now) {
          var p = Math.min((now - t0) / duration, 1);
          window.scrollTo(0, start + (end - start) * ease(p));
          if (p < 1) requestAnimationFrame(step);
        })(t0);
      });
    }

    /* ---- Parallax images (Apple-style: continuous RAF + lerp) ---- */
    var bodyEl = document.querySelector('.Article__Body');
    if (bodyEl) {
      bodyEl.querySelectorAll('img').forEach(function(img) {
        if (img.closest('.Article__ParallaxWrap')) return;
        if (img.closest('.art-product-card')) return;
        if (img.closest('.art-hotspot__img-wrap')) return;
        var wrap = document.createElement('div');
        wrap.className = 'Article__ParallaxWrap';
        img.parentNode.insertBefore(wrap, img);
        wrap.appendChild(img);
      });

      /* Wrap each hotspot in a parallax container */
      bodyEl.querySelectorAll('.art-hotspot__img-wrap').forEach(function(imgWrap) {
        var parWrap = document.createElement('div');
        parWrap.className = 'Article__ParallaxWrap';
        imgWrap.parentNode.insertBefore(parWrap, imgWrap);
        parWrap.appendChild(imgWrap);
      });

      var parItems = [];
      bodyEl.querySelectorAll('.Article__ParallaxWrap').forEach(function(wrap) {
        var target = wrap.querySelector('.art-hotspot__img-wrap') || wrap.querySelector('img');
        if (target) parItems.push({ wrap: wrap, img: target, cur: 0, tgt: 0 });
      });

      function parTick() {
        var vH = window.innerHeight;
        parItems.forEach(function(item) {
          var rect  = item.wrap.getBoundingClientRect();
          var range = vH / 2 + rect.height / 2;
          var prog  = (vH / 2 - (rect.top + rect.height / 2)) / range;
          var maxT  = rect.height * 0.08;
          item.tgt  = Math.max(-maxT, Math.min(maxT, prog * maxT * 1.6));
          item.cur += (item.tgt - item.cur) * 0.06; /* lerp factor — lower = smoother/lazier */
          item.img.style.transform = 'translateY(' + item.cur.toFixed(2) + 'px) scale(1.12)';
        });
        requestAnimationFrame(parTick);
      }

      parTick();
    }

  })();

  /* ── Embed: Pull Quote — scroll-in blur + stagger ── */
  (function() {
    document.querySelectorAll('[data-epq-id]').forEach(function(el) {
      el.innerHTML = el.textContent.trim().split(' ').map(function(w) {
        return '<span class="epq__word">' + w + '</span>';
      }).join(' ');

      var block    = el.closest('.epq');
      var words    = el.querySelectorAll('.epq__word');
      var fired    = false;

      new IntersectionObserver(function(entries, obs) {
        if (!entries[0].isIntersecting || fired) return;
        fired = true;
        obs.disconnect();
        words.forEach(function(w, i) {
          setTimeout(function() { w.classList.add('epq--in'); }, 350 + i * 80);
        });
      }, { threshold: 0.25 }).observe(block || el);
    });
  })();

  /* ---- Back to top button (mobile) ---- */
  (function() {
    var btn = document.getElementById('art-back-top');
    if (!btn) return;
    var content = document.querySelector('.Article__Content');
    if (!content) return;
    window.addEventListener('scroll', function() {
      var totalHeight = content.scrollHeight;
      var scrolled = window.scrollY;
      var show = scrolled > totalHeight * 0.4;
      btn.classList.toggle('art-back-top--visible', show);
    }, { passive: true });
    btn.addEventListener('click', function() {
      window.scrollTo({ top: 0, behavior: 'smooth' });
      trackEvent('back_to_top', { article_title: document.title });
    });
  })();
</script>

