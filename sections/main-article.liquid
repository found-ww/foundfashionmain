
{%- assign share_url = shop.url | append: article.url -%}
{%- assign twitter_text = article.title -%}
{%- assign pinterest_description = article.description | strip_html | truncatewords: 15 | url_param_escape -%}
{%- assign pinterest_image = article.image | img_url: '750x' | prepend: 'https:' -%}
{%- assign word_count = article.content | strip_html | split: ' ' | size -%}
{%- assign read_minutes = word_count | divided_by: 200 | at_least: 1 -%}
{%- assign par_word = article.metafields.custom.article_type.value -%}
{%- assign par_brand = article.metafields.custom.brand.value -%}
{%- assign par_sub = article.metafields.custom.hero_subtitle.value -%}
{%- assign pub_year = article.published_at | date: '%Y' -%}

<style>
  .ppv1-breadcrumb {
    padding: 14px 24px;
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #9a8f86;
    border-bottom: 1px solid #ede8e2;
  }
  .ppv1-breadcrumb__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px;
  }
  .ppv1-breadcrumb__item {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .ppv1-breadcrumb__item + .ppv1-breadcrumb__item::before {
    content: '/';
    color: #c8c0b8;
  }
  .ppv1-breadcrumb__link {
    color: #9a8f86;
    text-decoration: none;
    transition: color 0.15s;
  }
  .ppv1-breadcrumb__link:hover { color: #1c1c1c; }
  .ppv1-breadcrumb__current { color: #1c1c1c; }
</style>

<nav class="ppv1-breadcrumb" aria-label="Breadcrumb">
  <ol class="ppv1-breadcrumb__list" itemscope itemtype="https://schema.org/BreadcrumbList">
    <li class="ppv1-breadcrumb__item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
      <a class="ppv1-breadcrumb__link" href="{{ routes.root_url }}" itemprop="item">
        <span itemprop="name">{{ 'general.breadcrumb.home' | t }}</span>
      </a>
      <meta itemprop="position" content="1">
    </li>
    <li class="ppv1-breadcrumb__item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
      <a class="ppv1-breadcrumb__link" href="{{ blog.url }}" itemprop="item">
        <span itemprop="name">{{ blog.title }}</span>
      </a>
      <meta itemprop="position" content="2">
    </li>
    <li class="ppv1-breadcrumb__item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
      <span class="ppv1-breadcrumb__current" itemprop="name">{{ article.title }}</span>
      <meta itemprop="item" content="{{ shop.url }}{{ article.url }}">
      <meta itemprop="position" content="3">
    </li>
  </ol>
</nav>

<article class="Article" data-section-id="{{ section.id }}" data-section-type="article">
  <div class="Article__ProgressBar" id="article-progress-bar"></div>

  <aside class="ArticleToolbar hidden-phone">
    <div class="ArticleToolbar__Left">
      <span class="Heading Text--subdued u-h8 hidden-tablet">{{ 'blog.article.now_reading' | t }}</span>
      <span class="ArticleToolbar__ArticleTitle Heading u-h7">{{ article.title }}</span>
    </div>

    <div class="ArticleToolbar__Right">
      {%- if section.settings.show_share_buttons -%}
        <div class="ArticleToolbar__ShareList">
          <span class="ArticleToolbar__ShareLabel Heading Text--subdued u-h8">{{ 'blog.article.share' | t }}</span>

          <div class="HorizontalList">
            {%- if settings.social_instagram_link != blank -%}
              <a class="HorizontalList__Item Text--subdued Link" href="{{ settings.social_instagram_link }}" target="_blank" rel="noopener">{%- render 'icon' with 'instagram' -%}</a>
            {%- endif -%}
            <a class="HorizontalList__Item Text--subdued Link" href="https://wa.me/?text={{ article.title | url_encode }}%20{{ share_url | url_encode }}" target="_blank" rel="noopener">{%- render 'icon' with 'whatsapp' -%}</a>
            <a class="HorizontalList__Item Text--subdued Link" href="https://www.facebook.com/sharer.php?u={{ share_url }}" target="_blank" rel="noopener">{%- render 'icon' with 'facebook' -%}</a>
            <a class="HorizontalList__Item Text--subdued Link" href="https://twitter.com/share?{% if twitter_text != blank %}text={{ twitter_text }}&{% endif %}url={{ share_url }}" target="_blank" rel="noopener">{%- render 'icon' with 'x' -%}</a>
          </div>
        </div>
      {%- endif -%}

      {%- if blog.next_article or blog.previous_article -%}
        <div class="ArticleToolbar__Nav">
          {%- if blog.next_article -%}
            <a href="{{ blog.next_article }}" class="ArticleToolbar__NavItem ArticleToolbar__NavItem--next Heading Text--subdued Link u-h8">{% render 'icon' with 'select-arrow-left' %} {{ 'blog.article.previous' | t }}</a>
          {%- endif -%}

          {%- if blog.previous_article and blog.next_article -%}
            <span class="ArticleToolbar__NavItemSeparator"></span>
          {%- endif -%}

          {%- if blog.previous_article -%}
            <a href="{{ blog.previous_article }}" class="ArticleToolbar__NavItem ArticleToolbar__NavItem--prev Heading Text--subdued Link u-h8">{{ 'blog.article.next' | t }} {% render 'icon' with 'select-arrow-right' %}</a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </aside>

  {%- if article.image and section.settings.show_article_image -%}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;1,300;1,400&display=swap" rel="stylesheet">

    <div class="par-cursor-ring" id="par-cursor-ring"></div>
    <div class="par-cursor-dot"  id="par-cursor-dot"></div>

    <div class="par-hero" id="par-hero">
      <div class="par-img-wrap" id="par-img">
        <img src="{{ article.image | img_url: '1600x' }}"
             srcset="{{ article.image | img_url: '800x' }} 800w, {{ article.image | img_url: '1200x' }} 1200w, {{ article.image | img_url: '1600x' }} 1600w"
             sizes="100vw"
             width="{{ article.image.width }}"
             height="{{ article.image.height }}"
             loading="eager"
             fetchpriority="high"
             alt="{{ article.image.alt | default: article.title | escape }}">
      </div>
      <div class="par-dark" id="par-dark"></div>
      {%- if par_word != blank -%}
        <div class="par-ghost-layer" id="par-ghost-layer" aria-hidden="true">
          <span class="par-ghost" id="par-ghost">{{ par_word }}</span>
        </div>
      {%- endif -%}
      <div class="par-fg" id="par-fg">
        <div class="par-rule"></div>
        <p class="par-kicker">
          {%- if par_brand != blank -%}{{ par_brand }} &nbsp;·&nbsp; {%- endif -%}
          {{ pub_year }}
        </p>
        <div class="par-title-wrap">
          {%- assign title_words = article.title | split: ' ' -%}
          {%- assign tw_chunk = '' -%}
          {%- assign tw_line = 0 -%}
          {%- for word in title_words -%}
            {%- assign tw_chunk = tw_chunk | append: word | append: ' ' -%}
            {%- assign tw_mod = forloop.index | modulo: 2 -%}
            {%- if tw_mod == 0 or forloop.last -%}
              {%- assign tw_depth = tw_line | times: 4 | plus: 2 -%}
              <span class="par-title-word" data-depth="{{ tw_depth }}">{{ tw_chunk | strip }}</span>
              {%- assign tw_chunk = '' -%}
              {%- assign tw_line = tw_line | plus: 1 -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
        <div class="par-foot">
          <span class="par-readtime">{{ read_minutes }} min read</span>
          <a class="par-cta" id="par-cta" href="#article-body">
            Start reading
            <svg viewBox="0 0 10 10" width="10" height="10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 5h6M5 2l3 3-3 3"/></svg>
          </a>
        </div>
      </div>
      <div class="par-scroll-hint" aria-hidden="true">
        <span>Scroll</span>
        <div class="par-scroll-line"></div>
      </div>
    </div>
  {%- endif -%}

  <div id="article-body" class="Article__Wrapper">
    <div class="Article__Content">
      {%- unless article.image and section.settings.show_article_image -%}
      <header class="Article__Header">
        {%- capture article_meta -%}
          {%- if section.settings.show_date -%}
            <span class="Article__MetaItem">{{ article.published_at | date: format: 'month_day_year' }}</span>
          {%- endif -%}

          {%- if section.settings.show_category and article.tags != empty -%}
            <span class="Article__MetaItem">{{ article.tags.first }}</span>
          {%- endif -%}
        {%- endcapture -%}

        {%- if article_meta != blank -%}
          <div class="Article__Meta Heading Text--subdued u-h6">
            {{- article_meta -}}
          </div>
        {%- endif -%}

        <h1 class="Article__Title Heading u-h1">{{ article.title }}</h1>
      </header>
      {%- endunless -%}

      <div class="Article__Body Rte">
        {{ article.content }}
      </div>

      {%- capture article_footer -%}
        {%- if section.settings.show_author -%}
          <span class="Article__Author Heading Text--subdued u-h6">{{ 'blog.article.written_by' | t: author: article.author }}</span>
        {%- endif -%}

        {%- if section.settings.show_share_buttons -%}
          <div class="Article__ShareSection">
            <div class="Article__ShareHeader">
              <span class="Article__ShareCaption">Share this story</span>
              <span class="Article__ShareCount"><span id="article-share-count">0</span> shares</span>
            </div>
            <div class="Article__ShareRow">
              <a class="ShareButtons__Item ShareButtons__Item--instagram" href="{{ settings.social_instagram_link | default: 'https://www.instagram.com/' }}" target="_blank" rel="noopener" data-share-btn aria-label="Share on Instagram">{%- render 'icon' with 'instagram' -%}</a>
              <a class="ShareButtons__Item ShareButtons__Item--whatsapp" href="https://wa.me/?text={{ article.title | url_encode }}%20{{ share_url | url_encode }}" target="_blank" rel="noopener" data-share-btn aria-label="Share on WhatsApp">{%- render 'icon' with 'whatsapp' -%}</a>
              <a class="ShareButtons__Item ShareButtons__Item--facebook" href="https://www.facebook.com/sharer.php?u={{ share_url }}" target="_blank" rel="noopener" data-share-btn aria-label="Share on Facebook">{%- render 'icon' with 'facebook' -%}</a>
              <a class="ShareButtons__Item ShareButtons__Item--x" href="https://twitter.com/share?{% if twitter_text != blank %}text={{ twitter_text }}&{% endif %}url={{ share_url }}" target="_blank" rel="noopener" data-share-btn aria-label="Share on X">{%- render 'icon' with 'x' -%}</a>
              <button class="Article__CopyLinkBtn" id="article-copy-link" type="button" data-url="{{ share_url | escape }}">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>
                <span id="article-copy-label">Copy link</span>
              </button>
            </div>
          </div>
        {%- endif -%}
      {%- endcapture -%}

      {%- if article_footer != blank -%}
        <footer class="Article__Footer">
          {{ article_footer }}
        </footer>
      {%- endif -%}
    </div>

  </div>


  {%- if section.settings.show_prev_next and blog.next_article or blog.previous_article -%}
    <aside class="ArticleNav">
      <div class="Container Container--narrow">
        <div class="Grid Grid--m Grid--center">
          {%- if blog.next_article -%}
            <div class="Grid__Cell 1/2--tablet-and-up">
              {%- render 'article-item', article: blog.next_article -%}
            </div>
          {%- elsif blog.articles_count > 3 -%}
            <div class="Grid__Cell 1/2--tablet-and-up">
              {%- render 'article-item', article: blog.articles.last -%}
            </div>
          {%- endif -%}

          {%- if blog.previous_article -%}
            <div class="Grid__Cell 1/2--tablet-and-up">
              {%- render 'article-item', article: blog.previous_article -%}
            </div>
          {%- elsif blog.articles_count > 3 -%}
            <div class="Grid__Cell 1/2--tablet-and-up">
              {%- render 'article-item', article: blog.articles.first -%}
            </div>
          {%- endif -%}
        </div>
      </div>
    </aside>
  {%- endif -%}
</article>

<style>
  /* ---- Pin ArticleToolbar to the true left viewport edge ---- */
  .ArticleToolbar { left: 0; right: 0; }

  /* ---- Reading progress bar ---- */
  .Article__ProgressBar {
    position: fixed;
    top: 0;
    left: 0;
    width: 0%;
    height: 2px;
    background: #1c1c1c;
    z-index: 200;
    pointer-events: none;
    transition: width 0.1s linear;
  }

  /* ---- Share button hover colours ---- */
  .ShareButtons__Item--whatsapp:hover { background: #25D366; color: #ffffff; border-color: #25D366; outline: 1.5px solid #25D366; }
  .ShareButtons__Item--x:hover { color: #ffffff; background: #000000; border-color: #000000; outline: 1.5px solid #000000; }
  .ShareButtons__Item--instagram:hover { background: #e1306c; color: #ffffff; border-color: #e1306c; outline: 1.5px solid #e1306c; }

  /* ---- Wider article content ---- */
  .Article__Wrapper { max-width: 720px; margin-bottom: 0; }
  @media screen and (min-width: 641px) { .Article__Wrapper { margin-bottom: 0; } }
  @media screen and (min-width: 1008px) { .Article__Wrapper { max-width: 960px; margin-bottom: 0; } }

  /* ---- New badge ---- */
  .ArticleItem__ImageWrapper { position: relative; }
  .ArticleItem__NewBadge {
    position: absolute; top: 12px; left: 12px;
    background: #1c1c1c; color: #fff;
    font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase;
    padding: 5px 10px; z-index: 1; pointer-events: none;
  }

  /* ---- Share This Story section ---- */
  .Article__ShareSection {
    flex: 1;
    width: 100%;
    min-width: 0;
    margin-top: 48px;
    padding-top: 24px;
    border-top: 1px solid #e5e0da;
  }
  .Article__ShareHeader {
    display: flex !important;
    flex-direction: row !important;
    align-items: center !important;
    justify-content: space-between !important;
    width: 100%;
    margin-bottom: 14px;
  }
  .Article__ShareCaption {
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #1c1c1c;
    white-space: nowrap;
  }
  .Article__ShareCount {
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #b5ada5;
    white-space: nowrap;
  }
  .Article__ShareRow {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  /* Equal height for all share buttons */
  .Article__ShareSection .ShareButtons__Item,
  .Article__CopyLinkBtn {
    height: 40px !important;
    min-height: 40px;
    box-sizing: border-box;
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
  }
  .Article__CopyLinkBtn {
    padding: 0 40px;
    gap: 8px;
    border: 1px solid #d4cec8;
    background: transparent;
    color: #1c1c1c;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
    font-family: inherit;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .Article__CopyLinkBtn:hover,
  .Article__CopyLinkBtn--copied { background: #1c1c1c; color: #fff; }

  /* ---- Pull quote / blockquote ---- */
  .Article__Body blockquote {
    margin: 56px auto;
    max-width: 680px;
    padding: 36px 0;
    border-top: 1px solid #1c1c1c;
    border-bottom: 1px solid #1c1c1c;
    text-align: center;
  }
  .Article__Body blockquote::before {
    content: '\201C';
    display: block;
    font-size: 72px;
    line-height: 0.5;
    margin-bottom: 20px;
    color: #1c1c1c;
    font-family: Georgia, 'Times New Roman', serif;
    font-style: normal;
    opacity: 0.3;
  }
  .Article__Body blockquote,
  .Article__Body blockquote p {
    font-size: clamp(1.2rem, 2.5vw, 1.6rem);
    font-style: italic;
    line-height: 1.65;
    color: #1c1c1c;
    letter-spacing: 0.01em;
    font-family: Georgia, 'Times New Roman', serif;
  }

  /* ---- Parallax image wrapper ---- */
  .Article__ParallaxWrap {
    overflow: hidden;
    display: block;
    line-height: 0;
  }
  .Article__ParallaxWrap img {
    width: 100%;
    display: block;
    will-change: transform;
  }

  /* ---- Parallax hero ---- */
  .par-hero {
    position: relative;
    width: 100%;
    height: 90vh;
    min-height: 580px;
    overflow: hidden;
    background: #12100e;
    cursor: none;
  }
  .par-img-wrap {
    position: absolute;
    inset: -60px;
    z-index: 0;
  }
  .par-img-wrap img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center 20%;
    display: block;
  }
  .par-dark {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: rgba(18,16,14,0.82);
  }
  .par-ghost-layer {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    overflow: hidden;
    will-change: transform;
  }
  .par-ghost {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(110px, 20vw, 220px);
    font-weight: 300;
    font-style: italic;
    color: #fff;
    opacity: 0.04;
    letter-spacing: -0.03em;
    white-space: nowrap;
    user-select: none;
    transition: letter-spacing 0.6s cubic-bezier(0.16,1,0.3,1);
  }
  .par-fg {
    position: absolute;
    inset: 0;
    z-index: 3;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 0 3.5rem 3.5rem;
    pointer-events: none;
  }
  .par-rule {
    width: 32px;
    height: 0.5px;
    background: rgba(255,255,255,0.38);
    margin-bottom: 0.85rem;
  }
  .par-kicker {
    font-size: 10px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.45);
    margin-bottom: 1rem;
  }
  .par-title-wrap {
    display: flex;
    flex-direction: column;
    gap: 0.04em;
    margin-bottom: 2rem;
  }
  .par-title-word {
    display: block;
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-weight: 300;
    font-style: italic;
    color: #fff;
    line-height: 1.0;
    letter-spacing: -0.01em;
    font-size: clamp(26px, 3.6vw, 48px);
    will-change: transform;
  }
  .par-foot {
    display: flex;
    align-items: center;
    gap: 1.75rem;
    pointer-events: all;
  }
  .par-readtime {
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
  }
  .par-cta {
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #fff;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 13px 26px;
    border: 0.5px solid rgba(255,255,255,0.4);
    border-radius: 2px;
    background: rgba(255,255,255,0.06);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition: background 0.3s, border-color 0.3s, gap 0.35s cubic-bezier(0.16,1,0.3,1);
  }
  .par-cta:hover {
    background: rgba(255,255,255,0.13);
    border-color: rgba(255,255,255,0.7);
    gap: 20px;
  }
  .par-cta svg { flex-shrink: 0; }
  .par-cursor-ring {
    position: fixed;
    width: 44px; height: 44px;
    border-radius: 50%;
    border: 0.5px solid rgba(255,255,255,0.5);
    pointer-events: none;
    z-index: 9999;
    transform: translate(-50%, -50%);
    transition: width 0.3s cubic-bezier(0.16,1,0.3,1),
                height 0.3s cubic-bezier(0.16,1,0.3,1),
                border-color 0.3s,
                opacity 0.3s;
    opacity: 0;
  }
  .par-cursor-ring.visible { opacity: 1; }
  .par-cursor-ring.hovering-cta { width: 70px; height: 70px; border-color: rgba(255,255,255,0.8); }
  .par-cursor-dot {
    position: fixed;
    width: 4px; height: 4px;
    border-radius: 50%;
    background: rgba(255,255,255,0.9);
    pointer-events: none;
    z-index: 9999;
    transform: translate(-50%, -50%);
    opacity: 0;
    transition: opacity 0.3s;
  }
  .par-cursor-dot.visible { opacity: 1; }
  .par-scroll-hint {
    position: absolute;
    bottom: 3.5rem; right: 3.5rem;
    z-index: 4;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    animation: par-bob 2.4s ease-in-out infinite;
    pointer-events: none;
  }
  @keyframes par-bob {
    0%,100% { transform: translateY(0);   opacity: 0.28; }
    50%      { transform: translateY(6px); opacity: 0.45; }
  }
  .par-scroll-hint span {
    font-size: 9px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: #fff;
    writing-mode: vertical-rl;
  }
  .par-scroll-line {
    width: 0.5px; height: 44px;
    background: rgba(255,255,255,0.35);
  }
  @media screen and (max-width: 640px) {
    .par-hero { height: 80vh; min-height: 440px; cursor: auto; }
    .par-fg { padding: 0 24px 40px; }
    .par-title-word { font-size: clamp(22px, 6.5vw, 34px); }
    .par-cursor-ring, .par-cursor-dot { display: none; }
    .par-scroll-hint { right: 1.5rem; bottom: 2rem; }
  }
</style>

<script>
  (function() {

    /* ---- Progress bar: tracks article content, not full page ---- */
    var bar     = document.getElementById('article-progress-bar');
    var content = document.querySelector('.Article__Content');
    if (bar) {
      function updateBar() {
        var scrollTop = window.pageYOffset || document.documentElement.scrollTop;
        var pct = 0;
        if (content) {
          var contentTop = content.getBoundingClientRect().top + scrollTop;
          var scrollable = content.offsetHeight - window.innerHeight;
          if (scrollable > 0) {
            pct = Math.min(100, Math.max(0, (scrollTop - contentTop) / scrollable * 100));
          } else {
            pct = scrollTop >= contentTop ? 100 : 0;
          }
        } else {
          var docH = document.documentElement.scrollHeight - window.innerHeight;
          pct = docH > 0 ? Math.min(100, (scrollTop / docH) * 100) : 0;
        }
        bar.style.width = pct + '%';
      }
      window.addEventListener('scroll', updateBar, { passive: true });
      updateBar();
    }

    /* ---- Share count (localStorage per article URL) ---- */
    var SHARE_KEY  = 'ff_shares';
    var articleUrl = window.location.pathname;
    function getCount() {
      try { return (JSON.parse(localStorage.getItem(SHARE_KEY) || '{}')[articleUrl]) || 0; } catch(e) { return 0; }
    }
    function incrementCount() {
      try {
        var data = JSON.parse(localStorage.getItem(SHARE_KEY) || '{}');
        data[articleUrl] = (data[articleUrl] || 0) + 1;
        localStorage.setItem(SHARE_KEY, JSON.stringify(data));
        return data[articleUrl];
      } catch(e) { return 0; }
    }
    function updateCountEl(n) {
      var el = document.getElementById('article-share-count');
      if (el) el.textContent = n;
    }
    updateCountEl(getCount());
    document.querySelectorAll('[data-share-btn]').forEach(function(btn) {
      btn.addEventListener('click', function() { updateCountEl(incrementCount()); });
    });

    /* ---- Copy link button ---- */
    var copyBtn   = document.getElementById('article-copy-link');
    var copyLabel = document.getElementById('article-copy-label');
    if (copyBtn) {
      copyBtn.addEventListener('click', function() {
        var url = copyBtn.getAttribute('data-url') || window.location.href;
        function onCopied() {
          copyLabel.textContent = 'Copied!';
          copyBtn.classList.add('Article__CopyLinkBtn--copied');
          updateCountEl(incrementCount());
          setTimeout(function() {
            copyLabel.textContent = 'Copy link';
            copyBtn.classList.remove('Article__CopyLinkBtn--copied');
          }, 2000);
        }
        if (navigator.clipboard) {
          navigator.clipboard.writeText(url).then(onCopied);
        } else {
          var ta = document.createElement('textarea');
          ta.value = url; ta.style.cssText = 'position:fixed;opacity:0';
          document.body.appendChild(ta); ta.select(); document.execCommand('copy');
          document.body.removeChild(ta); onCopied();
        }
      });
    }

    /* ---- Parallax hero ---- */
    var parHero      = document.getElementById('par-hero');
    var parDark      = document.getElementById('par-dark');
    var parGhostWrap = document.getElementById('par-ghost-layer');
    var parGhost     = document.getElementById('par-ghost');
    var parWords     = document.querySelectorAll('.par-title-word');
    var parCtaEl     = document.getElementById('par-cta');
    var parRing      = document.getElementById('par-cursor-ring');
    var parDotEl     = document.getElementById('par-cursor-dot');

    if (parHero) {
      var pMouse  = { x: window.innerWidth / 2,  y: window.innerHeight / 2 };
      var pCur    = { x: window.innerWidth / 2,  y: window.innerHeight / 2 };
      var pInside = false;
      var pSpeed  = 0, pPrevX = pMouse.x, pPrevY = pMouse.y;
      var SPOT_R  = 200;

      var wT = [], wC = [];
      parWords.forEach(function() { wT.push({x:0,y:0}); wC.push({x:0,y:0}); });
      var gT = {x:0,y:0}, gC = {x:0,y:0};

      function plerp(a, b, n) { return a + (b - a) * n; }
      function pclamp(v, lo, hi) { return Math.max(lo, Math.min(hi, v)); }

      document.addEventListener('mousemove', function(e) {
        pSpeed  = Math.hypot(e.clientX - pPrevX, e.clientY - pPrevY);
        pPrevX  = pMouse.x; pPrevY = pMouse.y;
        pMouse.x = e.clientX; pMouse.y = e.clientY;
      });

      if (window.matchMedia('(hover: hover)').matches) {
        parHero.addEventListener('mouseenter', function() {
          pInside = true;
          if (parRing)  parRing.classList.add('visible');
          if (parDotEl) parDotEl.classList.add('visible');
        });
        parHero.addEventListener('mouseleave', function() {
          pInside = false;
          if (parRing)  parRing.classList.remove('visible');
          if (parDotEl) parDotEl.classList.remove('visible');
          parWords.forEach(function(w, i) { wT[i].x = 0; wT[i].y = 0; });
          gT.x = 0; gT.y = 0;
          if (parDark) parDark.style.background = 'rgba(18,16,14,0.82)';
        });
        if (parCtaEl) {
          parCtaEl.addEventListener('mouseenter', function() { if (parRing) parRing.classList.add('hovering-cta'); });
          parCtaEl.addEventListener('mouseleave', function() { if (parRing) parRing.classList.remove('hovering-cta'); });
        }
      }

      (function ptick() {
        if (parRing) {
          pCur.x = plerp(pCur.x, pMouse.x, 0.12);
          pCur.y = plerp(pCur.y, pMouse.y, 0.12);
          parRing.style.left = pCur.x + 'px';
          parRing.style.top  = pCur.y + 'px';
        }
        if (parDotEl) {
          parDotEl.style.left = pMouse.x + 'px';
          parDotEl.style.top  = pMouse.y + 'px';
        }

        if (pInside) {
          var r  = parHero.getBoundingClientRect();
          var nx = (pMouse.x - r.left) / r.width  - 0.5;
          var ny = (pMouse.y - r.top)  / r.height - 0.5;
          var sx = pMouse.x - r.left;
          var sy = pMouse.y - r.top;
          var dynR = SPOT_R + pclamp(pSpeed * 1.2, 0, 80);
          if (parDark) {
            parDark.style.background =
              'radial-gradient(circle ' + dynR + 'px at ' + sx + 'px ' + sy + 'px, ' +
              'transparent 0%, rgba(18,16,14,0.25) 55%, rgba(18,16,14,0.82) 100%)';
          }
          parWords.forEach(function(word, i) {
            var depth = parseFloat(word.getAttribute('data-depth'));
            wT[i].x = nx * depth;
            wT[i].y = ny * depth * 0.6;
          });
          gT.x = nx * -14;
          gT.y = ny * -10;
          if (parGhost) {
            var extraLS = pclamp(pSpeed * 0.004, 0, 0.12);
            parGhost.style.letterSpacing = (-0.03 + extraLS) + 'em';
          }
        }

        parWords.forEach(function(word, i) {
          wC[i].x = plerp(wC[i].x, wT[i].x, 0.07);
          wC[i].y = plerp(wC[i].y, wT[i].y, 0.07);
          word.style.transform = 'translate(' + wC[i].x + 'px,' + wC[i].y + 'px)';
        });
        gC.x = plerp(gC.x, gT.x, 0.05);
        gC.y = plerp(gC.y, gT.y, 0.05);
        if (parGhostWrap) parGhostWrap.style.transform = 'translate(' + gC.x + 'px,' + gC.y + 'px)';

        requestAnimationFrame(ptick);
      })();

      if (parCtaEl) {
        parCtaEl.addEventListener('click', function(e) {
          var target = document.getElementById('article-body');
          if (target) { e.preventDefault(); target.scrollIntoView({ behavior: 'smooth' }); }
        });
      }
    }

    /* ---- Parallax images ---- */
    var bodyEl = document.querySelector('.Article__Body');
    if (bodyEl) {
      bodyEl.querySelectorAll('img').forEach(function(img) {
        if (img.closest('.Article__ParallaxWrap')) return;
        var wrap = document.createElement('div');
        wrap.className = 'Article__ParallaxWrap';
        img.parentNode.insertBefore(wrap, img);
        wrap.appendChild(img);
      });
      var wraps = bodyEl.querySelectorAll('.Article__ParallaxWrap');
      function updateParallax() {
        var viewH = window.innerHeight;
        wraps.forEach(function(wrap) {
          var rect = wrap.getBoundingClientRect();
          if (rect.bottom < -100 || rect.top > viewH + 100) return;
          var progress = (viewH / 2 - (rect.top + rect.height / 2)) / viewH;
          var img = wrap.querySelector('img');
          if (img) img.style.transform = 'translateY(' + (progress * 35) + 'px) scale(1.07)';
        });
      }
      window.addEventListener('scroll', updateParallax, { passive: true });
      updateParallax();
    }

  })();
</script>

