    line-height: 1.4 !important;
    margin: 0 !important;
    font-family: inherit !important;
    font-style: normal !important;
  }

  /* Body text — fills centered column */
  .art-body-right { min-width: 0; }
  .art-body-right > p:first-child,
  .art-body-right > h3:first-child { margin-top: 0 !important; }
  .art-body-right h3 {
    font-size: 15px !important;
    font-weight: 600 !important;
    text-transform: uppercase !important;
    letter-spacing: 0.14em !important;
    color: #0f0f0f !important;
    line-height: 1.4 !important;
    margin: 2em 0 0.8em !important;
    font-family: inherit !important;
    font-style: normal !important;
  }
  .art-body-right > h3:first-child { margin-top: 0 !important; }

  /* Image caption — floated into right margin, sticky */
  .art-body-caption-wrap {
    float: right;
    width: clamp(120px, 10vw, 180px);
    margin-right: calc(-1 * clamp(120px, 10vw, 180px) - 48px);
