    .par-sub { padding-right: 3.5rem; }
    .par-scroll-hint { right: 1.5rem; bottom: 2rem; }
    .ppv1-breadcrumb { display: none; }
  }

  /* ── Timeline: vertical scroll-jacking ── */
  .tl-h-outer {
    position: relative;
    width: 100%;
  }
  .tl-h-sticky {
    position: sticky;
    top: 80px;
    margin-top: 80px;
    height: clamp(380px, 46vh, 520px);
    width: 100%;
    display: flex;
    flex-direction: column;
  }
  .tl-h-progress {
    height: 1.5px;
    background: rgba(25,13,4,0.08);
    margin-bottom: 18px;
    border-radius: 1px;
    overflow: hidden;
    flex-shrink: 0;
  }
  .tl-h-progress-fill {
    height: 100%;
    background: #947b69;
    width: 0%;
    border-radius: 1px;
  }
  .tl-h-track {
    flex: 1;
    position: relative;
    overflow: hidden;
    min-height: 0;
  }
  .tl-h-card {
    position: absolute;
    inset: 0;
    background: none;
    border: 0.5px solid rgba(0,0,0,0.08);
    padding: 26px 30px 22px;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transform: translateY(100%);
    transition: transform 0.55s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
  }
  .tl-h-card--active { transform: translateY(0); }
  .tl-h-card--prev   { transform: translateY(-100%); }
  .tl-h-date {
    font-size: clamp(28px, 2.6vw, 42px);
    font-style: italic;
    font-weight: 500;
    color: #1a1a1a;
    line-height: 1.1;
    margin: 0 0 6px;
    font-family: inherit;
    padding: 0;
    display: inline-block;
    transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: default;
  }
  .tl-h-date:hover { transform: scale(1.06); }
  .tl-h-rule {
    border: none;
    border-top: 0.5px solid rgba(0,0,0,0.1);
    margin: 0 0 12px;
    width: 100%;
    flex-shrink: 0;
  }
  .tl-h-tag {
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: rgba(0,0,0,0.38);
    margin: 0 0 7px;
    font-family: inherit;
    font-style: normal;
    padding: 0;
    flex-shrink: 0;
  }
  .tl-h-head {
    font-size: 13px;
    font-style: normal;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.13em;
    line-height: 1.4;
    color: #1a1a1a;
    margin: 0 0 10px;
    font-family: inherit;
    padding: 0;
    flex-shrink: 0;
  }
  .tl-h-body {
    font-size: 0.88em;
    line-height: 1.6;
    color: rgba(0,0,0,0.5);
    margin: 0;
    padding: 0;
    font-family: inherit;
    font-weight: 400;
    font-style: normal;
    flex: 1;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 7;
    -webkit-box-orient: vertical;
  }
  .tl-h-dots {
    display: flex;
    gap: 7px;
    padding-top: 14px;
    align-items: center;
    flex-shrink: 0;
  }
  .tl-h-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    border: none;
    background: rgba(25,13,4,0.3);
    padding: 0;
    cursor: pointer;
    transition: background 0.25s ease, transform 0.25s ease;
  }
  .tl-h-dot--active {
    background: #2a2a2a;
    transform: scale(1.5);
  }
  @media screen and (max-width: 767px) {
    .tl-h-outer { height: auto !important; }
    .tl-h-sticky {
      position: relative !important;
      top: 0 !important;
      height: auto !important;
      overflow: visible;
    }
    .tl-h-track {
      overflow-x: visible !important;
      overflow-y: auto !important;
      scroll-snap-type: y mandatory;
      -webkit-overflow-scrolling: touch;
    }
    .tl-h-card {
      position: relative !important;
      inset: auto !important;
      transform: none !important;
      transition: none !important;
      height: auto !important;
      min-height: 260px;
      display: none;
    }
    .tl-h-card--active {
      display: flex !important;
    }
  }

  /* ── Embed: Pull Quote / Large Text ── */
  .epq {
    margin: 0;
    padding: 16px 0 48px;
  }
  .epq__text {
    font-family: inherit;
    font-size: clamp(18px, 1.8vw, 26px);
    font-weight: 500;
    font-style: normal;
    line-height: 1.4;
    color: #0f0f0f;
    letter-spacing: 0.02em;
    text-transform: none;
    margin: 0;
  }
  .epq__word {
    display: inline-block;
    cursor: default;
    /* scroll-in start state */
    opacity: 0;
    filter: blur(14px);
    transform: translateY(10px);
    transition:
      opacity   .75s cubic-bezier(.16,1,.3,1),
      filter    .75s cubic-bezier(.16,1,.3,1),
      transform .75s cubic-bezier(.16,1,.3,1),
      color     .3s  ease;
  }
  .epq__word.epq--in {
    opacity: 1;
    filter: blur(0);
    transform: translateY(0);
  }
  .epq__word.epq--in:hover {
    transform: translateY(-5px);
    color: #947b69;
    filter: blur(0);
  }
</style>

<script>
  /* ── Centered article body restructure ── */
  (function() {
    var body = document.querySelector('.Article__Body');
    if (!body) return;

    /* Unwrap editor wrappers (ppv1-story__text etc.) so embeds become direct children */
    Array.from(body.querySelectorAll('.ppv1-story__text')).forEach(function(wrapper) {
      while (wrapper.firstChild) wrapper.parentNode.insertBefore(wrapper.firstChild, wrapper);
      wrapper.remove();
    });

    var nodes = Array.from(body.childNodes);
    var sections = [];
    var cur = null; // { type:'text', heading:el|null, right:[] } | { type:'img', el, alt } | { type:'rule' }

    function flush() { if (cur) { sections.push(cur); cur = null; } }

    function isFullWidthEmbed(n) {
      if (n.nodeType !== 1) return false;
      return n.classList.contains('tl-h-outer');
    }

    function isImgNode(n) {
      if (n.nodeType !== 1) return false;
      var t = n.tagName.toLowerCase();
      if (t === 'img') return true;
      if (t === 'figure') return true;
      /* div/p wrapping only an img (editor sometimes does this) */
      if ((t === 'div' || t === 'p') && n.children.length === 1 && n.querySelector('img') &&
          !n.classList.contains('epq') &&
          !n.classList.contains('tl-outer') && !n.querySelector('.tl-outer')) return true;
      return false;
    }

    nodes.forEach(function(n) {
      /* Skip pure whitespace text nodes */
      if (n.nodeType === 3 && !n.textContent.trim()) return;

      /* Elements */
      if (n.nodeType === 1) {
        var tag = n.tagName.toLowerCase();

        if (tag === 'h2') {
          flush();
          cur = { type: 'text', heading: n, right: [] };
          return;
        }
        if (tag === 'hr') { return; /* skip dividers */ }
        if (isFullWidthEmbed(n)) {
          flush();
          sections.push({ type: 'embed', el: n });
          return;
        }
        if (isImgNode(n)) {
          flush();
          var img = n.tagName.toLowerCase() === 'img' ? n : n.querySelector('img');
          sections.push({ type: 'img', el: n, alt: img ? (img.getAttribute('alt') || '') : '' });
          return;
        }
      }

      /* Everything else → right column of current text section */
      if (!cur || cur.type !== 'text') cur = { type: 'text', heading: null, right: [] };
      cur.right.push(n);
    });
    flush();

    if (!sections.length) return;

    var frag = document.createDocumentFragment();
    sections.forEach(function(sec, i) {
      if (sec.type === 'embed') {
        sec.el.classList.add('art-fade-in');
        frag.appendChild(sec.el);
        return;
      }
      if (sec.type === 'img') {
        var row = document.createElement('div');
        row.className = 'art-body-section-img art-fade-in';
        if (sec.alt) {
          var capWrap = document.createElement('div');
          capWrap.className = 'art-body-caption-wrap';
          var cp = document.createElement('p');
          cp.className = 'art-body-caption';
          cp.textContent = sec.alt;
          capWrap.appendChild(cp);
          row.appendChild(capWrap);
        }
        var imgCol = document.createElement('div');
        imgCol.className = 'art-body-img-col';
        imgCol.appendChild(sec.el);
        row.appendChild(imgCol);
        frag.appendChild(row);
        return;
      }
      if (sec.type === 'text') {
        if (!sec.heading && !sec.right.length) return;
        var row = document.createElement('div');
        row.className = 'art-body-section-text art-fade-in';
        var left = document.createElement('div');
        left.className = 'art-body-left';
        if (sec.heading) {
          sec.heading.className = 'art-body-section-h';
          left.appendChild(sec.heading);
        }
        var right = document.createElement('div');
        right.className = 'art-body-right';
        sec.right.forEach(function(n) { right.appendChild(n); });
        row.appendChild(left);
        row.appendChild(right);
        frag.appendChild(row);
      }
    });

    body.innerHTML = '';
    body.appendChild(frag);

    /* Scroll fade-in */
    var io = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); }
      });
    }, { threshold: 0.06, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.art-fade-in').forEach(function(el, i) {
      el.style.transitionDelay = (i * 0.05) + 's';
      io.observe(el);
    });

    /* ---- Product margin annotations ---- */
    document.querySelectorAll('.art-product-anchor').forEach(function(anchor) {
      var img = anchor.getAttribute('data-p-img');
      var caption = anchor.getAttribute('data-p-caption');
      var sub = anchor.getAttribute('data-p-sub');
      if (!img && !caption) return;
      var card = document.createElement('div');
      card.className = 'art-product-card';
      var html = '';
      if (img) html += '<img class="art-product-card__img" src="' + img + '" alt="' + (caption || '').replace(/"/g, '&quot;') + '" loading="lazy">';
      if (caption) html += '<span class="art-product-card__caption">' + caption + '</span>';
      if (sub) html += '<span class="art-product-card__sub">' + sub + '</span>';
      card.innerHTML = html;
      anchor.appendChild(card);
    });

    /* ---- Card block scroll-in ---- */
    var cbCards = document.querySelectorAll('.art-card-block__card');
    if (cbCards.length) {
      var cbIo = new IntersectionObserver(function(entries) {
        entries.forEach(function(e) {
          if (e.isIntersecting) { e.target.classList.add('art-cb--in'); cbIo.unobserve(e.target); }
        });
      }, { threshold: 0.2 });
      cbCards.forEach(function(card, i) {
        card.style.transitionDelay = (0.1 * i) + 's';
        cbIo.observe(card);
      });
    }

    /* ---- Product block scroll-in ---- */
    var pbCards = document.querySelectorAll('.art-product-block__card');
    if (pbCards.length) {
      var pbIo = new IntersectionObserver(function(entries) {
        entries.forEach(function(e) {
          if (e.isIntersecting) { e.target.classList.add('art-pb--in'); pbIo.unobserve(e.target); }
        });
      }, { threshold: 0.2 });
      pbCards.forEach(function(card, i) {
        card.style.transitionDelay = (0.1 * i) + 's';
        pbIo.observe(card);
      });
    }

    /* ---- Hotspot image ---- */
    document.querySelectorAll('.art-hotspot').forEach(function(hotspot) {
      var wrap = hotspot.querySelector('.art-hotspot__img-wrap');
      if (!wrap) return;
      var dots = wrap.querySelectorAll('.art-hotspot__dot');
      var isMobile = !window.matchMedia('(hover: hover)').matches;
      var activeTooltip = null;

      function showTooltip(dot) {
        hideTooltip();
        var label = dot.getAttribute('data-hs-label');
        if (!label) return;
        var tip = document.createElement('div');
        tip.className = 'art-hotspot__tooltip';
        tip.textContent = label;
        tip.style.left = dot.style.left;
        tip.style.top = dot.style.top;
        /* Position below if dot is near top */
        var yPct = parseFloat(dot.style.top);
        if (yPct < 25) tip.classList.add('art-hotspot__tooltip--below');
        wrap.appendChild(tip);
        activeTooltip = tip;
        requestAnimationFrame(function() {
          requestAnimationFrame(function() {
            tip.classList.add('art-hotspot__tooltip--visible');
          });
        });
      }

      function hideTooltip() {
        if (activeTooltip) { activeTooltip.remove(); activeTooltip = null; }
      }

      dots.forEach(function(dot) {
        if (isMobile) {
          dot.addEventListener('click', function(e) {
            e.stopPropagation();
            if (activeTooltip && activeTooltip._dot === dot) { hideTooltip(); return; }
            showTooltip(dot);
            if (activeTooltip) activeTooltip._dot = dot;
          });
        } else {
          dot.addEventListener('mouseenter', function() { showTooltip(dot); });
          dot.addEventListener('mouseleave', function() { hideTooltip(); });
        }
      });

      if (isMobile) {
        document.addEventListener('click', function() { hideTooltip(); });
      }

      /* Scroll-in: staggered dot appearance */
      var hsIo = new IntersectionObserver(function(entries) {
        entries.forEach(function(e) {
          if (!e.isIntersecting) return;
          hsIo.disconnect();
          dots.forEach(function(dot, i) {
            setTimeout(function() { dot.classList.add('art-hs--in'); }, 300 + i * 150);
          });
        });
      }, { threshold: 0.3 });
      hsIo.observe(wrap);
    });
  })();

  (function() {

    /* ---- Progress bar: tracks article content, not full page ---- */
    var bar     = document.getElementById('article-progress-bar');
    var content = document.querySelector('.Article__Content');
    if (bar) {
      function updateBar() {
        var scrollTop = window.pageYOffset || document.documentElement.scrollTop;
        var pct = 0;
        if (content) {
          var contentTop = content.getBoundingClientRect().top + scrollTop;
          var scrollable = content.offsetHeight - window.innerHeight;
          if (scrollable > 0) {
            pct = Math.min(100, Math.max(0, (scrollTop - contentTop) / scrollable * 100));
          } else {
            pct = scrollTop >= contentTop ? 100 : 0;
          }
        } else {
          var docH = document.documentElement.scrollHeight - window.innerHeight;
          pct = docH > 0 ? Math.min(100, (scrollTop / docH) * 100) : 0;
        }
        bar.style.width = pct + '%';
      }
      window.addEventListener('scroll', updateBar, { passive: true });
      updateBar();
    }

    /* ---- Share count (localStorage per article URL) ---- */
    var SHARE_KEY  = 'ff_shares';
    var articleUrl = window.location.pathname;
    function getCount() {
      try { return (JSON.parse(localStorage.getItem(SHARE_KEY) || '{}')[articleUrl]) || 0; } catch(e) { return 0; }
    }
    function incrementCount() {
      try {
        var data = JSON.parse(localStorage.getItem(SHARE_KEY) || '{}');
        data[articleUrl] = (data[articleUrl] || 0) + 1;
        localStorage.setItem(SHARE_KEY, JSON.stringify(data));
        return data[articleUrl];
      } catch(e) { return 0; }
    }
    function updateCountEl(n) {
      var el = document.getElementById('article-share-count');
      if (el) el.textContent = n;
    }
    updateCountEl(getCount());
    document.querySelectorAll('[data-share-btn]').forEach(function(btn) {
      btn.addEventListener('click', function() { updateCountEl(incrementCount()); });
    });

    /* ---- Copy link button ---- */
    var copyBtn   = document.getElementById('article-copy-link');
    var copyLabel = document.getElementById('article-copy-label');
    if (copyBtn) {
      copyBtn.addEventListener('click', function() {
        var url = copyBtn.getAttribute('data-url') || window.location.href;
        function onCopied() {
          copyLabel.textContent = 'Copied!';
          copyBtn.classList.add('Article__CopyLinkBtn--copied');
          updateCountEl(incrementCount());
          setTimeout(function() {
            copyLabel.textContent = 'Copy link';
            copyBtn.classList.remove('Article__CopyLinkBtn--copied');
          }, 2000);
        }
        if (navigator.clipboard) {
          navigator.clipboard.writeText(url).then(onCopied);
        } else {
          var ta = document.createElement('textarea');
          ta.value = url; ta.style.cssText = 'position:fixed;opacity:0';
          document.body.appendChild(ta); ta.select(); document.execCommand('copy');
          document.body.removeChild(ta); onCopied();
        }
      });
    }

    /* ---- Show toolbar only after hero scrolls fully past viewport top ---- */
    var toolbar  = document.querySelector('.ArticleToolbar');
    var heroTrigger = document.getElementById('par-hero') || document.querySelector('.art-editorial-header');
    if (toolbar && heroTrigger) {
      toolbar.classList.add('hero-locked');
      function checkToolbarVisibility() {
        var top = heroTrigger.getBoundingClientRect().top;
        toolbar.classList.toggle('hero-locked', top > 0);
      }
      window.addEventListener('scroll', checkToolbarVisibility, { passive: true });
      checkToolbarVisibility();
    }

    /* ---- Hide header on scroll down, reveal on scroll up (desktop only) ---- */
    if (window.innerWidth >= 1008) {
      var siteHeader = document.querySelector('header.Header');
      if (siteHeader) {
        var lastScrollY = window.scrollY;
        var scrollThreshold = 80;
        window.addEventListener('scroll', function() {
          var currentY = window.scrollY;
          var artToolbar = document.querySelector('.ArticleToolbar');
          if (currentY < scrollThreshold) {
            siteHeader.classList.remove('art-header-hidden');
            if (artToolbar) artToolbar.classList.remove('art-toolbar-top');
          } else if (currentY > lastScrollY) {
            siteHeader.classList.add('art-header-hidden');
            if (artToolbar) artToolbar.classList.add('art-toolbar-top');
          } else {
            siteHeader.classList.remove('art-header-hidden');
            if (artToolbar) artToolbar.classList.remove('art-toolbar-top');
          }
          lastScrollY = currentY;
        }, { passive: true });
      }
    }

    /* ---- Parallax hero ---- */
    var parHero  = document.getElementById('par-hero');
    var parImg   = document.getElementById('par-img');
    var parCtaEl = document.getElementById('par-cta');

    if (parHero && parImg && !window.matchMedia('(hover: hover)').matches) {
      /* Mobile: scroll-driven vertical parallax */
      function mobileParallax() {
        var rect  = parHero.getBoundingClientRect();
        var drift = Math.min(55, Math.max(0, (window.innerHeight - rect.top) * 0.06));
        parImg.style.transform = 'translateY(' + drift + 'px) scale(1.12)';
      }
      window.addEventListener('scroll', mobileParallax, { passive: true });
      mobileParallax();
    }

    if (parHero && parImg && window.matchMedia('(hover: hover)').matches) {
      var pMouse  = { x: 0, y: 0 };
      var imgT    = { x: 0, y: 0 };
      var imgC    = { x: 0, y: 0 };
      var pInside = false;

      function plerp(a, b, n) { return a + (b - a) * n; }

      parHero.addEventListener('mousemove', function(e) {
        var r  = parHero.getBoundingClientRect();
        pMouse.x = (e.clientX - r.left) / r.width  - 0.5;
        pMouse.y = (e.clientY - r.top)  / r.height - 0.5;
      });
      parHero.addEventListener('mouseenter', function() { pInside = true; });
      parHero.addEventListener('mouseleave', function() { pInside = false; imgT.x = 0; imgT.y = 0; });

      (function ptick() {
        if (pInside) { imgT.x = pMouse.x * -24; imgT.y = pMouse.y * -16; }
        imgC.x = plerp(imgC.x, imgT.x, 0.06);
        imgC.y = plerp(imgC.y, imgT.y, 0.06);
        parImg.style.transform = 'translate(' + imgC.x + 'px,' + imgC.y + 'px) scale(1.08)';
        requestAnimationFrame(ptick);
      })();
    }

    if (parCtaEl) {
      parCtaEl.addEventListener('click', function(e) {
        var target = document.getElementById('article-body');
        if (!target) return;
        e.preventDefault();
        var start      = window.pageYOffset;
        var toolbar    = document.querySelector('.ArticleToolbar');
        var headerH    = parseInt(getComputedStyle(document.documentElement).getPropertyValue('--header-height')) || 0;
        var toolbarH   = toolbar ? toolbar.offsetHeight : 0;
        var end        = parHero.getBoundingClientRect().bottom + start - headerH - toolbarH;
        var duration = 1400;
        var t0       = performance.now();
        function ease(t) { return t < 0.5 ? 4*t*t*t : 1 - Math.pow(-2*t+2, 3)/2; }
        (function step(now) {
          var p = Math.min((now - t0) / duration, 1);
          window.scrollTo(0, start + (end - start) * ease(p));
          if (p < 1) requestAnimationFrame(step);
        })(t0);
      });
    }

    /* ---- Parallax images (Apple-style: continuous RAF + lerp) ---- */
    var bodyEl = document.querySelector('.Article__Body');
    if (bodyEl) {
      bodyEl.querySelectorAll('img').forEach(function(img) {
        if (img.closest('.Article__ParallaxWrap')) return;
        if (img.closest('.art-product-card')) return;
        if (img.closest('.art-hotspot__img-wrap')) return;
        var wrap = document.createElement('div');
        wrap.className = 'Article__ParallaxWrap';
        img.parentNode.insertBefore(wrap, img);
        wrap.appendChild(img);
      });

      /* Wrap each hotspot in a parallax container */
      bodyEl.querySelectorAll('.art-hotspot__img-wrap').forEach(function(imgWrap) {
        var parWrap = document.createElement('div');
        parWrap.className = 'Article__ParallaxWrap';
        imgWrap.parentNode.insertBefore(parWrap, imgWrap);
        parWrap.appendChild(imgWrap);
      });

      var parItems = [];
      bodyEl.querySelectorAll('.Article__ParallaxWrap').forEach(function(wrap) {
        var target = wrap.querySelector('.art-hotspot__img-wrap') || wrap.querySelector('img');
        if (target) parItems.push({ wrap: wrap, img: target, cur: 0, tgt: 0 });
      });

      function parTick() {
        var vH = window.innerHeight;
        parItems.forEach(function(item) {
          var rect  = item.wrap.getBoundingClientRect();
          var range = vH / 2 + rect.height / 2;
          var prog  = (vH / 2 - (rect.top + rect.height / 2)) / range;
          var maxT  = rect.height * 0.08;
          item.tgt  = Math.max(-maxT, Math.min(maxT, prog * maxT * 1.6));
          item.cur += (item.tgt - item.cur) * 0.06; /* lerp factor — lower = smoother/lazier */
          item.img.style.transform = 'translateY(' + item.cur.toFixed(2) + 'px) scale(1.12)';
        });
        requestAnimationFrame(parTick);
      }

      parTick();
    }

  })();

  /* ── Embed: Pull Quote — scroll-in blur + stagger ── */
  (function() {
    document.querySelectorAll('[data-epq-id]').forEach(function(el) {
      el.innerHTML = el.textContent.trim().split(' ').map(function(w) {
        return '<span class="epq__word">' + w + '</span>';
      }).join(' ');

      var block    = el.closest('.epq');
      var words    = el.querySelectorAll('.epq__word');
      var fired    = false;

      new IntersectionObserver(function(entries, obs) {
        if (!entries[0].isIntersecting || fired) return;
        fired = true;
        obs.disconnect();
        words.forEach(function(w, i) {
          setTimeout(function() { w.classList.add('epq--in'); }, 350 + i * 80);
        });
      }, { threshold: 0.25 }).observe(block || el);
    });
  })();
</script>

{% schema %}
{
  "name": "Blog post page",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_article_image",
      "label": "Show article image",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "label": "Show article date",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_category",
      "label": "Show article category",
      "info": "The first article's tag is used as the main category.",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_author",
      "label": "Show author",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_share_buttons",
      "label": "Show share buttons",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_prev_next",
      "label": "Show prev/next articles",
      "default": true
    }
  ]
}
{% endschema %}