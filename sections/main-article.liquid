  .art-body-caption {
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: #1a1a1a;
    line-height: 1.4;
    margin: 0;
  }

  /* Product margin annotation cards */
  /* Product margin annotation cards (timeline-style) */
  .art-product-anchor { display: block; position: relative; height: 0; overflow: visible; }
  .art-product-card {
    position: absolute;
    right: calc(-1 * clamp(120px, 10vw, 180px) - 55px);
    top: 0;
    width: clamp(120px, 10vw, 180px);
