          {%- assign _content = _content | replace: '<p> [dual_image_1] </p>', _di_html -%}
          {%- assign _content = _content | replace: '<p>[dual_image_1] </p>', _di_html -%}
          {%- assign _content = _content | replace: '<p> [dual_image_1]</p>', _di_html -%}
        {%- else -%}
