                {%- for _ib_line in _ib_lines -%}
                  {%- assign _ib_line_s = _ib_line | strip -%}
                  {%- if _ib_line_s == blank -%}{%- continue -%}{%- endif -%}
                  {%- assign _ib_parts = _ib_line_s | split: ':' -%}
                  {%- if _ib_parts.size >= 2 -%}
                    {%- assign _ib_key = _ib_parts.first | strip -%}
                    {%- assign _ib_val_rest = _ib_line_s | remove_first: _ib_parts.first | remove_first: ':' | strip -%}
                    <div class="art-info-box__row">
                      <dt class="art-info-box__key">{{ _ib_key }}</dt>
                      <dd class="art-info-box__val">{{ _ib_val_rest }}</dd>
                    </div>
                  {%- else -%}
                    <div class="art-info-box__row art-info-box__row--full">
                      <dd class="art-info-box__val">{{ _ib_line_s }}</dd>
                    </div>
