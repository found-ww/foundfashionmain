                {%- endfor -%}
              </dl>
            </div>
          {%- endcapture -%}
          {%- assign _content = _content | replace: '<p>[info_box_1]</p>', _ib_html -%}
          {%- assign _content = _content | replace: '<p> [info_box_1] </p>', _ib_html -%}
          {%- assign _content = _content | replace: '<p>[info_box_1] </p>', _ib_html -%}
          {%- assign _content = _content | replace: '<p> [info_box_1]</p>', _ib_html -%}
        {%- else -%}
          {%- assign _content = _content | replace: '<p>[info_box_1]</p>', '' -%}
          {%- assign _content = _content | replace: '<p> [info_box_1] </p>', '' -%}
          {%- assign _content = _content | replace: '<p>[info_box_1] </p>', '' -%}
          {%- assign _content = _content | replace: '<p> [info_box_1]</p>', '' -%}
        {%- endif -%}

        {%- comment -%}--- Steps block ---{%- endcomment -%}
        {%- capture _steps_html -%}
          <div class="art-steps">
            <div class="art-step">
              <div class="art-step__num">1</div>
              <div class="art-step__content">
                <p class="art-step__title">Location</p>
                <p class="art-step__body">The system works best on French WiFi, but some people including UK visitors do apply successfully before travelling. Always worth trying early, and apply every day once you arrive.</p>
              </div>
            </div>
            <div class="art-step">
              <div class="art-step__num">2</div>
              <div class="art-step__content">
                <p class="art-step__title">Visit the website</p>
                <p class="art-step__body">Go to <a href="https://rendezvousparis.hermes.com" target="_blank" rel="noopener">rendezvousparis.hermes.com</a> on your smartphone between <strong>10:30 and 19:00 Paris time</strong>, the day before your desired appointment.</p>
              </div>
            </div>
            <div class="art-step">
              <div class="art-step__num">3</div>
              <div class="art-step__content">
                <p class="art-step__title">Fill in the form</p>
                <p class="art-step__body">Enter your name, passport number, phone number, email address and preferred store.</p>
              </div>
            </div>
            <div class="art-step art-step--accent">
              <div class="art-step__num art-step__num--icon">
                <svg width="15" height="15" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M8 1.5L14.5 13H1.5L8 1.5Z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/><line x1="8" y1="6" x2="8" y2="9.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><circle cx="8" cy="11.5" r="0.6" fill="currentColor"/></svg>
              </div>
              <div class="art-step__content">
                <p class="art-step__title">Confirm via email - do not skip this</p>
                <p class="art-step__body">You will receive a "Welcome to Hermès" email - this is <strong>not</strong> a confirmation. Find the second email titled "Please confirm your appointment request" and click the blue link. If you skip this, your entry is void.</p>
              </div>
            </div>
            <div class="art-step">
              <div class="art-step__num">5</div>
              <div class="art-step__content">
                <p class="art-step__title">Wait for results</p>
                <p class="art-step__body">Results come by email in the evening. No email means no appointment - try again tomorrow. If you do get one, keep checking on the day as your time slot can change.</p>
              </div>
            </div>
          </div>
        {%- endcapture -%}
        {%- assign _content = _content | replace: '<p>[steps_1]</p>', _steps_html -%}
        {%- assign _content = _content | replace: '<p> [steps_1] </p>', _steps_html -%}
        {%- assign _content = _content | replace: '<p>[steps_1] </p>', _steps_html -%}
        {%- assign _content = _content | replace: '<p> [steps_1]</p>', _steps_html -%}

        {%- comment -%}--- Callout block ---{%- endcomment -%}
        {%- assign _callout_val = article.metafields.custom.callout_1.value -%}
        {%- if _callout_val != blank -%}
          {%- capture _callout_html -%}
            <div class="art-callout">
              <div class="art-callout__icon">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M8 1.5L14.5 13H1.5L8 1.5Z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/><line x1="8" y1="6" x2="8" y2="9.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><circle cx="8" cy="11.5" r="0.6" fill="currentColor"/></svg>
              </div>
              <div class="art-callout__body">{{ _callout_val | newline_to_br }}</div>
            </div>
          {%- endcapture -%}
          {%- assign _content = _content | replace: '<p>[callout_1]</p>', _callout_html -%}
          {%- assign _content = _content | replace: '<p> [callout_1] </p>', _callout_html -%}
          {%- assign _content = _content | replace: '<p>[callout_1] </p>', _callout_html -%}
          {%- assign _content = _content | replace: '<p> [callout_1]</p>', _callout_html -%}
        {%- else -%}
          {%- assign _content = _content | replace: '<p>[callout_1]</p>', '' -%}
          {%- assign _content = _content | replace: '<p> [callout_1] </p>', '' -%}
          {%- assign _content = _content | replace: '<p>[callout_1] </p>', '' -%}
          {%- assign _content = _content | replace: '<p> [callout_1]</p>', '' -%}
        {%- endif -%}

        {%- comment -%}--- Large word block ---{%- endcomment -%}
        {%- assign _lw_val = article.metafields.custom.large_word.value -%}
        {%- if _lw_val != blank -%}
          {%- capture _lw_html -%}
            <div class="art-large-word" aria-hidden="true">{{ _lw_val | escape }}</div>
          {%- endcapture -%}
          {%- assign _content = _content | replace: '<p>[large_word]</p>', _lw_html -%}
          {%- assign _content = _content | replace: '<p> [large_word] </p>', _lw_html -%}
          {%- assign _content = _content | replace: '<p>[large_word] </p>', _lw_html -%}
          {%- assign _content = _content | replace: '<p> [large_word]</p>', _lw_html -%}
        {%- else -%}
          {%- assign _content = _content | replace: '<p>[large_word]</p>', '' -%}
          {%- assign _content = _content | replace: '<p> [large_word] </p>', '' -%}
          {%- assign _content = _content | replace: '<p>[large_word] </p>', '' -%}
          {%- assign _content = _content | replace: '<p> [large_word]</p>', '' -%}
        {%- endif -%}

        {%- comment -%}--- Store cards block (Paris) ---{%- endcomment -%}
        {%- capture _sc_html -%}
          <div class="art-store-grid">

            <div class="art-store-card">
              <div class="art-store-card__header">
                <span class="art-store-card__badge art-store-card__badge--featured">Flagship</span>
                <p class="art-store-card__name">Faubourg Saint-Honoré</p>
              </div>
              <div class="art-store-card__body">
                <div class="art-store-card__meta">
                  <span>24 Rue du Faubourg Saint-Honoré, 75008 Paris</span>
                  <span>Mon-Sat 10:30-18:30</span>
                </div>
                <p class="art-store-card__desc">The biggest store with the most stock. This is the best place to find a Birkin or Kelly. It is busy and popular, but has more bags than the other two stores.</p>
                <div class="art-store-card__divider"></div>
                <p class="art-store-card__best-label">Best for</p>
                <p class="art-store-card__best-val">Best chance of finding a Birkin or Kelly</p>
              </div>
            </div>

            <div class="art-store-card">
              <div class="art-store-card__header">
                <span class="art-store-card__badge">Near Champs-Élysées</span>
                <p class="art-store-card__name">George V</p>
              </div>
              <div class="art-store-card__body">
                <div class="art-store-card__meta">
                  <span>42 Avenue George V, 75008 Paris</span>
                  <span>Mon-Sat 10:30-18:30</span>
                </div>
                <p class="art-store-card__desc">A smaller store close to the Champs-Élysées. A good option if you are staying nearby. Less busy than the flagship store.</p>
                <div class="art-store-card__divider"></div>
                <p class="art-store-card__best-label">Best for</p>
                <p class="art-store-card__best-val">Central location, less busy</p>
              </div>
            </div>

            <div class="art-store-card">
              <div class="art-store-card__header">
                <span class="art-store-card__badge">Hidden Gem</span>
                <p class="art-store-card__name">Sèvres</p>
              </div>
              <div class="art-store-card__body">
                <div class="art-store-card__meta">
                  <span>17 Rue de Sèvres, 75006 Paris</span>
                  <span>Mon-Sat 10:30-19:00</span>
                </div>
                <p class="art-store-card__desc">Built inside a beautiful 1935 swimming pool. Has a café, a bookstore, and is the only Hermès store in the world to sell the Petit H collection. Most experienced Hermès shoppers say this is their favourite.</p>
                <div class="art-store-card__divider"></div>
                <p class="art-store-card__best-label">Best for</p>
                <p class="art-store-card__best-val">Best atmosphere, unique products, open the latest</p>
              </div>
            </div>

          </div>
          <p class="art-store-tip">Tip: Choose "No Preference" when applying to be entered into all three stores at the same time.</p>
        {%- endcapture -%}
        {%- assign _content = _content | replace: '<p>[store_cards]</p>', _sc_html -%}
        {%- assign _content = _content | replace: '<p> [store_cards] </p>', _sc_html -%}
        {%- assign _content = _content | replace: '<p>[store_cards] </p>', _sc_html -%}
        {%- assign _content = _content | replace: '<p> [store_cards]</p>', _sc_html -%}

        {%- comment -%}--- Store cards block (London) ---{%- endcomment -%}
        {%- capture _sc_london_html -%}
          <div class="art-store-grid">

            <div class="art-store-card">
              <div class="art-store-card__header">
                <span class="art-store-card__badge art-store-card__badge--featured">Flagship</span>
                <p class="art-store-card__name">Bond Street</p>
              </div>
              <div class="art-store-card__body">
                <div class="art-store-card__meta">
                  <span>179 New Bond Street, W1S 4RL</span>
                  <span>Mon-Sat 10:00-18:30, Sun 12:00-18:00</span>
                </div>
                <p class="art-store-card__desc">The London flagship. The largest selection in the city but also the most competitive. A strong base of high-spending local regulars means first-time visitors rarely receive quota bags here.</p>
                <div class="art-store-card__divider"></div>
                <p class="art-store-card__best-label">Best for</p>
                <p class="art-store-card__best-val">Established clients, widest selection</p>
              </div>
            </div>

            <div class="art-store-card">
              <div class="art-store-card__header">
                <span class="art-store-card__badge">Quieter</span>
                <p class="art-store-card__name">Sloane Street</p>
              </div>
              <div class="art-store-card__body">
                <div class="art-store-card__meta">
                  <span>41 Sloane Street, SW1X 9LP</span>
                  <span>Mon-Sat 10:00-18:30</span>
                </div>
                <p class="art-store-card__desc">Smaller and less busy than Bond Street. A better environment if you are building a relationship and do not visit London every month. The SAs have more time and the atmosphere is calmer.</p>
                <div class="art-store-card__divider"></div>
                <p class="art-store-card__best-label">Best for</p>
                <p class="art-store-card__best-val">Building a relationship, less competitive</p>
              </div>
            </div>

            <div class="art-store-card">
              <div class="art-store-card__header">
                <span class="art-store-card__badge">Department Store</span>
                <p class="art-store-card__name">Harrods</p>
              </div>
              <div class="art-store-card__body">
                <div class="art-store-card__meta">
                  <span>87-135 Brompton Road, SW1X 7XL</span>
                  <span>Mon-Sat 10:00-21:00, Sun 11:30-18:00</span>
                </div>
                <p class="art-store-card__desc">Worth visiting if you are already in Knightsbridge. Can occasionally have non-quota bags available and benefits from longer opening hours than the standalone boutiques.</p>
                <div class="art-store-card__divider"></div>
                <p class="art-store-card__best-label">Best for</p>
                <p class="art-store-card__best-val">Non-quota bags, longest opening hours</p>
              </div>
            </div>

          </div>
        {%- endcapture -%}
        {%- assign _content = _content | replace: '<p>[store_cards_london]</p>', _sc_london_html -%}
        {%- assign _content = _content | replace: '<p> [store_cards_london] </p>', _sc_london_html -%}
        {%- assign _content = _content | replace: '<p>[store_cards_london] </p>', _sc_london_html -%}
        {%- assign _content = _content | replace: '<p> [store_cards_london]</p>', _sc_london_html -%}

        {%- comment -%}--- FAQ accordion block ---{%- endcomment -%}
        {%- assign _faq_val = article.metafields.custom.faq_1.value -%}
        {%- if _faq_val != blank -%}
          {%- assign _faq_lines = _faq_val | split: '
' -%}
          {%- capture _faq_html -%}
            <div class="art-faq">
              {%- assign _faq_i = 0 -%}
              {%- for _line in _faq_lines -%}
                {%- assign _line_stripped = _line | strip -%}
                {%- if _line_stripped != '' -%}
                  {%- assign _faq_mod = _faq_i | modulo: 2 -%}
                  {%- if _faq_mod == 0 -%}
                    <div class="art-faq__item">
                      <button class="art-faq__question" type="button" aria-expanded="false">
                        <span>{{ _line_stripped }}</span>
                        <svg class="art-faq__icon" width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.2"><line x1="7" y1="2" x2="7" y2="12" class="art-faq__vline"/><line x1="2" y1="7" x2="12" y2="7"/></svg>
                      </button>
                  {%- else -%}
                      <div class="art-faq__answer">
                        <p>{{ _line_stripped }}</p>
                      </div>
                    </div>
                  {%- endif -%}
                  {%- assign _faq_i = _faq_i | plus: 1 -%}
                {%- endif -%}
              {%- endfor -%}
            </div>
          {%- endcapture -%}
          {%- assign _content = _content | replace: '<p>[faq_1]</p>', _faq_html -%}
          {%- assign _content = _content | replace: '<p> [faq_1] </p>', _faq_html -%}
          {%- assign _content = _content | replace: '<p>[faq_1] </p>', _faq_html -%}
          {%- assign _content = _content | replace: '<p> [faq_1]</p>', _faq_html -%}
        {%- else -%}
          {%- assign _content = _content | replace: '<p>[faq_1]</p>', '' -%}
          {%- assign _content = _content | replace: '<p> [faq_1] </p>', '' -%}
          {%- assign _content = _content | replace: '<p>[faq_1] </p>', '' -%}
          {%- assign _content = _content | replace: '<p> [faq_1]</p>', '' -%}
        {%- endif -%}

        {%- comment -%}--- FAQPage structured data ---{%- endcomment -%}
        {%- assign _faq_schema_val = article.metafields.custom.faq_1.value -%}
        {%- if _faq_schema_val != blank -%}
          {%- assign _faq_schema_lines = _faq_schema_val | split: '
' -%}
          {%- assign _faq_schema_i = 0 -%}
          {%- assign _faq_schema_q = '' -%}
          {%- assign _faq_schema_sep = '' -%}
          {%- capture _faq_schema_items -%}
            {%- for _line in _faq_schema_lines -%}
              {%- assign _line_s = _line | strip -%}
              {%- if _line_s != '' -%}
                {%- assign _faq_s_mod = _faq_schema_i | modulo: 2 -%}
                {%- if _faq_s_mod == 0 -%}
                  {%- assign _faq_schema_q = _line_s -%}
                {%- else -%}
                  {{ _faq_schema_sep }}{
                    "@type": "Question",
                    "name": {{ _faq_schema_q | json }},
                    "acceptedAnswer": {
                      "@type": "Answer",
                      "text": {{ _line_s | json }}
                    }
                  }
                  {%- assign _faq_schema_sep = ',' -%}
                {%- endif -%}
                {%- assign _faq_schema_i = _faq_schema_i | plus: 1 -%}
              {%- endif -%}
            {%- endfor -%}
          {%- endcapture -%}
          {%- if _faq_schema_items != blank -%}
            <script type="application/ld+json">
            {
              "@context": "https://schema.org",
              "@type": "FAQPage",
              "mainEntity": [{{ _faq_schema_items }}]
            }
            </script>
          {%- endif -%}
        {%- endif -%}

        {%- assign _gate_marker = '<p>[login_gate]</p>' -%}
        {%- if _content contains _gate_marker -%}
          {%- assign _content_parts = _content | split: _gate_marker -%}
          {{ _content_parts[0] }}
          <div class="art-gate" id="article-gate" data-logged-in="{{ customer.id | default: '' }}">
            <div class="art-gate__content">{{ _content_parts[1] }}</div>
            <div class="art-gate__overlay" hidden>
              <div class="art-gate__box">
                <p class="art-gate__eyebrow">Members only</p>
                <p class="art-gate__title">Continue reading</p>
                <p class="art-gate__body">Create an account or login to read the full article.</p>
                <a href="/account/register?return_url={{ request.path }}" class="art-gate__btn">Create a free account</a>
                <a href="/account/login?return_url={{ request.path }}" class="art-gate__link">Already have an account? Log in</a>
              </div>
            </div>
          </div>
          <script>
            (function(){
              var gate = document.querySelector('.art-gate');
              if (!gate) return;
              var loggedIn = gate.dataset.loggedIn !== '';
              if (!loggedIn) {
                gate.classList.add('art-gate--locked');
                gate.querySelector('.art-gate__overlay').hidden = false;
                gate.querySelectorAll('.art-gate__btn, .art-gate__link').forEach(function(el){
                  el.addEventListener('click', function(){
                    try { sessionStorage.setItem('gateReturn', window.location.pathname); } catch(e){}
                  });
                });
              }
            })();
          </script>
        {%- else -%}
          {{ _content }}
        {%- endif -%}
      </div>

      {%- capture article_footer -%}
        {%- if section.settings.show_author -%}
          <span class="Article__Author Heading Text--subdued u-h6">{{ 'blog.article.written_by' | t: author: article.author }}</span>
        {%- endif -%}

        {%- if section.settings.show_share_buttons -%}
          <div class="Article__ShareSection">
            <div class="Article__ShareHeader">
              <span class="Article__ShareCaption">Share this story</span>
              <span class="Article__ShareCount"><span id="article-share-count">0</span> shares</span>
            </div>
            <div class="Article__ShareRow">
              <a class="ShareButtons__Item ShareButtons__Item--instagram" href="{{ settings.social_instagram_link | default: 'https://www.instagram.com/' }}" target="_blank" rel="noopener" data-share-btn="instagram" aria-label="Share on Instagram">{%- render 'icon' with 'instagram' -%}</a>
              <a class="ShareButtons__Item ShareButtons__Item--whatsapp" href="https://wa.me/?text={{ article.title | url_encode }}%20{{ share_url | url_encode }}" target="_blank" rel="noopener" data-share-btn="whatsapp" aria-label="Share on WhatsApp">{%- render 'icon' with 'whatsapp' -%}</a>
              <a class="ShareButtons__Item ShareButtons__Item--facebook" href="https://www.facebook.com/sharer.php?u={{ share_url }}" target="_blank" rel="noopener" data-share-btn="facebook" aria-label="Share on Facebook">{%- render 'icon' with 'facebook' -%}</a>
              <a class="ShareButtons__Item ShareButtons__Item--x" href="https://twitter.com/share?{% if twitter_text != blank %}text={{ twitter_text }}&{% endif %}url={{ share_url }}" target="_blank" rel="noopener" data-share-btn="x" aria-label="Share on X">{%- render 'icon' with 'x' -%}</a>
              <button class="Article__CopyLinkBtn" id="article-copy-link" type="button" data-url="{{ share_url | escape }}">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>
                <span id="article-copy-label">Copy link</span>
              </button>
            </div>
          </div>
        {%- endif -%}
      {%- endcapture -%}

      {%- if article_footer != blank -%}
        <footer class="Article__Footer">
          {{ article_footer }}
        </footer>
      {%- endif -%}

    </div>

  </div>

  {%- if section.settings.show_prev_next and blog.next_article or blog.previous_article -%}
    <aside class="ArticleNav">
      <div class="Container Container--narrow">
        <div class="Grid Grid--m Grid--center">
          {%- if blog.next_article -%}
            <div class="Grid__Cell 1/2--tablet-and-up">
              {%- render 'article-item', article: blog.next_article -%}
            </div>
          {%- elsif blog.articles_count > 3 -%}
            <div class="Grid__Cell 1/2--tablet-and-up">
              {%- render 'article-item', article: blog.articles.last -%}
            </div>
          {%- endif -%}

          {%- if blog.previous_article -%}
            <div class="Grid__Cell 1/2--tablet-and-up">
              {%- render 'article-item', article: blog.previous_article -%}
            </div>
          {%- elsif blog.articles_count > 3 -%}
            <div class="Grid__Cell 1/2--tablet-and-up">
              {%- render 'article-item', article: blog.articles.first -%}
            </div>
          {%- endif -%}
        </div>
      </div>
    </aside>
  {%- endif -%}
</article>

