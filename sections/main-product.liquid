          {%- if ppv1_mat != blank -%}<dt class="ppv1-meta__key">Material</dt><dd class="ppv1-meta__val">{{ ppv1_mat }}</dd>{%- endif -%}
          {%- if ppv1_condition != blank -%}<dt class="ppv1-meta__key">Condition</dt><dd class="ppv1-meta__val">{{ ppv1_condition }}</dd>{%- endif -%}
