{%- comment -%} ─── Detect product category from tags ─── {%- endcomment -%}
{%- assign ppv1_cat = 'other' -%}
{%- for _tag in product.tags -%}
  {%- assign _tl = _tag | downcase -%}
  {%- if _tl == 'category:bags' or _tl == 'category:small leather goods' -%}
    {%- assign ppv1_cat = 'bags' -%}
  {%- elsif _tl == 'category:bag charm' -%}
    {%- assign ppv1_cat = 'charm' -%}
  {%- elsif _tl == 'category:clothingmen' or _tl == 'category:clothingwomen' -%}
    {%- assign ppv1_cat = 'clothing' -%}
  {%- elsif _tl == 'category:shoesmen' or _tl == 'category:shoeswomen' -%}
    {%- assign ppv1_cat = 'shoes' -%}
  {%- elsif _tl == 'category:scarf' or _tl == 'category:twilly' -%}
    {%- assign ppv1_cat = 'scarf' -%}
  {%- elsif _tl == 'category:belts' -%}
    {%- assign ppv1_cat = 'belts' -%}
  {%- elsif _tl == 'category:bracelet' -%}
    {%- assign ppv1_cat = 'bracelet' -%}
  {%- elsif _tl == 'section:homeware' -%}
    {%- assign ppv1_cat = 'homeware' -%}
  {%- elsif _tl == 'category:rings' -%}
    {%- assign ppv1_cat = 'rings' -%}
  {%- elsif _tl == 'category:necklace' -%}
    {%- assign ppv1_cat = 'necklace' -%}
  {%- elsif _tl == 'category:earrings' -%}
    {%- assign ppv1_cat = 'earrings' -%}
  {%- elsif _tl == 'category:watches' -%}
    {%- assign ppv1_cat = 'watches' -%}
  {%- endif -%}
  {%- if ppv1_cat != 'other' -%}{%- break -%}{%- endif -%}
{%- endfor -%}

<style>
  .ppv1-breadcrumb {
    padding: 14px 24px;
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #9a8f86;
    border-bottom: 1px solid #ede8e2;
  }
  .ppv1-breadcrumb__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px;
  }
  .ppv1-breadcrumb__item {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .ppv1-breadcrumb__item + .ppv1-breadcrumb__item::before {
    content: '/';
    color: #c8c0b8;
  }
  .ppv1-breadcrumb__link {
    color: #9a8f86;
    text-decoration: none;
    transition: color 0.15s;
  }
  .ppv1-breadcrumb__link:hover { color: #1c1c1c; }
  .ppv1-breadcrumb__current { color: #1c1c1c; }
</style>

<nav class="ppv1-breadcrumb" aria-label="Breadcrumb">
  <ol class="ppv1-breadcrumb__list" itemscope itemtype="https://schema.org/BreadcrumbList">
    <li class="ppv1-breadcrumb__item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
      <a class="ppv1-breadcrumb__link" href="{{ routes.root_url }}" itemprop="item">
        <span itemprop="name">{{ 'general.breadcrumb.home' | t }}</span>
      </a>
      <meta itemprop="position" content="1">
    </li>
    {%- if collection -%}
      <li class="ppv1-breadcrumb__item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <a class="ppv1-breadcrumb__link" href="{{ collection.url }}" itemprop="item">
          <span itemprop="name">{{ collection.title }}</span>
        </a>
        <meta itemprop="position" content="2">
      </li>
      <li class="ppv1-breadcrumb__item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <span class="ppv1-breadcrumb__current" itemprop="name">{{ product.title }}</span>
        <meta itemprop="item" content="{{ shop.url }}{{ product.url }}">
        <meta itemprop="position" content="3">
      </li>
    {%- else -%}
      <li class="ppv1-breadcrumb__item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <span class="ppv1-breadcrumb__current" itemprop="name">{{ product.title }}</span>
        <meta itemprop="item" content="{{ shop.url }}{{ product.url }}">
        <meta itemprop="position" content="2">
      </li>
    {%- endif -%}
  </ol>
</nav>

<section class="Product product-page-v1" data-section-id="{{ section.id }}" data-section-type="product" data-section-settings='{{ section_settings }}'>

  {%- comment -%} Hidden product form for theme JS / Offerly app compatibility {%- endcomment -%}
  {%- form 'product', product, class: 'ProductForm', style: 'display:none' -%}
    {%- render 'product-data', product: product -%}
    <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" data-product-select>
  {%- endform -%}

  {%- comment -%}----------------------------------------------------
  1. HERO SECTION
  ----------------------------------------------------{%- endcomment -%}

  {%- assign ppv1_img_count = 0 -%}
  {%- for media in product.media -%}{%- if media.media_type == 'image' -%}{%- assign ppv1_img_count = ppv1_img_count | plus: 1 -%}{%- endif -%}{%- endfor -%}

  <div class="ppv1-hero">
    <div class="ppv1-hero__gallery">
      {%- for media in product.media -%}
        {%- if media.media_type == 'image' -%}
          {%- assign hero_slide_url = media | img_url: '1x1' | replace: '_1x1.', '_{width}x.' -%}
          <div class="ppv1-hero__slide" data-pswp-src="{{ media | img_url: '1600x' }}" data-pswp-w="{{ media.width }}" data-pswp-h="{{ media.height }}">
            {%- if forloop.first -%}
              <img class="ppv1-hero__slide-img"
                   src="{{ media | img_url: '800x' }}"
                   width="{{ media.width }}"
                   height="{{ media.height }}"
                   loading="eager"
                   fetchpriority="high"
                   alt="{{ media.alt | default: product.title | escape }}">
            {%- else -%}
              <img class="ppv1-hero__slide-img Image--lazyLoad Image--fadeIn"
                   data-src="{{ hero_slide_url }}"
                   data-widths="[600, 800, 1000, 1200]"
                   data-sizes="auto"
                   alt="{{ media.alt | default: product.title | escape }}">
            {%- endif -%}
            <span class="Image__Loader"></span>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
    {%- if ppv1_img_count > 1 -%}
      <div class="ppv1-hero__dots" id="ppv1-hero-dots">
        {%- for i in (1..ppv1_img_count) -%}
          <span class="ppv1-hero__dot{% if forloop.first %} is-active{% endif %}"></span>
        {%- endfor -%}
      </div>
    {%- endif -%}

    <div class="ppv1-hero__info">

      <h1 class="ppv1-title Heading u-h2">{{ product.title }}</h1>
      <hr class="ppv1-divider">

      {%- comment -%} ─── Hero meta: category-specific fields ─── {%- endcomment -%}
      {%- capture ppv1_hero_rows -%}
        {%- if ppv1_cat == 'bags' or ppv1_cat == 'charm' -%}
          {%- if ppv1_colour != blank -%}<dt class="ppv1-meta__key">Colour</dt><dd class="ppv1-meta__val">{{ ppv1_colour }}</dd>{%- endif -%}
          {%- if ppv1_mat != blank -%}<dt class="ppv1-meta__key">Material</dt><dd class="ppv1-meta__val">{{ ppv1_mat }}</dd>{%- endif -%}
          {%- if ppv1_hardware != blank -%}<dt class="ppv1-meta__key">Hardware</dt><dd class="ppv1-meta__val">{{ ppv1_hardware }}</dd>{%- endif -%}
          {%- if ppv1_stamp != blank -%}<dt class="ppv1-meta__key">Stamp</dt><dd class="ppv1-meta__val">{{ ppv1_stamp }}</dd>{%- endif -%}
          {%- if ppv1_condition != blank -%}<dt class="ppv1-meta__key">Condition</dt><dd class="ppv1-meta__val">{{ ppv1_condition }}</dd>{%- endif -%}
          {%- if ppv1_location != blank -%}<dt class="ppv1-meta__key">Location</dt><dd class="ppv1-meta__val">{{ ppv1_location }}</dd>{%- endif -%}
        {%- elsif ppv1_cat == 'clothing' -%}
