<script>
(function() {
  // Accordion — only one open at a time (item 14)
  var triggers = document.querySelectorAll('.ppv1-accordion__trigger');
  triggers.forEach(function(btn) {
    btn.addEventListener('click', function() {
      var item = this.closest('.ppv1-accordion__item');
      var isOpen = item.classList.contains('is-open');

      // Close all
      triggers.forEach(function(otherBtn) {
        var otherItem = otherBtn.closest('.ppv1-accordion__item');
        otherItem.classList.remove('is-open');
        otherBtn.setAttribute('aria-expanded', 'false');
      });

      // Toggle clicked one
      if (!isOpen) {
        item.classList.add('is-open');
        this.setAttribute('aria-expanded', 'true');
      }
    });
  });

  // Hero gallery dots
  var heroGallery = document.querySelector('.ppv1-hero__gallery');
  var heroDots = document.querySelectorAll('.ppv1-hero__dot');
  if (heroGallery && heroDots.length > 0) {
    heroGallery.addEventListener('scroll', function() {
      var idx = Math.round(heroGallery.scrollLeft / heroGallery.offsetWidth);
      heroDots.forEach(function(dot, i) {
        dot.classList.toggle('is-active', i === idx);
      });
    }, { passive: true });
  }

  // ---- LIGHTBOX: Hero gallery + carousel strip ----
  (function() {
    var heroSlides = Array.from(document.querySelectorAll('.ppv1-hero__slide'));
    var stripSlides = Array.from(document.querySelectorAll('.ppv1-strip__slide'));
    if (!heroSlides.length) return;

    function buildItems() {
      return heroSlides.map(function(slide) {
        var img = slide.querySelector('img');
        // Use the Liquid-generated 1600px URL (reliable, no JS string manipulation)
        var src = slide.getAttribute('data-pswp-src') || '';
        // Use the already-loaded thumbnail as the low-res placeholder shown during load
        var loadedSrc = img ? (img.currentSrc || img.src) : '';
        var msrc = loadedSrc || src;
        var w = parseInt(slide.getAttribute('data-pswp-w')) || 0;
        var h = parseInt(slide.getAttribute('data-pswp-h')) || 0;
        // Scale dimensions to match the 1600px-wide URL
        if (w > 1600) { h = Math.round(h * 1600 / w); w = 1600; }
        if (!w || !h) { w = 1600; h = 1600; }
        var alt = img ? (img.getAttribute('alt') || '') : '';
        return { src: src, msrc: msrc, w: w, h: h, title: alt };
      });
    }

    function openLightbox(index, triggerEl) {
      var pswpEl = document.querySelector('.pswp');
      if (!pswpEl || typeof PhotoSwipe === 'undefined') return;

      var items = buildItems();

      var pswp = new PhotoSwipe(pswpEl, false, items, {
        index: index,
        showHideOpacity: false,
        showAnimationDuration: 333,
        loop: true,
        history: false,
        closeOnVerticalDrag: true,
        pinchToClose: true,
        clickToCloseNonZoomable: false,
        getDoubleTapZoom: function() { return 1.25; },
        maxSpreadZoom: 1.25,
        bgOpacity: 0.92,
        // Zoom-from-thumbnail animation: open from the clicked element's position
        getThumbBoundsFn: function() {
          if (!triggerEl) return null;
          var rect = triggerEl.getBoundingClientRect();
          if (!rect.width || !rect.height) return null;
          var scrollY = window.pageYOffset || document.documentElement.scrollTop;
          return { x: rect.left, y: rect.top + scrollY, w: rect.width };
        }
      });
      pswp.init();

      // ---- Click / tap to cycle zoom: fit → 2× → 3× → close ----
      // State-based so we don't rely on getZoomLevel() being accurate after programmatic zoom.
      // Native 'click' is used for desktop (reliable even when image is pannable at 2×).
      // PhotoSwipe 'tap' covers mobile touches (where click may be suppressed by preventDefault).
      // Both share _doZoomStep() with a 400ms dedup to prevent double-firing.
      var _pswpZoomStep = 0;
      var _pswpLastZoom = 0;
      var _pswpScrollWrap = pswpEl.querySelector('.pswp__scroll-wrap');

      function _doZoomStep(cx, cy) {
        var now = Date.now();
        if (now - _pswpLastZoom < 400) return;
        _pswpLastZoom = now;
        _pswpZoomStep = (_pswpZoomStep + 1) % 2;
        var center = { x: cx || window.innerWidth / 2, y: cy || window.innerHeight / 2 };
        if (_pswpZoomStep === 1) {
          pswp.zoomTo(1.25, center, 333);
          pswpEl.classList.add('pswp--zoomed');
        } else {
          pswp.close();
        }
      }

      // Desktop: native click event on scroll wrap
      function _pswpOnClick(e) {
        if (e.target && e.target.closest && e.target.closest('.pswp__ui')) return;
        // Clicking the dark overlay (not the image itself) always closes
        var onImage = e.target && e.target.classList && e.target.classList.contains('pswp__img');
        if (!onImage) { pswp.close(); return; }
        _doZoomStep(e.clientX, e.clientY);
      }
      if (_pswpScrollWrap) _pswpScrollWrap.addEventListener('click', _pswpOnClick);

      // Mobile: PhotoSwipe tap (fires after 300ms delay for non-drag touches)
      pswp.listen('tap', function(e) {
        var onImage = e.target && e.target.classList && e.target.classList.contains('pswp__img');
        if (!onImage) { pswp.close(); return; }
        _doZoomStep(0, 0);
      });

      // ---- Wire up UI manually (we pass false for the UI class) ----
      var uiEl    = pswpEl.querySelector('.pswp__ui');
      var btnClose = pswpEl.querySelector('.pswp__button--close');
      var btnPrev  = pswpEl.querySelector('.pswp__button--prev');
      var btnNext  = pswpEl.querySelector('.pswp__button--next');

      // ---- Idle fade: hide controls after 3s of no interaction ----
      var _idleTimer = null;
      function _showControls() {
        if (uiEl) uiEl.classList.remove('pswp__ui--idle');
        clearTimeout(_idleTimer);
        _idleTimer = setTimeout(function() {
          if (uiEl) uiEl.classList.add('pswp__ui--idle');
        }, 3000);
      }
      pswpEl.addEventListener('mousemove', _showControls);
      pswpEl.addEventListener('touchstart', _showControls);

      // Show controls once the opening animation ends; start idle timer
      pswp.listen('initialZoomInEnd', function() {
        if (uiEl) uiEl.classList.remove('pswp__ui--hidden');
        _showControls();
      });

      // Reset zoom step and cursor class on slide change
      pswp.listen('afterChange', function() {
        _pswpZoomStep = 0;
        pswpEl.classList.remove('pswp--zoomed');
      });

      // Button clicks — use .onclick so re-opening replaces rather than stacks handlers
      if (btnClose) btnClose.onclick = function() { pswp.close(); };
      if (btnPrev)  btnPrev.onclick  = function() { pswp.prev(); };
      if (btnNext)  btnNext.onclick  = function() { pswp.next(); };

      // Clean up on close
      pswp.listen('destroy', function() {
        if (btnClose) btnClose.onclick = null;
        if (btnPrev)  btnPrev.onclick  = null;
        if (btnNext)  btnNext.onclick  = null;
        if (_pswpScrollWrap) _pswpScrollWrap.removeEventListener('click', _pswpOnClick);
        clearTimeout(_idleTimer);
        pswpEl.removeEventListener('mousemove', _showControls);
        pswpEl.removeEventListener('touchstart', _showControls);
        pswpEl.classList.remove('pswp--zoomed');
      });
    }

    // Hero gallery: single click on the container works on both desktop (index 0)
    // and mobile (derive current slide from scroll position)
    var heroGalleryEl = document.querySelector('.ppv1-hero__gallery');
    if (heroGalleryEl) {
      heroGalleryEl.addEventListener('click', function() {
        var idx = heroGalleryEl.offsetWidth > 0
          ? Math.round(heroGalleryEl.scrollLeft / heroGalleryEl.offsetWidth)
          : 0;
        openLightbox(idx, heroGalleryEl);
      });
    }

    // Strip: each slide maps to its position in the full image set (strip uses offset:1)
    stripSlides.forEach(function(slide) {
      slide.addEventListener('click', function() {
        openLightbox(parseInt(slide.getAttribute('data-pswp-index')), slide);
      });
    });

    // ---- Hover prefetch: load full-res before the lightbox opens ----
    function prefetch(src) {
      var img = new Image();
      img.src = src;
    }
    heroSlides.forEach(function(slide) {
      slide.addEventListener('mouseenter', function() {
        var src = slide.getAttribute('data-pswp-src');
        if (src && !slide._pswpPrefetched) { slide._pswpPrefetched = true; prefetch(src); }
      }, { once: true });
    });
    stripSlides.forEach(function(slide) {
      slide.addEventListener('mouseenter', function() {
        var idx = parseInt(slide.getAttribute('data-pswp-index'));
        var heroSlide = heroSlides[idx];
        if (heroSlide && !heroSlide._pswpPrefetched) {
          heroSlide._pswpPrefetched = true;
          var src = heroSlide.getAttribute('data-pswp-src');
          if (src) prefetch(src);
        }
      }, { once: true });
    });
  })();

  // Carousel strip arrows
  var track = document.getElementById('ppv1-track');
  var prevBtn = document.getElementById('ppv1-prev');
  var nextBtn = document.getElementById('ppv1-next');

  if (track && prevBtn && nextBtn) {
    function getSlideWidth() {
      var slide = track.querySelector('.ppv1-strip__slide');
      return slide ? slide.offsetWidth + 10 : track.offsetWidth / 3;
    }
    prevBtn.addEventListener('click', function() {
      track.scrollBy({ left: -getSlideWidth(), behavior: 'smooth' });
    });
    nextBtn.addEventListener('click', function() {
      track.scrollBy({ left: getSlideWidth(), behavior: 'smooth' });
    });
  }
})();
</script>

{%- unless customer -%}
<div class="ppv1-source-modal" id="ppv1-source-modal" aria-modal="true" role="dialog">
  <div class="ppv1-source-modal__overlay" id="ppv1-source-overlay"></div>
  <div class="ppv1-source-modal__box">
    <button class="ppv1-source-modal__close" id="ppv1-source-close" type="button" aria-label="Close">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><line x1="2" y1="2" x2="14" y2="14"/><line x1="14" y1="2" x2="2" y2="14"/></svg>
    </button>
    <p class="ppv1-source-modal__title">Login to source</p>
    <p class="ppv1-source-modal__subtitle">You need to be logged in to contact our team about sourcing this piece.</p>
    <a class="Button Button--primary" href="/account/login?return_url={{ product.url | url_encode }}">Login</a>
  </div>
</div>
<script>
(function () {
  var modal   = document.getElementById('ppv1-source-modal');
  var overlay = document.getElementById('ppv1-source-overlay');
  var close   = document.getElementById('ppv1-source-close');
  if (!modal) return;
  function openModal()  { modal.classList.add('ppv1-source-modal--open'); document.body.style.overflow = 'hidden'; }
  function closeModal() { modal.classList.remove('ppv1-source-modal--open'); document.body.style.overflow = ''; }
  document.querySelectorAll('.ppv1-source-trigger').forEach(function(btn) {
    btn.addEventListener('click', openModal);
  });
  overlay.addEventListener('click', closeModal);
  close.addEventListener('click', closeModal);
  document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeModal(); });
})();
</script>
{%- endunless -%}

{%- comment -%} GA4 view_item + Meta ViewContent on product page load {%- endcomment -%}
<script>
(function() {
  var productData = {
    item_id: {{ product.id | json }},
    item_name: {{ product.title | json }},
    item_brand: {{ product.vendor | json }},
    item_category: {{ product.type | json }},
    price: {{ product.price | divided_by: 100.0 }},
    currency: {{ shop.currency | json }}
  };

  /* GA4 view_item */
  if (typeof gtag === 'function') {
    gtag('event', 'view_item', {
      currency: productData.currency,
      value: productData.price,
      items: [productData]
    });
  }
  window.dataLayer = window.dataLayer || [];
  window.dataLayer.push({
    event: 'view_item',
    currency: productData.currency,
    value: productData.price,
    items: [productData]
  });

  /* Meta Pixel ViewContent */
  if (typeof fbq === 'function') {
    fbq('track', 'ViewContent', {
      content_name: productData.item_name,
      content_ids: [String(productData.item_id)],
      content_type: 'product',
      value: productData.price,
      currency: productData.currency
    });
  }
})();
</script>

{%- comment -%} GA4 add_to_cart + Meta AddToCart — separate script to avoid breaking ATC {%- endcomment -%}
<script>
(function() {
  var atcBtn = document.getElementById('ppv1-atc-btn');
  if (!atcBtn) return;
  atcBtn.addEventListener('click', function() {
    try {
      var currency = {{ shop.currency | json }};
      var itemName = {{ product.title | json }};
      var variantInput = atcBtn.closest('form').querySelector('[data-product-select]');
      var variantId = variantInput ? variantInput.value : '';
      var price = {{ product.price | divided_by: 100.0 }};

      if (typeof gtag === 'function') {
        gtag('event', 'add_to_cart', {
          currency: currency,
          value: price,
          items: [{ item_id: String(variantId), item_name: itemName, price: price, quantity: 1 }]
        });
      }
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        event: 'add_to_cart',
        currency: currency,
        value: price,
        items: [{ item_id: String(variantId), item_name: itemName }]
      });
      if (typeof fbq === 'function') {
        fbq('track', 'AddToCart', {
          content_name: itemName,
          content_ids: [String(variantId)],
          content_type: 'product',
          value: price,
          currency: currency
        });
      }
    } catch(e) { /* tracking should never block ATC */ }
  });
})();
</script>

{%- comment -%} Hide loading bar on ATC + suppress max quantity error + added state {%- endcomment -%}
<style>
  .LoadingBar { display: none !important; }
  .ProductForm__Error.Alert--error { display: none !important; }
  .ppv1-atc-btn--added {
    opacity: 0.7;
    cursor: default;
  }
</style>
<script>
(function() {
  var section = document.querySelector('[data-section-id="{{ section.id }}"]');
  if (!section) return;

  /* After successful add, switch button to "Added to cart" */
  section.addEventListener('product:added', function() {
    var btn = document.getElementById('ppv1-atc-btn');
    if (!btn) return;
    btn.setAttribute('disabled', 'disabled');
    btn.removeAttribute('data-action');
    btn.setAttribute('type', 'button');
    btn.classList.remove('Button--primary');
    btn.classList.add('Button--secondary', 'ppv1-atc-btn--added');
    btn.textContent = 'ADDED TO CART';
  });

  /* Listen for cart item removal — check cart when remove/quantity buttons are clicked */
  document.addEventListener('click', function(e) {
    var target = e.target.closest('[data-action="remove-item"], [data-action="update-item-quantity"]');
    if (!target) return;
    /* Delay to let the cart AJAX complete */
    setTimeout(function() {
      fetch('/cart.js', { credentials: 'same-origin' })
        .then(function(r) { return r.json(); })
        .then(function(cart) {
          var btn = document.getElementById('ppv1-atc-btn');
          if (!btn || !btn.classList.contains('ppv1-atc-btn--added')) return;
          var productId = {{ product.id }};
          var inCart = cart.items.some(function(item) { return item.product_id === productId; });
          if (!inCart) {
            /* Re-enable main ATC button */
            if (btn) {
              btn.removeAttribute('disabled');
              btn.setAttribute('data-action', 'add-to-cart');
              btn.setAttribute('type', 'submit');
              btn.classList.remove('Button--secondary', 'ppv1-atc-btn--added');
              btn.classList.add('Button--primary');
              btn.textContent = 'ADD TO CART \u2022 ' + (btn.getAttribute('data-atc-price') || '');
            }
            /* Re-enable sticky ATC button */
            var sBtn = document.getElementById('ppv1-sticky-atc-btn');
            if (sBtn) {
              sBtn.removeAttribute('disabled');
              sBtn.setAttribute('data-action', 'add-to-cart');
              sBtn.setAttribute('type', 'submit');
              sBtn.classList.remove('Button--secondary', 'ppv1-atc-btn--added');
              sBtn.classList.add('Button--primary');
              sBtn.textContent = 'ADD TO CART';
            }
          }
        });
    }, 1000);
  });
  /* Also update sticky bar button */
  var stickyBtn = document.getElementById('ppv1-sticky-atc-btn');
  if (stickyBtn) {
    section.addEventListener('product:added', function() {
      stickyBtn.setAttribute('disabled', 'disabled');
      stickyBtn.classList.remove('Button--primary');
      stickyBtn.classList.add('Button--secondary', 'ppv1-atc-btn--added');
      stickyBtn.textContent = 'ADDED TO CART';
    });
  }
})();
</script>

{%- comment -%} Sticky ATC bar (mobile only) — two-row layout {%- endcomment -%}
<div class="ppv1-sticky-bar" id="ppv1-sticky-bar">
  <div class="ppv1-sticky-bar__actions">
    {%- if product.selected_or_first_available_variant.available -%}
      {%- form 'product', product, class: 'ppv1-sticky-form' -%}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" data-product-select>
        {%- if in_cart -%}
          <button type="button" class="Button Button--secondary ppv1-sticky-atc-btn ppv1-atc-btn--added" id="ppv1-sticky-atc-btn" disabled>
            ADDED TO CART
          </button>
        {%- else -%}
          <button type="submit" class="Button Button--primary ppv1-sticky-atc-btn" data-action="add-to-cart" id="ppv1-sticky-atc-btn">
            ADD TO CART &bull; {{ atc_variant.price | money }}
          </button>
        {%- endif -%}
      {%- endform -%}
      <button type="button" class="Button Button--secondary ppv1-sticky-offer-btn" id="ppv1-sticky-offer-btn">
        MAKE AN OFFER
      </button>
    {%- else -%}
      {%- if customer -%}
        {%- assign wa_product_url = shop.url | append: product.url -%}
        {%- assign wa_message_sticky = "Hi, I'm looking to source the " | append: product.title | append: ". Could you let me know if you're able to source one? " | append: wa_product_url | url_encode -%}
        <a href="https://wa.me/447405520466?text={{ wa_message_sticky }}" class="Button Button--primary ppv1-sticky-source-btn" target="_blank" rel="noopener">
          ASK OUR TEAM TO SOURCE
        </a>
      {%- else -%}
        <button type="button" class="Button Button--primary ppv1-sticky-source-btn ppv1-source-trigger">
          ASK OUR TEAM TO SOURCE
        </button>
      {%- endif -%}
    {%- endif -%}
  </div>
</div>

<style>
  .ppv1-sticky-bar {
    display: none;
  }
  @media screen and (max-width: 999px) {
    /* Hide main CTA row on mobile — sticky bar replaces it */
    .ppv1-cta-row {
      display: none !important;
    }
    /* Offerly's button is inside .ppv1-cta-row which is display:none on mobile.
       .click() still works on hidden elements so no extra hiding needed. */

    .ppv1-sticky-bar {
      display: block;
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 999;
      background: rgba(255, 255, 255, 0.85);
      -webkit-backdrop-filter: blur(20px);
      backdrop-filter: blur(20px);
      border-top: 1px solid rgba(0, 0, 0, 0.06);
      padding: 12px 20px 14px;
      padding-bottom: calc(14px + env(safe-area-inset-bottom));
      transform: translateY(100%);
      transition: transform 0.3s ease;
    }
    .ppv1-sticky-bar--visible {
      transform: translateY(0);
    }
    .ppv1-sticky-bar__actions {
      display: flex;
      gap: 8px;
    }
    .ppv1-sticky-bar__actions form {
      flex: 1;
    }
    .ppv1-sticky-atc-btn,
    .ppv1-sticky-offer-btn,
    .ppv1-sticky-source-btn {
      width: 100%;
      white-space: nowrap;
      padding: 12px 16px;
      font-size: 11px;
      letter-spacing: 0.08em;
      text-align: center;
      text-decoration: none;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .ppv1-sticky-offer-btn {
      flex: 1;
      border: 1px solid #1a1a1a;
      background: #fff;
      color: #1a1a1a;
      cursor: pointer;
    }
    .ppv1-sticky-source-btn {
      flex: 1;
    }
    /* Push Tidio chat widget above sticky bar when visible */
    body.ppv1-sticky-active #tidio-chat {
      bottom: 100px !important;
    }
  }
</style>
<script>
(function() {
  var stickyBar = document.getElementById('ppv1-sticky-bar');
  if (!stickyBar) return;

  var isMobile = window.matchMedia('(max-width: 999px)').matches;

  if (isMobile) {
    /* On mobile: show sticky bar immediately (main CTA is hidden) */
    stickyBar.classList.add('ppv1-sticky-bar--visible');
    document.body.classList.add('ppv1-sticky-active');
  } else {
    /* On desktop: show sticky bar when main CTA scrolls past */
    var mainCta = document.querySelector('.ppv1-cta-row');
    if (mainCta) {
      var hasScrolledPastCta = false;
      var stickyObserver = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (!entry.isIntersecting) {
            var rect = mainCta.getBoundingClientRect();
            if (rect.bottom < 0) {
              hasScrolledPastCta = true;
              stickyBar.classList.add('ppv1-sticky-bar--visible');
              document.body.classList.add('ppv1-sticky-active');
            }
          } else {
            if (hasScrolledPastCta) {
              stickyBar.classList.remove('ppv1-sticky-bar--visible');
              document.body.classList.remove('ppv1-sticky-active');
            }
          }
        });
      }, { threshold: 0 });
      stickyObserver.observe(mainCta);
    }
  }

  /* Prevent sticky form from native submit (would redirect to cart) */
  var stickyForm = stickyBar.querySelector('form');
  if (stickyForm) {
    stickyForm.addEventListener('submit', function(e) { e.preventDefault(); });
  }

  /* Sticky ATC button — use AJAX add to cart directly */
  var stickyBtn = document.getElementById('ppv1-sticky-atc-btn');
  if (stickyBtn && !stickyBtn.disabled) {
    stickyBtn.addEventListener('click', function(e) {
      e.preventDefault();
      if (stickyBtn.disabled) return;

      var variantInput = stickyBar.querySelector('[data-product-select]');
      var variantId = variantInput ? variantInput.value : '';
      if (!variantId) return;

      stickyBtn.setAttribute('disabled', 'disabled');

      fetch((window.routes && window.routes.cartAddUrl || '/cart/add') + '.js', {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
        body: JSON.stringify({ id: parseInt(variantId), quantity: 1 })
      }).then(function(response) {
        if (response.ok) {
          /* Update both buttons to "Added" state */
          stickyBtn.classList.remove('Button--primary');
          stickyBtn.classList.add('Button--secondary', 'ppv1-atc-btn--added');
          stickyBtn.textContent = 'ADDED TO CART';

          var mainBtn = document.getElementById('ppv1-atc-btn');
          if (mainBtn) {
            mainBtn.setAttribute('disabled', 'disabled');
            mainBtn.removeAttribute('data-action');
            mainBtn.setAttribute('type', 'button');
            mainBtn.classList.remove('Button--primary');
            mainBtn.classList.add('Button--secondary', 'ppv1-atc-btn--added');
            mainBtn.textContent = 'ADDED TO CART';
          }

          /* Update cart count + dot in header without opening drawer */
          fetch('/cart.js', { credentials: 'same-origin' })
            .then(function(r) { return r.json(); })
            .then(function(cart) {
              document.querySelectorAll('.Header__CartCount').forEach(function(el) {
                el.textContent = cart.item_count;
              });
              document.querySelectorAll('.Header__CartDot').forEach(function(el) {
                if (cart.item_count > 0) el.classList.add('is-visible');
              });
            });

          /* Fire tracking */
          try {
            if (typeof gtag === 'function') {
              gtag('event', 'add_to_cart', {
                currency: {{ shop.currency | json }},
                value: {{ product.price | divided_by: 100.0 }},
                items: [{ item_id: variantId, item_name: {{ product.title | json }}, quantity: 1 }]
              });
            }
            if (typeof fbq === 'function') {
              fbq('track', 'AddToCart', {
                content_name: {{ product.title | json }},
                content_ids: [variantId],
                content_type: 'product',
                value: {{ product.price | divided_by: 100.0 }},
                currency: {{ shop.currency | json }}
              });
            }
          } catch(err) {}
        } else {
          stickyBtn.removeAttribute('disabled');
          stickyBtn.innerHTML = 'ADD TO CART &bull; {{ atc_variant.price | money }}';
        }
      }).catch(function() {
        stickyBtn.removeAttribute('disabled');
        stickyBtn.innerHTML = 'ADD TO CART &bull; {{ atc_variant.price | money }}';
      });
    });
  }

  /* Make an Offer button — trigger Offerly's #offerButton */
  var offerBtn = document.getElementById('ppv1-sticky-offer-btn');
  if (offerBtn) {
    offerBtn.addEventListener('click', function() {
      var maoBtn = document.getElementById('offerButton') || document.querySelector('.offerButton');
      if (maoBtn) maoBtn.click();
    });
  }
})();
</script>

{% schema %}
{
  "name": "Product page",
  "class": "shopify-section--bordered",
  "blocks": [
    {
