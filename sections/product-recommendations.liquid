{%- comment -%}
  YOU MAY LIKE
  Finds the product's segment by looking for a "Collection:X" tag,
  e.g. "Collection:Bags", "Collection:Clothing".
  Uses collections["x"] to get real products from that segment.
  Falls back to the product's first collection if no Collection: tag is found.
  Hides itself if fewer than 1 other product is available.
{%- endcomment -%}

{%- assign ps_rec_col = blank -%}
{%- assign ps_rec_label = blank -%}

{%- comment -%} Step 1: find a Collection: tag {%- endcomment -%}
{%- for tag in product.tags -%}
  {%- if tag contains 'Collection:' -%}
    {%- assign ps_rec_label = tag | split: ':' | last | strip -%}
    {%- assign ps_rec_handle = ps_rec_label | downcase | replace: ' ', '-' -%}
    {%- assign ps_rec_col = collections[ps_rec_handle] -%}
    {%- if ps_rec_col != blank -%}{%- break -%}{%- endif -%}
  {%- endif -%}
{%- endfor -%}

{%- comment -%} Step 2: fall back to first collection {%- endcomment -%}
{%- if ps_rec_col == blank -%}
  {%- assign ps_rec_col = product.collections.first -%}
{%- endif -%}

{%- comment -%} Step 3: count available products (excluding current) {%- endcomment -%}
{%- assign ps_rec_count = 0 -%}
{%- if ps_rec_col != blank -%}
  {%- for p in ps_rec_col.products limit: 20 -%}
    {%- unless p.id == product.id -%}
      {%- if ps_rec_count < 4 -%}
        {%- assign ps_rec_count = ps_rec_count | plus: 1 -%}
      {%- endif -%}
    {%- endunless -%}
  {%- endfor -%}
{%- endif -%}

{%- if ps_rec_count > 0 -%}

<section class="ppv1-recs-section" data-section-type="product-recommendations">

  {%- if section.settings.heading != blank -%}
    <h2 class="ppv1-recs__heading">{{ section.settings.heading | escape }}</h2>
  {%- endif -%}

  <div class="ppv1-recs__track-wrap">
    <div class="ppv1-recs__track">
      {%- assign ps_rec_shown = 0 -%}
      {%- for p in ps_rec_col.products limit: 20 -%}
        {%- unless p.id == product.id -%}
          {%- if ps_rec_shown < 4 -%}
            <a href="{{ p.url }}" class="ppv1-recs__card">
              <div class="ppv1-recs__img-wrap">
                {%- if p.featured_image -%}
                  {%- assign rec_img_url = p.featured_image | img_url: '1x1' | replace: '_1x1.', '_{width}x.' -%}
                  <img class="ppv1-recs__img Image--lazyLoad Image--fadeIn"
                       data-src="{{ rec_img_url }}"
                       data-widths="[400, 600]"
                       data-sizes="auto"
                       alt="{{ p.featured_image.alt | default: p.title | escape }}">
                  <span class="Image__Loader"></span>
                {%- else -%}
                  <div class="ppv1-recs__img--placeholder"></div>
                {%- endif -%}
              </div>
              <div class="ppv1-recs__info">
                <p class="ppv1-recs__title">{{ p.title | escape }}</p>
                <p class="ppv1-recs__price">{{ p.price | money }}</p>
              </div>
            </a>
            {%- assign ps_rec_shown = ps_rec_shown | plus: 1 -%}
          {%- endif -%}
        {%- endunless -%}
      {%- endfor -%}
    </div>
  </div>

</section>

{%- endif -%}

<style>
.ppv1-recs-section {
  padding: 60px 35px 48px;
  background: #ffffff;
  font-family: 'Jost', sans-serif;
}

.ppv1-recs__heading {
  font-size: 16px;
  font-weight: 400;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: #1a1a1a;
  text-align: center;
  margin: 0 0 40px;
}

.ppv1-recs__track-wrap {
  overflow: hidden;
}

.ppv1-recs__track {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
}

.ppv1-recs__card {
  text-decoration: none;
  color: inherit;
  display: block;
}

.ppv1-recs__img-wrap {
  aspect-ratio: 3 / 4;
  overflow: hidden;
  background: #f5f5f5;
  margin-bottom: 12px;
  position: relative;
}

.ppv1-recs__img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.4s ease;
}

.ppv1-recs__card:hover .ppv1-recs__img {
  transform: scale(1.04);
}

.ppv1-recs__img--placeholder {
  position: absolute;
  inset: 0;
  background: #ece9e4;
}

.ppv1-recs__info {
  padding: 0 2px;
}

.ppv1-recs__title {
  font-size: 12px;
  font-weight: 400;
  letter-spacing: 0.06em;
  color: #1a1a1a;
  margin: 0 0 4px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.ppv1-recs__price {
  font-size: 12px;
  font-weight: 300;
  color: #888;
  margin: 0;
}

@media screen and (max-width: 900px) {
  .ppv1-recs-section {
    padding: 40px 24px 32px;
  }

  .ppv1-recs__track {
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }
}
</style>

{% schema %}
{
  "name": "YOU MAY LIKE",
  "class": "product-recommendations",
  "templates": ["product"],
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "YOU MAY LIKE"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "category": "Product",
      "name": "YOU MAY LIKE"
    }
  ]
}
{% endschema %}
