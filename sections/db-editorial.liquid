{%- assign sid = section.id -%}
{%- assign s = section.settings -%}

<style>
  #db-editorial-{{ sid }} {
    background: {{ s.bg_color }};
    color: {{ s.text_color }};
    padding: clamp(40px, 7vw, 96px) clamp(18px, 4vw, 48px);
  }
  .db-ed__head { max-width: 1600px; margin: 0 auto clamp(28px, 4vw, 48px); }
  .db-ed__eyebrow { font-family: 'Figtree', sans-serif; font-size: 12px; font-weight: 600; letter-spacing: 0.24em; text-transform: uppercase; opacity: 0.55; margin: 0 0 12px; }
  .db-ed__title { font-family: 'Fraunces', serif; font-weight: 300; font-size: clamp(28px, 4vw, 56px); line-height: 1.02; letter-spacing: -0.01em; margin: 0; max-width: 18ch; }
  .db-ed__title em { font-style: italic; }

  .db-ed__grid {
    max-width: 1600px; margin: 0 auto;
    display: grid; grid-template-columns: repeat(4, 1fr); gap: clamp(10px, 1.2vw, 18px);
  }
  .db-ed__tile {
    position: relative; display: block; text-decoration: none; color: #fff;
    aspect-ratio: 3 / 4; overflow: hidden; border-radius: 4px;
    transition: border-radius 0.5s var(--db-ease);
  }
  .db-ed__tile:hover { border-radius: 20px; }
  .db-ed__tile img, .db-ed__tile .placeholder-svg { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.8s var(--db-ease); }
  .db-ed__tile:hover img { transform: scale(1.06); }
  .db-ed__tile-overlay { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(25,25,25,0.05) 40%, rgba(25,25,25,0.6) 100%); transition: background 0.5s ease; }
  .db-ed__tile:hover .db-ed__tile-overlay { background: linear-gradient(180deg, rgba(25,25,25,0.15) 30%, rgba(25,25,25,0.72) 100%); }
  .db-ed__tile-body { position: absolute; left: 0; right: 0; bottom: 0; padding: clamp(16px, 1.6vw, 26px); }
  .db-ed__tile-sub { font-family: 'Figtree', sans-serif; font-size: 11px; font-weight: 600; letter-spacing: 0.16em; text-transform: uppercase; opacity: 0.85; margin: 0 0 8px; }
  .db-ed__tile-name { font-family: 'Fraunces', serif; font-weight: 300; font-size: clamp(20px, 1.8vw, 30px); line-height: 1.05; margin: 0; }
  .db-ed__tile-cta {
    display: inline-flex; align-items: center; gap: 8px; margin-top: 14px;
    font-family: 'Figtree', sans-serif; font-size: 11px; font-weight: 600; letter-spacing: 0.16em; text-transform: uppercase;
    opacity: 0; transform: translateY(8px); transition: opacity 0.45s ease, transform 0.45s var(--db-ease);
  }
  .db-ed__tile:hover .db-ed__tile-cta { opacity: 1; transform: none; }

  /* feature first tile across two columns when 5+ tiles */
  .db-ed__grid[data-feature="true"] .db-ed__tile:first-child { grid-column: span 2; grid-row: span 2; aspect-ratio: auto; }

  @media (max-width: 900px) { .db-ed__grid { grid-template-columns: repeat(2, 1fr); } .db-ed__grid[data-feature="true"] .db-ed__tile:first-child { grid-column: span 2; grid-row: auto; aspect-ratio: 4/3; } }
  @media (max-width: 540px) { .db-ed__grid { grid-template-columns: 1fr; } }
</style>

<section id="db-editorial-{{ sid }}">
  {%- if s.title != blank or s.eyebrow != blank -%}
    <div class="db-ed__head" data-reveal="up">
      {%- if s.eyebrow != blank -%}<p class="db-ed__eyebrow">{{ s.eyebrow | escape }}</p>{%- endif -%}
      {%- if s.title != blank -%}<h2 class="db-ed__title">{{ s.title }}</h2>{%- endif -%}
    </div>
  {%- endif -%}

  <div class="db-ed__grid" data-reveal="fade" {% if section.blocks.size > 4 %}data-feature="true"{% endif %}>
    {%- for block in section.blocks -%}
      <a class="db-ed__tile" href="{{ block.settings.link | default: '#' }}" data-cursor="{{ block.settings.cursor | default: 'EXPLORE' }}" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          <img src="{{ block.settings.image | img_url: '900x' }}" alt="{{ block.settings.image.alt | escape }}" loading="lazy">
        {%- else -%}
          {%- assign ph = forloop.index0 | modulo: 6 | plus: 1 -%}
          {{ 'product-' | append: ph | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
        <div class="db-ed__tile-overlay"></div>
        <div class="db-ed__tile-body">
          {%- if block.settings.subheading != blank -%}<p class="db-ed__tile-sub">{{ block.settings.subheading | escape }}</p>{%- endif -%}
          <h3 class="db-ed__tile-name">{{ block.settings.heading }}</h3>
          <span class="db-ed__tile-cta">{{ block.settings.cta | default: 'Shop now' }} →</span>
        </div>
      </a>
    {%- else -%}
      {%- assign names = 'Bags,Shoes,Jewellery,Accessories' | split: ',' -%}
      {%- for i in (1..4) -%}
        {%- assign nidx = i | minus: 1 -%}
        <a class="db-ed__tile" href="#" data-cursor="SHOP">
          {{ 'product-' | append: i | placeholder_svg_tag: 'placeholder-svg' }}
          <div class="db-ed__tile-overlay"></div>
          <div class="db-ed__tile-body">
            <p class="db-ed__tile-sub">The edit</p>
            <h3 class="db-ed__tile-name">{{ names[nidx] }}</h3>
            <span class="db-ed__tile-cta">Shop now →</span>
          </div>
        </a>
      {%- endfor -%}
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "DB Editorial",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Shop by category" },
    { "type": "text", "id": "title", "label": "Title", "default": "The edit" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#191919" }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Tile",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "subheading", "label": "Subheading", "default": "The edit" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Category" },
        { "type": "text", "id": "cta", "label": "CTA", "default": "Shop now" },
        { "type": "text", "id": "cursor", "label": "Cursor label", "default": "SHOP" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "DB Editorial",
      "blocks": [ { "type": "tile" }, { "type": "tile" }, { "type": "tile" }, { "type": "tile" } ]
    }
  ]
}
{% endschema %}
