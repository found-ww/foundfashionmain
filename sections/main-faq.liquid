{%- assign has_section_separator = false -%}

{%- for block in section.blocks -%}
  {%- if block.type == 'separator' -%}
    {%- assign has_section_separator = true -%}
    {%- break -%}
  {%- endif -%}
{%- endfor -%}

{%- capture faq_content -%}
  <div class="Faq ff-faq">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'separator' -%}
          <div class="ff-faq__section-label" {{ block.shopify_attributes }}>
            <span class="Anchor" id="block-{{ block.id }}"></span>
            {{- block.settings.title | escape -}}
          </div>

        {%- when 'question' -%}
          {%- if block.settings.title != blank and block.settings.answer != blank -%}
            <div class="Faq__Item ff-faq__item {% if section.blocks[forloop.index].type == 'separator' or forloop.last %}Faq__Item--lastOfSection{% endif %}" aria-expanded="false" {{ block.shopify_attributes }}>
              <span class="Faq__Icon ff-faq__icon">{% render 'icon' with 'select-arrow-right' %}</span>

              <div class="Faq__ItemWrapper ff-faq__wrapper">
                <button class="Faq__Question ff-faq__question">{{ block.settings.title | escape }}</button>

                <div class="Faq__AnswerWrapper" aria-hidden="true">
                  <div class="Faq__Answer Rte ff-faq__answer">
                    {{ block.settings.answer }}
                  </div>
                </div>
              </div>
            </div>
          {%- endif -%}
      {%- endcase -%}
    {%- endfor -%}
  </div>
{%- endcapture -%}

<style>
  /* ── Layout overrides ── */
  [data-section-id="{{ section.id }}"] .PageLayout__Section--secondary {
    max-width: 160px !important;
    min-width: 160px !important;
    flex-basis: 160px !important;
  }
  [data-section-id="{{ section.id }}"] .PageLayout__Section + .PageLayout__Section {
    margin-left: 56px !important;
  }

  /* ── Hero header ── */
  .ff-faq-hero {
    background: #1c1c1c;
    padding: 72px 24px 64px;
    text-align: center;
    margin-bottom: 0;
  }
  .ff-faq-hero__eyebrow {
    font-size: 10px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.45);
    margin-bottom: 16px;
  }
  .ff-faq-hero__title {
    font-size: clamp(1.8rem, 4vw, 3rem);
    font-weight: 400;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #fff;
    margin: 0 0 16px;
    line-height: 1.1;
  }
  .ff-faq-hero__sub {
    font-size: 14px;
    font-weight: 300;
    color: rgba(255,255,255,0.55);
    max-width: 440px;
    margin: 0 auto;
    line-height: 1.7;
    letter-spacing: 0.01em;
  }

  /* ── Sidebar nav ── */
  [data-section-id="{{ section.id }}"] .FaqSummary {
    list-style: none;
    padding: 0;
    margin: 0;
    position: sticky;
    top: 80px;
  }
  [data-section-id="{{ section.id }}"] .FaqSummary__Item {
    margin-bottom: 4px;
  }
  [data-section-id="{{ section.id }}"] .FaqSummary__Link {
    display: block;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #b5ada5;
    text-decoration: none;
    padding: 6px 0;
    border-left: 2px solid transparent;
    padding-left: 12px;
    transition: color 0.2s, border-color 0.2s;
  }
  [data-section-id="{{ section.id }}"] .FaqSummary__Link:hover,
  [data-section-id="{{ section.id }}"] .FaqSummary__Item.is-active .FaqSummary__Link {
    color: #2a2420;
    border-left-color: #8a7268;
  }

  /* ── Section label ── */
  .ff-faq__section-label {
    font-size: 10px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: #9a8f86;
    margin: 48px 0 4px;
    padding-bottom: 16px;
    border-bottom: 1px solid #ede8e2;
  }
  .ff-faq__section-label:first-child {
    margin-top: 0;
  }

  /* ── FAQ items ── */
  [data-section-id="{{ section.id }}"] .ff-faq__item {
    border-bottom: 1px solid #ede8e2;
    border-top: none;
    padding: 0;
  }
  [data-section-id="{{ section.id }}"] .ff-faq__question {
    font-size: 14px !important;
    font-weight: 400 !important;
    letter-spacing: 0.02em !important;
    color: #1c1c1c !important;
    padding: 20px 0 !important;
    text-align: left;
    width: 100%;
    background: none;
    border: none;
    cursor: pointer;
    transition: color 0.2s;
  }
  [data-section-id="{{ section.id }}"] .ff-faq__item:hover .ff-faq__question {
    color: #8a7268 !important;
  }
  [data-section-id="{{ section.id }}"] .ff-faq__answer {
    font-size: 14px !important;
    font-weight: 300 !important;
    color: #6b6259 !important;
    line-height: 1.8 !important;
    padding-bottom: 20px !important;
  }
  [data-section-id="{{ section.id }}"] .ff-faq__answer p {
    margin: 0 0 8px;
  }
  [data-section-id="{{ section.id }}"] .ff-faq__icon {
    color: #b5ada5;
    transition: color 0.2s, transform 0.3s;
    flex-shrink: 0;
    margin-top: 20px;
  }
  [data-section-id="{{ section.id }}"] .Faq__Item[aria-expanded="true"] .ff-faq__icon {
    color: #8a7268;
  }

  /* ── Container spacing ── */
  [data-section-id="{{ section.id }}"] .Container {
    padding-top: 64px;
    padding-bottom: 80px;
  }

  /* ── Hide old header (replaced by hero) ── */
  .ff-faq-hide { display: none !important; }

  @media screen and (max-width: 767px) {
    .ff-faq-hero { padding: 56px 24px 48px; }
    [data-section-id="{{ section.id }}"] .Container { padding-top: 48px; padding-bottom: 60px; }
  }
</style>

{%- comment -%} ── Hero ── {%- endcomment -%}
<div class="ff-faq-hero">
  <p class="ff-faq-hero__eyebrow">{{ section.settings.eyebrow | default: 'Found Fashion' }}</p>
  <h1 class="ff-faq-hero__title">{{ page.title }}</h1>
  {%- if section.settings.description != blank -%}
    <p class="ff-faq-hero__sub">{{ section.settings.description }}</p>
  {%- endif -%}
</div>

<section data-section-type="faq" data-section-id="{{ section.id }}">
  <div class="Container">
    <div class="PageContent {% unless has_section_separator %}PageContent--narrow{% endunless %}">

      {%- if has_section_separator -%}
        <div class="PageLayout">
          <div class="PageLayout__Section PageLayout__Section--secondary PageLayout__Section--sticky hidden-phone">
            <ol class="FaqSummary">
              {%- assign faq_separator_count = 0 -%}

              {%- for block in section.blocks -%}
                {%- if block.type == 'separator' -%}
                  <li class="FaqSummary__Item {% if faq_separator_count == 0 %}is-active{% endif %}">
                    <a href="#block-{{ block.id }}" class="FaqSummary__Link" data-offset="80">
                      <span class="FaqSummary__LinkLabel">{{ block.settings.title | escape }}</span>
                    </a>
                  </li>

                  {%- assign faq_separator_count = faq_separator_count | plus: 1 -%}
                {%- endif -%}
              {%- endfor -%}
            </ol>
          </div>

          <div class="PageLayout__Section">
            {{- faq_content -}}
          </div>
        </div>
      {%- else -%}
        {{- faq_content -}}
      {%- endif -%}

      {%- comment -%} Contact CTA {%- endcomment -%}
      {%- if section.settings.cta_title != blank -%}
        <div style="text-align: center; padding: 64px 24px 16px; border-top: 1px solid #ede8e2; margin-top: 48px;">
          <p style="font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase; color: #9a8f86; margin-bottom: 12px;">{{ section.settings.cta_eyebrow }}</p>
          <h2 style="font-size: 22px; letter-spacing: 0.06em; font-weight: 400; text-transform: uppercase; color: #1c1c1c; margin-bottom: 12px;">{{ section.settings.cta_title }}</h2>
          {%- if section.settings.cta_subtitle != blank -%}
            <p style="font-size: 14px; color: #9a8f86; margin-bottom: 28px; line-height: 1.6;">{{ section.settings.cta_subtitle }}</p>
          {%- endif -%}
          {%- if section.settings.cta_button_label != blank and section.settings.cta_button_url != blank -%}
            <a href="{{ section.settings.cta_button_url }}"
               style="display: inline-block; background: #1c1c1c; color: #fff; padding: 14px 32px; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; font-weight: 500; text-decoration: none; transition: background 0.2s;"
               onmouseover="this.style.background='#3d3530'" onmouseout="this.style.background='#1c1c1c'">
              {{ section.settings.cta_button_label }}
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}

    </div>
  </div>
</section>

{%- comment -%} FAQPage schema {%- endcomment -%}
{%- assign has_faq_questions = false -%}
{%- for block in section.blocks -%}
  {%- if block.type == 'question' and block.settings.title != blank and block.settings.answer != blank -%}
    {%- assign has_faq_questions = true -%}
    {%- break -%}
  {%- endif -%}
{%- endfor -%}

{%- if has_faq_questions -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {%- assign _faq_sep = '' -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'question' and block.settings.title != blank and block.settings.answer != blank -%}
        {{ _faq_sep }}{
          "@type": "Question",
          "name": {{ block.settings.title | escape | json }},
          "acceptedAnswer": {
            "@type": "Answer",
            "text": {{ block.settings.answer | strip_html | json }}
          }
        }
        {%- assign _faq_sep = ',' -%}
      {%- endif -%}
    {%- endfor -%}
  ]
}
</script>
{%- endif -%}

{% schema %}
{
  "name": "FAQ",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Hero eyebrow",
      "default": "Found Fashion"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Hero subtext",
      "default": "Below you'll find answers to our most common questions. If you need further help, our team is always happy to assist."
    },
    {
      "type": "header",
      "content": "Contact CTA"
    },
    {
      "type": "text",
      "id": "cta_eyebrow",
      "label": "Eyebrow text",
      "default": "Still have questions?"
    },
    {
      "type": "text",
      "id": "cta_title",
      "label": "Heading",
      "default": "We're here to help"
    },
    {
      "type": "text",
      "id": "cta_subtitle",
      "label": "Subtitle",
      "default": "Our team typically responds within 24 hours."
    },
    {
      "type": "text",
      "id": "cta_button_label",
      "label": "Button label",
      "default": "Contact us"
    },
    {
      "type": "url",
      "id": "cta_button_url",
      "label": "Button URL"
    }
  ],
  "blocks": [
    {
      "type": "separator",
      "name": "Section separator",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "Default"
        }
      ]
    },
    {
      "type": "question",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Question"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "separator",
        "settings": {
          "title": "Shipping"
        }
      },
      {
        "type": "question",
        "settings": {
          "title": "Do you ship overseas?",
          "answer": "<p>Yes, we ship all over the world. Shipping costs will apply, and will be added at checkout. We run discounts and promotions all year, so stay tuned for exclusive deals.</p>"
        }
      },
      {
        "type": "question",
        "settings": {
          "title": "How long will it take to get my order?",
          "answer": "<p>It depends on where you are. Orders processed here will take 5-7 business days to arrive. Overseas deliveries can take anywhere from 7-16 days. Delivery details will be provided in your confirmation email.</p>"
        }
      },
      {
        "type": "separator",
        "settings": {
          "title": "General"
        }
      },
      {
        "type": "question",
        "settings": {
          "title": "Any question?",
          "answer": "<p>You can contact us through our contact page! We will be happy to assist you.</p>"
        }
      }
    ]
  }
}
{% endschema %}
