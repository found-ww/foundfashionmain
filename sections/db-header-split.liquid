{%- assign main_menu = linklists['main-menu'] -%}
{%- assign sid = section.id -%}

{% render 'db-anim' %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Figtree:wght@400;500;600;700&family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;1,9..144,300&display=swap" rel="stylesheet">

<style>
  :root {
    --db-ink: #191919;
    --db-paper: #f4f0ea;
    --db-header-h: 76px;
  }

  /* ---------------- Top bar ---------------- */
  .dbs-header {
    position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
    height: var(--db-header-h);
    display: flex; align-items: center;
    color: #fff;
    transition: transform 0.5s var(--db-ease), color 0.4s ease;
  }
  .dbs-header::before {
    content: ''; position: absolute; inset: 0; z-index: -1;
    backdrop-filter: blur(0px); -webkit-backdrop-filter: blur(0px);
    background: rgba(244, 240, 234, 0);
    transition: background 0.5s ease, backdrop-filter 0.5s ease, -webkit-backdrop-filter 0.5s ease;
  }
  .dbs-header.is-solid { color: var(--db-ink); }
  .dbs-header.is-solid::before {
    backdrop-filter: blur(18px); -webkit-backdrop-filter: blur(18px);
    background: rgba(244, 240, 234, 0.82);
    box-shadow: 0 1px 0 rgba(25,25,25,0.06);
  }
  .dbs-header.is-hidden { transform: translateY(-100%); }

  .dbs-header__inner {
    width: 100%; max-width: 1600px; margin: 0 auto;
    padding: 0 clamp(18px, 4vw, 48px);
    display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: 16px;
  }
  .dbs-header__logo {
    grid-column: 2; justify-self: center;
    font-family: 'Fraunces', serif; font-weight: 300;
    font-size: clamp(20px, 2.4vw, 28px); letter-spacing: 0.02em;
    text-decoration: none; color: inherit; line-height: 1;
  }
  .dbs-header__left { grid-column: 1; display: flex; align-items: center; gap: 28px; }
  .dbs-header__right { grid-column: 3; display: flex; align-items: center; justify-content: flex-end; gap: 22px; }

  .dbs-link {
    position: relative; font-family: 'Figtree', sans-serif; font-size: 12px; font-weight: 500;
    letter-spacing: 0.16em; text-transform: uppercase; color: inherit; text-decoration: none;
    background: none; border: 0; padding: 0; cursor: pointer;
  }
  .dbs-link::after {
    content: ''; position: absolute; left: 0; bottom: -5px; width: 100%; height: 1px;
    background: currentColor; transform: scaleX(0); transform-origin: right;
    transition: transform 0.4s var(--db-ease);
  }
  .dbs-link:hover::after { transform: scaleX(1); transform-origin: left; }

  .dbs-burger {
    display: inline-flex; flex-direction: column; justify-content: center; gap: 5px;
    width: 26px; height: 26px; background: none; border: 0; padding: 0; cursor: pointer; color: inherit;
  }
  .dbs-burger span { display: block; height: 1.5px; width: 100%; background: currentColor; }

  @media (max-width: 900px) { .dbs-header__left .dbs-link { display: none; } }

  /* ---------------- Split overlay ---------------- */
  .dbs-menu {
    position: fixed; inset: 0; z-index: 1100;
    background: var(--db-ink); color: #fff;
    display: grid; grid-template-columns: 1.05fr 0.95fr;
    clip-path: inset(0 0 100% 0);
    transition: clip-path 0.8s var(--db-ease);
    pointer-events: none; overflow: hidden;
  }
  .dbs-menu.is-open { clip-path: inset(0 0 0 0); pointer-events: auto; }

  .dbs-menu__left {
    display: flex; flex-direction: column;
    padding: clamp(20px, 5vh, 56px) clamp(18px, 4vw, 64px);
  }
  .dbs-menu__top { display: flex; align-items: center; justify-content: space-between; }
  .dbs-menu__close {
    font-family: 'Figtree', sans-serif; font-size: 12px; letter-spacing: 0.16em;
    text-transform: uppercase; color: #fff; background: none; border: 0; cursor: pointer;
  }
  .dbs-menu__logo {
    font-family: 'Fraunces', serif; font-weight: 300; font-size: clamp(18px,2vw,24px);
    color: #fff; text-decoration: none;
  }

  .dbs-menu__nav { flex: 1; display: flex; flex-direction: column; justify-content: center; gap: clamp(2px, 0.6vh, 8px); padding: 4vh 0; }
  .dbs-menu__row { overflow: hidden; }
  .dbs-menu__link {
    display: flex; align-items: baseline; gap: 16px;
    font-family: 'Fraunces', serif; font-weight: 300;
    font-size: clamp(30px, 5.4vw, 64px); line-height: 1.08; letter-spacing: -0.01em;
    color: rgba(255,255,255,0.62); text-decoration: none;
    transform: translateY(110%); transition: transform 0.7s var(--db-ease), color 0.4s ease, opacity 0.4s ease;
  }
  .dbs-menu.is-open .dbs-menu__link { transform: translateY(0); }
  .dbs-menu__link:hover, .dbs-menu__link.is-active { color: #fff; font-style: italic; }
  .dbs-menu__num { font-family: 'Figtree', sans-serif; font-size: 11px; letter-spacing: 0.2em; opacity: 0.4; font-style: normal; }

  .dbs-menu__foot {
    display: flex; flex-wrap: wrap; gap: 28px; justify-content: space-between;
    border-top: 1px solid rgba(255,255,255,0.14); padding-top: 22px;
  }
  .dbs-menu__foot a, .dbs-menu__foot span {
    font-family: 'Figtree', sans-serif; font-size: 12px; letter-spacing: 0.06em;
    color: rgba(255,255,255,0.7); text-decoration: none;
  }
  .dbs-menu__foot a:hover { color: #fff; }

  /* right image panel */
  .dbs-menu__visual { position: relative; overflow: hidden; background: #111; }
  .dbs-menu__img {
    position: absolute; inset: 0; opacity: 0; transform: scale(1.06);
    transition: opacity 0.7s var(--db-ease), transform 1.2s var(--db-ease);
  }
  .dbs-menu__img.is-active { opacity: 1; transform: scale(1); }
  .dbs-menu__img img, .dbs-menu__img .placeholder-svg { width: 100%; height: 100%; object-fit: cover; display: block; }
  .dbs-menu__img::after { content: ''; position: absolute; inset: 0; background: linear-gradient(180deg, rgba(0,0,0,0) 55%, rgba(0,0,0,0.45) 100%); }
  .dbs-menu__caption {
    position: absolute; left: 0; right: 0; bottom: 0; z-index: 2;
    padding: clamp(20px, 3vw, 40px);
    font-family: 'Figtree', sans-serif; font-size: 12px; letter-spacing: 0.16em; text-transform: uppercase;
    color: #fff; opacity: 0.9;
  }

  @media (max-width: 800px) {
    .dbs-menu { grid-template-columns: 1fr; }
    .dbs-menu__visual { display: none; }
  }

  body.db-menu-open { overflow: hidden; }
</style>

<header class="dbs-header" id="dbs-header-{{ sid }}" data-db-header>
  <div class="dbs-header__inner">
    <nav class="dbs-header__left">
      <button class="dbs-link" type="button" data-dbs-open data-cursor="MENU">Menu</button>
      {%- if main_menu.links.size > 0 -%}
        <a class="dbs-link" href="{{ main_menu.links[0].url }}">{{ main_menu.links[0].title }}</a>
      {%- endif -%}
    </nav>

    <a class="dbs-header__logo" href="{{ routes.root_url }}">{{ shop.name }}</a>

    <div class="dbs-header__right">
      <a class="dbs-link" href="{{ routes.search_url }}">Search</a>
      <a class="dbs-link" href="{{ routes.cart_url }}" data-cursor="VIEW BAG">Bag ({{ cart.item_count }})</a>
      <button class="dbs-burger" type="button" data-dbs-open aria-label="Open menu"><span></span><span></span></button>
    </div>
  </div>
</header>

<div class="dbs-menu" id="dbs-menu-{{ sid }}" aria-hidden="true">
  <div class="dbs-menu__left">
    <div class="dbs-menu__top">
      <a class="dbs-menu__logo" href="{{ routes.root_url }}">{{ shop.name }}</a>
      <button class="dbs-menu__close" type="button" data-dbs-close>Close ✕</button>
    </div>

    <nav class="dbs-menu__nav">
      {%- for link in main_menu.links -%}
        <div class="dbs-menu__row">
          <a class="dbs-menu__link" href="{{ link.url }}" data-cursor="EXPLORE" data-img="{{ forloop.index0 }}">
            <span class="dbs-menu__num">0{{ forloop.index }}</span>{{ link.title }}
          </a>
        </div>
      {%- else -%}
        <div class="dbs-menu__row"><a class="dbs-menu__link" href="{{ routes.all_products_collection_url }}" data-img="0"><span class="dbs-menu__num">01</span>Shop All</a></div>
      {%- endfor -%}
    </nav>

    <div class="dbs-menu__foot">
      <a href="{{ routes.search_url }}">Search</a>
      <a href="{{ routes.cart_url }}">Bag ({{ cart.item_count }})</a>
      <a href="/pages/contact">Contact</a>
      <span>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}</span>
    </div>
  </div>

  <div class="dbs-menu__visual" aria-hidden="true">
    {%- assign img_blocks = section.blocks -%}
    {%- for link in main_menu.links -%}
      {%- assign blk = img_blocks[forloop.index0] -%}
      <figure class="dbs-menu__img{% if forloop.first %} is-active{% endif %}" data-img="{{ forloop.index0 }}">
        {%- if blk and blk.settings.image != blank -%}
          <img src="{{ blk.settings.image | img_url: '1100x' }}" alt="{{ blk.settings.image.alt | escape }}" loading="lazy">
        {%- else -%}
          {%- assign ph = forloop.index0 | modulo: 6 | plus: 1 -%}
          {{ 'product-' | append: ph | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
        <figcaption class="dbs-menu__caption">{{ link.title }}</figcaption>
      </figure>
    {%- else -%}
      <figure class="dbs-menu__img is-active" data-img="0">
        {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
        <figcaption class="dbs-menu__caption">Shop All</figcaption>
      </figure>
    {%- endfor -%}
  </div>
</div>

<script>
(function () {
  var header = document.getElementById('dbs-header-{{ sid }}');
  var menu = document.getElementById('dbs-menu-{{ sid }}');
  if (!header || !menu) return;

  var lastY = window.pageYOffset;
  function onScroll() {
    var y = window.pageYOffset;
    header.classList.toggle('is-solid', y > 40);
    if (y > 200 && y > lastY && !menu.classList.contains('is-open')) header.classList.add('is-hidden');
    else header.classList.remove('is-hidden');
    lastY = y;
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  var links = menu.querySelectorAll('.dbs-menu__link');
  var imgs = menu.querySelectorAll('.dbs-menu__img');
  function activate(idx) {
    links.forEach(function (l) { l.classList.toggle('is-active', l.getAttribute('data-img') === idx); });
    imgs.forEach(function (im) { im.classList.toggle('is-active', im.getAttribute('data-img') === idx); });
  }
  links.forEach(function (l) {
    l.addEventListener('mouseenter', function () { activate(l.getAttribute('data-img')); });
    l.addEventListener('focus', function () { activate(l.getAttribute('data-img')); });
  });

  function stagger(open) {
    links.forEach(function (el, i) { el.style.transitionDelay = open ? (120 + i * 70) + 'ms' : '0ms'; });
  }
  function openMenu() {
    stagger(true);
    menu.classList.add('is-open'); menu.setAttribute('aria-hidden', 'false');
    document.body.classList.add('db-menu-open');
    if (window.dbLenis && window.dbLenis.stop) window.dbLenis.stop();
  }
  function closeMenu() {
    stagger(false);
    menu.classList.remove('is-open'); menu.setAttribute('aria-hidden', 'true');
    document.body.classList.remove('db-menu-open');
    if (window.dbLenis && window.dbLenis.start) window.dbLenis.start();
  }
  document.querySelectorAll('[data-dbs-open]').forEach(function (b) { b.addEventListener('click', openMenu); });
  document.querySelectorAll('[data-dbs-close]').forEach(function (b) { b.addEventListener('click', closeMenu); });
  document.addEventListener('keydown', function (e) { if (e.key === 'Escape') closeMenu(); });
})();
</script>

{% schema %}
{
  "name": "DB Header Split",
  "settings": [
    { "type": "paragraph", "content": "Split overlay menu: nav list on the left, a featured image on the right that swaps as you hover each link. Add an image block per top-level menu item (in order) to set the preview images; otherwise placeholders are used." }
  ],
  "blocks": [
    {
      "type": "menu_image",
      "name": "Menu image",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" }
      ]
    }
  ]
}
{% endschema %}
