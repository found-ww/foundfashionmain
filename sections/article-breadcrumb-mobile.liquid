<style>
  .ppv1-breadcrumb-footer { display: none; }
  @media screen and (max-width: 640px) {
    .ppv1-breadcrumb-footer {
      display: block;
      padding: 14px 24px;
      font-size: 10px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #9a8f86;
      border-top: 1px solid #ede8e2;
    }
    .ppv1-breadcrumb-footer__list {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 6px;
    }
    .ppv1-breadcrumb-footer__item {
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .ppv1-breadcrumb-footer__item + .ppv1-breadcrumb-footer__item::before {
      content: '/';
      color: #c8c0b8;
    }
    .ppv1-breadcrumb-footer__link { color: #9a8f86; text-decoration: none; }
    .ppv1-breadcrumb-footer__link:hover { color: #1c1c1c; }
    .ppv1-breadcrumb-footer__current { color: #1c1c1c; }
  }
</style>

<nav class="ppv1-breadcrumb-footer" aria-label="Breadcrumb">
  <ol class="ppv1-breadcrumb-footer__list" itemscope itemtype="https://schema.org/BreadcrumbList">
    <li class="ppv1-breadcrumb-footer__item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
      <a class="ppv1-breadcrumb-footer__link" href="{{ routes.root_url }}" itemprop="item"><span itemprop="name">{{ 'general.breadcrumb.home' | t }}</span></a>
      <meta itemprop="position" content="1">
    </li>
    <li class="ppv1-breadcrumb-footer__item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
      <a class="ppv1-breadcrumb-footer__link" href="{{ blog.url }}" itemprop="item"><span itemprop="name">{{ blog.title }}</span></a>
      <meta itemprop="position" content="2">
    </li>
    <li class="ppv1-breadcrumb-footer__item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
      <span class="ppv1-breadcrumb-footer__current" itemprop="name">{{ article.title }}</span>
      <meta itemprop="item" content="{{ shop.url }}{{ article.url }}">
      <meta itemprop="position" content="3">
    </li>
  </ol>
</nav>

{% schema %}
{
  "name": "Article Breadcrumb Mob",
  "settings": []
}
{% endschema %}
