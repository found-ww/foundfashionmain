{%- assign sid = section.id -%}
{%- assign s = section.settings -%}

<style>
  #db-marquee-{{ sid }} {
    background: {{ s.bg_color }};
    color: {{ s.text_color }};
    padding: clamp(18px, 4vw, 40px) 0;
    border-top: 1px solid rgba(25,25,25,0.08);
    border-bottom: 1px solid rgba(25,25,25,0.08);
  }
  #db-marquee-{{ sid }} .db-marquee__item {
    display: inline-flex; align-items: center; flex: 0 0 auto;
    font-family: 'Fraunces', serif; font-weight: 300; font-style: italic;
    font-size: clamp(30px, 6vw, 84px); line-height: 1;
    letter-spacing: -0.01em; padding: 0 0.4em;
    white-space: nowrap;
  }
  #db-marquee-{{ sid }} .db-marquee__star { font-style: normal; opacity: 0.35; padding: 0 0.35em; font-size: 0.55em; }
</style>

<section id="db-marquee-{{ sid }}">
  <div class="db-marquee" data-marquee="{{ s.speed | default: 28 }}" data-direction="{{ s.direction }}">
    <div class="db-marquee__track">
      <span class="db-marquee__item">{{ s.text | escape }}<span class="db-marquee__star">✦</span></span>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "DB Marquee",
  "settings": [
    { "type": "text", "id": "text", "label": "Text", "default": "Hermès · Chanel · Louis Vuitton · Dior · Bottega Veneta" },
    { "type": "range", "id": "speed", "label": "Loop seconds", "min": 10, "max": 60, "step": 2, "unit": "s", "default": 28 },
    { "type": "select", "id": "direction", "label": "Direction", "options": [ {"value":"left","label":"Left"}, {"value":"right","label":"Right"} ], "default": "left" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#f4f0ea" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#191919" }
  ],
  "presets": [ { "name": "DB Marquee" } ]
}
{% endschema %}
