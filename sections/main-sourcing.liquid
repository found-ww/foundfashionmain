<style>
  /* ── Hero banner ── */
  .Sourcing__Hero {
    position: relative;
    width: 100%;
    height: 52vh;
    min-height: 340px;
    overflow: hidden;
  }
  .Sourcing__HeroImg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    background-color: #2a2420;
  }
  .Sourcing__HeroOverlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.36);
  }
  .Sourcing__HeroContent {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    padding: 0 24px 64px;
    text-align: center;
    color: #fff;
  }
  .Sourcing__HeroEyebrow {
    font-size: 10px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    opacity: 0.65;
    margin-bottom: 16px;
  }
  .Sourcing__HeroTitle {
    font-size: clamp(2rem, 4.5vw, 3.6rem);
    font-weight: 400;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    line-height: 1.1;
    margin: 0 0 18px;
  }
  .Sourcing__HeroSub {
    font-size: clamp(13px, 1.2vw, 15px);
    font-weight: 300;
    letter-spacing: 0.03em;
    opacity: 0.8;
    max-width: 460px;
    line-height: 1.7;
    margin: 0;
  }

  /* ── Body: split layout ── */
  .SourcingPage {
    display: flex;
    position: relative;
  }
  /* Grey right-hand stripe always fills full section height */
  .SourcingPage::after {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 35%;
    bottom: 0;
    background: #f0f0f0;
    z-index: 0;
  }

  /* ── Left: grid panel ── */
  .SourcingPage__Grid {
    flex: 0 0 65%;
    padding: 40px 40px;
    background: #fff;
    position: relative;
    z-index: 1;
  }

  /* 3-col × 4-row tile grid */
  .SourcingGrid__Tiles {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
  }
  .SourcingTile {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: #f0ece7;
    display: block;
    text-decoration: none;
    cursor: pointer;
  }
  .SourcingTile__Img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s cubic-bezier(0.16,1,0.3,1);
  }
  .SourcingTile:hover .SourcingTile__Img {
    transform: scale(1.05);
  }

  /* Hover reveal panel */
  .SourcingTile__Hover {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    padding: 0 14px 18px;
    background: linear-gradient(to top, rgba(0,0,0,0.55) 0%, transparent 60%);
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.3s ease, transform 0.3s ease;
    pointer-events: none;
  }
  .SourcingTile:hover .SourcingTile__Hover {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  .SourcingTile__Name {
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #fff;
    text-align: center;
    margin-bottom: 10px;
    line-height: 1.4;
  }
  .SourcingTile__AddBtn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(255,255,255,0.92);
    border: none;
    padding: 8px 14px;
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #1c1c1c;
    font-family: inherit;
    cursor: pointer;
    font-weight: 500;
    transition: background 0.2s;
    white-space: nowrap;
  }
  .SourcingTile__AddBtn:hover {
    background: #fff;
  }
  .SourcingTile__AddBtn svg {
    flex-shrink: 0;
  }

  /* Added / remove state */
  .SourcingTile__AddBtn.is-added {
    background: rgba(28,28,28,0.88);
    color: #fff;
  }

  /* Empty tile */
  .SourcingTile--empty {
    cursor: default;
  }
  .SourcingTile--empty .SourcingTile__Placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .SourcingTile--empty .SourcingTile__Placeholder::after {
    content: '';
    width: 20px;
    height: 20px;
    border: 1px solid #c8c0b8;
    border-radius: 50%;
  }

  /* ── Right: form panel ── */
  .SourcingPage__Form {
    flex: 0 0 35%;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 56px 36px;
    background: transparent;
    position: relative;
    z-index: 1;
  }
  .SourcingPage__FormInner {
    width: 100%;
    max-width: 400px;
    position: sticky;
    top: 32px;
  }

  @media screen and (max-width: 989px) {
    .SourcingPage { flex-direction: column; }
    .SourcingPage__Grid,
    .SourcingPage__Form { padding: 48px 24px; }
    .SourcingPage__FormInner { position: static; }
    .SourcingGrid__Tiles { gap: 6px; }
  }

  /* ── Form typography ── */
  .SourcingForm__Title {
    font-size: 20px;
    letter-spacing: 0.06em;
    font-weight: 400;
    text-transform: uppercase;
    color: #1c1c1c;
    margin-bottom: 8px;
  }
  .SourcingForm__Subtitle {
    font-size: 13px;
    color: #6b6259;
    line-height: 1.65;
    margin-bottom: 28px;
  }

  /* Added items pills */
  .SourcingForm__Items {
    margin-bottom: 20px;
    display: none;
  }
  .SourcingForm__Items.has-items {
    display: block;
  }
  .SourcingForm__ItemsLabel {
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #9a8f86;
    margin-bottom: 10px;
  }
  .SourcingForm__ItemsList {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .SourcingForm__ItemPill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: #fff;
    border: 1px solid #e0dbd5;
    padding: 5px 10px 5px 12px;
    font-size: 11px;
    letter-spacing: 0.06em;
    color: #3d3530;
    font-family: inherit;
  }
  .SourcingForm__ItemPillRemove {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    color: #b5ada5;
    display: flex;
    align-items: center;
    font-size: 14px;
    line-height: 1;
    transition: color 0.15s;
    font-family: inherit;
  }
  .SourcingForm__ItemPillRemove:hover { color: #1c1c1c; }

  /* ── Floating label fields ── */
  .SourcingForm__Field {
    position: relative;
    margin-bottom: 16px;
  }
  .SourcingForm__Input,
  .SourcingForm__Textarea {
    width: 100%;
    border: 1px solid #e0dbd5;
    border-radius: 0;
    background: #fff;
    padding: 20px 16px 8px;
    font-size: 14px;
    color: #3d3530;
    font-family: inherit;
    outline: none;
    transition: border-color 0.2s;
    display: block;
    box-sizing: border-box;
  }
  .SourcingForm__Textarea {
    resize: vertical;
    min-height: 100px;
  }
  .SourcingForm__Input:focus,
  .SourcingForm__Textarea:focus { border-color: #9a8f86; }

  .SourcingForm__Label {
    position: absolute;
    left: 16px;
    top: 14px;
    font-size: 14px;
    color: #b5ada5;
    pointer-events: none;
    transition: top 0.15s, font-size 0.15s, color 0.15s, letter-spacing 0.15s;
    font-family: inherit;
  }
  .SourcingForm__Input:focus ~ .SourcingForm__Label,
  .SourcingForm__Input:not(:placeholder-shown) ~ .SourcingForm__Label,
  .SourcingForm__Textarea:focus ~ .SourcingForm__Label,
  .SourcingForm__Textarea:not(:placeholder-shown) ~ .SourcingForm__Label {
    top: 6px;
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #9a8f86;
  }

  /* ── Select field ── */
  .SourcingForm__SelectWrapper {
    position: relative;
    margin-bottom: 16px;
  }
  .SourcingForm__Select {
    width: 100%;
    border: 1px solid #e0dbd5;
    border-radius: 0;
    background: #fff;
    padding: 14px 40px 14px 16px;
    font-size: 14px;
    color: #3d3530;
    font-family: inherit;
    outline: none;
    transition: border-color 0.2s;
    display: block;
    box-sizing: border-box;
    appearance: none;
    cursor: pointer;
  }
  .SourcingForm__Select:focus { border-color: #9a8f86; }
  .SourcingForm__Select option[value=""] { color: #b5ada5; }
  .SourcingForm__SelectChevron {
    position: absolute;
    right: 14px;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
    color: #9a8f86;
  }

  /* ── WhatsApp row: code select + number ── */
  .SourcingForm__WhatsAppRow {
    display: flex;
    gap: 0;
    margin-bottom: 16px;
  }
  .SourcingForm__CountryCode {
    flex: 0 0 auto;
    border: 1px solid #e0dbd5;
    border-right: none;
    border-radius: 0;
    background: #fff;
    padding: 14px 32px 14px 12px;
    font-size: 14px;
    color: #3d3530;
    font-family: inherit;
    outline: none;
    appearance: none;
    cursor: pointer;
    background-image: url("data:image/svg+xml,%3Csvg width='10' height='6' viewBox='0 0 10 6' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1L5 5L9 1' stroke='%239a8f86' stroke-width='1.2' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 10px center;
    transition: border-color 0.2s;
    min-width: 90px;
  }
  .SourcingForm__CountryCode:focus { border-color: #9a8f86; outline: none; }
  .SourcingForm__WhatsAppNumber {
    flex: 1;
    border: 1px solid #e0dbd5;
    border-radius: 0;
    background: #fff;
    padding: 14px 16px;
    font-size: 14px;
    color: #3d3530;
    font-family: inherit;
    outline: none;
    transition: border-color 0.2s;
  }
  .SourcingForm__WhatsAppNumber:focus { border-color: #9a8f86; }
  .SourcingForm__WhatsAppNumber::placeholder { color: #b5ada5; }

  /* ── File upload ── */
  .SourcingForm__Field--file {
    border: 1px dashed #d4cdc6;
    background: #fff;
    padding: 14px 16px;
    cursor: pointer;
    transition: border-color 0.2s;
  }
  .SourcingForm__Field--file:hover { border-color: #9a8f86; }
  .SourcingForm__FileLabel {
    display: flex;
    align-items: center;
    justify-content: space-between;
    cursor: pointer;
  }
  .SourcingForm__FileLabelText {
    font-size: 14px;
    color: #b5ada5;
  }
  .SourcingForm__FileHint {
    font-size: 10px;
    letter-spacing: 0.08em;
    color: #c8c0b8;
    text-transform: uppercase;
  }
  .SourcingForm__FileInput {
    position: absolute;
    inset: 0;
    opacity: 0;
    width: 100%;
    height: 100%;
    cursor: pointer;
  }
  .SourcingForm__Field--file.has-file .SourcingForm__FileLabelText {
    color: #3d3530;
  }

  /* ── Submit ── */
  .SourcingForm__Submit {
    width: 100%;
    background: #1c1c1c;
    color: #fff;
    border: none;
    padding: 16px 24px;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 500;
    font-family: inherit;
    cursor: pointer;
    margin-top: 4px;
    transition: background 0.2s;
  }
  .SourcingForm__Submit:hover { background: #3d3530; }
  .SourcingForm__Note {
    font-size: 11px;
    letter-spacing: 0.06em;
    color: #9a8f86;
    text-align: center;
    margin-top: 14px;
  }

  /* ── Alerts ── */
  .SourcingForm__Alert--error {
    background: #fdf0f0;
    border: 1px solid #e5c5c5;
    color: #9a4040;
    padding: 12px 16px;
    font-size: 13px;
    margin-bottom: 16px;
  }

  /* ── Success state ── */
  .SourcingForm__Success {
    padding: 40px 0;
    text-align: center;
  }
  .SourcingForm__SuccessMark {
    width: 40px;
    height: 40px;
    border: 1px solid #c8c0b8;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
    color: #9a8f86;
  }
  .SourcingForm__SuccessTitle {
    font-size: 16px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 400;
    color: #1c1c1c;
    margin-bottom: 10px;
  }
  .SourcingForm__SuccessNote {
    font-size: 13px;
    color: #9a8f86;
    line-height: 1.6;
  }
</style>

{%- comment -%} ── Hero Banner ── {%- endcomment -%}
<div class="Sourcing__Hero">
  {%- assign hero_bg = '' -%}
  {%- if section.settings.hero_image -%}
    {%- assign hero_bg = section.settings.hero_image | img_url: '2000x' -%}
  {%- elsif section.settings.hero_image_url != blank -%}
    {%- assign hero_bg = section.settings.hero_image_url -%}
  {%- endif -%}
  <div class="Sourcing__HeroImg"
    {%- if hero_bg != '' -%}
      style="background-image: url({{ hero_bg }});"
    {%- endif -%}
  ></div>
  <div class="Sourcing__HeroOverlay"></div>
  <div class="Sourcing__HeroContent">
    {%- if section.settings.hero_eyebrow != blank -%}
      <p class="Sourcing__HeroEyebrow">{{ section.settings.hero_eyebrow }}</p>
    {%- endif -%}
    <h1 class="Sourcing__HeroTitle">{{ section.settings.hero_title | default: page.title }}</h1>
    {%- if section.settings.hero_sub != blank -%}
      <p class="Sourcing__HeroSub">{{ section.settings.hero_sub }}</p>
    {%- endif -%}
  </div>
</div>

{%- comment -%} ── Split body ── {%- endcomment -%}
<section class="SourcingPage" data-section-id="{{ section.id }}" data-section-type="sourcing">

  {%- comment -%} LEFT: 3×4 product grid {%- endcomment -%}
  <div class="SourcingPage__Grid">

    {%- comment -%} Use a dedicated sourcing collection if it exists, else scan all products {%- endcomment -%}
    {%- if collections['sourcing'] != blank -%}
      {%- assign sourcing_pool = collections['sourcing'].products -%}
    {%- elsif collections['Sourcing'] != blank -%}
      {%- assign sourcing_pool = collections['Sourcing'].products -%}
    {%- else -%}
      {%- assign sourcing_pool = collections.all.products -%}
    {%- endif -%}

    <div class="SourcingGrid__Tiles" id="sourcing-grid">
      {%- assign rendered = 0 -%}
      {%- for product in sourcing_pool -%}
        {%- assign product_tags_down = product.tags | join: ',' | downcase -%}
        {%- unless product_tags_down contains 'sourcing' -%}{%- continue -%}{%- endunless -%}
        {%- if rendered >= 12 -%}{%- break -%}{%- endif -%}
        {%- assign rendered = rendered | plus: 1 -%}
        <div class="SourcingTile"
          data-product-title="{{ product.title | escape }}"
          data-product-handle="{{ product.handle }}"
          data-product-type="{{ product.type | escape }}"
          data-product-brand="{{ product.metafields.custom.brand_name.value | first | default: product.metafields.custom.brand_name.value | escape }}">
          {%- if product.featured_image -%}
            <img
              class="SourcingTile__Img"
              src="{{ product.featured_image | img_url: '600x800', crop: 'center' }}"
              srcset="{{ product.featured_image | img_url: '300x400', crop: 'center' }} 300w,
                      {{ product.featured_image | img_url: '600x800', crop: 'center' }} 600w"
              sizes="(max-width: 989px) 33vw, 20vw"
              alt="{{ product.title | escape }}"
              loading="lazy">
          {%- endif -%}
          <div class="SourcingTile__Hover">
            <p class="SourcingTile__Name">{{ product.title }}</p>
            <button class="SourcingTile__AddBtn" type="button">
              <svg class="SourcingTile__AddIcon" width="10" height="10" viewBox="0 0 10 10" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M5 1V9M1 5H9" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
              </svg>
              <span class="SourcingTile__AddLabel">Add to request</span>
            </button>
          </div>
        </div>
      {%- endfor -%}

      {%- if rendered < 12 -%}
        {%- assign empty_tiles = 12 | minus: rendered -%}
        {%- for i in (1..empty_tiles) -%}
          <div class="SourcingTile SourcingTile--empty">
            <div class="SourcingTile__Placeholder"></div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

  </div>

  {%- comment -%} RIGHT: Form panel {%- endcomment -%}
  <div class="SourcingPage__Form">
    <div class="SourcingPage__FormInner">

      {%- form 'contact', class: 'SourcingForm', id: 'sourcing-form' -%}

        {%- if form.posted_successfully? -%}

          <div class="SourcingForm__Success">
            <div class="SourcingForm__SuccessMark" aria-hidden="true">
              <svg width="16" height="12" viewBox="0 0 16 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M1 6L5.5 10.5L15 1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <p class="SourcingForm__SuccessTitle">Request received</p>
            <p class="SourcingForm__SuccessNote">{{ section.settings.response_note | default: 'Our sourcing team will be in touch within 48 hours.' }}</p>
          </div>

        {%- else -%}

          <h2 class="SourcingForm__Title">{{ section.settings.form_title | default: 'Your request' }}</h2>
          {%- if section.settings.form_subtitle != blank -%}
            <p class="SourcingForm__Subtitle">{{ section.settings.form_subtitle }}</p>
          {%- endif -%}

          {%- if form.errors -%}
            <div class="SourcingForm__Alert SourcingForm__Alert--error">
              {%- for field in form.errors -%}
                {%- if field == 'form' -%}
                  <p>{{ form.errors.messages[field] }}</p>
                {%- else -%}
                  <p><strong>{{ form.errors.translated_fields[field] }}</strong> {{ form.errors.messages[field] }}</p>
                {%- endif -%}
              {%- endfor -%}
            </div>
          {%- endif -%}


          {%- comment -%} Name {%- endcomment -%}
          <div class="SourcingForm__Field">
            <input type="text" id="sourcing-name" class="SourcingForm__Input" name="contact[name]"
              placeholder=" " autocomplete="name" required
              {% if customer %}value="{{ customer.name }}"{% endif %}>
            <label class="SourcingForm__Label" for="sourcing-name">Name</label>
          </div>

          {%- comment -%} Email {%- endcomment -%}
          <div class="SourcingForm__Field">
            <input type="email" id="sourcing-email" class="SourcingForm__Input" name="contact[email]"
              placeholder=" " autocomplete="email" required
              {% if customer %}value="{{ customer.email }}"{% endif %}>
            <label class="SourcingForm__Label" for="sourcing-email">Email</label>
          </div>

          {%- comment -%} WhatsApp: country code + number {%- endcomment -%}
          <div class="SourcingForm__WhatsAppRow">
            <select class="SourcingForm__CountryCode" name="contact[WhatsApp Country Code]" aria-label="Country code">
              <optgroup label="Popular">
                <option value="+44">🇬🇧 +44</option>
                <option value="+1">🇺🇸 +1</option>
                <option value="+971">🇦🇪 +971</option>
                <option value="+86">🇨🇳 +86</option>
                <option value="+852">🇭🇰 +852</option>
              </optgroup>
              <optgroup label="All countries">
                <option value="+93">🇦🇫 +93</option>
                <option value="+355">🇦🇱 +355</option>
                <option value="+213">🇩🇿 +213</option>
                <option value="+376">🇦🇩 +376</option>
                <option value="+244">🇦🇴 +244</option>
                <option value="+54">🇦🇷 +54</option>
                <option value="+374">🇦🇲 +374</option>
                <option value="+61">🇦🇺 +61</option>
                <option value="+43">🇦🇹 +43</option>
                <option value="+994">🇦🇿 +994</option>
                <option value="+973">🇧🇭 +973</option>
                <option value="+880">🇧🇩 +880</option>
                <option value="+32">🇧🇪 +32</option>
                <option value="+501">🇧🇿 +501</option>
                <option value="+229">🇧🇯 +229</option>
                <option value="+975">🇧🇹 +975</option>
                <option value="+591">🇧🇴 +591</option>
                <option value="+387">🇧🇦 +387</option>
                <option value="+267">🇧🇼 +267</option>
                <option value="+55">🇧🇷 +55</option>
                <option value="+673">🇧🇳 +673</option>
                <option value="+359">🇧🇬 +359</option>
                <option value="+226">🇧🇫 +226</option>
                <option value="+257">🇧🇮 +257</option>
                <option value="+855">🇰🇭 +855</option>
                <option value="+237">🇨🇲 +237</option>
                <option value="+1">🇨🇦 +1</option>
                <option value="+238">🇨🇻 +238</option>
                <option value="+236">🇨🇫 +236</option>
                <option value="+56">🇨🇱 +56</option>
                <option value="+57">🇨🇴 +57</option>
                <option value="+269">🇰🇲 +269</option>
                <option value="+243">🇨🇩 +243</option>
                <option value="+506">🇨🇷 +506</option>
                <option value="+385">🇭🇷 +385</option>
                <option value="+53">🇨🇺 +53</option>
                <option value="+357">🇨🇾 +357</option>
                <option value="+420">🇨🇿 +420</option>
                <option value="+45">🇩🇰 +45</option>
                <option value="+253">🇩🇯 +253</option>
                <option value="+1767">🇩🇲 +1767</option>
                <option value="+1809">🇩🇴 +1809</option>
                <option value="+593">🇪🇨 +593</option>
                <option value="+20">🇪🇬 +20</option>
