<style>
  /* ── Hero banner ── */
  .Sourcing__Hero {
    position: relative;
    width: 100%;
    height: 52vh;
    min-height: 340px;
    overflow: hidden;
  }
  .Sourcing__HeroImg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    background-color: #2a2420;
  }
  .Sourcing__HeroOverlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.36);
  }
  .Sourcing__HeroContent {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    padding: 0 24px 64px;
    text-align: center;
    color: #fff;
  }
  .Sourcing__HeroEyebrow {
    font-size: 10px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    opacity: 0.65;
    margin-bottom: 16px;
  }
  .Sourcing__HeroTitle {
    font-size: clamp(2rem, 4.5vw, 3.6rem);
    font-weight: 400;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    line-height: 1.1;
    margin: 0 0 18px;
  }
  .Sourcing__HeroSub {
    font-size: clamp(13px, 1.2vw, 15px);
    font-weight: 300;
    letter-spacing: 0.03em;
    opacity: 0.8;
    max-width: 460px;
    line-height: 1.7;
    margin: 0;
  }

  /* ── Body: split layout ── */
  .SourcingPage {
    display: flex;
    min-height: 100vh;
    align-items: flex-start;
  }

  /* ── Left: grid panel ── */
  .SourcingPage__Grid {
    flex: 0 0 65%;
    padding: 40px 40px;
    background: #fff;
  }

  /* 3-col × 4-row tile grid */
  .SourcingGrid__Tiles {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
  }
  .SourcingTile {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: #f0ece7;
    display: block;
    text-decoration: none;
    cursor: pointer;
  }
  .SourcingTile__Img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s cubic-bezier(0.16,1,0.3,1);
  }
  .SourcingTile:hover .SourcingTile__Img {
    transform: scale(1.05);
  }

  /* Hover reveal panel */
  .SourcingTile__Hover {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    padding: 0 14px 18px;
    background: linear-gradient(to top, rgba(0,0,0,0.55) 0%, transparent 60%);
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.3s ease, transform 0.3s ease;
    pointer-events: none;
  }
  .SourcingTile:hover .SourcingTile__Hover {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  .SourcingTile__Name {
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #fff;
    text-align: center;
    margin-bottom: 10px;
    line-height: 1.4;
  }
  .SourcingTile__AddBtn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(255,255,255,0.92);
    border: none;
    padding: 8px 14px;
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #1c1c1c;
    font-family: inherit;
    cursor: pointer;
    font-weight: 500;
    transition: background 0.2s;
    white-space: nowrap;
  }
  .SourcingTile__AddBtn:hover {
    background: #fff;
  }
  .SourcingTile__AddBtn svg {
    flex-shrink: 0;
  }

  /* Added state */
  .SourcingTile__AddBtn.is-added {
    background: #1c1c1c;
    color: #fff;
  }

  /* Empty tile */
  .SourcingTile--empty {
    cursor: default;
  }
  .SourcingTile--empty .SourcingTile__Placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .SourcingTile--empty .SourcingTile__Placeholder::after {
    content: '';
    width: 20px;
    height: 20px;
    border: 1px solid #c8c0b8;
    border-radius: 50%;
  }

  /* ── Right: form panel ── */
  .SourcingPage__Form {
    flex: 0 0 35%;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 56px 48px;
    background: #f0f0f0;
    min-height: 100vh;
  }
  .SourcingPage__FormInner {
    width: 100%;
    max-width: 400px;
    position: sticky;
    top: 32px;
  }

  @media screen and (max-width: 989px) {
    .SourcingPage { flex-direction: column; }
    .SourcingPage__Grid,
    .SourcingPage__Form { padding: 48px 24px; min-height: unset; }
    .SourcingPage__FormInner { position: static; }
    .SourcingGrid__Tiles { gap: 6px; }
  }

  /* ── Form typography ── */
  .SourcingForm__Title {
    font-size: 20px;
    letter-spacing: 0.06em;
    font-weight: 400;
    text-transform: uppercase;
    color: #1c1c1c;
    margin-bottom: 8px;
  }
  .SourcingForm__Subtitle {
    font-size: 13px;
    color: #6b6259;
    line-height: 1.65;
    margin-bottom: 28px;
  }

  /* Added items pills */
  .SourcingForm__Items {
    margin-bottom: 20px;
    display: none;
  }
  .SourcingForm__Items.has-items {
    display: block;
  }
  .SourcingForm__ItemsLabel {
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #9a8f86;
    margin-bottom: 10px;
  }
  .SourcingForm__ItemsList {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .SourcingForm__ItemPill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: #fff;
    border: 1px solid #e0dbd5;
    padding: 5px 10px 5px 12px;
    font-size: 11px;
    letter-spacing: 0.06em;
    color: #3d3530;
    font-family: inherit;
  }
  .SourcingForm__ItemPillRemove {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    color: #b5ada5;
    display: flex;
    align-items: center;
    font-size: 14px;
    line-height: 1;
    transition: color 0.15s;
    font-family: inherit;
  }
  .SourcingForm__ItemPillRemove:hover { color: #1c1c1c; }

  /* ── Floating label fields ── */
  .SourcingForm__Field {
    position: relative;
    margin-bottom: 16px;
  }
  .SourcingForm__Input,
  .SourcingForm__Textarea {
    width: 100%;
    border: 1px solid #e0dbd5;
    border-radius: 0;
    background: #fff;
    padding: 20px 16px 8px;
    font-size: 14px;
    color: #3d3530;
    font-family: inherit;
    outline: none;
    transition: border-color 0.2s;
    display: block;
    box-sizing: border-box;
  }
  .SourcingForm__Textarea {
    resize: vertical;
    min-height: 100px;
  }
  .SourcingForm__Input:focus,
  .SourcingForm__Textarea:focus { border-color: #9a8f86; }

  .SourcingForm__Label {
    position: absolute;
    left: 16px;
    top: 14px;
    font-size: 14px;
    color: #b5ada5;
    pointer-events: none;
    transition: top 0.15s, font-size 0.15s, color 0.15s, letter-spacing 0.15s;
    font-family: inherit;
  }
  .SourcingForm__Input:focus ~ .SourcingForm__Label,
  .SourcingForm__Input:not(:placeholder-shown) ~ .SourcingForm__Label,
  .SourcingForm__Textarea:focus ~ .SourcingForm__Label,
  .SourcingForm__Textarea:not(:placeholder-shown) ~ .SourcingForm__Label {
    top: 6px;
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #9a8f86;
  }

  /* ── Select field ── */
  .SourcingForm__SelectWrapper {
    position: relative;
    margin-bottom: 16px;
  }
  .SourcingForm__Select {
    width: 100%;
    border: 1px solid #e0dbd5;
    border-radius: 0;
    background: #fff;
    padding: 14px 40px 14px 16px;
    font-size: 14px;
    color: #3d3530;
    font-family: inherit;
    outline: none;
    transition: border-color 0.2s;
    display: block;
    box-sizing: border-box;
    appearance: none;
    cursor: pointer;
  }
  .SourcingForm__Select:focus { border-color: #9a8f86; }
  .SourcingForm__Select option[value=""] { color: #b5ada5; }
  .SourcingForm__SelectChevron {
    position: absolute;
    right: 14px;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
    color: #9a8f86;
  }

  /* Two-column row */
  .SourcingForm__Row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-bottom: 16px;
  }
  .SourcingForm__Row .SourcingForm__Field {
    margin-bottom: 0;
  }

  /* ── File upload ── */
  .SourcingForm__Field--file {
    border: 1px dashed #d4cdc6;
    background: #fff;
    padding: 14px 16px;
    cursor: pointer;
    transition: border-color 0.2s;
  }
  .SourcingForm__Field--file:hover { border-color: #9a8f86; }
  .SourcingForm__FileLabel {
    display: flex;
    align-items: center;
    justify-content: space-between;
    cursor: pointer;
  }
  .SourcingForm__FileLabelText {
    font-size: 14px;
    color: #b5ada5;
  }
  .SourcingForm__FileHint {
    font-size: 10px;
    letter-spacing: 0.08em;
    color: #c8c0b8;
    text-transform: uppercase;
  }
  .SourcingForm__FileInput {
    position: absolute;
    inset: 0;
    opacity: 0;
    width: 100%;
    height: 100%;
    cursor: pointer;
  }
  .SourcingForm__Field--file.has-file .SourcingForm__FileLabelText {
    color: #3d3530;
  }

  /* ── Submit ── */
  .SourcingForm__Submit {
    width: 100%;
    background: #1c1c1c;
    color: #fff;
    border: none;
    padding: 16px 24px;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 500;
    font-family: inherit;
    cursor: pointer;
    margin-top: 4px;
    transition: background 0.2s;
  }
  .SourcingForm__Submit:hover { background: #3d3530; }
  .SourcingForm__Note {
    font-size: 11px;
    letter-spacing: 0.06em;
    color: #9a8f86;
    text-align: center;
    margin-top: 14px;
  }

  /* ── Alerts ── */
  .SourcingForm__Alert--error {
    background: #fdf0f0;
    border: 1px solid #e5c5c5;
    color: #9a4040;
    padding: 12px 16px;
    font-size: 13px;
    margin-bottom: 16px;
  }

  /* ── Success state ── */
  .SourcingForm__Success {
    padding: 40px 0;
    text-align: center;
  }
  .SourcingForm__SuccessMark {
    width: 40px;
    height: 40px;
    border: 1px solid #c8c0b8;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
    color: #9a8f86;
  }
  .SourcingForm__SuccessTitle {
    font-size: 16px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 400;
    color: #1c1c1c;
    margin-bottom: 10px;
  }
  .SourcingForm__SuccessNote {
    font-size: 13px;
    color: #9a8f86;
    line-height: 1.6;
  }
</style>

{%- comment -%} ── Hero Banner ── {%- endcomment -%}
<div class="Sourcing__Hero">
  {%- assign hero_bg = '' -%}
  {%- if section.settings.hero_image -%}
    {%- assign hero_bg = section.settings.hero_image | img_url: '2000x' -%}
  {%- elsif section.settings.hero_image_url != blank -%}
    {%- assign hero_bg = section.settings.hero_image_url -%}
  {%- endif -%}
  <div class="Sourcing__HeroImg"
    {%- if hero_bg != '' -%}
      style="background-image: url({{ hero_bg }});"
    {%- endif -%}
  ></div>
  <div class="Sourcing__HeroOverlay"></div>
  <div class="Sourcing__HeroContent">
    {%- if section.settings.hero_eyebrow != blank -%}
      <p class="Sourcing__HeroEyebrow">{{ section.settings.hero_eyebrow }}</p>
    {%- endif -%}
    <h1 class="Sourcing__HeroTitle">{{ section.settings.hero_title | default: page.title }}</h1>
    {%- if section.settings.hero_sub != blank -%}
      <p class="Sourcing__HeroSub">{{ section.settings.hero_sub }}</p>
    {%- endif -%}
  </div>
</div>

{%- comment -%} ── Split body ── {%- endcomment -%}
<section class="SourcingPage" data-section-id="{{ section.id }}" data-section-type="sourcing">

  {%- comment -%} LEFT: 3×4 product grid {%- endcomment -%}
  <div class="SourcingPage__Grid">

    {%- assign sourcing_collection = collections[section.settings.sourcing_collection] -%}
    {%- assign sourcing_products = sourcing_collection.products | default: empty -%}

    <div class="SourcingGrid__Tiles" id="sourcing-grid">
      {%- assign rendered = 0 -%}
      {%- for product in sourcing_products limit: 12 -%}
        {%- assign rendered = rendered | plus: 1 -%}
        <div class="SourcingTile"
          data-product-title="{{ product.title | escape }}"
          data-product-handle="{{ product.handle }}">
          {%- if product.featured_image -%}
            <img
              class="SourcingTile__Img"
              src="{{ product.featured_image | img_url: '600x800', crop: 'center' }}"
              srcset="{{ product.featured_image | img_url: '300x400', crop: 'center' }} 300w,
                      {{ product.featured_image | img_url: '600x800', crop: 'center' }} 600w"
              sizes="(max-width: 989px) 33vw, 20vw"
              alt="{{ product.title | escape }}"
              loading="lazy">
          {%- endif -%}
          <div class="SourcingTile__Hover">
            <p class="SourcingTile__Name">{{ product.title }}</p>
            <button class="SourcingTile__AddBtn" type="button" aria-label="Add {{ product.title | escape }} to sourcing request">
              <svg width="10" height="10" viewBox="0 0 10 10" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M5 1V9M1 5H9" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
              </svg>
              Add to request
            </button>
          </div>
        </div>
      {%- endfor -%}

      {%- if rendered < 12 -%}
        {%- assign empty_tiles = 12 | minus: rendered -%}
        {%- for i in (1..empty_tiles) -%}
          <div class="SourcingTile SourcingTile--empty">
            <div class="SourcingTile__Placeholder"></div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

  </div>

  {%- comment -%} RIGHT: Form panel {%- endcomment -%}
  <div class="SourcingPage__Form">
    <div class="SourcingPage__FormInner">

      {%- form 'contact', class: 'SourcingForm', id: 'sourcing-form' -%}

        {%- if form.posted_successfully? -%}

          <div class="SourcingForm__Success">
            <div class="SourcingForm__SuccessMark" aria-hidden="true">
              <svg width="16" height="12" viewBox="0 0 16 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M1 6L5.5 10.5L15 1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <p class="SourcingForm__SuccessTitle">Request received</p>
            <p class="SourcingForm__SuccessNote">{{ section.settings.response_note | default: 'Our sourcing team will be in touch within 48 hours.' }}</p>
          </div>

        {%- else -%}

          <h2 class="SourcingForm__Title">{{ section.settings.form_title | default: 'Your request' }}</h2>
          {%- if section.settings.form_subtitle != blank -%}
            <p class="SourcingForm__Subtitle">{{ section.settings.form_subtitle }}</p>
          {%- endif -%}

          {%- if form.errors -%}
            <div class="SourcingForm__Alert SourcingForm__Alert--error">
              {%- for field in form.errors -%}
                {%- if field == 'form' -%}
                  <p>{{ form.errors.messages[field] }}</p>
                {%- else -%}
                  <p><strong>{{ form.errors.translated_fields[field] }}</strong> {{ form.errors.messages[field] }}</p>
                {%- endif -%}
              {%- endfor -%}
            </div>
          {%- endif -%}

          {%- comment -%} Selected items pills {%- endcomment -%}
          <div class="SourcingForm__Items" id="sourcing-items-panel">
            <p class="SourcingForm__ItemsLabel">Items added</p>
            <div class="SourcingForm__ItemsList" id="sourcing-items-list"></div>
          </div>

          {%- comment -%} Hidden field populated by JS {%- endcomment -%}
          <input type="hidden" name="contact[Items requested]" id="sourcing-items-input" value="">

          {%- comment -%} Name + Email {%- endcomment -%}
          <div class="SourcingForm__Row">
            <div class="SourcingForm__Field">
              <input type="text" id="sourcing-name" class="SourcingForm__Input" name="contact[name]"
                placeholder=" " autocomplete="name" required
                {% if customer %}value="{{ customer.name }}"{% endif %}>
              <label class="SourcingForm__Label" for="sourcing-name">Name</label>
            </div>
            <div class="SourcingForm__Field">
              <input type="email" id="sourcing-email" class="SourcingForm__Input" name="contact[email]"
                placeholder=" " autocomplete="email" required
                {% if customer %}value="{{ customer.email }}"{% endif %}>
              <label class="SourcingForm__Label" for="sourcing-email">Email</label>
            </div>
          </div>

          {%- comment -%} WhatsApp + Country {%- endcomment -%}
          <div class="SourcingForm__Row">
            <div class="SourcingForm__Field">
              <input type="tel" id="sourcing-whatsapp" class="SourcingForm__Input" name="contact[WhatsApp]"
                placeholder=" " autocomplete="tel">
              <label class="SourcingForm__Label" for="sourcing-whatsapp">WhatsApp</label>
            </div>
            <div class="SourcingForm__Field">
              <input type="text" id="sourcing-country" class="SourcingForm__Input" name="contact[Country]"
                placeholder=" " autocomplete="country-name">
              <label class="SourcingForm__Label" for="sourcing-country">Country</label>
            </div>
          </div>

          {%- comment -%} Category {%- endcomment -%}
          <div class="SourcingForm__SelectWrapper">
            <select id="sourcing-category" name="contact[Category]" class="SourcingForm__Select" required aria-label="Category">
              <option value="" disabled selected>Category</option>
              <option value="Bags">Bags</option>
              <option value="Jewellery">Jewellery</option>
              <option value="Shoes">Shoes</option>
              <option value="Accessories">Accessories</option>
              <option value="Ready to Wear">Ready to Wear</option>
              <option value="Other">Other</option>
            </select>
            <span class="SourcingForm__SelectChevron" aria-hidden="true">
              <svg width="10" height="6" viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </div>

          {%- comment -%} Brand + Item Name {%- endcomment -%}
          <div class="SourcingForm__Row">
            <div class="SourcingForm__Field">
              <input type="text" id="sourcing-brand" class="SourcingForm__Input" name="contact[Brand]"
                placeholder=" ">
              <label class="SourcingForm__Label" for="sourcing-brand">Brand</label>
            </div>
            <div class="SourcingForm__Field">
              <input type="text" id="sourcing-item" class="SourcingForm__Input" name="contact[Item Name]"
                placeholder=" " required>
              <label class="SourcingForm__Label" for="sourcing-item">Item Name</label>
            </div>
          </div>

          {%- comment -%} Upload image {%- endcomment -%}
          <div class="SourcingForm__Field SourcingForm__Field--file">
            <label class="SourcingForm__FileLabel" for="sourcing-image">
              <span class="SourcingForm__FileLabelText">Upload image</span>
              <span class="SourcingForm__FileHint" id="sourcing-image-hint">Optional — jpg, png, webp</span>
            </label>
            <input type="file" id="sourcing-image" name="contact[Image]"
              class="SourcingForm__FileInput"
              accept="image/jpeg,image/png,image/webp"
              aria-label="Upload image">
          </div>

          {%- comment -%} Notes — condition, size, material, hardware {%- endcomment -%}
          <div class="SourcingForm__Field">
            <textarea id="sourcing-notes" name="contact[body]" class="SourcingForm__Textarea"
              placeholder=" " aria-label="Notes"></textarea>
            <label class="SourcingForm__Label" for="sourcing-notes">Notes (condition, size, material, hardware)</label>
          </div>

          <button type="submit" class="SourcingForm__Submit">Submit sourcing request</button>

          {%- if section.settings.response_note != blank -%}
            <p class="SourcingForm__Note">{{ section.settings.response_note }}</p>
          {%- endif -%}

        {%- endif -%}

      {%- endform -%}

    </div>
  </div>

</section>

<script>
(function () {
  var addedItems = [];

  var itemsPanel = document.getElementById('sourcing-items-panel');
  var itemsList  = document.getElementById('sourcing-items-list');
  var itemsInput = document.getElementById('sourcing-items-input');

  function syncInput() {
    itemsInput.value = addedItems.join(', ');
    if (addedItems.length > 0) {
      itemsPanel.classList.add('has-items');
    } else {
      itemsPanel.classList.remove('has-items');
    }
  }

  function removePill(title) {
    addedItems = addedItems.filter(function(t) { return t !== title; });

    // Re-enable tile button
    var tiles = document.querySelectorAll('.SourcingTile[data-product-title]');
    tiles.forEach(function(tile) {
      if (tile.dataset.productTitle === title) {
        var btn = tile.querySelector('.SourcingTile__AddBtn');
        if (btn) {
          btn.classList.remove('is-added');
          btn.innerHTML = '<svg width="10" height="10" viewBox="0 0 10 10" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M5 1V9M1 5H9" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg> Add to request';
        }
      }
    });

    renderPills();
    syncInput();
  }

  function renderPills() {
    itemsList.innerHTML = '';
    addedItems.forEach(function(title) {
      var pill = document.createElement('span');
      pill.className = 'SourcingForm__ItemPill';
      pill.innerHTML = title + '<button class="SourcingForm__ItemPillRemove" type="button" aria-label="Remove ' + title + '">×</button>';
      pill.querySelector('button').addEventListener('click', function() {
        removePill(title);
      });
      itemsList.appendChild(pill);
    });
  }

  // File input: show filename when selected
  var fileInput = document.getElementById('sourcing-image');
  if (fileInput) {
    fileInput.addEventListener('change', function() {
      var field = fileInput.closest('.SourcingForm__Field--file');
      var hint  = document.getElementById('sourcing-image-hint');
      if (fileInput.files && fileInput.files[0]) {
        field.classList.add('has-file');
        hint.textContent = fileInput.files[0].name;
      } else {
        field.classList.remove('has-file');
        hint.textContent = 'Optional — jpg, png, webp';
      }
    });
  }

  document.querySelectorAll('.SourcingTile[data-product-title]').forEach(function(tile) {
    var btn = tile.querySelector('.SourcingTile__AddBtn');
    if (!btn) return;

    btn.addEventListener('click', function(e) {
      e.preventDefault();
      var title = tile.dataset.productTitle;
      if (addedItems.indexOf(title) !== -1) return;

      addedItems.push(title);

      btn.classList.add('is-added');
      btn.innerHTML = '<svg width="10" height="10" viewBox="0 0 10 10" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M2 5L4.5 7.5L8 3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg> Added';

      renderPills();
      syncInput();

      // Scroll form into view on mobile
      if (window.innerWidth < 990) {
        var form = document.getElementById('sourcing-form');
        if (form) form.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });
})();
</script>

