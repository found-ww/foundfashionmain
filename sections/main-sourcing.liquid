<script>
(function () {
  var activeTile = null;

  var fieldItem     = document.getElementById('sourcing-item');
  var fieldBrand    = document.getElementById('sourcing-brand');
  var fieldCategory = document.getElementById('sourcing-category');

  var PLUS_ICON  = '<svg class="SourcingTile__AddIcon" width="10" height="10" viewBox="0 0 10 10" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M5 1V9M1 5H9" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>';
  var MINUS_ICON = '<svg class="SourcingTile__AddIcon" width="10" height="2" viewBox="0 0 10 2" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M1 1H9" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>';

  function resetTile(tile) {
    var btn = tile.querySelector('.SourcingTile__AddBtn');
    btn.classList.remove('is-added');
    btn.querySelector('.SourcingTile__AddIcon').outerHTML; // replaced below
    btn.innerHTML = PLUS_ICON + '<span class="SourcingTile__AddLabel">Add to request</span>';
  }

  function clearFields() {
    if (fieldItem)     { fieldItem.value = '';     fieldItem.dispatchEvent(new Event('input')); }
    if (fieldBrand)    { fieldBrand.value = '';    fieldBrand.dispatchEvent(new Event('input')); }
    if (fieldCategory) { fieldCategory.value = ''; }
  }

  function fillFields(title, brand, type) {
    if (fieldItem)  { fieldItem.value = title;  fieldItem.dispatchEvent(new Event('input')); }
    if (fieldBrand) { fieldBrand.value = brand; fieldBrand.dispatchEvent(new Event('input')); }
    // Map product type to category option if possible
    if (fieldCategory) {
      var options = Array.from(fieldCategory.options).map(function(o) { return o.value.toLowerCase(); });
      var match   = options.indexOf((type || '').toLowerCase());
      fieldCategory.selectedIndex = match > 0 ? match : 0;
    }
  }

  // File input: show filename when selected
  var fileInput = document.getElementById('sourcing-image');
  if (fileInput) {
    fileInput.addEventListener('change', function() {
      var field = fileInput.closest('.SourcingForm__Field--file');
      var hint  = document.getElementById('sourcing-image-hint');
      if (fileInput.files && fileInput.files[0]) {
        field.classList.add('has-file');
        hint.textContent = fileInput.files[0].name;
      } else {
        field.classList.remove('has-file');
        hint.textContent = 'Optional — jpg, png, webp';
      }
    });
  }

  document.querySelectorAll('.SourcingTile[data-product-title]').forEach(function(tile) {
    var btn = tile.querySelector('.SourcingTile__AddBtn');
    if (!btn) return;

    btn.addEventListener('click', function(e) {
      e.preventDefault();

      // Clicking the active tile → remove
      if (activeTile === tile) {
        btn.classList.remove('is-added');
        btn.innerHTML = PLUS_ICON + '<span class="SourcingTile__AddLabel">Add to request</span>';
        clearFields();
        activeTile = null;
        return;
      }

      // Deselect any previously active tile
      if (activeTile) {
        var prevBtn = activeTile.querySelector('.SourcingTile__AddBtn');
        if (prevBtn) {
          prevBtn.classList.remove('is-added');
          prevBtn.innerHTML = PLUS_ICON + '<span class="SourcingTile__AddLabel">Add to request</span>';
        }
      }

      // Select this tile
      activeTile = tile;
      btn.classList.add('is-added');
      btn.innerHTML = MINUS_ICON + '<span class="SourcingTile__AddLabel">Remove item</span>';

      fillFields(
        tile.dataset.productTitle || '',
        tile.dataset.productBrand || '',
        tile.dataset.productType  || ''
      );

      // Scroll form into view on mobile
      if (window.innerWidth < 990) {
        var form = document.getElementById('sourcing-form');
        if (form) form.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });
})();
</script>

