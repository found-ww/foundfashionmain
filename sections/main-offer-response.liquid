<style>
  .or-wrap {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 80px 24px;
    background: #f4f1ed;
  }
  .or-card {
    background: #fff;
    max-width: 480px;
    width: 100%;
    padding: 48px 40px 40px;
  }
  .or-eyebrow {
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #a59c90;
    margin: 0 0 12px;
  }
  .or-heading {
    font-size: 22px;
    font-weight: 400;
    letter-spacing: 0.04em;
    color: #1a1a1a;
    margin: 0 0 12px;
    line-height: 1.3;
  }
  .or-body {
    font-size: 14px;
    line-height: 1.75;
    color: #6b6259;
    margin: 0 0 32px;
  }
  .or-spinner {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    color: #9a8f86;
    margin-bottom: 32px;
  }
  .or-spinner__dot {
    width: 6px;
    height: 6px;
    background: #9a8f86;
    border-radius: 50%;
    animation: or-pulse 1.2s ease-in-out infinite;
  }
  .or-spinner__dot:nth-child(2) { animation-delay: 0.2s; }
  .or-spinner__dot:nth-child(3) { animation-delay: 0.4s; }
  @keyframes or-pulse {
    0%, 80%, 100% { opacity: 0.2; transform: scale(0.8); }
    40% { opacity: 1; transform: scale(1); }
  }
  .or-btn {
    display: inline-block;
    background: #1a1a1a;
    color: #fff;
    padding: 14px 28px;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: background 0.2s;
  }
  .or-btn:hover { background: #3d3530; }
  .or-btn--outline {
    background: #fff;
    color: #1a1a1a;
    border: 1px solid #1a1a1a;
    margin-left: 12px;
  }
  .or-btn--outline:hover { background: #f4f1ed; }
  .or-divider {
    border: none;
    border-top: 1px solid #ece7e0;
    margin: 32px 0;
  }
  .or-link {
    font-size: 12px;
    color: #9a8f86;
    text-decoration: none;
    letter-spacing: 0.04em;
  }
  .or-link:hover { color: #1a1a1a; }
  .or-icon {
    display: block;
    width: 40px;
    height: 40px;
    margin-bottom: 24px;
  }
  @media (max-width: 480px) {
    .or-card { padding: 36px 24px 28px; }
    .or-btn--outline { margin-left: 0; margin-top: 10px; }
  }
</style>

<div class="or-wrap">
  <div class="or-card" id="or-card">

    <!-- Loading state -->
    <div id="or-loading">
      <div class="or-spinner">
        <div class="or-spinner__dot"></div>
        <div class="or-spinner__dot"></div>
        <div class="or-spinner__dot"></div>
        <span>Processing your response&hellip;</span>
      </div>
    </div>

    <!-- Success: accepted -->
    <div id="or-accepted" style="display:none;">
      <svg class="or-icon" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="20" cy="20" r="19.5" stroke="#1a1a1a" stroke-opacity="0.12"/>
        <path d="M13 20.5L17.5 25L27 15" stroke="#1a1a1a" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <p class="or-eyebrow">Counter offer accepted</p>
      <h1 class="or-heading">You&rsquo;re all set</h1>
      <p class="or-body">Thank you for accepting our offer. We&rsquo;ve sent a payment link to your email — check your inbox to complete your purchase.</p>
      <a href="/" class="or-btn">Continue browsing</a>
      <hr class="or-divider">
      <a href="https://wa.me/447405520466" class="or-link">Questions? Message us on WhatsApp &rarr;</a>
    </div>

    <!-- Success: declined -->
    <div id="or-declined" style="display:none;">
      <svg class="or-icon" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="20" cy="20" r="19.5" stroke="#1a1a1a" stroke-opacity="0.12"/>
        <path d="M15 15L25 25M25 15L15 25" stroke="#1a1a1a" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      <p class="or-eyebrow">Offer declined</p>
      <h1 class="or-heading">We&rsquo;re sorry it didn&rsquo;t work out</h1>
      <p class="or-body">No worries at all. We hope to find you the perfect piece soon — browse our current collection or get in touch if you&rsquo;d like to discuss further.</p>
      <a href="/collections/all" class="or-btn">Browse collection</a>
      <a href="https://wa.me/447405520466" class="or-btn or-btn--outline">WhatsApp us</a>
      <hr class="or-divider">
      <a href="/" class="or-link">Return to Found Fashion &rarr;</a>
    </div>

    <!-- Error state -->
    <div id="or-error" style="display:none;">
      <svg class="or-icon" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="20" cy="20" r="19.5" stroke="#1a1a1a" stroke-opacity="0.12"/>
        <path d="M20 13v8M20 25v2" stroke="#1a1a1a" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      <p class="or-eyebrow">Something went wrong</p>
      <h1 class="or-heading">This link is no longer valid</h1>
      <p class="or-body" id="or-error-msg">This offer may have already been responded to, or the link has expired. Please get in touch if you need help.</p>
      <a href="https://wa.me/447405520466" class="or-btn">Message us on WhatsApp</a>
      <hr class="or-divider">
      <a href="/" class="or-link">Return to Found Fashion &rarr;</a>
    </div>

  </div>
</div>

<script>
(async () => {
  const params = new URLSearchParams(window.location.search);
  const token = params.get('token');
  const action = params.get('action');

  function show(id) {
    ['or-loading','or-accepted','or-declined','or-error'].forEach(s => {
      document.getElementById(s).style.display = s === id ? 'block' : 'none';
    });
  }

  if (!token || !action) {
    show('or-error');
    return;
  }

  try {
    const res = await fetch('https://prh8oillgk.execute-api.eu-north-1.amazonaws.com/offer/respond', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ token, action })
    });

    const data = await res.json();

    if (!res.ok) {
      document.getElementById('or-error-msg').textContent = data.error || 'Something went wrong. Please get in touch if you need help.';
      show('or-error');
      return;
    }

    show(action === 'accept' ? 'or-accepted' : 'or-declined');
  } catch (err) {
    show('or-error');
  }
})();
</script>

{% schema %}
{
  "name": "Offer Response",
  "settings": []
}
{% endschema %}
