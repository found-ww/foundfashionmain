<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Figtree:wght@400;500;700&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">

{%- assign main_menu = linklists['main-menu'] -%}
{%- comment -%}Which menu items get mega menus (lowercase match){%- endcomment -%}
{%- assign mega_items = 'bags,clothing,shoes,accessories,jewellery & watches' | split: ',' -%}

<style>
  :root {
    --use-sticky-header: 1;
    --use-unsticky-header: 0;
    --header-is-not-transparent: {% if template == 'index' %}0{% else %}1{% endif %};
    --header-is-transparent: {% if template == 'index' %}1{% else %}0{% endif %};
  }

  .shopify-section--header {
    position: -webkit-sticky;
    position: sticky;
    top: 0;
    z-index: 100;
    background: transparent !important;
  }

  {% unless template == 'index' %}
  .shopify-section--header {
    background: #ffffff !important;
  }
  {% endunless %}

  {% if template == 'index' %}
  .shopify-section--header {
    margin-bottom: calc(-1 * var(--ff-header-height, 66px));
  }
  {% endif %}

  /* ====================================================
     FF Header
     ==================================================== */

  .ff-header {
    width: 100%;
    {% if template == 'index' %}
    color: #ffffff;
    {% else %}
    color: #1c1b1b;
    background: #ffffff;
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.06);
    {% endif %}
    font-family: 'Figtree', sans-serif;
    transition: background 0.3s ease, color 0.3s ease;
  }

  .ff-header:hover {
    background: #ffffff;
    color: #1c1b1b;
  }

  .ff-header__main {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 28px;
  }

  .ff-header__left { flex: 1; display: flex; align-items: center; }

  .ff-header__hamburger {
    background: none;
    border: none;
    color: inherit;
    cursor: pointer;
    padding: 4px;
    display: flex;
    align-items: center;
  }

  .ff-header__center { flex: 0 0 auto; text-align: center; }

  .ff-header__logo {
    font-family: 'Figtree', sans-serif;
    font-weight: 500;
    font-size: 18px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin: 0;
  }

  .ff-header__logo a { color: inherit; text-decoration: none; }

  .ff-header__right {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 24px;
  }

  .ff-header__link {
    font-family: 'Figtree', sans-serif;
    font-weight: 400;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: inherit;
    white-space: nowrap;
    transition: opacity 0.2s ease;
  }

  .ff-header__link:hover { opacity: 0.7; }

  /* ====================================================
     Hover-reveal navigation
     ==================================================== */

  .ff-header__reveal {
    max-height: 0;
    overflow: visible;
    opacity: 0;
    transition: max-height 0.35s cubic-bezier(0.4, 0, 0.2, 1),
                opacity 0.25s ease;
    position: relative;
  }

  .ff-header:hover .ff-header__reveal {
    max-height: 50px;
    opacity: 1;
  }

  .ff-header__reveal-inner {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 32px;
    padding: 0 28px 14px;
  }

  .ff-header__reveal-item {
    position: relative;
  }

  .ff-header__reveal-link {
    font-family: 'Figtree', sans-serif;
    font-weight: 400;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    color: inherit;
    white-space: nowrap;
    transition: opacity 0.2s ease;
    display: block;
    padding: 2px 0;
  }

  .ff-header__reveal-link:hover { opacity: 0.6; }

  /* ====================================================
     Mega Menu — matching old FoundMegaMenu exactly
     ==================================================== */

  .ff-mega {
    position: fixed;
    top: auto;
    left: 0;
    right: 0;
    width: 100vw;
    background: #ffffff;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.25s ease, visibility 0.25s ease;
    z-index: 200;
    color: #1c1b1b;
    pointer-events: none;
  }

  .ff-header__reveal-item:hover .ff-mega {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .ff-mega__inner {
    display: flex;
    align-items: stretch;
    width: 100%;
  }

  /* Left column: nav links */
  .ff-mega__nav {
    flex: 0 0 auto;
    width: 190px;
    padding: 28px 40px;
  }

  .ff-mega__nav-label {
    display: block;
    font-family: 'Jost', sans-serif;
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #7a7468;
    margin-bottom: 20px;
  }

  .ff-mega__nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .ff-mega__nav-item { margin-bottom: 14px; }
  .ff-mega__nav-item:last-child { margin-bottom: 0; }

  .ff-mega__nav-link {
    font-family: 'Jost', sans-serif;
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #1a1814;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .ff-mega__nav-link:hover { color: #b8a07a; }

  /* Right section: 4-card product strip */
  .ff-mega__strip {
    flex: 1;
    display: flex;
    min-width: 0;
    border-left: 1px solid #e8e2d8;
  }

  .ff-mega__card {
    flex: 1;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    background: #ffffff;
    min-width: 0;
    transition: background-color 0.2s ease;
  }

  .ff-mega__card + .ff-mega__card { border-left: 1px solid #e8e2d8; }
  .ff-mega__card:hover { background: #faf8f5; }

  .ff-mega__empty {
    flex: 1;
    min-width: 0;
    background: #ffffff;
  }

  .ff-mega__img-wrap {
    height: 280px;
    overflow: hidden;
    background: #f5f3ef;
    flex-shrink: 0;
  }

  .ff-mega__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.45s ease;
  }

  .ff-mega__card:hover .ff-mega__img { transform: scale(1.04); }

  .ff-mega__info {
    border-top: 1px solid #e8e2d8;
    padding: 14px 20px 18px;
    display: flex;
    flex-direction: column;
  }

  .ff-mega__brand {
    font-family: 'Jost', sans-serif;
    font-size: 9px;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #bbbbbb;
    margin-bottom: 6px;
  }

  .ff-mega__name {
    font-family: 'Jost', sans-serif;
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #444444;
    line-height: 1.5;
    margin-bottom: 5px;
  }

  .ff-mega__price {
    font-family: 'Jost', sans-serif;
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 0.04em;
    color: #7a7468;
  }

  /* Mobile */
  @media screen and (max-width: 768px) {
    .ff-header__right-desktop { display: none; }
    .ff-header__reveal { display: none; }
    .ff-header__logo { font-size: 14px; letter-spacing: 0.15em; }
  }

  @media screen and (min-width: 769px) {
    .ff-header__right-mobile { display: none; }
  }
</style>

<div class="ff-header" id="ff-header">
  <div class="ff-header__main">
    <div class="ff-header__left">
      <button class="ff-header__hamburger" data-action="open-drawer" data-drawer-id="sidebar-menu" aria-label="Open menu">
        <svg width="20" height="14" viewBox="0 0 20 14" fill="none" xmlns="http://www.w3.org/2000/svg">
          <line y1="1" x2="20" y2="1" stroke="currentColor" stroke-width="1.5"/>
          <line y1="7" x2="20" y2="7" stroke="currentColor" stroke-width="1.5"/>
          <line y1="13" x2="20" y2="13" stroke="currentColor" stroke-width="1.5"/>
        </svg>
      </button>
    </div>

    <div class="ff-header__center">
      {% if template == 'index' %}<h1 class="ff-header__logo">{% else %}<div class="ff-header__logo">{% endif %}
        <a href="/">FOUND FASHION</a>
      {% if template == 'index' %}</h1>{% else %}</div>{% endif %}
    </div>

    <div class="ff-header__right">
      <nav class="ff-header__right-desktop">
        <a href="/collections/bags" class="ff-header__link">SHOP BAGS</a>
      </nav>
      <nav class="ff-header__right-desktop">
        <a href="/blogs/found-magazine" class="ff-header__link">MAGAZINE</a>
      </nav>
      <a href="/cart" class="ff-header__link ff-header__right-desktop" data-action="open-drawer" data-drawer-id="sidebar-cart">CART{% if cart.item_count > 0 %} ({{ cart.item_count }}){% endif %}</a>
      <a href="/cart" class="ff-header__link ff-header__right-mobile" data-action="open-drawer" data-drawer-id="sidebar-cart" aria-label="Cart">
        {%- render 'icon' with 'cart' -%}
      </a>
    </div>
  </div>

  {%- comment -%}Hover-reveal nav — dynamically built from main-menu{%- endcomment -%}
  <div class="ff-header__reveal">
    <nav class="ff-header__reveal-inner">
      {%- for link in main_menu.links -%}
        {%- assign downcased_title = link.title | downcase | strip -%}
        {%- assign has_mega = false -%}
        {%- if mega_items contains downcased_title -%}
          {%- assign has_mega = true -%}
        {%- endif -%}

        <div class="ff-header__reveal-item">
          <a href="{{ link.url }}" class="ff-header__reveal-link">{{ link.title | escape }}</a>

          {%- if has_mega -%}
            {%- comment -%}Extract collection handle from the link URL{%- endcomment -%}
            {%- assign col_handle = '' -%}
            {%- if link.url contains '/collections/' -%}
              {%- assign col_handle = link.url | split: '/collections/' | last | split: '?' | first | split: '/' | first -%}
            {%- endif -%}
            {%- assign mega_col = collections[col_handle] -%}

            <div class="ff-mega">
              <div class="ff-mega__inner">
                {%- comment -%}Left: sub-links from the Shopify menu structure{%- endcomment -%}
                <div class="ff-mega__nav">
                  <span class="ff-mega__nav-label">Shop {{ link.title }}</span>
                  <ul class="ff-mega__nav-list">
                    <li class="ff-mega__nav-item">
                      <a href="{{ link.url }}" class="ff-mega__nav-link">VIEW ALL</a>
                    </li>
                    {%- for sub_link in link.links -%}
                      <li class="ff-mega__nav-item">
                        <a href="{{ sub_link.url }}" class="ff-mega__nav-link">{{ sub_link.title | upcase }}</a>
                      </li>
                      {%- for sub_sub_link in sub_link.links -%}
                        <li class="ff-mega__nav-item">
                          <a href="{{ sub_sub_link.url }}" class="ff-mega__nav-link">{{ sub_sub_link.title | upcase }}</a>
                        </li>
                      {%- endfor -%}
                    {%- endfor -%}
                  </ul>
                </div>

                {%- comment -%}Right: 4 product cards from the collection{%- endcomment -%}
                <div class="ff-mega__strip">
                  {%- if mega_col != blank -%}
                    {%- assign rendered = 0 -%}
                    {%- for product in mega_col.products limit: 20 -%}
                      {%- if product.available and rendered < 4 -%}
                        {%- assign rendered = rendered | plus: 1 -%}
                        <a href="{{ product.url }}" class="ff-mega__card">
                          <div class="ff-mega__img-wrap">
                            {%- if product.featured_media -%}
                              {%- assign img_url = product.featured_media | img_url: '1x1' | replace: '_1x1.', '_{width}x.' -%}
                              <img class="ff-mega__img Image--lazyLoad Image--fadeIn"
                                   data-src="{{ img_url }}"
                                   data-widths="[300, 400, 600]"
                                   data-sizes="auto"
                                   alt="{{ product.featured_media.alt | default: product.title | escape }}">
                            {%- endif -%}
                          </div>
                          <div class="ff-mega__info">
                            {%- if product.vendor != blank -%}
                              <span class="ff-mega__brand">{{ product.vendor | upcase }}</span>
                            {%- endif -%}
                            <span class="ff-mega__name">{{ product.title | escape }}</span>
                            <span class="ff-mega__price">{{ product.price | money }}</span>
                          </div>
                        </a>
                      {%- endif -%}
                    {%- endfor -%}
                    {%- if rendered < 4 -%}
                      {%- assign empty = 4 | minus: rendered -%}
                      {%- for i in (1..empty) -%}
                        <div class="ff-mega__empty"></div>
                      {%- endfor -%}
                    {%- endif -%}
                  {%- endif -%}
                </div>
              </div>
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </nav>
  </div>
</div>

<script>
  (function() {
    var h = document.getElementById('ff-header');
    if (h) {
      var height = h.offsetHeight;
      document.documentElement.style.setProperty('--ff-header-height', height + 'px');
      document.documentElement.style.setProperty('--header-height', height + 'px');
    }
  })();
</script>

{% schema %}
{
  "name": "Header",
  "class": "shopify-section--header"
}
{% endschema %}
