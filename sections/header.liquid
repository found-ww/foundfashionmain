<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Figtree:wght@400;500;700&display=swap" rel="stylesheet">

<style>
  :root {
    --use-sticky-header: 1;
    --use-unsticky-header: 0;
    --header-is-not-transparent: {% if template == 'index' %}0{% else %}1{% endif %};
    --header-is-transparent: {% if template == 'index' %}1{% else %}0{% endif %};
  }

  .shopify-section--header {
    position: -webkit-sticky;
    position: sticky;
    top: 0;
    z-index: 100;
    background: transparent !important;
  }

  {% unless template == 'index' %}
  .shopify-section--header {
    background: #ffffff !important;
  }
  {% endunless %}

  {% if template == 'index' %}
  .shopify-section--header {
    margin-bottom: calc(-1 * var(--ff-header-height, 66px));
  }
  {% endif %}

  /* ====================================================
     FF Header — 100% custom, no theme dependencies
     ==================================================== */

  .ff-header {
    width: 100%;
    {% if template == 'index' %}
    color: #ffffff;
    {% else %}
    color: #1c1b1b;
    background: #ffffff;
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.06);
    {% endif %}
    font-family: 'Figtree', sans-serif;
  }

  .ff-header__main {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 28px;
  }

  /* Left */
  .ff-header__left {
    flex: 1;
    display: flex;
    align-items: center;
  }

  .ff-header__hamburger {
    background: none;
    border: none;
    color: inherit;
    cursor: pointer;
    padding: 4px;
    display: flex;
    align-items: center;
  }

  /* Center */
  .ff-header__center {
    flex: 0 0 auto;
    text-align: center;
  }

  .ff-header__logo {
    font-family: 'Figtree', sans-serif;
    font-weight: 500;
    font-size: 18px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    text-decoration: none;
    color: inherit;
    white-space: nowrap;
    margin: 0;
  }

  .ff-header__logo a {
    color: inherit;
    text-decoration: none;
  }

  /* Right */
  .ff-header__right {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 24px;
  }

  .ff-header__link {
    font-family: 'Figtree', sans-serif;
    font-weight: 400;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: inherit;
    white-space: nowrap;
    transition: opacity 0.2s ease;
  }

  .ff-header__link:hover {
    opacity: 0.7;
  }

  /* ====================================================
     Hover-reveal navigation
     ==================================================== */

  .ff-header__reveal {
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition: max-height 0.35s cubic-bezier(0.4, 0, 0.2, 1),
                opacity 0.25s ease;
  }

  .ff-header:hover .ff-header__reveal {
    max-height: 50px;
    opacity: 1;
  }

  .ff-header__reveal-inner {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 32px;
    padding: 0 28px 14px;
  }

  .ff-header__reveal-link {
    font-family: 'Figtree', sans-serif;
    font-weight: 400;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    color: inherit;
    white-space: nowrap;
    transition: opacity 0.2s ease;
  }

  .ff-header__reveal-link:hover {
    opacity: 0.6;
  }

  /* Mobile */
  @media screen and (max-width: 768px) {
    .ff-header__right-desktop {
      display: none;
    }

    .ff-header__reveal {
      display: none;
    }

    .ff-header__logo {
      font-size: 14px;
      letter-spacing: 0.15em;
    }
  }

  @media screen and (min-width: 769px) {
    .ff-header__right-mobile {
      display: none;
    }
  }
</style>

<div class="ff-header" id="ff-header">
  {%- comment -%}Main bar{%- endcomment -%}
  <div class="ff-header__main">
    <div class="ff-header__left">
      <button class="ff-header__hamburger" data-action="open-drawer" data-drawer-id="sidebar-menu" aria-label="Open menu">
        <svg width="20" height="14" viewBox="0 0 20 14" fill="none" xmlns="http://www.w3.org/2000/svg">
          <line y1="1" x2="20" y2="1" stroke="currentColor" stroke-width="1.5"/>
          <line y1="7" x2="20" y2="7" stroke="currentColor" stroke-width="1.5"/>
          <line y1="13" x2="20" y2="13" stroke="currentColor" stroke-width="1.5"/>
        </svg>
      </button>
    </div>

    <div class="ff-header__center">
      {% if template == 'index' %}<h1 class="ff-header__logo">{% else %}<div class="ff-header__logo">{% endif %}
        <a href="/">FOUND FASHION</a>
      {% if template == 'index' %}</h1>{% else %}</div>{% endif %}
    </div>

    <div class="ff-header__right">
      {%- comment -%}Desktop links{%- endcomment -%}
      <nav class="ff-header__right-desktop">
        <a href="/collections/bags" class="ff-header__link">SHOP BAGS</a>
      </nav>
      <nav class="ff-header__right-desktop">
        <a href="/blogs/found-magazine" class="ff-header__link">MAGAZINE</a>
      </nav>
      <a href="/cart" class="ff-header__link ff-header__right-desktop" data-action="open-drawer" data-drawer-id="sidebar-cart">CART{% if cart.item_count > 0 %} ({{ cart.item_count }}){% endif %}</a>

      {%- comment -%}Mobile cart icon{%- endcomment -%}
      <a href="/cart" class="ff-header__link ff-header__right-mobile" data-action="open-drawer" data-drawer-id="sidebar-cart" aria-label="Cart">
        {%- render 'icon' with 'cart' -%}
      </a>
    </div>
  </div>

  {%- comment -%}Hover-reveal full nav{%- endcomment -%}
  <div class="ff-header__reveal">
    <nav class="ff-header__reveal-inner">
      <a href="/collections/new-arrivals" class="ff-header__reveal-link">New Arrivals</a>
      <a href="/collections/bags" class="ff-header__reveal-link">Bags</a>
      <a href="/collections/clothing" class="ff-header__reveal-link">Clothing</a>
      <a href="/collections/shoes" class="ff-header__reveal-link">Shoes</a>
      <a href="/collections/accessories" class="ff-header__reveal-link">Accessories</a>
      <a href="/collections/jewellery-watches" class="ff-header__reveal-link">Jewellery & Watches</a>
      <a href="/pages/personal-shopping" class="ff-header__reveal-link">Personal Shopping</a>
      <a href="/pages/contact" class="ff-header__reveal-link">Contact</a>
      <a href="/blogs/found-magazine" class="ff-header__reveal-link">Magazine</a>
    </nav>
  </div>
</div>

<script>
  // Set header height CSS var for transparent header overlap
  (function() {
    var h = document.getElementById('ff-header');
    if (h) {
      var height = h.offsetHeight;
      document.documentElement.style.setProperty('--ff-header-height', height + 'px');
      document.documentElement.style.setProperty('--header-height', height + 'px');
    }
  })();
</script>

{% schema %}
{
  "name": "Header",
  "class": "shopify-section--header"
}
{% endschema %}
