    </div>

    <div class="ff-header__right">
      <nav class="ff-header__right-desktop">
        <a href="/collections/bags" class="ff-header__link">SHOP BAGS</a>
      </nav>
      <nav class="ff-header__right-desktop">
        <a href="/blogs/found-magazine" class="ff-header__link">MAGAZINE</a>
      </nav>
