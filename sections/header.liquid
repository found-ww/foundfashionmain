                <li class="ff-mega__nav-item"><a href="/collections/bags" class="ff-mega__nav-link">BAGS</a></li>
                <li class="ff-mega__nav-item"><a href="/collections/shoes" class="ff-mega__nav-link">SHOES</a></li>
                <li class="ff-mega__nav-item"><a href="/collections/clothing" class="ff-mega__nav-link">CLOTHING</a></li>
                <li class="ff-mega__nav-item"><a href="/collections/accessories" class="ff-mega__nav-link">ACCESSORIES</a></li>
              </ul>
            </div>
            <div class="ff-mega__strip">
              {%- assign rendered = 0 -%}
              {%- for product in mega_col.products limit: 20 -%}
                {%- if product.available and rendered < 4 -%}
                  {%- assign rendered = rendered | plus: 1 -%}
                  <a href="{{ product.url }}" class="ff-mega__card">
                    <div class="ff-mega__img-wrap">
                      {%- if product.featured_media -%}
                        <img class="ff-mega__img" src="{{ product.featured_media | img_url: '400x' }}" alt="{{ product.title | escape }}" loading="lazy">
                      {%- endif -%}
                    </div>
                    <div class="ff-mega__info">
                      {%- if product.vendor != blank -%}<span class="ff-mega__brand">{{ product.vendor | upcase }}</span>{%- endif -%}
                      <span class="ff-mega__name">{{ product.title | escape }}</span>
                      <span class="ff-mega__price">{{ product.price | money }}</span>
                    </div>
                  </a>
                {%- endif -%}
              {%- endfor -%}
              {%- if rendered < 4 -%}{%- assign empty = 4 | minus: rendered -%}{%- for i in (1..empty) -%}<div class="ff-mega__empty"></div>{%- endfor -%}{%- endif -%}
            </div>
          </div>
        </div>
        {%- endif -%}
      </div>

