{%- comment -%}
  Custom simplified header for Found Fashion homepage redesign.
  - Left: hamburger menu
  - Center: FOUND FASHION text
  - Right: SHOP BAGS, MAGAZINE, CART
  - Hover reveals full nav bar below
  - Transparent on homepage, solid on other pages
  - Compatible with existing theme.js HeaderSection class
{%- endcomment -%}

{%- assign use_transparent_header = false -%}
{%- if template == 'index' and section.settings.enable_transparent_header -%}
  {%- assign use_transparent_header = true -%}
{%- endif -%}

{%- assign main_menu = linklists[section.settings.navigation_menu | default: 'main-menu'] -%}

{%- comment -%}Search modal — must be directly before <header> for CSS to work{%- endcomment -%}
<div id="Search" class="Search" aria-hidden="true">
  <div class="Search__Inner">
    <div class="Search__SearchBar">
      <form action="{{ routes.search_url }}" name="GET" role="search" class="Search__Form">
        <div class="Search__InputIconWrapper">
          <span class="hidden-tablet-and-up">{%- render 'icon' with 'search' -%}</span>
          <span class="hidden-phone">{%- render 'icon' with 'search-desktop' -%}</span>
        </div>
        <input type="search" class="Search__Input Heading" name="q" autocomplete="off" autocorrect="off" autocapitalize="off" aria-label="{{ 'search.general.input_placeholder' | t }}" placeholder="{{ 'search.general.input_placeholder' | t }}" autofocus>
        <input type="hidden" name="type" value="product">
      </form>
      <button class="Search__Close Link Link--primary" data-action="close-search" aria-label="{{ 'header.navigation.close_search' | t }}">{% render 'icon' with 'close' %}</button>
    </div>
    <div class="Search__Results" aria-hidden="true">
      {%- if settings.search_mode != 'product' -%}
        <div class="PageLayout PageLayout--breakLap">
          <div class="PageLayout__Section"></div>
          <div class="PageLayout__Section PageLayout__Section--secondary"></div>
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{%- capture section_settings -%}
{
  "navigationStyle": "sidebar",
  "hasTransparentHeader": {% if use_transparent_header %}true{% else %}false{% endif %},
  "isSticky": {% if section.settings.use_sticky_header %}true{% else %}false{% endif %}
}
{%- endcapture -%}

<header id="section-{{ section.id }}"
        class="Header Header--sidebar Header--initialized {% if use_transparent_header %}Header--transparent{% endif %} Header--withIcons"
        data-section-id="{{ section.id }}"
        data-section-type="header"
        data-section-settings='{{ section_settings }}'
        role="banner">

  {%- comment -%}Main header bar{%- endcomment -%}
  <div class="Header__Wrapper ff-header__bar">
    {%- comment -%}Left: hamburger{%- endcomment -%}
    <div class="Header__FlexItem Header__FlexItem--fill ff-header__left">
      <button class="ff-header__hamburger" aria-expanded="false" data-action="open-drawer" data-drawer-id="sidebar-menu" aria-label="{{ 'header.navigation.open_sidebar' | t }}">
        <svg width="20" height="14" viewBox="0 0 20 14" fill="none" xmlns="http://www.w3.org/2000/svg">
          <line y1="1" x2="20" y2="1" stroke="currentColor" stroke-width="1.5"/>
          <line y1="7" x2="20" y2="7" stroke="currentColor" stroke-width="1.5"/>
          <line y1="13" x2="20" y2="13" stroke="currentColor" stroke-width="1.5"/>
        </svg>
      </button>
    </div>

    {%- comment -%}Center: logo text{%- endcomment -%}
    <div class="Header__FlexItem Header__FlexItem--logo ff-header__center">
      {%- if template == 'index' -%}
        <h1 class="Header__Logo ff-header__logo-text">
          <a href="{{ routes.root_url }}" class="Header__LogoLink ff-header__logo-link">FOUND FASHION</a>
        </h1>
      {%- else -%}
        <div class="Header__Logo ff-header__logo-text">
          <a href="{{ routes.root_url }}" class="Header__LogoLink ff-header__logo-link">FOUND FASHION</a>
        </div>
      {%- endif -%}
    </div>

    {%- comment -%}Right: nav links + cart{%- endcomment -%}
    <div class="Header__FlexItem Header__FlexItem--fill ff-header__right">
      <nav class="ff-header__nav hidden-pocket hidden-lap">
        <a href="/collections/bags" class="ff-header__nav-link">SHOP BAGS</a>
        <a href="/blogs/found-magazine" class="ff-header__nav-link">MAGAZINE</a>
        <a href="{{ routes.cart_url }}" class="ff-header__nav-link" {% unless template == 'cart' or settings.cart_type == 'page' %}data-action="open-drawer" data-drawer-id="sidebar-cart" aria-label="{{ 'header.navigation.open_cart' | t }}"{% endunless %}>
          CART{% if cart.item_count > 0 %} ({{ cart.item_count }}){% endif %}
        </a>
      </nav>

      {%- comment -%}Mobile: just cart icon{%- endcomment -%}
      <a href="{{ routes.cart_url }}" class="Header__Icon Icon-Wrapper Icon-Wrapper--clickable hidden-tablet-and-up" {% if settings.cart_type == 'drawer' %}data-action="open-drawer" data-drawer-id="sidebar-cart" aria-expanded="false" aria-label="{{ 'header.navigation.open_cart' | t }}"{% endif %}>
        {%- render 'icon' with 'cart' -%}
        <span class="Header__CartDot {% if cart.item_count > 0 %}is-visible{% endif %}"></span>
      </a>
    </div>
  </div>

  {%- comment -%}Hover-reveal full navigation bar{%- endcomment -%}
  <div class="ff-header__reveal hidden-pocket hidden-lap">
    <nav class="ff-header__reveal-nav">
      {%- for link in main_menu.links -%}
        <a href="{{ link.url }}" class="ff-header__reveal-link">{{ link.title | escape }}</a>
      {%- endfor -%}
    </nav>
  </div>
</header>

<style>
  {%- if section.settings.use_sticky_header -%}
    :root {
      --use-sticky-header: 1;
      --use-unsticky-header: 0;
    }
    .shopify-section--header {
      position: -webkit-sticky;
      position: sticky;
    }
  {%- else -%}
    :root {
      --use-sticky-header: 0;
      --use-unsticky-header: 1;
    }
  {%- endif -%}

  {%- if use_transparent_header -%}
    :root {
      --header-is-not-transparent: 0;
      --header-is-transparent: 1;
    }
    .shopify-section--header {
      margin-bottom: calc(-1 * var(--header-height));
    }
    .supports-sticky .Search[aria-hidden="true"] + .Header--transparent {
      {%- if section.settings.show_transparent_header_border -%}
        box-shadow: 0 -1px {{ section.settings.transparent_text_color | color_modify: 'alpha', 0.25 }} inset;
      {%- else -%}
        box-shadow: none;
      {%- endif -%}
      color: {{ section.settings.transparent_text_color }};
    }
  {%- else -%}
    :root {
      --header-is-not-transparent: 1;
      --header-is-transparent: 0;
    }
  {%- endif -%}

  /* ====================================================
     Found Fashion — Custom Minimal Header
     ==================================================== */

  /* Ensure the header is always hoverable, even when transparent.
     A 1x1 transparent GIF background tricks the browser into treating
     the entire area as a hover target. */
  #section-{{ section.id }} {
    background-image: url('data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7') !important;
    background-size: cover;
  }

  .ff-header__left {
    justify-content: flex-start;
  }

  .ff-header__hamburger {
    background: none;
    border: none;
    color: inherit;
    cursor: pointer;
    padding: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ff-header__center {
    justify-content: center;
    text-align: center;
  }

  .ff-header__logo-text {
    margin: 0;
  }

  .ff-header__logo-link {
    font-family: 'Figtree', sans-serif;
    font-weight: 500;
    font-size: 18px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    text-decoration: none;
    color: inherit;
    white-space: nowrap;
  }

  .ff-header__right {
    justify-content: flex-end;
  }

  .ff-header__nav {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .ff-header__nav-link {
    font-family: 'Figtree', sans-serif;
    font-weight: 400;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: inherit;
    white-space: nowrap;
    transition: opacity 0.2s ease;
  }

  .ff-header__nav-link:hover {
    opacity: 0.7;
  }

  /* ====================================================
     Hover-reveal navigation
     ==================================================== */

  .ff-header__reveal {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s cubic-bezier(0.4, 0, 0.2, 1),
                opacity 0.3s ease;
    opacity: 0;
  }

  /* Show on header hover (desktop only) */
  .Header:hover .ff-header__reveal {
    max-height: 60px;
    opacity: 1;
  }

  .ff-header__reveal-nav {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 32px;
    padding: 12px 24px;
    border-top: 1px solid rgba(255, 255, 255, 0.15);
  }

  /* When NOT transparent (solid header), use dark border */
  .Header:not(.Header--transparent) .ff-header__reveal-nav {
    border-top-color: rgba(0, 0, 0, 0.08);
  }

  .ff-header__reveal-link {
    font-family: 'Figtree', sans-serif;
    font-weight: 400;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    color: inherit;
    white-space: nowrap;
    transition: opacity 0.2s ease;
  }

  .ff-header__reveal-link:hover {
    opacity: 0.6;
  }

  @media screen and (max-width: 640px) {
    .ff-header__logo-link {
      font-size: 14px;
      letter-spacing: 0.15em;
    }
  }
</style>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Figtree:wght@400;500;700&display=swap" rel="stylesheet">

<script>
  document.documentElement.style.setProperty('--header-height', document.getElementById('shopify-section-header').offsetHeight + 'px');
</script>

{% schema %}
{
  "name": "Header",
  "class": "shopify-section--header",
  "settings": [
    {
      "type": "checkbox",
      "id": "use_sticky_header",
      "label": "Use sticky header",
      "default": true
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "link_list",
      "id": "navigation_menu",
      "label": "Menu",
      "default": "main-menu",
      "info": "Full navigation menu — shown in sidebar drawer and hover-reveal bar"
    },
    {
      "type": "header",
      "content": "Transparent header"
    },
    {
      "type": "checkbox",
      "id": "enable_transparent_header",
      "label": "Enable on homepage",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_transparent_header_border",
      "label": "Show separation border",
      "default": false
    },
    {
      "type": "color",
      "id": "transparent_text_color",
      "label": "Text/icon colour",
      "default": "#ffffff"
    }
  ]
}
{% endschema %}
