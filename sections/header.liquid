<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Figtree:wght@400;500;700&display=swap" rel="stylesheet">

<style>
  :root {
    --use-sticky-header: 1;
    --use-unsticky-header: 0;
    --header-is-not-transparent: {% if template == 'index' %}0{% else %}1{% endif %};
    --header-is-transparent: {% if template == 'index' %}1{% else %}0{% endif %};
  }

  .shopify-section--header {
    position: -webkit-sticky;
    position: sticky;
    top: 0;
    z-index: 100;
    background: transparent !important;
  }

  {% unless template == 'index' %}
  .shopify-section--header {
    background: #ffffff !important;
  }
  {% endunless %}

  {% if template == 'index' %}
  .shopify-section--header {
    margin-bottom: calc(-1 * var(--ff-header-height, 66px));
  }
  {% endif %}

  /* ====================================================
     FF Header
     ==================================================== */

  .ff-header {
    width: 100%;
    {% if template == 'index' %}
    color: #ffffff;
    {% else %}
    color: #1c1b1b;
    background: #ffffff;
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.06);
    {% endif %}
    font-family: 'Figtree', sans-serif;
  }

  .ff-header__main {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 28px;
  }

  .ff-header__left { flex: 1; display: flex; align-items: center; }

  .ff-header__hamburger {
    background: none;
    border: none;
    color: inherit;
    cursor: pointer;
    padding: 4px;
    display: flex;
    align-items: center;
  }

  .ff-header__center { flex: 0 0 auto; text-align: center; }

  .ff-header__logo {
    font-family: 'Figtree', sans-serif;
    font-weight: 500;
    font-size: 18px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin: 0;
  }

  .ff-header__logo a { color: inherit; text-decoration: none; }

  .ff-header__right {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 24px;
  }

  .ff-header__link {
    font-family: 'Figtree', sans-serif;
    font-weight: 400;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: inherit;
    white-space: nowrap;
    transition: opacity 0.2s ease;
  }

  .ff-header__link:hover { opacity: 0.7; }

  /* ====================================================
     Hover-reveal navigation
     ==================================================== */

  .ff-header__reveal {
    max-height: 0;
    overflow: visible;
    opacity: 0;
    transition: max-height 0.35s cubic-bezier(0.4, 0, 0.2, 1),
                opacity 0.25s ease;
    position: relative;
  }

  .ff-header:hover .ff-header__reveal {
    max-height: 50px;
    opacity: 1;
  }

  .ff-header__reveal-inner {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 32px;
    padding: 0 28px 14px;
  }

  /* Each reveal link wrapper (for mega menu positioning) */
  .ff-header__reveal-item {
    position: relative;
  }

  .ff-header__reveal-link {
    font-family: 'Figtree', sans-serif;
    font-weight: 400;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    color: inherit;
    white-space: nowrap;
    transition: opacity 0.2s ease;
    display: block;
    padding: 2px 0;
  }

  .ff-header__reveal-link:hover { opacity: 0.6; }

  /* ====================================================
     Mega Menu Dropdown
     ==================================================== */

  .ff-mega {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    width: 90vw;
    max-width: 1200px;
    background: #ffffff;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.12);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.25s ease, visibility 0.25s ease;
    z-index: 200;
    color: #1c1b1b;
    pointer-events: none;
  }

  .ff-header__reveal-item:hover .ff-mega {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .ff-mega__inner {
    display: flex;
    align-items: stretch;
    width: 100%;
  }

  /* Left column: nav links */
  .ff-mega__nav {
    flex: 0 0 auto;
    width: 190px;
    padding: 28px 40px;
  }

  .ff-mega__nav-label {
    display: block;
    font-family: 'Figtree', sans-serif;
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #7a7468;
    margin-bottom: 20px;
  }

  .ff-mega__nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .ff-mega__nav-item { margin-bottom: 14px; }
  .ff-mega__nav-item:last-child { margin-bottom: 0; }

  .ff-mega__nav-link {
    font-family: 'Figtree', sans-serif;
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #1a1814;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .ff-mega__nav-link:hover { color: #b8a07a; }

  /* Right section: 4-card product strip */
  .ff-mega__strip {
    flex: 1;
    display: flex;
    min-width: 0;
    border-left: 1px solid #e8e2d8;
  }

  .ff-mega__card {
    flex: 1;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    background: #ffffff;
    min-width: 0;
    transition: background-color 0.2s ease;
  }

  .ff-mega__card + .ff-mega__card { border-left: 1px solid #e8e2d8; }
  .ff-mega__card:hover { background: #faf8f5; }

  .ff-mega__empty {
    flex: 1;
    min-width: 0;
    background: #ffffff;
  }

  .ff-mega__img-wrap {
    height: 280px;
    overflow: hidden;
    background: #f5f3ef;
    flex-shrink: 0;
  }

  .ff-mega__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.45s ease;
  }

  .ff-mega__card:hover .ff-mega__img { transform: scale(1.04); }

  .ff-mega__info {
    border-top: 1px solid #e8e2d8;
    padding: 14px 20px 18px;
    display: flex;
    flex-direction: column;
  }

  .ff-mega__brand {
    font-family: 'Figtree', sans-serif;
    font-size: 9px;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #bbbbbb;
    margin-bottom: 6px;
  }

  .ff-mega__name {
    font-family: 'Figtree', sans-serif;
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #444444;
    line-height: 1.5;
    margin-bottom: 5px;
  }

  .ff-mega__price {
    font-family: 'Figtree', sans-serif;
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 0.04em;
    color: #7a7468;
  }

  /* Mobile */
  @media screen and (max-width: 768px) {
    .ff-header__right-desktop { display: none; }
    .ff-header__reveal { display: none; }
    .ff-header__logo { font-size: 14px; letter-spacing: 0.15em; }
  }

  @media screen and (min-width: 769px) {
    .ff-header__right-mobile { display: none; }
  }
</style>

