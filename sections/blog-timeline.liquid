<div id="section-{{ section.id }}" class="Section BlogTimeline" data-section-id="{{ section.id }}" data-section-type="blog-timeline">

  {%- comment -%} ── Page header ── {%- endcomment -%}
  <div class="Blog">
    <div class="Container">
      <header class="PageHeader">
        <div class="SectionHeader SectionHeader--center">
          <h1 class="SectionHeader__Heading Heading u-h1">{{ blog.title }}</h1>
        </div>
      </header>
    </div>
  </div>

  {%- comment -%}
  ─────────────────────────────────────────────────────────────────────────────
  TIMELINE
  Edit the timeline by pasting .entry divs into the "Timeline content" field
  in the theme customiser, or directly in sections/blog-timeline.liquid.

  Each entry can be:
    class="entry full"   — centred text, no image
    class="entry left"   — text on left, image on right
    class="entry right"  — image on left, text on right

  Structure of a full entry:
    <div class="entry full">
      <div class="text">
        <span class="year">YEAR</span>
        <div class="title">Milestone title</div>
        <p class="desc">Description text.</p>
      </div>
    </div>

  Structure of a left/right entry:
    <div class="entry left">
      <div class="text">
        <span class="year">YEAR</span>
        <div class="title">Milestone title</div>
        <p class="desc">Description text.</p>
      </div>
      <div class="visual">
        <img src="..." alt="...">
      </div>
    </div>
  ─────────────────────────────────────────────────────────────────────────────
  {%- endcomment -%}

  {%- if section.settings.show_timeline -%}
    <div class="BlogTimeline__Section">
      {%- if section.settings.timeline_heading != blank -%}
        <h2 class="BlogTimeline__Heading">{{ section.settings.timeline_heading }}</h2>
      {%- endif -%}

      <div class="BlogTimeline__Wrap">
        <div class="BlogTimeline__Timeline timeline">
          <div class="spine"></div>

          {%- comment -%}
          ═══════════════════════════════════════════════════════════════
          HARDCODED TIMELINE — paste your .entry divs between the capture
          tags below. This takes priority over the customiser setting.
          Leave empty to fall back to the customiser "Timeline content" field.
          ═══════════════════════════════════════════════════════════════
          {%- endcomment -%}
          {%- capture hardcoded_timeline -%}

          {%- endcapture -%}

          {%- assign timeline_content = section.settings.timeline_html -%}
          {%- if hardcoded_timeline != blank -%}
            {{ hardcoded_timeline }}
          {%- elsif timeline_content != blank -%}
            {{ timeline_content }}
          {%- else -%}
            {%- comment -%} Default example card shown when no content is set {%- endcomment -%}
            <div class="entry full">
              <div class="text">
                <span class="year">YEAR</span>
                <div class="title">Your milestone title</div>
                <p class="desc">Paste your timeline entries between the capture tags in sections/blog-timeline.liquid, or use the "Timeline content" field in the theme customiser.</p>
              </div>
            </div>
          {%- endif -%}

        </div>
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} ── Regular article list below the timeline ── {%- endcomment -%}
  {%- if section.settings.show_articles -%}
    <div class="Blog">
      <div class="Container">
        {%- assign articles_per_page = 12 -%}
        {%- paginate blog.articles by articles_per_page -%}
          <div class="ArticleListWrapper">
            <div class="ArticleList Grid Grid--m">
              {%- for article in blog.articles -%}
                <div class="Grid__Cell 1/2--tablet 1/3--lap-and-up">
                  {%- render 'article-item', article: article -%}
                </div>
              {%- endfor -%}
            </div>
          </div>
          {%- render 'pagination', paginate: paginate -%}
        {%- endpaginate -%}
      </div>
    </div>
  {%- endif -%}

</div>

<style>
  /* ── Section wrapper ── */
  .BlogTimeline__Section {
    padding: 60px 0 72px;
    border-top: 1px solid #e8e8e8;
  }

  .BlogTimeline__Heading {
    text-align: center;
    font-family: inherit;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #7a7468;
    margin-bottom: 56px;
  }

  .BlogTimeline__Wrap {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ── Vertical timeline container ── */
  .BlogTimeline__Timeline.timeline {
    max-width: 900px;
    margin: 0 auto;
    position: relative;
  }

  /* ── Centre spine ── */
  .BlogTimeline__Timeline .spine {
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 1px;
    background: #ececec;
    transform: translateX(-50%);
    pointer-events: none;
  }

  /* ── Entry (row) ── */
  .BlogTimeline__Timeline .entry {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0 72px;
    margin-bottom: 52px;
    position: relative;
    opacity: 0;
    animation: btlRise 0.55s ease forwards;
  }

  /* Staggered fade-in */
  .BlogTimeline__Timeline .entry:nth-child(1) { animation-delay: 0s; }
  .BlogTimeline__Timeline .entry:nth-child(2) { animation-delay: 0.1s; }
  .BlogTimeline__Timeline .entry:nth-child(3) { animation-delay: 0.2s; }
  .BlogTimeline__Timeline .entry:nth-child(4) { animation-delay: 0.3s; }
  .BlogTimeline__Timeline .entry:nth-child(5) { animation-delay: 0.4s; }
  .BlogTimeline__Timeline .entry:nth-child(6) { animation-delay: 0.5s; }
  .BlogTimeline__Timeline .entry:nth-child(7) { animation-delay: 0.6s; }
  .BlogTimeline__Timeline .entry:nth-child(8) { animation-delay: 0.7s; }
  .BlogTimeline__Timeline .entry:nth-child(9) { animation-delay: 0.8s; }
  .BlogTimeline__Timeline .entry:nth-child(10) { animation-delay: 0.9s; }

  @keyframes btlRise {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Dot on the spine ── */
  .BlogTimeline__Timeline .entry::before {
    content: '';
    position: absolute;
    left: 50%;
    top: 22px;
    transform: translateX(-50%);
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #190D04;
    z-index: 2;
  }

  /* ── Full (centred, no image) ── */
  .BlogTimeline__Timeline .entry.full {
    display: flex;
    justify-content: center;
  }
  .BlogTimeline__Timeline .entry.full .text {
    text-align: center;
    max-width: 480px;
  }

  /* ── Left (text left, image right) ── */
  .BlogTimeline__Timeline .entry.left .text {
    grid-column: 1;
    text-align: right;
    padding-right: 44px;
  }
  .BlogTimeline__Timeline .entry.left .visual {
    grid-column: 2;
    padding-left: 44px;
  }

  /* ── Right (image left, text right) ── */
  .BlogTimeline__Timeline .entry.right .text {
    grid-column: 2;
    text-align: left;
    padding-left: 44px;
    order: 2;
  }
  .BlogTimeline__Timeline .entry.right .visual {
    grid-column: 1;
    padding-right: 44px;
    order: 1;
    display: flex;
    justify-content: flex-end;
  }

  /* ── Images ── */
  .BlogTimeline__Timeline .visual img {
    display: block;
    mix-blend-mode: multiply;
    max-width: 300px;
    width: 100%;
  }

  /* ── Text elements ── */
  .BlogTimeline__Timeline .year {
    display: block;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: #190D04;
    margin-bottom: 8px;
  }

  .BlogTimeline__Timeline .title {
    font-size: 14px;
    font-weight: 500;
    color: #190D04;
    line-height: 1.4;
    margin-bottom: 8px;
  }

  .BlogTimeline__Timeline .desc {
    font-size: 13px;
    font-weight: 400;
    line-height: 1.7;
    color: #6e6e6e;
  }

  /* ── Mobile: single column ── */
  @media screen and (max-width: 767px) {
    .BlogTimeline__Timeline .spine { display: none; }

    .BlogTimeline__Timeline .entry,
    .BlogTimeline__Timeline .entry.left,
    .BlogTimeline__Timeline .entry.right {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .BlogTimeline__Timeline .entry::before { left: 0; transform: none; }

    .BlogTimeline__Timeline .entry.left .text,
    .BlogTimeline__Timeline .entry.right .text {
      text-align: left;
      padding: 0;
      order: 1;
    }

    .BlogTimeline__Timeline .entry.left .visual,
    .BlogTimeline__Timeline .entry.right .visual {
      padding: 0;
      order: 2;
      justify-content: flex-start;
    }

    .BlogTimeline__Timeline .visual img {
      max-width: 100%;
    }
  }
</style>

{% schema %}
{
  "name": "Blog with Timeline",
  "settings": [
    {
      "type": "header",
      "content": "Timeline"
    },
    {
      "type": "checkbox",
      "id": "show_timeline",
      "label": "Show timeline",
      "default": true
    },
    {
      "type": "text",
      "id": "timeline_heading",
      "label": "Timeline heading",
      "default": "Our Story"
    },
    {
      "type": "html",
      "id": "timeline_html",
      "label": "Timeline content (entry HTML)",
      "info": "Paste your .entry divs here. Use class=\"entry full\", \"entry left\", or \"entry right\". For image-heavy timelines, edit sections/blog-timeline.liquid directly."
    },
    {
      "type": "header",
      "content": "Articles"
    },
    {
      "type": "checkbox",
      "id": "show_articles",
      "label": "Show article grid below timeline",
      "default": true
    }
  ]
}
{% endschema %}
