<div id="section-{{ section.id }}" class="Section BlogTimeline" data-section-id="{{ section.id }}" data-section-type="blog-timeline">

  {%- comment -%} ── Page header ── {%- endcomment -%}
  <div class="Blog">
    <div class="Container">
      <header class="PageHeader">
        <div class="SectionHeader SectionHeader--center">
          <h1 class="SectionHeader__Heading Heading u-h1">{{ blog.title }}</h1>
        </div>
      </header>
    </div>
  </div>

  {%- comment -%}
  ─────────────────────────────────────────────────────────────────────────────
  TIMELINE STRIP
  Edit the cards below to update the timeline.
  Each card needs class="card above" (content above line) or "card below"
  (content below line) or "card center" (no image, centred on line).
  ─────────────────────────────────────────────────────────────────────────────
  {%- endcomment -%}

  {%- if section.settings.show_timeline -%}
    <div class="BlogTimeline__Section">
      {%- if section.settings.timeline_heading != blank -%}
        <h2 class="BlogTimeline__Heading">{{ section.settings.timeline_heading }}</h2>
      {%- endif -%}

      <div class="BlogTimeline__ScrollOuter">
        <div class="BlogTimeline__Strip strip">

          {%- comment -%} ── PASTE / EDIT YOUR TIMELINE CARDS HERE ── {%- endcomment -%}

          {%- assign timeline_content = section.settings.timeline_html -%}
          {%- if timeline_content != blank -%}
            {{ timeline_content }}
          {%- else -%}
            {%- comment -%} Default example cards shown when no custom HTML is set {%- endcomment -%}
            <div class="card center">
              <div class="top">
                <span class="year">YEAR</span>
                <div class="title">Your milestone title</div>
                <p class="desc">Edit the timeline HTML in the Timeline Content field in the theme customizer, or directly in sections/blog-timeline.liquid.</p>
              </div>
              <div class="dot"></div>
              <div class="bottom"></div>
            </div>
          {%- endif -%}

        </div>
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} ── Regular article list below the timeline ── {%- endcomment -%}
  {%- if section.settings.show_articles -%}
    <div class="Blog">
      <div class="Container">
        {%- assign articles_per_page = 12 -%}
        {%- paginate blog.articles by articles_per_page -%}
          <div class="ArticleListWrapper">
            <div class="ArticleList Grid Grid--m">
              {%- for article in blog.articles -%}
                <div class="Grid__Cell 1/2--tablet 1/3--lap-and-up">
                  {%- render 'article-item', article: article -%}
                </div>
              {%- endfor -%}
            </div>
          </div>
          {%- render 'pagination', paginate: paginate -%}
        {%- endpaginate -%}
      </div>
    </div>
  {%- endif -%}

</div>

<style>
  /* ── Timeline scroll container ── */
  .BlogTimeline__Section {
    padding: 60px 0 40px;
    border-top: 1px solid #e8e8e8;
  }

  .BlogTimeline__Heading {
    text-align: center;
    font-family: inherit;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #7a7468;
    margin-bottom: 40px;
  }

  .BlogTimeline__ScrollOuter {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    /* Hide scrollbar — visible on hover */
    scrollbar-width: thin;
    scrollbar-color: #d0ccc5 transparent;
  }

  .BlogTimeline__ScrollOuter::-webkit-scrollbar {
    height: 4px;
  }

  .BlogTimeline__ScrollOuter::-webkit-scrollbar-thumb {
    background: #d0ccc5;
    border-radius: 2px;
  }

  /* ── Timeline strip (from user example) ── */
  .BlogTimeline__Strip.strip {
    display: flex;
    align-items: stretch;
    min-width: max-content;
    padding: 0 64px;
    position: relative;
  }

  .BlogTimeline__Strip.strip::before {
    content: '';
    position: absolute;
    top: 50%; left: 0; right: 0;
    height: 1px;
    background: #e0ddd6;
    pointer-events: none;
    z-index: 0;
  }

  .BlogTimeline__Strip .card {
    width: 220px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    position: relative;
    z-index: 1;
    padding: 0 16px;
    opacity: 0;
    animation: blogTimelineIn .5s ease forwards;
  }

  .BlogTimeline__Strip .card:nth-child(1){animation-delay:0s}
  .BlogTimeline__Strip .card:nth-child(2){animation-delay:.08s}
  .BlogTimeline__Strip .card:nth-child(3){animation-delay:.16s}
  .BlogTimeline__Strip .card:nth-child(4){animation-delay:.24s}
  .BlogTimeline__Strip .card:nth-child(5){animation-delay:.32s}
  .BlogTimeline__Strip .card:nth-child(6){animation-delay:.40s}
  .BlogTimeline__Strip .card:nth-child(7){animation-delay:.48s}
  .BlogTimeline__Strip .card:nth-child(8){animation-delay:.56s}
  .BlogTimeline__Strip .card:nth-child(9){animation-delay:.64s}
  .BlogTimeline__Strip .card:nth-child(10){animation-delay:.72s}

  @keyframes blogTimelineIn {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .BlogTimeline__Strip .dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: #190D04;
    flex-shrink: 0;
    margin: 0 auto;
    position: relative; z-index: 2;
  }

  /* Above: image+text sit above line, year below */
  .BlogTimeline__Strip .card.above .top {
    display: flex; flex-direction: column;
    flex: 1;
    padding-bottom: 20px;
    justify-content: flex-end;
  }
  .BlogTimeline__Strip .card.above .bottom {
    padding-top: 16px;
  }

  /* Below: year sits above line, image+text below */
  .BlogTimeline__Strip .card.below .top {
    padding-bottom: 16px;
    display: flex; align-items: flex-end;
    justify-content: center;
  }
  .BlogTimeline__Strip .card.below .bottom {
    padding-top: 20px;
    flex: 1;
  }

  /* Center: text only, centred on line */
  .BlogTimeline__Strip .card.center .top {
    display: flex; flex-direction: column;
    flex: 1; padding-bottom: 20px;
    justify-content: flex-end;
    align-items: center; text-align: center;
  }
  .BlogTimeline__Strip .card.center .bottom {
    padding-top: 16px;
    text-align: center;
  }

  .BlogTimeline__Strip img {
    width: 100%; display: block; mix-blend-mode: multiply;
  }

  .BlogTimeline__Strip .year {
    font-size: 10px; font-weight: 500;
    letter-spacing: 3.5px; color: #190D04;
    text-transform: uppercase; margin-bottom: 6px;
    display: block;
  }

  .BlogTimeline__Strip .title {
    font-size: 12px; font-weight: 500;
    color: #190D04; line-height: 1.4; margin-bottom: 6px;
  }

  .BlogTimeline__Strip .desc {
    font-size: 11.5px; line-height: 1.65; color: #6e6e6e;
  }
</style>

{% schema %}
{
  "name": "Blog with Timeline",
  "settings": [
    {
      "type": "header",
      "content": "Timeline"
    },
    {
      "type": "checkbox",
      "id": "show_timeline",
      "label": "Show timeline",
      "default": true
    },
    {
      "type": "text",
      "id": "timeline_heading",
      "label": "Timeline heading",
      "default": "Our Story"
    },
    {
      "type": "html",
      "id": "timeline_html",
      "label": "Timeline content (HTML cards)",
      "info": "Paste your timeline card HTML here. Use class=\"card above\", \"card below\", or \"card center\". See sections/blog-timeline.liquid for examples."
    },
    {
      "type": "header",
      "content": "Articles"
    },
    {
      "type": "checkbox",
      "id": "show_articles",
      "label": "Show article grid below timeline",
      "default": true
    }
  ]
}
{% endschema %}
