<style>
  .ArticleCommentsSection .Article__Comments,
  .ArticleCommentsSection .Article__CommentFormWrapper { margin-top: 0; }

  /* Reduce gap between Post Comment button and Comments heading */
  .ArticleCommentsSection .Article__CommentFormWrapper { margin-bottom: 8px !important; }
  .ArticleCommentsSection .Article__Comments { margin-top: 8px !important; }
  .ArticleCommentsSection .Form__Submit { margin-bottom: 0; }

  /* Comment card */
  .ArticleCommentsSection .ArticleComment {
    border: 1px solid #e8e3de;
    padding: 24px;
    margin-bottom: 12px;
  }

  /* Footer: meta left, actions right */
  .ArticleComment__Footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 16px;
    flex-wrap: wrap;
    gap: 12px;
  }
  .ArticleComment__Actions { display: flex; align-items: center; gap: 12px; }

  /* Section headings: Leave a comment + Comments */
  .ArticleCommentsSection .Heading.u-h1 {
    font-size: 16px !important;
    letter-spacing: 0.2em !important;
    font-weight: 400 !important;
    text-transform: uppercase;
  }

  /* Comment body text */
  .ArticleComment__Body.Rte,
  .ArticleComment__Body.Rte p {
    font-size: 17px;
    line-height: 1.6;
  }

  /* Comment meta: name · date */
  .ArticleComment__Meta {
    font-size: 10px !important;
    letter-spacing: 0.12em !important;
  }

  /* Form inputs */
  .ArticleCommentsSection .Form__Input,
  .ArticleCommentsSection .Form__Textarea {
    font-size: 16px;
  }

  /* Post comment button */
  .ArticleCommentsSection .Form__Submit {
    font-size: 11px !important;
    letter-spacing: 0.14em !important;
    font-weight: 500 !important;
  }

  /* Vote buttons */
  .ArticleComment__Votes { display: flex; align-items: center; gap: 6px; }
  .ArticleComment__VoteBtn {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    background: none;
    border: 1px solid #e5e0da;
    padding: 5px 10px;
    font-size: 11px;
    letter-spacing: 0.05em;
    cursor: pointer;
    color: #9a8f86;
    transition: border-color 0.15s, color 0.15s, background 0.15s;
    font-family: inherit;
  }
  .ArticleComment__VoteBtn:hover { border-color: #1c1c1c; color: #1c1c1c; }
  .ArticleComment__VoteBtn--active { border-color: #1c1c1c; color: #1c1c1c; background: #f5f1ed; }

  /* Reply button */
  .ArticleComment__ReplyBtn {
    background: none;
    border: none;
    padding: 0;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #9a8f86;
    cursor: pointer;
    font-family: inherit;
    text-decoration: none;
    transition: color 0.15s;
  }
  .ArticleComment__ReplyBtn:hover { color: #1c1c1c; }

  /* Reply indicator banner */
  .Article__ReplyIndicator {
    display: none;
    align-items: center;
    justify-content: space-between;
    background: #f5f1ed;
    padding: 10px 16px;
    margin-bottom: 16px;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #7a6f66;
  }
  .Article__ReplyIndicator__Cancel {
    background: none;
    border: none;
    font-size: 18px;
    line-height: 1;
    cursor: pointer;
    color: #9a8f86;
    padding: 0;
    font-family: inherit;
  }
  .Article__ReplyIndicator__Cancel:hover { color: #1c1c1c; }

  /* Login modal */
  .ArticleLoginModal {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .ArticleLoginModal__Overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
  }
  .ArticleLoginModal__Box {
    position: relative;
    background: #fff;
    padding: 48px 40px 40px;
    max-width: 360px;
    width: calc(100% - 40px);
    text-align: center;
    z-index: 1;
  }
  .ArticleLoginModal__Close {
    position: absolute;
    top: 14px;
    right: 14px;
    background: none;
    border: none;
    cursor: pointer;
    color: #aaa;
    padding: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.15s;
  }
  .ArticleLoginModal__Close:hover { color: #1c1c1c; }
  .ArticleLoginModal__Title {
    font-size: 13px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #1c1c1c;
    margin-bottom: 10px;
  }
  .ArticleLoginModal__Subtitle {
    font-size: 13px;
    color: #888;
    margin-bottom: 28px;
    line-height: 1.6;
  }
  .ArticleLoginModal__Btn {
    display: inline-block;
    min-width: 140px;
  }

  /* Comments header with sort */
  .Article__CommentsHeader {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
  }
  .Article__CommentsHeader .Heading { margin-bottom: 0; }
  .Article__SortWrap {
    position: relative;
    display: inline-flex;
    align-items: center;
  }
  .Article__SortSelect {
    appearance: none;
    -webkit-appearance: none;
    background: #fff;
    border: 1px solid #e5e0da;
    padding: 7px 28px 7px 12px;
    font-family: inherit;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #9a8f86;
    cursor: pointer;
    outline: none;
    transition: border-color 0.15s, color 0.15s;
  }
  .Article__SortSelect:hover { border-color: #b5ada5; color: #1c1c1c; }
  .Article__SortArrow {
    position: absolute;
    right: 10px;
    pointer-events: none;
    color: #b5ada5;
  }
</style>

{%- comment -%} Login modal (rendered once, shown on demand) {%- endcomment -%}
<div class="ArticleLoginModal" id="article-login-modal" style="display:none" aria-modal="true" role="dialog">
  <div class="ArticleLoginModal__Overlay" id="article-login-overlay"></div>
  <div class="ArticleLoginModal__Box">
    <button class="ArticleLoginModal__Close" id="article-login-close" type="button" aria-label="Close">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><line x1="2" y1="2" x2="14" y2="14"/><line x1="14" y1="2" x2="2" y2="14"/></svg>
    </button>
    <p class="ArticleLoginModal__Title">Login to reply</p>
    <p class="ArticleLoginModal__Subtitle">You need to be logged in to reply to a comment.</p>
    <a class="ArticleLoginModal__Btn Button Button--primary" href="/account/login?return_url={{ request.path | url_encode }}">Login</a>
  </div>
</div>

<div class="ArticleCommentsSection" data-section-id="{{ section.id }}" data-section-type="article-comments">
  <div class="Article__Wrapper">
    {%- if blog.comments_enabled? -%}

      <div class="Article__CommentFormWrapper">
        <span class="Anchor" id="comment_form"></span>
        <h2 class="Heading u-h1">{{ 'blog.comments.form_title' | t }}</h2>

        {%- form 'new_comment', article, class: 'Article__CommentForm Form', id: '' -%}
          {%- if form.posted_successfully? -%}
            <p class="Form__Alert Alert Alert--success">
              {%- if blog.moderated? -%}
                {{- 'blog.comments.success_moderated' | t -}}
              {%- else -%}
                {{- 'blog.comments.success' | t -}}
              {%- endif -%}
            </p>
          {%- endif -%}

          {%- if form.errors -%}
            <div class="Form__Alert Alert Alert--error">
              <ul class="Alert__ErrorList">
                {%- for field in form.errors -%}
                  {%- if field == 'form' -%}
                    <li class="Alert__ErrorItem">{{ form.errors.messages[field] }}</li>
                  {%- else -%}
                    <li class="Alert__ErrorItem"><strong>{{ form.errors.translated_fields[field] }}</strong> {{ form.errors.messages[field] }}</li>
                  {%- endif -%}
                {%- endfor -%}
              </ul>
            </div>
          {%- endif -%}

          <div class="Form__Group">
            <div class="Form__Item">
              <input type="text" class="Form__Input" name="comment[author]" placeholder="{{ 'blog.comments.name_placeholder' | t }}" aria-label="{{ 'blog.comments.name_placeholder' | t }}" value="{{ form.author | escape | default: customer.first_name }}" required="required">
              <label class="Form__FloatingLabel">{{ 'blog.comments.name_placeholder' | t }}</label>
            </div>
            <input type="hidden" name="comment[email]" value="{{ form.email | escape | default: customer.email | default: 'anonymous@found.fashion' }}">
          </div>

          <div class="Article__ReplyIndicator" id="article-reply-indicator">
            <span id="article-reply-to-name"></span>
            <button type="button" class="Article__ReplyIndicator__Cancel" id="article-reply-cancel" aria-label="Cancel reply">&times;</button>
          </div>

          <div class="Form__Item">
            <textarea name="comment[body]" rows="6" class="Form__Textarea" id="article-comment-body" placeholder="{{ 'blog.comments.comment_placeholder' | t }}" aria-label="{{ 'blog.comments.comment_placeholder' | t }}" required="required">{{- form.body -}}</textarea>
            <label class="Form__FloatingLabel">{{ 'blog.comments.comment_placeholder' | t }}</label>
          </div>

          {%- if blog.moderated? -%}
            <p class="Form__Hint">{{ 'blog.comments.approval_notice' | t }}</p>
          {%- endif -%}

          <button type="submit" class="Form__Submit Button Button--primary">{{ 'blog.comments.submit' | t }}</button>
        {%- endform -%}
      </div>

      {%- if article.comments_count > 0 -%}
        <div class="Article__Comments">
          <span class="Anchor" id="comments"></span>

          <div class="Article__CommentsHeader">
            <h2 class="Heading u-h1">Comments</h2>
            <div class="Article__SortWrap">
              <select class="Article__SortSelect" id="article-comment-sort" aria-label="Sort comments">
                <option value="top">Top rated</option>
                <option value="recent">Most recent</option>
                <option value="oldest">Oldest first</option>
              </select>
              <svg class="Article__SortArrow" width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><polyline points="2,3 5,7 8,3"/></svg>
            </div>
          </div>

          <div class="Article__CommentList" id="article-comment-list">
            {%- paginate article.comments by 25 -%}
              {%- for comment in article.comments -%}
                <div class="ArticleComment" id="comment-{{ comment.id }}" data-comment-id="{{ comment.id }}" data-timestamp="{{ comment.created_at | date: '%s' }}">
                  <div class="ArticleComment__Body Rte">
                    {{ comment.content }}
                  </div>
                  <div class="ArticleComment__Footer">
                    <div class="ArticleComment__Meta Heading Text--subdued u-h8">
                      <span class="ArticleComment__Author">{{ comment.author }}</span>
                      <span class="ArticleComment__Date">{{ comment.created_at | date: format: 'month_day_year' }}</span>
                    </div>
                    <div class="ArticleComment__Actions">
                      <div class="ArticleComment__Votes">
                        <button class="ArticleComment__VoteBtn" data-comment-id="{{ comment.id }}" data-vote="up" type="button" aria-label="Upvote">
                          <svg width="11" height="11" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="2,8 6,4 10,8"/></svg>
                          <span class="ArticleComment__VoteCount">0</span>
                        </button>
                        <button class="ArticleComment__VoteBtn" data-comment-id="{{ comment.id }}" data-vote="down" type="button" aria-label="Downvote">
                          <svg width="11" height="11" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="2,4 6,8 10,4"/></svg>
                          <span class="ArticleComment__VoteCount">0</span>
                        </button>
                      </div>
                      {%- if customer -%}
                        <button class="ArticleComment__ReplyBtn" type="button" data-reply-to="{{ comment.author | split: ' ' | first | escape }}">Reply</button>
                      {%- else -%}
                        <button class="ArticleComment__ReplyBtn ArticleComment__ReplyBtn--needs-login" type="button">Reply</button>
                      {%- endif -%}
                    </div>
                  </div>
                </div>
              {%- endfor -%}

              {% render 'pagination', paginate: paginate, hash: '#comments' %}
            {%- endpaginate -%}
          </div>
        </div>
      {%- endif -%}

    {%- endif -%}
  </div>
</div>

<script>
  (function() {
    var VOTE_KEY = 'ff_cvotes';

    function getVoteData() {
      try { return JSON.parse(localStorage.getItem(VOTE_KEY) || '{}'); } catch(e) { return {}; }
    }
    function saveVoteData(d) {
      try { localStorage.setItem(VOTE_KEY, JSON.stringify(d)); } catch(e) {}
    }

    /* ---- Vote counts ---- */
    var voteData = getVoteData();
    document.querySelectorAll('.ArticleComment__VoteBtn').forEach(function(btn) {
      var cid    = btn.getAttribute('data-comment-id');
      var type   = btn.getAttribute('data-vote');
      var cdata  = voteData[cid] || { up: 0, down: 0, userVote: null };
      var countEl = btn.querySelector('.ArticleComment__VoteCount');
      if (countEl) countEl.textContent = cdata[type] || 0;
      if (cdata.userVote === type) btn.classList.add('ArticleComment__VoteBtn--active');

      btn.addEventListener('click', function() {
        var data = getVoteData();
        if (!data[cid]) data[cid] = { up: 0, down: 0, userVote: null };
        var prev = data[cid].userVote;
        if (prev === type) {
          data[cid][type] = Math.max(0, (data[cid][type] || 0) - 1);
          data[cid].userVote = null;
        } else {
          if (prev) {
            data[cid][prev] = Math.max(0, (data[cid][prev] || 0) - 1);
            var prevBtn = document.querySelector('.ArticleComment__VoteBtn[data-comment-id="' + cid + '"][data-vote="' + prev + '"]');
            if (prevBtn) {
              prevBtn.classList.remove('ArticleComment__VoteBtn--active');
              var pc = prevBtn.querySelector('.ArticleComment__VoteCount');
              if (pc) pc.textContent = data[cid][prev];
            }
          }
          data[cid][type] = (data[cid][type] || 0) + 1;
          data[cid].userVote = type;
        }
        saveVoteData(data);
        if (countEl) countEl.textContent = data[cid][type];
        btn.classList.toggle('ArticleComment__VoteBtn--active', data[cid].userVote === type);
      });
    });

    /* ---- Reply (logged in) ---- */
    var indicator   = document.getElementById('article-reply-indicator');
    var replyToName = document.getElementById('article-reply-to-name');
    var cancelBtn   = document.getElementById('article-reply-cancel');
    var formAnchor  = document.getElementById('comment_form');
    var textarea    = document.getElementById('article-comment-body');

    document.querySelectorAll('.ArticleComment__ReplyBtn[data-reply-to]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var name = btn.getAttribute('data-reply-to');
        if (textarea) textarea.value = '@' + name + ': ';
        if (replyToName) replyToName.textContent = 'Replying to @' + name;
        if (indicator)  indicator.style.display = 'flex';
        if (formAnchor) formAnchor.scrollIntoView({ behavior: 'smooth', block: 'start' });
        setTimeout(function() {
          if (textarea) { textarea.focus(); textarea.setSelectionRange(textarea.value.length, textarea.value.length); }
        }, 400);
      });
    });

    if (cancelBtn) {
      cancelBtn.addEventListener('click', function() {
        if (indicator) indicator.style.display = 'none';
        if (textarea)  textarea.value = '';
      });
    }

    /* ---- Sort comments ---- */
    var sortSelect = document.getElementById('article-comment-sort');
    var commentList = document.getElementById('article-comment-list');

    function getNetVotes(cid) {
      var d = getVoteData()[cid];
      return d ? (d.up || 0) - (d.down || 0) : 0;
    }

    function sortComments(mode) {
      if (!commentList) return;
      var cards = Array.prototype.slice.call(commentList.querySelectorAll('.ArticleComment'));
      cards.sort(function(a, b) {
        if (mode === 'top') {
          return getNetVotes(b.getAttribute('data-comment-id')) - getNetVotes(a.getAttribute('data-comment-id'));
        } else if (mode === 'recent') {
          return parseInt(b.getAttribute('data-timestamp'), 10) - parseInt(a.getAttribute('data-timestamp'), 10);
        } else { /* oldest */
          return parseInt(a.getAttribute('data-timestamp'), 10) - parseInt(b.getAttribute('data-timestamp'), 10);
        }
      });
      cards.forEach(function(card) { commentList.appendChild(card); });
    }

    if (sortSelect) {
      sortSelect.addEventListener('change', function() { sortComments(this.value); });
    }

    /* ---- Login modal (not-logged-in reply) ---- */
    var modal    = document.getElementById('article-login-modal');
    var overlay  = document.getElementById('article-login-overlay');
    var closeBtn = document.getElementById('article-login-close');

    function openModal()  { if (modal) modal.style.display = 'flex'; document.body.style.overflow = 'hidden'; }
    function closeModal() { if (modal) modal.style.display = 'none';  document.body.style.overflow = ''; }

    document.querySelectorAll('.ArticleComment__ReplyBtn--needs-login').forEach(function(btn) {
      btn.addEventListener('click', openModal);
    });
    if (overlay)  overlay.addEventListener('click', closeModal);
    if (closeBtn) closeBtn.addEventListener('click', closeModal);
    document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeModal(); });
  })();
</script>

{% schema %}
{
  "name": "Article comments",
  "settings": []
}
{% endschema %}
