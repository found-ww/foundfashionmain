{%- assign sid = section.id -%}

<style>
  /* ── Hero ── */
  .auth-hero {
    position: relative;
    width: 100%;
    height: 60vh;
    min-height: 400px;
    overflow: hidden;
  }
  .auth-hero__img {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
  }
  .auth-hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.38);
  }
  .auth-hero__content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    padding: 0 24px 72px;
    text-align: center;
    color: #fff;
  }
  .auth-hero__eyebrow {
    font-size: 10px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    opacity: 0.7;
    margin-bottom: 20px;
  }
  .auth-hero__title {
    font-size: clamp(2.2rem, 5vw, 4rem);
    font-weight: 400;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    line-height: 1.1;
    margin: 0 0 20px;
    max-width: 700px;
  }
  .auth-hero__word {
    display: inline-block;
    opacity: 0;
    transform: translateY(18px);
    transition: opacity 0.6s cubic-bezier(0.16,1,0.3,1), transform 0.6s cubic-bezier(0.16,1,0.3,1);
  }
  .auth-hero__word.auth--in {
    opacity: 1;
    transform: translateY(0);
  }
  .auth-hero__sub {
    font-size: clamp(13px, 1.2vw, 15px);
    font-weight: 300;
    letter-spacing: 0.04em;
    opacity: 0;
    max-width: 480px;
    line-height: 1.7;
    margin: 0;
    transform: translateY(12px);
    transition: opacity 0.7s 0.5s cubic-bezier(0.16,1,0.3,1), transform 0.7s 0.5s cubic-bezier(0.16,1,0.3,1);
  }
  .auth-hero__sub.auth--in {
    opacity: 0.85;
    transform: translateY(0);
  }

  /* ── Intro ── */
  .auth-intro {
    padding: 80px 24px;
    text-align: center;
    background: #faf9f7;
  }
  .auth-intro__text {
    max-width: 640px;
    margin: 0 auto;
    font-size: clamp(15px, 1.4vw, 18px);
    font-weight: 300;
    line-height: 1.75;
    color: #2a2420;
    letter-spacing: 0.01em;
  }

  /* ── Process ── */
  .auth-process {
    padding: 80px 24px;
    background: #fff;
  }
  .auth-process__label {
    text-align: center;
    font-size: 16px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #9a8f86;
    margin-bottom: 56px;
  }
  .auth-process__steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    column-gap: 1px;
    background: #e5e0da;
    max-width: 960px;
    margin: 0 auto;
  }
  .auth-step {
    background: #fff;
    padding: 40px;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s cubic-bezier(0.16,1,0.3,1), transform 0.4s cubic-bezier(0.16,1,0.3,1), box-shadow 0.4s cubic-bezier(0.16,1,0.3,1);
    cursor: default;
  }
  .auth-step.auth--in {
    opacity: 1;
    transform: translateY(0);
  }
  .auth-step.auth--in:hover {
    transform: translateY(-8px) scale(1.03);
    box-shadow: 0 16px 40px rgba(0,0,0,0.07);
    position: relative;
    z-index: 1;
  }
  .auth-step.auth--in:hover .auth-step__num { color: #8a7268; }
  .auth-step__num {
    font-size: 12px;
    letter-spacing: 0.2em;
    color: #b5ada5;
    margin-bottom: 20px;
    display: block;
    transition: color 0.3s;
  }
  .auth-step__title {
    font-size: 13px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #1c1c1c;
    font-weight: 400;
    margin-bottom: 14px;
  }
  .auth-step__body {
    font-size: 14px;
    font-weight: 300;
    line-height: 1.8;
    color: #6b6259;
  }

  /* ── Service ── */
  .auth-service {
    padding: 80px 24px;
    background: #1c1c1c;
    text-align: center;
  }
  .auth-service__label {
    font-size: 10px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    margin-bottom: 20px;
  }
  .auth-service__title {
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 400;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #fff;
    margin-bottom: 20px;
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.7s cubic-bezier(0.16,1,0.3,1), transform 0.7s cubic-bezier(0.16,1,0.3,1);
  }
  .auth-service__title.auth--in {
    opacity: 1;
    transform: translateY(0);
  }
  .auth-service__body {
    font-size: 15px;
    font-weight: 300;
    color: rgba(255,255,255,0.65);
    line-height: 1.75;
    max-width: 480px;
    margin: 0 auto 36px;
  }
  .auth-service__btn {
    display: inline-block;
    background: transparent;
    color: #fff;
    text-decoration: none;
    padding: 15px 48px;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 500;
    font-family: inherit;
    border: 1px solid rgba(255,255,255,0.4);
    transition: background 0.25s, border-color 0.25s;
  }
  .auth-service__btn:hover {
    background: rgba(255,255,255,0.08);
    border-color: rgba(255,255,255,0.7);
    color: #fff;
  }

  /* ── Mobile ── */
  @media screen and (max-width: 767px) {
    .auth-hero { height: 50vh; min-height: 320px; }
    .auth-hero__content { padding-bottom: 48px; }
    .auth-intro,
    .auth-process,
    .auth-service { padding: 60px 24px; }
    .auth-process__steps { grid-template-columns: 1fr; column-gap: 0; row-gap: 1px; }
    .auth-step { padding: 36px 24px; }
  }
</style>

{%- comment -%} ── Hero ── {%- endcomment -%}
<div class="auth-hero">
  {%- if section.settings.hero_image -%}
    <div class="auth-hero__img Image--lazyLoad Image--zoomOut"
         data-optimumx="1.4"
         data-expand="-150"
         style="background-image: url({{ section.settings.hero_image | img_url: '1x1' }})"
         data-bgset="{{ section.settings.hero_image | img_url: '750x' }} 750w, {{ section.settings.hero_image | img_url: '1200x' }} 1200w, {{ section.settings.hero_image | img_url: '1800x' }} 1800w">
    </div>
    <noscript>
      <div class="auth-hero__img" style="background-image: url({{ section.settings.hero_image | img_url: '1200x' }})"></div>
    </noscript>
  {%- else -%}
    <div class="auth-hero__img" style="background: #2a2420;"></div>
  {%- endif -%}
  <div class="auth-hero__overlay"></div>
  <div class="auth-hero__content">
    {%- if section.settings.hero_eyebrow != blank -%}
      <p class="auth-hero__eyebrow">{{ section.settings.hero_eyebrow }}</p>
    {%- endif -%}
    <h1 class="auth-hero__title" data-auth-title>{{ section.settings.hero_title | default: 'Every Piece. Verified.' }}</h1>
    {%- if section.settings.hero_sub != blank -%}
      <p class="auth-hero__sub" data-auth-sub>{{ section.settings.hero_sub }}</p>
    {%- endif -%}
  </div>
</div>

{%- comment -%} ── Intro ── {%- endcomment -%}
{%- if section.settings.intro_text != blank -%}
  <div class="auth-intro">
    <p class="auth-intro__text">{{ section.settings.intro_text }}</p>
  </div>
{%- endif -%}

{%- comment -%} ── Process ── {%- endcomment -%}
<div class="auth-process">
  <p class="auth-process__label">{{ section.settings.process_label | default: 'Our process' }}</p>
  <div class="auth-process__steps">
    <div class="auth-step" data-auth-step>
      <span class="auth-step__num">01</span>
      <p class="auth-step__title">{{ section.settings.step_1_title | default: 'Sourced with care' }}</p>
      <p class="auth-step__body">{{ section.settings.step_1_body | default: 'Every item enters our inventory through our own acquisitions team or a carefully vetted network of trusted resellers — never from unknown sources.' }}</p>
    </div>
    <div class="auth-step" data-auth-step style="transition-delay: 0.1s;">
      <span class="auth-step__num">02</span>
      <p class="auth-step__title">{{ section.settings.step_2_title | default: 'Verified in house' }}</p>
      <p class="auth-step__body">{{ section.settings.step_2_body | default: 'Each piece is examined by our specialists before listing. We check hardware, stitching, date stamps, leather grain and provenance documentation.' }}</p>
    </div>
    <div class="auth-step" data-auth-step style="transition-delay: 0.2s;">
      <span class="auth-step__num">03</span>
      <p class="auth-step__title">{{ section.settings.step_3_title | default: 'Guaranteed authentic' }}</p>
      <p class="auth-step__body">{{ section.settings.step_3_body | default: 'We stand behind every item we sell. If a piece is ever found to be inauthentic, we offer a full refund — no questions asked.' }}</p>
    </div>
  </div>
</div>

{%- comment -%} ── Authentication service ── {%- endcomment -%}
<div class="auth-service">
  <p class="auth-service__label">Additional service</p>
  <h2 class="auth-service__title" data-auth-service-title>{{ section.settings.service_title | default: 'Authentication Service' }}</h2>
  <p class="auth-service__body">{{ section.settings.service_body | default: 'We offer an independent authentication service at an additional cost — for pieces purchased elsewhere or under consideration. Our specialists will assess and certify your item.' }}</p>
  {%- if section.settings.service_cta_url != blank -%}
    <a href="{{ section.settings.service_cta_url }}" class="auth-service__btn">{{ section.settings.service_cta_label | default: 'Get in Touch' }}</a>
  {%- endif -%}
</div>

<script>
(function () {
  /* ── Hero word reveal + cursor scale ── */
  var titleEl = document.querySelector('[data-auth-title]');
  var subEl   = document.querySelector('[data-auth-sub]');
  var heroEl  = document.querySelector('.auth-hero');

  if (titleEl) {
    var raw = titleEl.textContent.trim();
    titleEl.innerHTML = raw.split(' ').map(function (w, i) {
      return '<span class="auth-hero__word" style="transition-delay:' + (0.08 * i) + 's">' + w + '</span>';
    }).join(' ');
    requestAnimationFrame(function () {
      requestAnimationFrame(function () {
        titleEl.querySelectorAll('.auth-hero__word').forEach(function (w) {
          w.classList.add('auth--in');
        });
        if (subEl) subEl.classList.add('auth--in');
      });
    });

    /* Cursor: one word at a time, slow scale to 1.1 */
    if (heroEl && window.matchMedia('(hover: hover)').matches) {
      setTimeout(function () {
        var words = titleEl.querySelectorAll('.auth-hero__word');
        var activeWord = null;
        heroEl.addEventListener('mousemove', function (e) {
          var mx = e.clientX, my = e.clientY;
          var closest = null, closestDist = Infinity;
          words.forEach(function (w) {
            var r = w.getBoundingClientRect();
            var cx = r.left + r.width / 2;
            var cy = r.top  + r.height / 2;
            var dist = Math.sqrt(Math.pow(mx - cx, 2) + Math.pow(my - cy, 2));
            if (dist < closestDist) { closestDist = dist; closest = w; }
          });
          if (closest !== activeWord) {
            if (activeWord) {
              activeWord.style.transition = 'transform 0.7s cubic-bezier(0.16,1,0.3,1)';
              activeWord.style.transform = 'scale(1)';
            }
            activeWord = closest;
          }
          if (closest) {
            closest.style.transition = 'transform 0.7s cubic-bezier(0.16,1,0.3,1)';
            closest.style.transform = 'scale(1.1)';
          }
        });
        heroEl.addEventListener('mouseleave', function () {
          words.forEach(function (w) {
            w.style.transition = 'transform 0.7s cubic-bezier(0.16,1,0.3,1)';
            w.style.transform = 'scale(1)';
          });
          activeWord = null;
        });
      }, 1000);
    }
  }

  /* ── Step stagger reveal ── */
  var steps = document.querySelectorAll('[data-auth-step]');
  if (steps.length) {
    var stepObs = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('auth--in');
          stepObs.unobserve(entry.target);
        }
      });
    }, { threshold: 0.2 });
    steps.forEach(function (s) { stepObs.observe(s); });
  }

  /* ── Service title reveal ── */
  var serviceTitle = document.querySelector('[data-auth-service-title]');
  if (serviceTitle) {
    var svcObs = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('auth--in');
          svcObs.unobserve(entry.target);
        }
      });
    }, { threshold: 0.3 });
    svcObs.observe(serviceTitle);
  }
})();
</script>

