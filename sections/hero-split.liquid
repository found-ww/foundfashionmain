{%- assign sid = section.id -%}

<style>
  #hero-split-{{ sid }} {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .hero-split__grid-{{ sid }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 100vh;
  }

  .hero-split__cell {
    position: relative;
    overflow: hidden;
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .hero-split__cell img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.8s ease;
  }

  .hero-split__cell-overlay {
    position: absolute;
    inset: 0;
    background: {{ section.settings.overlay_color }};
    opacity: {{ section.settings.inactive_opacity | default: 40 | divided_by: 100.0 }};
    transition: opacity 0.5s ease;
    z-index: 1;
    pointer-events: none;
  }

  /* Hovered side lightens */
  .hero-split__cell:hover .hero-split__cell-overlay {
    opacity: {{ section.settings.hover_opacity | default: 0 | divided_by: 100.0 }};
  }

  .hero-split__cell:hover img {
    transform: scale(1.03);
  }

  /* Heading container */
  .hero-split__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    z-index: 3;
    pointer-events: none;
  }

  .hero-split__headings {
    position: relative;
    overflow: hidden;
  }

  .hero-split__heading {
    color: {{ section.settings.text_color }};
    font-family: 'Times New Roman', Georgia, serif;
    font-style: italic;
    font-weight: 400;
    font-size: clamp(28px, 4vw, 52px);
    letter-spacing: 0.02em;
    text-align: center;
    padding: 0 24px;
    margin: 0;
    white-space: nowrap;
  }

  /* Each letter is wrapped in a span for the flip animation */
  .hero-split__heading .hero-char {
    display: inline-block;
    transition: transform 0.4s cubic-bezier(0.77, 0, 0.175, 1),
                opacity 0.4s cubic-bezier(0.77, 0, 0.175, 1);
  }

  /* Heading A (left) — visible by default */
  .hero-split__heading--a {
    position: relative;
  }

  .hero-split__heading--a .hero-char {
    transform: translateY(0);
    opacity: 1;
  }

  /* Heading B (right) — hidden below by default */
  .hero-split__heading--b {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
  }

  .hero-split__heading--b .hero-char {
    transform: translateY(110%);
    opacity: 0;
  }

  /* When hovering right side: A flips up, B flips in from below */
  .hero-split__grid-{{ sid }}.is-hover-right ~ .hero-split__overlay .hero-split__heading--a .hero-char {
    transform: translateY(-110%);
    opacity: 0;
  }

  .hero-split__grid-{{ sid }}.is-hover-right ~ .hero-split__overlay .hero-split__heading--b .hero-char {
    transform: translateY(0);
    opacity: 1;
  }

  .hero-split__scroll {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    color: {{ section.settings.text_color }};
    font-size: 10px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    text-align: center;
    pointer-events: none;
  }

  .hero-split__cell-label {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    color: {{ section.settings.text_color }};
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
    white-space: nowrap;
  }

  .hero-split__cell:hover .hero-split__cell-label {
    opacity: 1;
  }

  @media screen and (max-width: 640px) {
    .hero-split__grid-{{ sid }} {
      grid-template-columns: 1fr;
      min-height: 80vh;
    }

    .hero-split__cell:nth-child(2) {
      display: none;
    }

    .hero-split__scroll {
      bottom: 20px;
    }

    .hero-split__cell-label {
      opacity: 1;
    }

    .hero-split__heading {
      white-space: normal;
    }
  }
</style>

<section id="hero-split-{{ sid }}">
  <div class="hero-split__grid-{{ sid }}" id="hero-grid-{{ sid }}">
    {%- comment -%} Left cell {%- endcomment -%}
    <{% if section.settings.link_a != blank %}a href="{{ section.settings.link_a }}"{% else %}div{% endif %} class="hero-split__cell" data-hero-side="left">
      {%- if section.settings.image_a != blank -%}
        <img
          src="{{ section.settings.image_a | img_url: '1200x' }}"
          srcset="{{ section.settings.image_a | img_url: '600x' }} 600w, {{ section.settings.image_a | img_url: '900x' }} 900w, {{ section.settings.image_a | img_url: '1200x' }} 1200w"
          sizes="(max-width: 640px) 100vw, 50vw"
          alt="{{ section.settings.image_a.alt | escape }}"
          loading="eager"
          fetchpriority="high">
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
      <div class="hero-split__cell-overlay"></div>
      {%- if section.settings.label_a != blank -%}
        <span class="hero-split__cell-label">{{ section.settings.label_a | escape }}</span>
      {%- endif -%}
    </{% if section.settings.link_a != blank %}a{% else %}div{% endif %}>

    {%- comment -%} Right cell {%- endcomment -%}
    <{% if section.settings.link_b != blank %}a href="{{ section.settings.link_b }}"{% else %}div{% endif %} class="hero-split__cell" data-hero-side="right">
      {%- if section.settings.image_b != blank -%}
        <img
          src="{{ section.settings.image_b | img_url: '1200x' }}"
          srcset="{{ section.settings.image_b | img_url: '600x' }} 600w, {{ section.settings.image_b | img_url: '900x' }} 900w, {{ section.settings.image_b | img_url: '1200x' }} 1200w"
          sizes="50vw"
          alt="{{ section.settings.image_b.alt | escape }}"
          loading="eager">
      {%- else -%}
        {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
      <div class="hero-split__cell-overlay"></div>
      {%- if section.settings.label_b != blank -%}
        <span class="hero-split__cell-label">{{ section.settings.label_b | escape }}</span>
      {%- endif -%}
    </{% if section.settings.link_b != blank %}a{% else %}div{% endif %}>
  </div>

  <div class="hero-split__overlay">
    <div class="hero-split__headings">
      <h1 class="hero-split__heading hero-split__heading--a" id="hero-heading-a-{{ sid }}">
        {{ section.settings.heading_text | escape }}
      </h1>
      {%- if section.settings.heading_text_b != blank -%}
        <div class="hero-split__heading hero-split__heading--b" id="hero-heading-b-{{ sid }}" aria-hidden="true">
          {{ section.settings.heading_text_b | escape }}
        </div>
      {%- endif -%}
    </div>
  </div>

  {%- if section.settings.scroll_text != blank -%}
    <div class="hero-split__scroll">{{ section.settings.scroll_text | escape }}</div>
  {%- endif -%}
</section>

<script>
(function() {
  var grid = document.getElementById('hero-grid-{{ sid }}');
  var headingA = document.getElementById('hero-heading-a-{{ sid }}');
  var headingB = document.getElementById('hero-heading-b-{{ sid }}');
  if (!grid || !headingA) return;

  /* Wrap each character in a span for staggered animation */
  function wrapChars(el) {
    var text = el.textContent.trim();
    el.innerHTML = '';
    for (var i = 0; i < text.length; i++) {
      var span = document.createElement('span');
      span.className = 'hero-char';
      span.textContent = text[i] === ' ' ? '\u00A0' : text[i];
      /* Stagger the delay per character */
      span.style.transitionDelay = (i * 25) + 'ms';
      el.appendChild(span);
    }
  }

  wrapChars(headingA);
  if (headingB) wrapChars(headingB);

  /* Add/remove hover class on the grid */
  var cells = grid.querySelectorAll('.hero-split__cell');

  cells.forEach(function(cell) {
    cell.addEventListener('mouseenter', function() {
      var side = cell.getAttribute('data-hero-side');
      if (side === 'right') {
        grid.classList.add('is-hover-right');
      } else {
        grid.classList.remove('is-hover-right');
      }
    });
  });

  grid.addEventListener('mouseleave', function() {
    grid.classList.remove('is-hover-right');
  });
})();
</script>

{% schema %}
{
  "name": "Hero Split",
  "settings": [
    {
      "type": "header",
      "content": "Left side"
    },
    {
      "type": "image_picker",
      "id": "image_a",
      "label": "Left image",
      "info": "900 x 1200px .jpg recommended"
    },
    {
      "type": "url",
      "id": "link_a",
      "label": "Left link"
    },
    {
      "type": "text",
      "id": "label_a",
      "label": "Left hover label",
      "info": "Shows on hover (e.g. SHOP WOMEN)"
    },
    {
      "type": "header",
      "content": "Right side"
    },
    {
      "type": "image_picker",
      "id": "image_b",
      "label": "Right image",
      "info": "900 x 1200px .jpg recommended"
    },
    {
      "type": "url",
      "id": "link_b",
      "label": "Right link"
    },
    {
      "type": "text",
      "id": "label_b",
      "label": "Right hover label",
      "info": "Shows on hover (e.g. SHOP MEN)"
    },
    {
      "type": "header",
      "content": "Headings"
    },
    {
      "type": "text",
      "id": "heading_text",
      "label": "Left heading (default)",
      "default": "curated for those who know"
    },
    {
      "type": "text",
      "id": "heading_text_b",
      "label": "Right heading",
      "default": "we find what others can't",
      "info": "Shows when hovering the right side"
    },
    {
      "type": "header",
      "content": "General"
    },
    {
      "type": "text",
      "id": "scroll_text",
      "label": "Scroll text",
      "default": "SCROLL TO EXPLORE"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text colour",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay colour",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Default overlay",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 30,
      "info": "Darkness when not hovering"
    },
    {
      "type": "range",
      "id": "hover_opacity",
      "label": "Hover overlay (active side)",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 5,
      "info": "Darkness when hovering (lighter = brighter)"
    },
    {
      "type": "range",
      "id": "inactive_opacity",
      "label": "Hover overlay (inactive side)",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 50,
      "info": "Darkness of the OTHER side when hovering"
    }
  ],
  "presets": [
    {
      "name": "Hero Split"
    }
  ]
}
{% endschema %}
