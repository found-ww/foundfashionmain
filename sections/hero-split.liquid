{%- assign sid = section.id -%}

<style>
  #hero-split-{{ sid }} {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .hero-split__grid-{{ sid }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 100vh;
  }

  .hero-split__cell {
    position: relative;
    overflow: hidden;
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .hero-split__cell img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.8s ease;
  }

  /* Per-cell dark overlay */
  .hero-split__cell-overlay {
    position: absolute;
    inset: 0;
    background: {{ section.settings.overlay_color }};
    opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    transition: opacity 0.5s ease;
    z-index: 1;
    pointer-events: none;
  }

  /* When hovering a cell, its overlay fades out (image lights up) */
  .hero-split__cell:hover .hero-split__cell-overlay {
    opacity: {{ section.settings.hover_opacity | default: 0 | divided_by: 100.0 }};
  }

  /* Subtle zoom on hover */
  .hero-split__cell:hover img {
    transform: scale(1.03);
  }

  /* When hovering one cell, darken the OTHER cell more */
  .hero-split__grid-{{ sid }}:hover .hero-split__cell:not(:hover) .hero-split__cell-overlay {
    opacity: {{ section.settings.inactive_opacity | default: 40 | divided_by: 100.0 }};
  }

  /* Centered heading spanning both cells */
  .hero-split__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    z-index: 3;
    pointer-events: none;
  }

  .hero-split__heading {
    position: relative;
    color: {{ section.settings.text_color }};
    font-family: 'Times New Roman', Georgia, serif;
    font-style: italic;
    font-weight: 400;
    font-size: clamp(28px, 4vw, 52px);
    letter-spacing: 0.02em;
    text-align: center;
    padding: 0 24px;
    margin: 0;
  }

  .hero-split__scroll {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    color: {{ section.settings.text_color }};
    font-size: 10px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    text-align: center;
    pointer-events: none;
  }

  /* Cell link label (e.g. "SHOP WOMEN" / "SHOP MEN") */
  .hero-split__cell-label {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    color: {{ section.settings.text_color }};
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
    white-space: nowrap;
  }

  .hero-split__cell:hover .hero-split__cell-label {
    opacity: 1;
  }

  @media screen and (max-width: 640px) {
    .hero-split__grid-{{ sid }} {
      grid-template-columns: 1fr;
      min-height: 80vh;
    }

    .hero-split__cell:nth-child(2) {
      display: none;
    }

    .hero-split__scroll {
      bottom: 20px;
    }

    .hero-split__cell-label {
      opacity: 1;
    }
  }
</style>

<section id="hero-split-{{ sid }}">
  <div class="hero-split__grid-{{ sid }}">
    {%- comment -%} Left cell {%- endcomment -%}
    <{% if section.settings.link_a != blank %}a href="{{ section.settings.link_a }}"{% else %}div{% endif %} class="hero-split__cell">
      {%- if section.settings.image_a != blank -%}
        <img
          src="{{ section.settings.image_a | img_url: '1200x' }}"
          srcset="{{ section.settings.image_a | img_url: '600x' }} 600w, {{ section.settings.image_a | img_url: '900x' }} 900w, {{ section.settings.image_a | img_url: '1200x' }} 1200w"
          sizes="(max-width: 640px) 100vw, 50vw"
          alt="{{ section.settings.image_a.alt | escape }}"
          loading="eager"
          fetchpriority="high">
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
      <div class="hero-split__cell-overlay"></div>
      {%- if section.settings.label_a != blank -%}
        <span class="hero-split__cell-label">{{ section.settings.label_a | escape }}</span>
      {%- endif -%}
    </{% if section.settings.link_a != blank %}a{% else %}div{% endif %}>

    {%- comment -%} Right cell {%- endcomment -%}
    <{% if section.settings.link_b != blank %}a href="{{ section.settings.link_b }}"{% else %}div{% endif %} class="hero-split__cell">
      {%- if section.settings.image_b != blank -%}
        <img
          src="{{ section.settings.image_b | img_url: '1200x' }}"
          srcset="{{ section.settings.image_b | img_url: '600x' }} 600w, {{ section.settings.image_b | img_url: '900x' }} 900w, {{ section.settings.image_b | img_url: '1200x' }} 1200w"
          sizes="50vw"
          alt="{{ section.settings.image_b.alt | escape }}"
          loading="eager">
      {%- else -%}
        {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
      <div class="hero-split__cell-overlay"></div>
      {%- if section.settings.label_b != blank -%}
        <span class="hero-split__cell-label">{{ section.settings.label_b | escape }}</span>
      {%- endif -%}
    </{% if section.settings.link_b != blank %}a{% else %}div{% endif %}>
  </div>

  <div class="hero-split__overlay">
    {%- if section.settings.heading_text != blank -%}
      <h1 class="hero-split__heading">{{ section.settings.heading_text | escape }}</h1>
    {%- endif -%}
  </div>

  {%- if section.settings.scroll_text != blank -%}
    <div class="hero-split__scroll">{{ section.settings.scroll_text | escape }}</div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Hero Split",
  "settings": [
    {
      "type": "header",
      "content": "Left side"
    },
    {
      "type": "image_picker",
      "id": "image_a",
      "label": "Left image",
      "info": "900 x 1200px .jpg recommended"
    },
    {
      "type": "url",
      "id": "link_a",
      "label": "Left link"
    },
    {
      "type": "text",
      "id": "label_a",
      "label": "Left hover label",
      "info": "Shows on hover (e.g. SHOP WOMEN)"
    },
    {
      "type": "header",
      "content": "Right side"
    },
    {
      "type": "image_picker",
      "id": "image_b",
      "label": "Right image",
      "info": "900 x 1200px .jpg recommended"
    },
    {
      "type": "url",
      "id": "link_b",
      "label": "Right link"
    },
    {
      "type": "text",
      "id": "label_b",
      "label": "Right hover label",
      "info": "Shows on hover (e.g. SHOP MEN)"
    },
    {
      "type": "header",
      "content": "Text & overlay"
    },
    {
      "type": "text",
      "id": "heading_text",
      "label": "Heading",
      "default": "curated for those who know"
    },
    {
      "type": "text",
      "id": "scroll_text",
      "label": "Scroll text",
      "default": "SCROLL TO EXPLORE"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text colour",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay colour",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Default overlay",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 30,
      "info": "Darkness when not hovering"
    },
    {
      "type": "range",
      "id": "hover_opacity",
      "label": "Hover overlay (active side)",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 5,
      "info": "Darkness when hovering (lighter = brighter)"
    },
    {
      "type": "range",
      "id": "inactive_opacity",
      "label": "Hover overlay (inactive side)",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 50,
      "info": "Darkness of the OTHER side when hovering"
    }
  ],
  "presets": [
    {
      "name": "Hero Split"
    }
  ]
}
{% endschema %}
