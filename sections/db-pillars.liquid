{%- assign sid = section.id -%}
{%- assign s = section.settings -%}

<style>
  #db-pillars-{{ sid }} {
    background: {{ s.bg_color }};
    color: {{ s.text_color }};
    padding: clamp(48px, 8vw, 110px) clamp(18px, 4vw, 48px);
  }
  .db-pil__head { max-width: 1600px; margin: 0 auto clamp(36px, 5vw, 64px); text-align: center; }
  .db-pil__eyebrow { font-family: 'Figtree', sans-serif; font-size: 12px; font-weight: 600; letter-spacing: 0.24em; text-transform: uppercase; opacity: 0.55; margin: 0 0 14px; }
  .db-pil__title { font-family: 'Fraunces', serif; font-weight: 300; font-size: clamp(30px, 4vw, 56px); line-height: 1.04; margin: 0 auto; max-width: 20ch; }
  .db-pil__title em { font-style: italic; }

  .db-pil__grid { max-width: 1600px; margin: 0 auto; display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(16px, 2vw, 40px); }
  .db-pil__item { border-top: 1px solid currentColor; padding-top: 26px; }
  .db-pil__num { font-family: 'Figtree', sans-serif; font-size: 12px; font-weight: 600; letter-spacing: 0.18em; opacity: 0.4; margin: 0 0 clamp(28px, 6vw, 80px); }
  .db-pil__name { font-family: 'Fraunces', serif; font-weight: 300; font-size: clamp(24px, 2.4vw, 34px); line-height: 1.08; margin: 0 0 14px; }
  .db-pil__name em { font-style: italic; }
  .db-pil__text { font-family: 'Figtree', sans-serif; font-size: 15px; line-height: 1.6; opacity: 0.8; margin: 0 0 22px; }
  .db-pil__link { font-family: 'Figtree', sans-serif; font-size: 12px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: inherit; text-decoration: none; border-bottom: 1px solid currentColor; padding-bottom: 4px; }

  @media (max-width: 800px) { .db-pil__grid { grid-template-columns: 1fr; gap: 0; } .db-pil__item { padding: 26px 0; } .db-pil__num { margin-bottom: 22px; } }
</style>

<section id="db-pillars-{{ sid }}">
  <div class="db-pil__head" data-reveal="up">
    {%- if s.eyebrow != blank -%}<p class="db-pil__eyebrow">{{ s.eyebrow | escape }}</p>{%- endif -%}
    {%- if s.title != blank -%}<h2 class="db-pil__title">{{ s.title }}</h2>{%- endif -%}
  </div>

  <div class="db-pil__grid" data-stagger data-reveal="fade">
    {%- for block in section.blocks -%}
      <div class="db-pil__item" data-reveal="up" {{ block.shopify_attributes }}>
        <p class="db-pil__num">0{{ forloop.index }} / {{ block.settings.tag }}</p>
        <h3 class="db-pil__name">{{ block.settings.heading }}</h3>
        <p class="db-pil__text">{{ block.settings.text | escape }}</p>
        {%- if block.settings.link_text != blank -%}
          <a class="db-pil__link" href="{{ block.settings.link }}">{{ block.settings.link_text | escape }}</a>
        {%- endif -%}
      </div>
    {%- else -%}
      {%- assign d_tags = 'Guarantee,Consignment,Sourcing' | split: ',' -%}
      {%- assign d_names = 'Authentic & quality,Sell with us,Let us source' | split: ',' -%}
      {%- assign d_text = 'Every item is 100% authenticated by our in-house experts before it reaches you.|Turn your luxury pieces into value with our trusted global consignment network.|Looking for something rare? Our personal shoppers will find it, wherever it is.' | split: '|' -%}
      {%- for i in (0..2) -%}
        <div class="db-pil__item" data-reveal="up">
          <p class="db-pil__num">0{{ i | plus: 1 }} / {{ d_tags[i] }}</p>
          <h3 class="db-pil__name">{{ d_names[i] }}</h3>
          <p class="db-pil__text">{{ d_text[i] }}</p>
          <a class="db-pil__link" href="#">Learn more</a>
        </div>
      {%- endfor -%}
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "DB Pillars",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Why FoundFashion" },
    { "type": "text", "id": "title", "label": "Title", "default": "Trusted by collectors worldwide" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#191919" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#f4f0ea" }
  ],
  "blocks": [
    {
      "type": "pillar",
      "name": "Pillar",
      "settings": [
        { "type": "text", "id": "tag", "label": "Tag", "default": "Guarantee" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Authentic & quality" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Every item is 100% authenticated by our in-house experts before it reaches you." },
        { "type": "text", "id": "link_text", "label": "Link text", "default": "Learn more" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    { "name": "DB Pillars", "blocks": [ { "type": "pillar" }, { "type": "pillar" }, { "type": "pillar" } ] }
  ]
}
{% endschema %}
