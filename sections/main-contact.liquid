<style>
  .ContactPage {
    display: flex;
    min-height: 100vh;
  }

  /* ── Left: info panel ── */
  .ContactPage__Info {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 80px 48px;
    background-color: #f0f0f0;
    background-size: cover;
    background-position: center;
  }
  .ContactPage__InfoInner {
    width: 100%;
    max-width: 360px;
  }

  /* ── Right: form panel ── */
  .ContactPage__Form {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 80px 48px;
    background: #ffffff;
  }
  .ContactPage__FormInner {
    width: 100%;
    max-width: 380px;
  }

  @media screen and (max-width: 767px) {
    .ContactPage { flex-direction: column; }
    .ContactPage__Info,
    .ContactPage__Form { padding: 60px 24px; }
    .ContactPage__InfoInner { max-width: 100%; }
  }

  /* ── Info typography ── */
  .ContactInfo__Tagline {
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #9a8f86;
    margin-bottom: 20px;
  }
  .ContactInfo__Heading {
    font-size: 22px;
    letter-spacing: 0.06em;
    font-weight: 400;
    text-transform: uppercase;
    color: #1c1c1c;
    margin-bottom: 12px;
  }
  .ContactInfo__Description {
    font-size: 13px;
    color: #6b6259;
    line-height: 1.7;
    margin-bottom: 40px;
  }
  .ContactInfo__Groups {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .ContactInfo__Label {
    font-size: 9px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #9a8f86;
    margin-bottom: 5px;
  }
  .ContactInfo__Value {
    font-size: 13px;
    color: #1c1c1c;
    line-height: 1.65;
  }
  .ContactInfo__Value a {
    color: #1c1c1c;
    text-decoration: none;
    border-bottom: 1px solid #c8c0b8;
    padding-bottom: 1px;
    transition: color 0.15s, border-color 0.15s;
  }
  .ContactInfo__Value a:hover {
    color: #7a6f66;
    border-color: transparent;
  }
  .ContactInfo__Divider {
    width: 32px;
    height: 1px;
    background: #c8c0b8;
    margin: 8px 0 32px;
  }
  .ContactInfo__Social {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }
  .ContactInfo__SocialLink {
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #9a8f86;
    text-decoration: none;
    transition: color 0.15s;
  }
  .ContactInfo__SocialLink:hover { color: #1c1c1c; }

  /* ── Form title ── */
  .ContactForm__Title {
    font-size: 22px;
    letter-spacing: 0.06em;
    font-weight: 400;
    text-transform: uppercase;
    color: #1c1c1c;
    margin-bottom: 32px;
  }

  /* ── Floating label fields ── */
  .ContactForm__Field {
    position: relative;
    margin-bottom: 20px;
  }
  .ContactForm__Input,
  .ContactForm__Textarea {
    width: 100%;
    border: 1px solid #e0dbd5;
    border-radius: 0;
    background: #fff;
    padding: 20px 16px 8px;
    font-size: 14px;
    color: #3d3530;
    font-family: inherit;
    outline: none;
    transition: border-color 0.2s;
    display: block;
    box-sizing: border-box;
  }
  .ContactForm__Textarea {
    resize: vertical;
    min-height: 140px;
  }
  .ContactForm__Input:focus,
  .ContactForm__Textarea:focus { border-color: #9a8f86; }

  /* Floating label */
  .ContactForm__Label {
    position: absolute;
    left: 16px;
    top: 14px;
    font-size: 14px;
    color: #b5ada5;
    pointer-events: none;
    transition: top 0.15s, font-size 0.15s, color 0.15s, letter-spacing 0.15s;
    font-family: inherit;
  }
  .ContactForm__Input:focus ~ .ContactForm__Label,
  .ContactForm__Input:not(:placeholder-shown) ~ .ContactForm__Label,
  .ContactForm__Textarea:focus ~ .ContactForm__Label,
  .ContactForm__Textarea:not(:placeholder-shown) ~ .ContactForm__Label {
    top: 6px;
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #9a8f86;
  }

  /* ── Select field ── */
  .ContactForm__SelectWrapper {
    position: relative;
  }
  .ContactForm__Select {
    width: 100%;
    border: 1px solid #e0dbd5;
    border-radius: 0;
    background: #fff;
    padding: 14px 40px 14px 16px;
    font-size: 14px;
    color: #3d3530;
    font-family: inherit;
    outline: none;
    transition: border-color 0.2s;
    display: block;
    box-sizing: border-box;
    appearance: none;
    cursor: pointer;
  }
  .ContactForm__Select:focus { border-color: #9a8f86; }
  .ContactForm__Select option[value=""] { color: #b5ada5; }
  .ContactForm__SelectChevron {
    position: absolute;
    right: 14px;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
    color: #9a8f86;
  }

  /* ── Submit & notes ── */
  .ContactForm__Submit {
    width: 100%;
    background: #1c1c1c;
    color: #fff;
    border: none;
    padding: 16px 24px;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 500;
    font-family: inherit;
    cursor: pointer;
    margin-top: 8px;
    transition: background 0.2s;
  }
  .ContactForm__Submit:hover { background: #3d3530; }
  .ContactForm__Note {
    font-size: 11px;
    letter-spacing: 0.06em;
    color: #9a8f86;
    text-align: center;
    margin-top: 16px;
  }

  /* ── Alerts ── */
  .ContactForm__Alert--error {
    background: #fdf0f0;
    border: 1px solid #e5c5c5;
    color: #9a4040;
    padding: 12px 16px;
    font-size: 13px;
    margin-bottom: 20px;
  }

  /* ── Success state ── */
  .ContactForm__Success {
    padding: 40px 0;
    text-align: center;
  }
  .ContactForm__SuccessMark {
    width: 40px;
    height: 40px;
    border: 1px solid #c8c0b8;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
    color: #9a8f86;
  }
  .ContactForm__SuccessTitle {
    font-size: 16px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 400;
    color: #1c1c1c;
    margin-bottom: 10px;
  }
  .ContactForm__SuccessNote {
    font-size: 13px;
    color: #9a8f86;
    line-height: 1.6;
  }
</style>

<section class="ContactPage" data-section-id="{{ section.id }}" data-section-type="contact">

  {%- comment -%} LEFT: Info panel {%- endcomment -%}
  <div class="ContactPage__Info"
    {%- if section.settings.image -%}
      style="background-image: url({{ section.settings.image | img_url: '1200x' }}); background-color: #f0f0f0;"
    {%- endif -%}
  >
    <div class="ContactPage__InfoInner">

      {%- if section.settings.tagline != blank -%}
        <p class="ContactInfo__Tagline">{{ section.settings.tagline }}</p>
      {%- endif -%}

      <h2 class="ContactInfo__Heading">{{ section.settings.heading | default: 'Get in touch' }}</h2>
      <div class="ContactInfo__Divider"></div>

      {%- if section.settings.description != blank -%}
        <p class="ContactInfo__Description">{{ section.settings.description }}</p>
      {%- endif -%}

      <div class="ContactInfo__Groups">

        {%- if section.settings.london_address != blank -%}
          <div>
            <p class="ContactInfo__Label">London</p>
            <p class="ContactInfo__Value">{{ section.settings.london_address | newline_to_br }}</p>
          </div>
        {%- endif -%}

        {%- if section.settings.hk_address != blank -%}
          <div>
            <p class="ContactInfo__Label">Hong Kong</p>
            <p class="ContactInfo__Value">{{ section.settings.hk_address | newline_to_br }}</p>
          </div>
        {%- endif -%}

        {%- if section.settings.email != blank or section.settings.press_email != blank -%}
          <div>
            <p class="ContactInfo__Label">Email</p>
            <p class="ContactInfo__Value">
              {%- if section.settings.email != blank -%}
                <a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a>
              {%- endif -%}
              {%- if section.settings.email != blank and section.settings.press_email != blank -%}<br>{%- endif -%}
              {%- if section.settings.press_email != blank -%}
                Press: <a href="mailto:{{ section.settings.press_email }}">{{ section.settings.press_email }}</a>
              {%- endif -%}
            </p>
          </div>
        {%- endif -%}

        {%- if section.settings.whatsapp != blank -%}
          {%- assign wa_number = section.settings.whatsapp | remove: '+' | remove: ' ' | remove: '-' -%}
          <div>
            <p class="ContactInfo__Label">WhatsApp</p>
            <p class="ContactInfo__Value">
              <a href="https://wa.me/{{ wa_number }}">{{ section.settings.whatsapp }}</a><br>
              <a href="https://wa.me/447405520466">+447405520466</a>
            </p>
          </div>
        {%- endif -%}

        {%- if section.settings.hours != blank -%}
          <div>
            <p class="ContactInfo__Label">Hours</p>
            <p class="ContactInfo__Value">{{ section.settings.hours }}</p>
          </div>
        {%- endif -%}

        {%- assign has_social = false -%}
        {%- if section.settings.instagram_url != blank or section.settings.tiktok_url != blank or section.settings.facebook_url != blank -%}
          {%- assign has_social = true -%}
        {%- endif -%}
        {%- if has_social -%}
          <div>
            <p class="ContactInfo__Label">Follow us</p>
            <div class="ContactInfo__Social">
              {%- if section.settings.instagram_url != blank -%}
                <a class="ContactInfo__SocialLink" href="{{ section.settings.instagram_url }}" target="_blank" rel="noopener">Instagram</a>
              {%- endif -%}
              {%- if section.settings.tiktok_url != blank -%}
                <a class="ContactInfo__SocialLink" href="{{ section.settings.tiktok_url }}" target="_blank" rel="noopener">TikTok</a>
              {%- endif -%}
              {%- if section.settings.facebook_url != blank -%}
                <a class="ContactInfo__SocialLink" href="{{ section.settings.facebook_url }}" target="_blank" rel="noopener">Facebook</a>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}

      </div>
    </div>
  </div>

  {%- comment -%} RIGHT: Form panel {%- endcomment -%}
  <div class="ContactPage__Form">
    <div class="ContactPage__FormInner">

      {%- form 'contact', class: 'ContactForm' -%}

        {%- if form.posted_successfully? -%}

          <div class="ContactForm__Success">
            <div class="ContactForm__SuccessMark" aria-hidden="true">
              <svg width="16" height="12" viewBox="0 0 16 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M1 6L5.5 10.5L15 1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <p class="ContactForm__SuccessTitle">Message sent</p>
            <p class="ContactForm__SuccessNote">{{ section.settings.response_note | default: 'We typically respond within 24 hours.' }}</p>
          </div>

        {%- else -%}

          <h1 class="ContactForm__Title">{{ page.title }}</h1>

          {%- if form.errors -%}
            <div class="ContactForm__Alert ContactForm__Alert--error">
              {%- for field in form.errors -%}
                {%- if field == 'form' -%}
                  <p>{{ form.errors.messages[field] }}</p>
                {%- else -%}
                  <p><strong>{{ form.errors.translated_fields[field] }}</strong> {{ form.errors.messages[field] }}</p>
                {%- endif -%}
              {%- endfor -%}
            </div>
          {%- endif -%}

          <div class="ContactForm__Field">
            <input type="text" id="contact-name" class="ContactForm__Input" name="contact[name]"
              placeholder=" "
              autocomplete="name"
              aria-label="{{ 'contact.form.name' | t }}"
              required
              {% if customer %}value="{{ customer.name }}"{% endif %}>
            <label class="ContactForm__Label" for="contact-name">{{ 'contact.form.name' | t }}</label>
          </div>

          <div class="ContactForm__Field">
            <input type="email" id="contact-email" class="ContactForm__Input" name="contact[email]"
              placeholder=" "
              autocomplete="email"
              aria-label="{{ 'contact.form.email' | t }}"
              required
              {% if customer %}value="{{ customer.email }}"{% endif %}>
            <label class="ContactForm__Label" for="contact-email">{{ 'contact.form.email' | t }}</label>
          </div>

          {%- for block in section.blocks -%}
            {%- assign field_title = block.settings.title -%}
            {%- if field_title == blank -%}
              {%- capture field_title -%}Custom field {% increment custom_field %}{%- endcapture -%}
            {%- endif -%}
            {%- assign block_field_id = 'contact-block-' | append: forloop.index -%}

            {%- if block.type == 'text' -%}
              <div class="ContactForm__Field">
                {%- if block.settings.use_long_text -%}
                  <textarea id="{{ block_field_id }}" name="contact[{{ field_title | escape }}]" class="ContactForm__Textarea"
                    placeholder=" "
                    aria-label="{{ field_title | escape }}"
                    {% if block.settings.is_required %}required{% endif %}></textarea>
                  <label class="ContactForm__Label" for="{{ block_field_id }}">{{ field_title | escape }}</label>
                {%- else -%}
                  <input type="text" id="{{ block_field_id }}" class="ContactForm__Input" name="contact[{{ field_title | escape }}]"
                    placeholder=" "
                    aria-label="{{ field_title | escape }}"
                    {% if block.settings.is_required %}required{% endif %}>
                  <label class="ContactForm__Label" for="{{ block_field_id }}">{{ field_title | escape }}</label>
                {%- endif -%}
              </div>

            {%- elsif block.type == 'dropdown' -%}
              {%- assign values = block.settings.values | split: ',' -%}
              {%- if values == empty -%}{%- continue -%}{%- endif -%}
              <div class="ContactForm__Field">
                <div class="ContactForm__SelectWrapper">
                  <select id="{{ block_field_id }}" name="contact[{{ field_title | escape }}]" class="ContactForm__Select" required aria-label="{{ field_title | escape }}">
                    <option value="" disabled selected>{{ field_title | escape }}</option>
                    {%- for value in values -%}
                      {%- assign trim_value = value | strip -%}
                      <option value="{{ trim_value | escape }}">{{ trim_value | escape }}</option>
                    {%- endfor -%}
                  </select>
                  <span class="ContactForm__SelectChevron" aria-hidden="true">
                    <svg width="10" height="6" viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}

          <div class="ContactForm__Field">
            <textarea id="contact-message" name="contact[body]" class="ContactForm__Textarea"
              placeholder=" "
              aria-label="{{ 'contact.form.message' | t }}"
              required></textarea>
            <label class="ContactForm__Label" for="contact-message">{{ 'contact.form.message' | t }}</label>
          </div>

          <button type="submit" class="ContactForm__Submit">{{ 'contact.form.submit' | t }}</button>

          {%- if section.settings.response_note != blank -%}
            <p class="ContactForm__Note">{{ section.settings.response_note }}</p>
          {%- endif -%}

        {%- endif -%}

      {%- endform -%}

    </div>
  </div>

</section>

{%- comment -%} ContactPage + Organization schema {%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": {{ page.title | json }},
  "url": "{{ shop.url }}{{ page.url }}",
  {%- if section.settings.description != blank -%}
  "description": {{ section.settings.description | json }},
  {%- endif -%}
  "mainEntity": {
    "@type": "Organization",
    "name": {{ shop.name | json }},
    "url": {{ shop.url | json }},
    {%- if section.settings.email != blank -%}
    "email": {{ section.settings.email | json }},
    {%- endif -%}
    {%- if section.settings.whatsapp != blank -%}
    "telephone": {{ section.settings.whatsapp | json }},
    {%- endif -%}
    {%- assign social_same_as = '' -%}
    {%- if section.settings.instagram_url != blank -%}{%- assign social_same_as = social_same_as | append: section.settings.instagram_url | append: '|' -%}{%- endif -%}
    {%- if section.settings.tiktok_url != blank -%}{%- assign social_same_as = social_same_as | append: section.settings.tiktok_url | append: '|' -%}{%- endif -%}
    {%- if section.settings.facebook_url != blank -%}{%- assign social_same_as = social_same_as | append: section.settings.facebook_url | append: '|' -%}{%- endif -%}
    {%- assign social_same_as_array = social_same_as | split: '|' -%}
    {%- if social_same_as_array.size > 0 -%}
    "sameAs": [
      {%- assign _sa_sep = '' -%}
      {%- for link in social_same_as_array -%}
        {%- if link != blank -%}{{ _sa_sep }}{{ link | json }}{%- assign _sa_sep = ',' -%}{%- endif -%}
      {%- endfor -%}
    ],
    {%- endif -%}
    "contactPoint": [
      {%- assign _cp_sep = '' -%}
      {%- if section.settings.email != blank -%}
        {{ _cp_sep }}{
          "@type": "ContactPoint",
          "contactType": "customer support",
          "email": {{ section.settings.email | json }}
          {%- if section.settings.hours != blank -%},"hoursAvailable": {{ section.settings.hours | json }}{%- endif -%}
        }
        {%- assign _cp_sep = ',' -%}
      {%- endif -%}
      {%- if section.settings.whatsapp != blank -%}
        {{ _cp_sep }}{
          "@type": "ContactPoint",
          "contactType": "customer support",
          "telephone": {{ section.settings.whatsapp | json }},
          "contactOption": "https://schema.org/TollFree"
        }
        {%- assign _cp_sep = ',' -%}
      {%- endif -%}
      {%- if section.settings.press_email != blank -%}
        {{ _cp_sep }}{
          "@type": "ContactPoint",
          "contactType": "press",
          "email": {{ section.settings.press_email | json }}
        }
      {%- endif -%}
    ],
    "address": [
      {%- assign _addr_sep = '' -%}
      {%- if section.settings.london_address != blank -%}
        {{ _addr_sep }}{
          "@type": "PostalAddress",
          "streetAddress": {{ section.settings.london_address | newline_to_br | strip_html | json }},
          "addressLocality": "London",
          "postalCode": {{ section.settings.london_postcode | json }},
          "addressCountry": "GB"
        }
        {%- assign _addr_sep = ',' -%}
      {%- endif -%}
      {%- if section.settings.hk_address != blank -%}
        {{ _addr_sep }}{
          "@type": "PostalAddress",
          "streetAddress": {{ section.settings.hk_address | newline_to_br | strip_html | json }},
          "addressLocality": "Sheung Wan",
          "addressRegion": "Hong Kong",
          "addressCountry": "HK"
        }
      {%- endif -%}
    ]
  }
}
</script>

{% schema %}
{
  "name": "Contact page",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Editorial image (left panel)"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Found Fashion"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Get in touch"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "We're here to help with any enquiries about our pieces, authenticity, sizing, or sourcing."
    },
    {
      "type": "header",
      "content": "London office"
    },
    {
      "type": "textarea",
      "id": "london_address",
      "label": "Address (display)",
      "default": "2 Principal Place\nLondon, EC2A"
    },
    {
      "type": "text",
      "id": "london_postcode",
      "label": "Postcode (for schema)",
      "default": "EC2A"
    },
    {
      "type": "header",
      "content": "Hong Kong office"
    },
    {
      "type": "textarea",
      "id": "hk_address",
      "label": "Address (display)",
      "default": "The Found Collective Group\n4\/F 299QRC, 299 Queen's Road Central\nSheung Wan, Hong Kong"
    },
    {
      "type": "header",
      "content": "Contact details"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email",
      "default": "contact@found-fashion.com"
    },
    {
      "type": "text",
      "id": "press_email",
      "label": "Press email",
      "default": "press@found-fashion.com"
    },
    {
      "type": "text",
      "id": "whatsapp",
      "label": "WhatsApp number (include country code)",
      "default": "+85264954710"
    },
    {
      "type": "text",
      "id": "whatsapp_uk",
      "label": "WhatsApp number 2 (include country code)",
      "default": "+447405520466"
    },
    {
      "type": "text",
      "id": "hours",
      "label": "Hours",
      "default": "Monday \u2013 Friday, 9am \u2013 5.30pm"
    },
    {
      "type": "header",
      "content": "Social media"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "tiktok_url",
      "label": "TikTok URL"
    },
    {
      "type": "url",
      "id": "facebook_url",
