{%- assign sid = section.id -%}
{%- assign total_blocks = section.blocks.size -%}
{%- assign pair_count = total_blocks | divided_by: 2 -%}

<style>
  .editorial-{{ sid }} {
    position: relative;
    margin: 20px 0 0;
  }

  .editorial-{{ sid }}__viewport {
    width: 100%;
    margin: 0 auto;
    padding: 0 24px;
    max-width: 1600px;
  }

  .editorial-{{ sid }}__pairs-wrap {
    position: relative;
    overflow: hidden;
    touch-action: pan-y pinch-zoom;
  }

  .editorial-{{ sid }}__pair {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    width: 100%;
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
    position: absolute;
    top: 0;
    left: 0;
  }

  .editorial-{{ sid }}__pair.is-active {
    opacity: 1;
    pointer-events: auto;
    position: relative;
  }

  .editorial-{{ sid }}__item {
    position: relative;
    overflow: hidden;
    display: block;
    text-decoration: none;
  }

  .editorial-{{ sid }}__item img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    aspect-ratio: 3 / 2;
    max-height: 450px;
    transition: transform 0.6s ease;
  }

  .editorial-{{ sid }}__item:hover img {
    transform: scale(1.03);
  }

  .editorial-{{ sid }}__btn {
    position: absolute;
    bottom: 28px;
    left: 50%;
    transform: translateX(-50%);
    background: #ffffff;
    color: #1c1b1b;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 12px 28px;
    text-decoration: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
    white-space: nowrap;
  }

  .editorial-{{ sid }}__dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    padding: 20px 0 0;
  }

  .editorial-{{ sid }}__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #d4d4d4;
    transition: background 0.3s ease;
    border: none;
    padding: 0;
    cursor: pointer;
  }

  .editorial-{{ sid }}__dot.is-active {
    background: #1c1b1b;
  }

  @media screen and (max-width: 640px) {
    .editorial-{{ sid }}__pair {
      gap: 8px;
    }

    .editorial-{{ sid }}__item img {
      aspect-ratio: 1 / 1;
      max-height: 300px;
    }

    .editorial-{{ sid }}__btn {
      bottom: 16px;
      padding: 8px 16px;
      font-size: 10px;
    }
  }
</style>

<section id="editorial-{{ sid }}" class="editorial-{{ sid }}">
  <div class="editorial-{{ sid }}__viewport">
    <div class="editorial-{{ sid }}__pairs-wrap" id="editorial-pairs-{{ sid }}">
    {%- for block in section.blocks -%}
      {%- assign pair_index = forloop.index0 | divided_by: 2 -%}
      {%- assign within_pair = forloop.index0 | modulo: 2 -%}

      {%- if within_pair == 0 -%}
        <div class="editorial-{{ sid }}__pair{% if pair_index == 0 %} is-active{% endif %}" data-pair-index="{{ pair_index }}">
      {%- endif -%}

      <a href="{{ block.settings.link_url | default: '#' }}" class="editorial-{{ sid }}__item" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          <img
            src="{{ block.settings.image | img_url: '900x' }}"
            srcset="{{ block.settings.image | img_url: '400x' }} 400w, {{ block.settings.image | img_url: '600x' }} 600w, {{ block.settings.image | img_url: '900x' }} 900w"
            sizes="(max-width: 640px) 50vw, 45vw"
            alt="{{ block.settings.image.alt | escape }}"
            loading="lazy">
        {%- else -%}
          {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
        {%- if block.settings.button_text != blank -%}
          <span class="editorial-{{ sid }}__btn">{{ block.settings.button_text | escape }}</span>
        {%- endif -%}
      </a>

      {%- if within_pair == 1 or forloop.last -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
    </div>

    {%- if pair_count > 1 -%}
      <div class="editorial-{{ sid }}__dots">
        {%- for i in (1..pair_count) -%}
          <button class="editorial-{{ sid }}__dot{% if forloop.first %} is-active{% endif %}" data-dot-index="{{ forloop.index0 }}" aria-label="View pair {{ forloop.index }}"></button>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

<script>
(function() {
  var section = document.getElementById('editorial-{{ sid }}');
  if (!section) return;

  var pairsWrap = document.getElementById('editorial-pairs-{{ sid }}');
  var pairs = section.querySelectorAll('.editorial-{{ sid }}__pair');
  var dots = section.querySelectorAll('.editorial-{{ sid }}__dot');
  var pairCount = pairs.length;
  if (pairCount < 2) return;

  var currentPair = 0;

  function showPair(index) {
    if (index < 0 || index >= pairCount || index === currentPair) return;
    pairs[currentPair].classList.remove('is-active');
    if (dots[currentPair]) dots[currentPair].classList.remove('is-active');
    currentPair = index;
    pairs[currentPair].classList.add('is-active');
    if (dots[currentPair]) dots[currentPair].classList.add('is-active');
  }

  /* Dot clicks */
  dots.forEach(function(dot) {
    dot.addEventListener('click', function() {
      var index = parseInt(dot.getAttribute('data-dot-index'), 10);
      showPair(index);
    });
  });

  /* Horizontal swipe on the pairs area */
  var touchStartX = 0;
  var touchStartY = 0;
  var swiping = false;

  pairsWrap.addEventListener('touchstart', function(e) {
    touchStartX = e.touches[0].clientX;
    touchStartY = e.touches[0].clientY;
    swiping = false;
  }, { passive: true });

  pairsWrap.addEventListener('touchmove', function(e) {
    if (swiping) e.preventDefault();
    var dx = e.touches[0].clientX - touchStartX;
    var dy = e.touches[0].clientY - touchStartY;
    /* If horizontal movement is greater than vertical, it's a swipe */
    if (!swiping && Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 10) {
      swiping = true;
    }
  }, { passive: false });

  pairsWrap.addEventListener('touchend', function(e) {
    if (!swiping) return;
    var dx = e.changedTouches[0].clientX - touchStartX;
    if (dx < -40) {
      /* Swipe left — next pair */
      showPair(currentPair + 1);
    } else if (dx > 40) {
      /* Swipe right — previous pair */
      showPair(currentPair - 1);
    }
    swiping = false;
  }, { passive: true });
})();
</script>

{% schema %}
{
  "name": "Editorial Pinned",
  "max_blocks": 6,
  "settings": [],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "900 x 600px .jpg recommended"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button text",
          "default": "READ MORE"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Editorial Pinned",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}
