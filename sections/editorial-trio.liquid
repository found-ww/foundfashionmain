{%- assign sid = section.id -%}
{%- assign total_blocks = section.blocks.size -%}
{%- assign pair_count = total_blocks | divided_by: 2 -%}

<style>
  /*
   * Apple-style scroll-progress approach:
   * - Outer section is very tall (100vh per pair) to create scroll runway
   * - Inner content is position:sticky so it stays pinned
   * - JS watches scroll progress through the section to swap pairs
   * - No scroll hijacking, no overflow:hidden, no preventDefault
   */
  .editorial-scroll-{{ sid }} {
    position: relative;
    margin: 20px 0 0;
  }

  .editorial-scroll__sticky {
    position: sticky;
    top: 20px;
    width: 100%;
    z-index: 1;
  }

  .editorial-scroll__viewport {
    width: 100%;
    margin: 0 auto;
    padding: 0 24px;
    max-width: 1600px;
  }

  .editorial-scroll__pairs-wrap {
    position: relative;
  }

  .editorial-scroll__pair {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    width: 100%;
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
    position: absolute;
    top: 0;
    left: 0;
  }

  .editorial-scroll__pair.is-active {
    opacity: 1;
    pointer-events: auto;
    position: relative;
  }

  .editorial-scroll__item {
    position: relative;
    overflow: hidden;
    display: block;
    text-decoration: none;
  }

  .editorial-scroll__item img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    aspect-ratio: 3 / 2;
    max-height: 450px;
    transition: transform 0.6s ease;
  }

  .editorial-scroll__item:hover img {
    transform: scale(1.03);
  }

  .editorial-scroll__btn {
    position: absolute;
    bottom: 28px;
    left: 50%;
    transform: translateX(-50%);
    background: #ffffff;
    color: #1c1b1b;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 12px 28px;
    text-decoration: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
    white-space: nowrap;
  }

  .editorial-scroll__dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    padding: 20px 0 0;
  }

  .editorial-scroll__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #d4d4d4;
    transition: background 0.3s ease;
    border: none;
    padding: 0;
    cursor: pointer;
  }

  .editorial-scroll__dot.is-active {
    background: #1c1b1b;
  }

  @media screen and (max-width: 640px) {
    .editorial-scroll__pair {
      gap: 8px;
    }

    .editorial-scroll__item img {
      aspect-ratio: 1 / 1;
      max-height: 300px;
    }

    .editorial-scroll__btn {
      bottom: 16px;
      padding: 8px 16px;
      font-size: 10px;
    }
  }
</style>

<section id="editorial-scroll-{{ sid }}" class="editorial-scroll-{{ sid }}">
  <div class="editorial-scroll__sticky">
    <div class="editorial-scroll__viewport">
      <div class="editorial-scroll__pairs-wrap">
      {%- for block in section.blocks -%}
        {%- assign pair_index = forloop.index0 | divided_by: 2 -%}
        {%- assign within_pair = forloop.index0 | modulo: 2 -%}

        {%- if within_pair == 0 -%}
          <div class="editorial-scroll__pair{% if pair_index == 0 %} is-active{% endif %}" data-pair-index="{{ pair_index }}">
        {%- endif -%}

        <a href="{{ block.settings.link_url | default: '#' }}" class="editorial-scroll__item" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <img
              src="{{ block.settings.image | img_url: '900x' }}"
              srcset="{{ block.settings.image | img_url: '400x' }} 400w, {{ block.settings.image | img_url: '600x' }} 600w, {{ block.settings.image | img_url: '900x' }} 900w"
              sizes="(max-width: 640px) 50vw, 45vw"
              alt="{{ block.settings.image.alt | escape }}"
              loading="lazy">
          {%- else -%}
            {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
          {%- if block.settings.button_text != blank -%}
            <span class="editorial-scroll__btn">{{ block.settings.button_text | escape }}</span>
          {%- endif -%}
        </a>

        {%- if within_pair == 1 or forloop.last -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
      </div>

      {%- if pair_count > 1 -%}
        <div class="editorial-scroll__dots">
          {%- for i in (1..pair_count) -%}
            <button class="editorial-scroll__dot{% if forloop.first %} is-active{% endif %}" data-dot-index="{{ forloop.index0 }}" aria-label="View pair {{ forloop.index }}"></button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<script>
(function() {
  var section = document.getElementById('editorial-scroll-{{ sid }}');
  if (!section) return;

  var stickyEl = section.querySelector('.editorial-scroll__sticky');
  var pairs = section.querySelectorAll('.editorial-scroll__pair');
  var dots = section.querySelectorAll('.editorial-scroll__dot');
  var pairCount = pairs.length;
  if (pairCount < 2) return;

  var currentPair = 0;
  /* Extra scroll distance per swap (px). Increase for more scroll between swaps. */
  var RUNWAY_PER_SWAP = 400;

  function setSectionHeight() {
    /* Measure the actual content height (the sticky element) */
    var contentHeight = stickyEl.offsetHeight;
    /* Total section height = content + runway for each swap */
    var totalHeight = contentHeight + (RUNWAY_PER_SWAP * (pairCount - 1));
    section.style.height = totalHeight + 'px';
  }

  /* Set height on load and resize */
  setSectionHeight();
  window.addEventListener('resize', setSectionHeight);

  function showPair(index) {
    if (index === currentPair || index < 0 || index >= pairCount) return;
    pairs[currentPair].classList.remove('is-active');
    if (dots[currentPair]) dots[currentPair].classList.remove('is-active');
    currentPair = index;
    pairs[currentPair].classList.add('is-active');
    if (dots[currentPair]) dots[currentPair].classList.add('is-active');
  }

  function onScroll() {
    var rect = section.getBoundingClientRect();
    var sectionHeight = section.offsetHeight;
    var contentHeight = stickyEl.offsetHeight;
    /* The scroll range is the extra height beyond the content */
    var scrollRange = sectionHeight - contentHeight;
    if (scrollRange <= 0) return;

    /* How far we've scrolled past the point where the sticky pins */
    var scrolled = -rect.top;
    var progress = scrolled / scrollRange;

    /* Clamp 0-1 */
    progress = Math.max(0, Math.min(0.999, progress));

    /* Map progress to pair index */
    var targetPair = Math.floor(progress * pairCount);
    targetPair = Math.max(0, Math.min(pairCount - 1, targetPair));

    if (targetPair !== currentPair) {
      showPair(targetPair);
    }
  }

  var ticking = false;
  window.addEventListener('scroll', function() {
    if (!ticking) {
      requestAnimationFrame(function() {
        onScroll();
        ticking = false;
      });
      ticking = true;
    }
  }, { passive: true });

  /* Dot clicks */
  dots.forEach(function(dot) {
    dot.addEventListener('click', function() {
      var index = parseInt(dot.getAttribute('data-dot-index'), 10);
      if (index >= 0 && index < pairCount) {
        var sectionTop = section.offsetTop;
        var contentHeight = stickyEl.offsetHeight;
        var scrollRange = section.offsetHeight - contentHeight;
        var targetScroll = sectionTop + (index / pairCount) * scrollRange;
        window.scrollTo({ top: targetScroll, behavior: 'smooth' });
      }
    });
  });
})();
</script>

{% schema %}
{
  "name": "Editorial Pinned",
  "max_blocks": 6,
  "settings": [],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "900 x 600px .jpg recommended"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button text",
          "default": "READ MORE"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Editorial Pinned",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}
