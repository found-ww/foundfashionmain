{%- assign sid = section.id -%}
{%- assign total_blocks = section.blocks.size -%}
{%- assign pair_count = total_blocks | divided_by: 2 -%}

<style>
  .editorial-pin-{{ sid }} {
    position: relative;
    margin: 20px 0 0;
  }

  .editorial-pin__viewport {
    width: 100%;
    margin: 0 auto;
    padding: 0 24px;
    position: relative;
    max-width: 1600px;
  }

  .editorial-pin__pairs-wrap {
    position: relative;
  }

  .editorial-pin__pair {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    width: 100%;
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
    position: absolute;
    top: 0;
    left: 0;
  }

  .editorial-pin__pair.is-active {
    opacity: 1;
    pointer-events: auto;
    position: relative;
  }

  .editorial-pin__item {
    position: relative;
    overflow: hidden;
    display: block;
    text-decoration: none;
  }

  .editorial-pin__item img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    aspect-ratio: 3 / 2;
    max-height: 450px;
    transition: transform 0.6s ease;
  }

  .editorial-pin__item:hover img {
    transform: scale(1.03);
  }

  .editorial-pin__btn {
    position: absolute;
    bottom: 28px;
    left: 50%;
    transform: translateX(-50%);
    background: #ffffff;
    color: #1c1b1b;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 12px 28px;
    text-decoration: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
    white-space: nowrap;
  }

  .editorial-pin__dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    padding: 20px 0 0;
  }

  .editorial-pin__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #d4d4d4;
    transition: background 0.3s ease;
    border: none;
    padding: 0;
    cursor: pointer;
  }

  .editorial-pin__dot.is-active {
    background: #1c1b1b;
  }

  @media screen and (max-width: 640px) {
    .editorial-pin__pair {
      gap: 8px;
    }

    .editorial-pin__item img {
      aspect-ratio: 1 / 1;
      max-height: 300px;
    }

    .editorial-pin__btn {
      bottom: 16px;
      padding: 8px 16px;
      font-size: 10px;
    }
  }
</style>

<section id="editorial-pin-{{ sid }}" class="editorial-pin-{{ sid }}">
  <div class="editorial-pin__viewport">
    <div class="editorial-pin__pairs-wrap">
    {%- for block in section.blocks -%}
      {%- assign pair_index = forloop.index0 | divided_by: 2 -%}
      {%- assign within_pair = forloop.index0 | modulo: 2 -%}

      {%- if within_pair == 0 -%}
        <div class="editorial-pin__pair{% if pair_index == 0 %} is-active{% endif %}" data-pair-index="{{ pair_index }}">
      {%- endif -%}

      <a href="{{ block.settings.link_url | default: '#' }}" class="editorial-pin__item" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          <img
            src="{{ block.settings.image | img_url: '900x' }}"
            srcset="{{ block.settings.image | img_url: '400x' }} 400w, {{ block.settings.image | img_url: '600x' }} 600w, {{ block.settings.image | img_url: '900x' }} 900w"
            sizes="(max-width: 640px) 50vw, 45vw"
            alt="{{ block.settings.image.alt | escape }}"
            loading="lazy">
        {%- else -%}
          {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
        {%- if block.settings.button_text != blank -%}
          <span class="editorial-pin__btn">{{ block.settings.button_text | escape }}</span>
        {%- endif -%}
      </a>

      {%- if within_pair == 1 or forloop.last -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
    </div>

    {%- if pair_count > 1 -%}
      <div class="editorial-pin__dots">
        {%- for i in (1..pair_count) -%}
          <button class="editorial-pin__dot{% if forloop.first %} is-active{% endif %}" data-dot-index="{{ forloop.index0 }}" aria-label="View pair {{ forloop.index }}"></button>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

<script>
(function() {
  var section = document.getElementById('editorial-pin-{{ sid }}');
  if (!section) return;

  var pairs = section.querySelectorAll('.editorial-pin__pair');
  var dots = section.querySelectorAll('.editorial-pin__dot');
  var pairCount = pairs.length;
  if (pairCount < 2) return;

  var currentPair = 0;
  var locked = false;
  var scrollAccum = 0;
  var SCROLL_THRESHOLD = 120; /* px of wheel delta to trigger swap */
  var COOLDOWN = 500; /* ms after swap before releasing lock */

  function showPair(index) {
    if (index === currentPair || index < 0 || index >= pairCount) return false;
    pairs[currentPair].classList.remove('is-active');
    if (dots[currentPair]) dots[currentPair].classList.remove('is-active');
    currentPair = index;
    pairs[currentPair].classList.add('is-active');
    if (dots[currentPair]) dots[currentPair].classList.add('is-active');
    return true;
  }

  function isInCenter() {
    var rect = section.getBoundingClientRect();
    var vh = window.innerHeight;
    var sectionCenter = rect.top + rect.height / 2;
    /* Section center is within 40%-65% of viewport */
    return sectionCenter > vh * 0.40 && sectionCenter < vh * 0.65;
  }

  function onWheel(e) {
    if (!isInCenter()) {
      locked = false;
      scrollAccum = 0;
      return;
    }

    var scrollingDown = e.deltaY > 0;
    var scrollingUp = e.deltaY < 0;

    /* At boundaries, ALWAYS let page scroll (regardless of lock state) */
    if (scrollingUp && currentPair === 0) {
      scrollAccum = 0;
      return;
    }
    if (scrollingDown && currentPair === pairCount - 1) {
      scrollAccum = 0;
      return;
    }

    /* During cooldown, block scroll but don't accumulate */
    if (locked) {
      e.preventDefault();
      return;
    }

    /* We're in the zone and have pairs to show — hijack scroll */
    e.preventDefault();
    scrollAccum += e.deltaY;

    if (Math.abs(scrollAccum) >= SCROLL_THRESHOLD) {
      var next = scrollingDown ? currentPair + 1 : currentPair - 1;
      var swapped = showPair(next);
      scrollAccum = 0;

      if (swapped) {
        locked = true;
        setTimeout(function() {
          locked = false;
          scrollAccum = 0;
        }, COOLDOWN);
      }
    }
  }

  window.addEventListener('wheel', onWheel, { passive: false });
})();
</script>

{% schema %}
{
  "name": "Editorial Pinned",
  "max_blocks": 6,
  "settings": [],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "900 x 600px .jpg recommended"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button text",
          "default": "READ MORE"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Editorial Pinned",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}
