{%- assign sid = section.id -%}

<style>
  #editorial-grid-{{ sid }} {
    padding: 0;
    margin: 0 auto;
  }

  .editorial-grid__grid-{{ sid }} {
    display: grid;
    grid-template-columns: repeat({{ section.blocks.size }}, 1fr);
    gap: 8px;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .editorial-grid__item {
    position: relative;
    overflow: hidden;
    display: block;
    text-decoration: none;
  }

  .editorial-grid__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    aspect-ratio: 4 / 5;
    transition: transform 0.6s ease;
  }

  .editorial-grid__item:hover img {
    transform: scale(1.03);
  }

  .editorial-grid__btn {
    position: absolute;
    bottom: 24px;
    left: 24px;
    background: #ffffff;
    color: #1c1b1b;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 10px 20px;
    text-decoration: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
  }

  @media screen and (max-width: 640px) {
    .editorial-grid__grid-{{ sid }} {
      grid-template-columns: 1fr 1fr;
      gap: 4px;
      padding: 0 16px;
    }

    .editorial-grid__item img {
      aspect-ratio: 3 / 4;
    }
  }
</style>

<section id="editorial-grid-{{ sid }}">
  <div class="editorial-grid__grid-{{ sid }}">
    {%- for block in section.blocks -%}
      <a href="{{ block.settings.link_url | default: '#' }}" class="editorial-grid__item" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          <img
            src="{{ block.settings.image | img_url: '800x' }}"
            srcset="{{ block.settings.image | img_url: '400x' }} 400w, {{ block.settings.image | img_url: '600x' }} 600w, {{ block.settings.image | img_url: '800x' }} 800w"
            sizes="(max-width: 640px) 50vw, 25vw"
            alt="{{ block.settings.image.alt | escape }}"
            loading="lazy">
        {%- else -%}
          {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
        {%- if block.settings.button_text != blank -%}
          <span class="editorial-grid__btn">{{ block.settings.button_text | escape }}</span>
        {%- endif -%}
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Editorial Grid",
  "max_blocks": 6,
  "settings": [],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "800 x 1000px .jpg recommended"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button text",
          "default": "READ MORE"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Editorial Grid",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}
