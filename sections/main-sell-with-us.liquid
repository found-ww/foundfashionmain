{%- assign sid = section.id -%}

<style>
  /* ── Hero ── */
  .swu-hero {
    position: relative;
    width: 100%;
    height: 60vh;
    min-height: 400px;
    overflow: hidden;
  }
  .swu-hero__img {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
  }
  .swu-hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.35);
  }
  .swu-hero__content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    padding: 0 64px 72px;
    text-align: center;
    color: #fff;
  }
  .swu-hero__eyebrow {
    font-size: 10px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    opacity: 0.7;
    margin-bottom: 20px;
  }
  .swu-hero__title {
    font-size: clamp(2.2rem, 5vw, 4rem);
    font-weight: 400;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    line-height: 1.1;
    margin: 0 0 20px;
    max-width: 600px;
  }
  /* Hero word-by-word reveal */
  .swu-hero__word {
    display: inline-block;
    opacity: 0;
    transform: translateY(18px);
    transition: opacity 0.6s cubic-bezier(0.16,1,0.3,1), transform 0.6s cubic-bezier(0.16,1,0.3,1);
  }
  .swu-hero__word.swu--in {
    opacity: 1;
    transform: translateY(0);
  }
  .swu-hero__sub {
    font-size: clamp(13px, 1.2vw, 15px);
    font-weight: 300;
    letter-spacing: 0.04em;
    opacity: 0;
    max-width: 440px;
    line-height: 1.7;
    margin: 0;
    transform: translateY(12px);
    transition: opacity 0.7s 0.5s cubic-bezier(0.16,1,0.3,1), transform 0.7s 0.5s cubic-bezier(0.16,1,0.3,1);
  }
  .swu-hero__sub.swu--in {
    opacity: 0.85;
    transform: translateY(0);
  }

  /* ── Intro ── */
  .swu-intro {
    padding: 80px 24px;
    text-align: center;
    background: #faf9f7;
  }
  .swu-intro__text {
    max-width: 620px;
    margin: 0 auto;
    font-size: clamp(15px, 1.4vw, 18px);
    font-weight: 300;
    line-height: 1.75;
    color: #2a2420;
    letter-spacing: 0.01em;
  }

  /* ── Marquee ── */
  .swu-marquee {
    overflow: hidden;
    background: #fff;
    border-top: 0.5px solid #e5e0da;
    border-bottom: 0.5px solid #e5e0da;
    padding: 16px 0;
    white-space: nowrap;
  }
  .swu-marquee__track {
    display: inline-flex;
    animation: swu-marquee 28s linear infinite;
  }
  .swu-marquee__item {
    font-size: 10px;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: #9a8f86;
    padding: 0 40px;
  }
  .swu-marquee__dot {
    color: #c8c0b8;
    padding: 0;
  }
  @keyframes swu-marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  /* ── Process ── */
  .swu-process {
    padding: 80px 24px;
    background: #fff;
  }
  .swu-process__label {
    text-align: center;
    font-size: 10px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: #9a8f86;
    margin-bottom: 56px;
  }
  .swu-process__steps {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0;
    max-width: 1100px;
    margin: 0 auto;
  }
  .swu-step {
    padding: 0 28px;
    border-right: 0.5px solid #e5e0da;
  }
  .swu-step:last-child { border-right: none; }
  .swu-step__num {
    font-size: 11px;
    letter-spacing: 0.2em;
    color: #b5ada5;
    margin-bottom: 16px;
    display: block;
  }
  .swu-step__body {
    font-size: 13px;
    font-weight: 300;
    line-height: 1.75;
    color: #6b6259;
  }

  /* ── Commission ── */
  .swu-commission {
    padding: 80px 24px;
    background: #eeece8;
    text-align: center;
  }
  .swu-commission__label {
    font-size: 10px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(28,28,28,0.4);
    margin-bottom: 24px;
  }
  .swu-commission__rate {
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 300;
    letter-spacing: 0.04em;
    color: #1c1c1c;
    line-height: 1;
    margin-bottom: 16px;
  }
  .swu-commission__fee {
    font-size: 13px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(28,28,28,0.45);
    margin-bottom: 32px;
  }
  .swu-commission__note {
    font-size: 13px;
    font-weight: 300;
    color: rgba(28,28,28,0.5);
    line-height: 1.7;
    max-width: 480px;
    margin: 0 auto;
    font-style: italic;
  }

  /* ── Condition guide ── */
  .swu-condition {
    padding: 80px 24px;
    background: #faf9f7;
  }
  .swu-condition__label {
    text-align: center;
    font-size: 10px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: #9a8f86;
    margin-bottom: 56px;
  }
  .swu-condition__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    max-width: 900px;
    margin: 0 auto 40px;
    background: #e5e0da;
  }
  .swu-tier {
    background: #faf9f7;
    padding: 40px 36px;
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s cubic-bezier(0.16,1,0.3,1), transform 0.6s cubic-bezier(0.16,1,0.3,1);
  }
  .swu-tier.swu--in {
    opacity: 1;
    transform: translateY(0);
  }
  .swu-tier__name {
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #1c1c1c;
    font-weight: 500;
    margin-bottom: 16px;
  }
  .swu-tier__desc {
    font-size: 13px;
    font-weight: 300;
    line-height: 1.75;
    color: #6b6259;
  }
  .swu-condition__note {
    text-align: center;
    font-size: 12px;
    font-style: italic;
    color: #9a8f86;
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* ── CTA ── */
  .swu-cta {
    padding: 80px 24px;
    background: #fff;
    text-align: center;
  }
  .swu-cta__title {
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 400;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #1c1c1c;
    margin-bottom: 16px;
  }
  .swu-cta__sub {
    font-size: 14px;
    font-weight: 300;
    color: #6b6259;
    line-height: 1.7;
    margin-bottom: 36px;
    max-width: 400px;
    margin-left: auto;
    margin-right: auto;
  }
  .swu-cta__btn {
    display: inline-block;
    background: #1c1c1c;
    color: #fff;
    text-decoration: none;
    padding: 16px 48px;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 500;
    font-family: inherit;
    transition: background 0.2s;
  }
  .swu-cta__btn:hover { background: #3d3530; color: #fff; }

  /* ── Mobile ── */
  @media screen and (max-width: 767px) {
    .swu-hero { height: 50vh; min-height: 320px; }
    .swu-hero__content { padding: 0 24px 48px; }
    .swu-intro,
    .swu-process,
    .swu-commission,
    .swu-condition,
    .swu-cta { padding: 60px 24px; }
    .swu-process__steps { grid-template-columns: 1fr; gap: 36px; }
    .swu-step { padding: 0; border-right: none; border-bottom: 0.5px solid #e5e0da; padding-bottom: 36px; }
    .swu-step:last-child { border-bottom: none; padding-bottom: 0; }
    .swu-condition__grid { grid-template-columns: 1fr; }
  }
</style>

{%- comment -%} ── Hero ── {%- endcomment -%}
<div class="swu-hero">
  {%- if section.settings.hero_image -%}
    <div class="swu-hero__img Image--lazyLoad Image--zoomOut"
         data-optimumx="1.4"
         data-expand="-150"
         style="background-image: url({{ section.settings.hero_image | img_url: '1x1' }})"
         data-bgset="{{ section.settings.hero_image | img_url: '750x' }} 750w, {{ section.settings.hero_image | img_url: '1200x' }} 1200w, {{ section.settings.hero_image | img_url: '1800x' }} 1800w">
    </div>
    <noscript>
      <div class="swu-hero__img" style="background-image: url({{ section.settings.hero_image | img_url: '1200x' }})"></div>
    </noscript>
  {%- else -%}
    <div class="swu-hero__img" style="background: #2a2420;"></div>
  {%- endif -%}
  <div class="swu-hero__overlay"></div>
  <div class="swu-hero__content">
    {%- if section.settings.hero_eyebrow != blank -%}
      <p class="swu-hero__eyebrow">{{ section.settings.hero_eyebrow }}</p>
    {%- endif -%}
    <h1 class="swu-hero__title" data-swu-title>{{ section.settings.hero_title | default: 'Sell With Us' }}</h1>
    {%- if section.settings.hero_sub != blank -%}
      <p class="swu-hero__sub" data-swu-sub>{{ section.settings.hero_sub }}</p>
    {%- endif -%}
  </div>
</div>

{%- comment -%} ── Intro ── {%- endcomment -%}
{%- if section.settings.intro_text != blank -%}
  <div class="swu-intro">
    <p class="swu-intro__text">{{ section.settings.intro_text }}</p>
  </div>
{%- endif -%}

{%- comment -%} ── Marquee ── {%- endcomment -%}
{%- assign m1 = section.settings.marquee_1 | default: 'Authenticated in London' -%}
{%- assign m2 = section.settings.marquee_2 | default: 'Shipped Worldwide' -%}
{%- assign m3 = section.settings.marquee_3 | default: 'Trusted by Collectors' -%}
{%- assign m4 = section.settings.marquee_4 | default: 'Fairer Commission' -%}
<div class="swu-marquee" aria-hidden="true">
  <div class="swu-marquee__track">
    {%- for i in (1..2) -%}
      <span class="swu-marquee__item">{{ m1 }}</span>
      <span class="swu-marquee__dot">·</span>
      <span class="swu-marquee__item">{{ m2 }}</span>
      <span class="swu-marquee__dot">·</span>
      <span class="swu-marquee__item">{{ m3 }}</span>
      <span class="swu-marquee__dot">·</span>
      <span class="swu-marquee__item">{{ m4 }}</span>
      <span class="swu-marquee__dot">·</span>
    {%- endfor -%}
  </div>
</div>

{%- comment -%} ── Process ── {%- endcomment -%}
<div class="swu-process">
  <p class="swu-process__label">{{ section.settings.process_label | default: 'How it works' }}</p>
  <div class="swu-process__steps">
    {%- for i in (1..5) -%}
      {%- assign step_key = 'step_' | append: i -%}
      {%- assign step_body = section.settings[step_key] -%}
      {%- if step_body != blank -%}
        <div class="swu-step">
          <span class="swu-step__num">0{{ i }}</span>
          <p class="swu-step__body">{{ step_body }}</p>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

{%- comment -%} ── Commission ── {%- endcomment -%}
<div class="swu-commission">
  <p class="swu-commission__label">{{ section.settings.commission_label | default: 'Our commission' }}</p>
  <p class="swu-commission__rate" data-swu-counter data-swu-from="25" data-swu-to="15">15%</p>
  {%- if section.settings.commission_fee != blank -%}
    <p class="swu-commission__fee">{{ section.settings.commission_fee }}</p>
  {%- endif -%}
  {%- if section.settings.commission_note != blank -%}
    <p class="swu-commission__note">{{ section.settings.commission_note }}</p>
  {%- endif -%}
</div>

{%- comment -%} ── Condition guide ── {%- endcomment -%}
<div class="swu-condition">
  <p class="swu-condition__label">{{ section.settings.condition_label | default: 'Condition guide' }}</p>
  <div class="swu-condition__grid">
    <div class="swu-tier" data-swu-tier style="transition-delay: 0s;">
      <p class="swu-tier__name">{{ section.settings.tier_1_name | default: 'Pristine' }}</p>
      <p class="swu-tier__desc">{{ section.settings.tier_1_desc | default: 'Never used. Stored perfectly with no signs of wear. Original tags and receipt included.' }}</p>
    </div>
    <div class="swu-tier" data-swu-tier style="transition-delay: 0.12s;">
      <p class="swu-tier__name">{{ section.settings.tier_2_name | default: 'Excellent' }}</p>
      <p class="swu-tier__desc">{{ section.settings.tier_2_desc | default: 'Appears unworn but has been used. No visible scratches or signs of wear.' }}</p>
    </div>
    <div class="swu-tier" data-swu-tier style="transition-delay: 0.24s;">
      <p class="swu-tier__name">{{ section.settings.tier_3_name | default: 'Very Good' }}</p>
      <p class="swu-tier__desc">{{ section.settings.tier_3_desc | default: 'Minimal use and wear. Any scratches are small and only visible on close inspection.' }}</p>
    </div>
  </div>
  {%- if section.settings.condition_note != blank -%}
    <p class="swu-condition__note">{{ section.settings.condition_note }}</p>
  {%- endif -%}
</div>

{%- comment -%} ── CTA ── {%- endcomment -%}
<div class="swu-cta">
  <h2 class="swu-cta__title">{{ section.settings.cta_title | default: 'Ready to sell?' }}</h2>
  {%- if section.settings.cta_sub != blank -%}
    <p class="swu-cta__sub">{{ section.settings.cta_sub }}</p>
  {%- endif -%}
  {%- if section.settings.cta_url != blank -%}
    <a href="{{ section.settings.cta_url }}" class="swu-cta__btn">{{ section.settings.cta_label | default: 'List an Item' }}</a>
  {%- endif -%}
</div>

<script>
(function () {
  /* ── 1. Hero word reveal ── */
  var titleEl = document.querySelector('[data-swu-title]');
  var subEl   = document.querySelector('[data-swu-sub]');

  if (titleEl) {
    var raw = titleEl.textContent.trim();
    titleEl.innerHTML = raw.split(' ').map(function (w, i) {
      return '<span class="swu-hero__word" style="transition-delay:' + (0.08 * i) + 's">' + w + '</span>';
    }).join(' ');
    requestAnimationFrame(function () {
      requestAnimationFrame(function () {
        titleEl.querySelectorAll('.swu-hero__word').forEach(function (w) {
          w.classList.add('swu--in');
        });
        if (subEl) subEl.classList.add('swu--in');
      });
    });
  }

  /* ── 2. Commission counter 25 → 15 ── */
  var counterEl = document.querySelector('[data-swu-counter]');
  if (counterEl) {
    var from = parseInt(counterEl.getAttribute('data-swu-from'), 10);
    var to   = parseInt(counterEl.getAttribute('data-swu-to'),   10);
    var started = false;

    var obs = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting && !started) {
          started = true;
          obs.disconnect();
          var start = null;
          var duration = 1200;
          function step(ts) {
            if (!start) start = ts;
            var progress = Math.min((ts - start) / duration, 1);
            var eased = 1 - Math.pow(1 - progress, 3);
            var current = Math.round(from + (to - from) * eased);
            counterEl.textContent = current + '%';
            if (progress < 1) requestAnimationFrame(step);
          }
          requestAnimationFrame(step);
        }
      });
    }, { threshold: 0.5 });
    obs.observe(counterEl);
  }

  /* ── 3. Condition tier stagger reveal ── */
  var tiers = document.querySelectorAll('[data-swu-tier]');
  if (tiers.length) {
    var tierObs = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('swu--in');
          tierObs.unobserve(entry.target);
        }
      });
    }, { threshold: 0.2 });
    tiers.forEach(function (t) { tierObs.observe(t); });
  }
})();
</script>

