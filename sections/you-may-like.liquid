{%- comment -%}
  YOU MAY LIKE — standalone section, no Shopify recommendations API.

  Tag logic (checked in order):
    1. Product has a tag matching "Collection:X" (e.g. "Collection:Bags", "Collection:Clothing")
       → look up collections["x"] and show up to 4 products from it.
    2. No Collection: tag → fall back to product.collections.first.
    3. Fewer than 1 other product found → section renders nothing.
{%- endcomment -%}

{%- assign yml_col = blank -%}

{%- for tag in product.tags -%}
  {%- if tag contains 'Collection:' -%}
    {%- assign yml_handle = tag | split: ':' | last | strip | downcase | replace: ' ', '-' -%}
    {%- assign yml_col = collections[yml_handle] -%}
    {%- if yml_col != blank -%}{%- break -%}{%- endif -%}
  {%- endif -%}
{%- endfor -%}

{%- if yml_col == blank -%}
  {%- assign yml_col = product.collections.first -%}
{%- endif -%}

{%- assign yml_count = 0 -%}
{%- if yml_col != blank -%}
  {%- for p in yml_col.products limit: 20 -%}
    {%- unless p.id == product.id -%}
      {%- if yml_count < 4 -%}{%- assign yml_count = yml_count | plus: 1 -%}{%- endif -%}
    {%- endunless -%}
  {%- endfor -%}
{%- endif -%}

{%- if yml_count > 0 -%}

<section class="yml-section" {{ section.shopify_attributes }}>

  {%- if section.settings.heading != blank -%}
    <h2 class="yml-heading">{{ section.settings.heading | escape }}</h2>
  {%- endif -%}

  <div class="yml-grid">
    {%- assign yml_shown = 0 -%}
    {%- for p in yml_col.products limit: 20 -%}
      {%- unless p.id == product.id -%}
        {%- if yml_shown < 4 -%}
          <a href="{{ p.url }}" class="yml-card">
            <div class="yml-card__img-wrap">
              {%- if p.featured_image -%}
                {%- assign yml_img = p.featured_image | img_url: '1x1' | replace: '_1x1.', '_{width}x.' -%}
                <img class="yml-card__img Image--lazyLoad Image--fadeIn"
                     data-src="{{ yml_img }}"
                     data-widths="[400, 600]"
                     data-sizes="auto"
                     alt="{{ p.featured_image.alt | default: p.title | escape }}">
                <span class="Image__Loader"></span>
              {%- else -%}
                <div class="yml-card__placeholder"></div>
              {%- endif -%}
            </div>
            <div class="yml-card__info">
              <p class="yml-card__title">{{ p.title | escape }}</p>
              <p class="yml-card__price">{{ p.price | money }}</p>
            </div>
          </a>
          {%- assign yml_shown = yml_shown | plus: 1 -%}
        {%- endif -%}
      {%- endunless -%}
    {%- endfor -%}
  </div>

</section>

{%- endif -%}

<style>
.yml-section {
  padding: 60px 35px 52px;
  background: #ffffff;
  font-family: 'Jost', sans-serif;
}

.yml-heading {
  font-size: 16px;
  font-weight: 400;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: #1a1a1a;
  text-align: center;
  margin: 0 0 40px;
}

.yml-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
  align-items: start;
}

.yml-card {
  text-decoration: none;
  color: inherit;
  display: block;
}

.yml-card__img-wrap {
  position: relative;
  width: 100%;
  height: 0;
  padding-bottom: 100%;
  overflow: hidden;
  background: #f5f5f5;
  margin-bottom: 12px;
}

.yml-card__img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.4s ease;
}

.yml-card:hover .yml-card__img {
  transform: scale(1.04);
}

.yml-card__placeholder {
  position: absolute;
  inset: 0;
  background: #ece9e4;
}

.yml-card__info {
  padding: 0 2px;
}

.yml-card__title {
  font-size: 12px;
  font-weight: 400;
  letter-spacing: 0.06em;
  color: #1a1a1a;
  margin: 0 0 4px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.yml-card__price {
  font-size: 12px;
  font-weight: 300;
  color: #888888;
  margin: 0;
}

@media screen and (max-width: 900px) {
  .yml-section {
    padding: 40px 0 36px;
  }

  .yml-heading {
    padding: 0 24px;
  }

  .yml-grid {
    display: flex;
    flex-direction: row;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
    gap: 12px;
    padding: 0 24px;
  }

  .yml-grid::-webkit-scrollbar {
    display: none;
  }

  .yml-card {
    flex: 0 0 58%;
    scroll-snap-align: start;
  }
}
</style>

{% schema %}
{
  "name": "You May Like",
  "templates": ["product"],
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "YOU MAY LIKE"
    }
  ],
  "presets": [
    {
      "name": "You May Like"
    }
  ]
}
{% endschema %}
