{% comment %}
  embed-timeline-cards.liquid
  Full-viewport sticky timeline. Cards slide left as user scrolls; text fades in per card.
  Format: groups of 3 lines (year / headline / body), up to 5 blocks. No blank lines needed.
{% endcomment %}

{%- assign _tc_id    = id | default: article.id -%}
{%- assign _tc_lines = content | newline_to_br | split: '<br />' -%}

{%- assign _tc_total = 0 -%}
{%- for _i in (0..4) -%}
  {%- assign _tc_i0    = _i | times: 3 -%}
  {%- assign _tc_check = _tc_lines[_tc_i0] | strip -%}
  {%- if _tc_check != blank -%}{%- assign _tc_total = _tc_total | plus: 1 -%}{%- endif -%}
{%- endfor -%}

{%- if _tc_total == 0 -%}{%- break -%}{%- endif -%}

<style>
/* ── Full-width breakout from article column ── */
#tl-sentinel-{{ _tc_id }} {
  position: relative;
  width: 100vw;
  margin-left: calc(50% - 50vw);
}

/* ── Sticky panel — full viewport, black ── */
#tl-sentinel-{{ _tc_id }} .tl-sticky {
  position: sticky !important;
  top: 0 !important;
  height: 100vh !important;
  background: #000 !important;
  overflow: hidden !important;
  display: flex !important;
  flex-direction: column !important;
}

/* ── Progress bar ── */
#tl-sentinel-{{ _tc_id }} .tl-prog {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1px;
  background: rgba(255,255,255,.08);
  z-index: 10;
}
#tl-sentinel-{{ _tc_id }} .tl-prog-fill {
  position: absolute;
  top: 0; left: 0;
  height: 100%; width: 0;
  background: rgb(128,111,100);
}

/* ── Horizontal card track ── */
#tl-sentinel-{{ _tc_id }} .tl-track {
  display: flex !important;
  height: 100% !important;
  will-change: transform;
}

/* ── Single card — full viewport wide ── */
#tl-sentinel-{{ _tc_id }} .tl-card {
  flex-shrink: 0 !important;
  height: 100% !important;
  display: flex !important;
  flex-direction: column !important;
  align-items: center !important;
  justify-content: center !important;
  padding: 6rem 2rem 5rem !important;
  text-align: center !important;
  margin: 0 !important;
  background: transparent !important;
}

/* ── Eyebrow ── */
#tl-sentinel-{{ _tc_id }} .tl-eyebrow {
  display: block !important;
  font-family: 'Jost', -apple-system, sans-serif !important;
  font-size: clamp(10px, 1vw, 12px) !important;
  font-weight: 400 !important;
  font-style: normal !important;
  letter-spacing: .18em !important;
  text-transform: uppercase !important;
  color: rgb(128,111,100) !important;
  margin: 0 0 1.8rem 0 !important;
  padding: 0 !important;
  opacity: 0;
  transform: translateY(8px);
  transition: opacity .55s, transform .55s cubic-bezier(.16,1,.3,1);
}

/* ── Year — bold, modern, clean ── */
#tl-sentinel-{{ _tc_id }} .tl-year {
  display: block !important;
  font-family: 'Jost', -apple-system, sans-serif !important;
  font-size: clamp(80px, 14vw, 180px) !important;
  font-weight: 700 !important;
  font-style: normal !important;
  color: #fff !important;
  line-height: 1 !important;
  letter-spacing: -.03em !important;
  margin: 0 0 2rem 0 !important;
  padding: 0 !important;
  opacity: 0;
  transform: translateY(20px);
  transition: opacity .6s .07s, transform .6s .07s cubic-bezier(.16,1,.3,1);
}

/* ── Headline ── */
#tl-sentinel-{{ _tc_id }} .tl-h {
  font-family: 'Jost', -apple-system, sans-serif !important;
  font-size: clamp(20px, 3vw, 40px) !important;
  font-weight: 500 !important;
  font-style: normal !important;
  color: rgba(255,255,255,.88) !important;
  line-height: 1.1 !important;
  letter-spacing: -.015em !important;
  text-transform: none !important;
  max-width: 680px;
  margin: 0 0 1.5rem 0 !important;
  padding: 0 !important;
  opacity: 0;
  transform: translateY(16px);
  transition: opacity .6s .16s, transform .6s .16s cubic-bezier(.16,1,.3,1);
}

/* ── Body ── */
#tl-sentinel-{{ _tc_id }} .tl-p {
  font-family: 'Jost', -apple-system, sans-serif !important;
  font-size: clamp(14px, 1.4vw, 16px) !important;
  font-weight: 300 !important;
  font-style: normal !important;
  color: rgba(255,255,255,.38) !important;
  line-height: 1.75 !important;
  max-width: 520px;
  letter-spacing: 0 !important;
  margin: 0 !important;
  padding: 0 !important;
  opacity: 0;
  transform: translateY(12px);
  transition: opacity .6s .26s, transform .6s .26s cubic-bezier(.16,1,.3,1);
}

/* ── Active: reveal ── */
#tl-sentinel-{{ _tc_id }} .tl-card.active .tl-eyebrow {
  opacity: .65;
  transform: translateY(0);
}
#tl-sentinel-{{ _tc_id }} .tl-card.active .tl-year,
#tl-sentinel-{{ _tc_id }} .tl-card.active .tl-h,
#tl-sentinel-{{ _tc_id }} .tl-card.active .tl-p {
  opacity: 1;
  transform: translateY(0);
}
#tl-sentinel-{{ _tc_id }} .tl-card.active .tl-p { opacity: .38; }

/* ── Dots — bottom centre ── */
#tl-sentinel-{{ _tc_id }} .tl-counter {
  position: absolute;
  bottom: 2.5rem;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  gap: 8px;
  z-index: 10;
}
#tl-sentinel-{{ _tc_id }} .tl-step {
  width: 5px; height: 5px;
  border-radius: 50%;
  background: rgba(255,255,255,.18);
  cursor: pointer;
  pointer-events: all;
  transition: background .3s, transform .3s;
  flex-shrink: 0;
}
#tl-sentinel-{{ _tc_id }} .tl-step.active {
  background: #fff;
  transform: scale(1.4);
}

/* ── Hint — bottom right ── */
#tl-sentinel-{{ _tc_id }} .tl-hint {
  position: absolute;
  right: 3rem; bottom: 2.5rem;
  z-index: 10;
  font-family: 'Jost', -apple-system, sans-serif !important;
  font-size: 10px !important;
  font-style: normal !important;
  letter-spacing: .16em;
  text-transform: uppercase;
  color: rgba(255,255,255,.12);
  transition: color .4s;
  margin: 0 !important; padding: 0 !important;
}
#tl-sentinel-{{ _tc_id }} .tl-hint.last { color: rgba(255,255,255,.3); }

/* ── Mobile ── */
@media (max-width: 640px) {
  #tl-sentinel-{{ _tc_id }} .tl-year { font-size: clamp(60px, 19vw, 96px) !important; }
  #tl-sentinel-{{ _tc_id }} .tl-hint { display: none; }
  #tl-sentinel-{{ _tc_id }} .tl-card { padding: 5rem 1.5rem 5.5rem !important; }
}
</style>

<div id="tl-sentinel-{{ _tc_id }}" data-n="{{ _tc_total }}">
  <div class="tl-sticky">

    <div class="tl-prog">
      <div class="tl-prog-fill" id="tl-pf-{{ _tc_id }}"></div>
    </div>

    <div class="tl-track" id="tl-track-{{ _tc_id }}">

      {%- assign _tc_card_idx = 0 -%}
      {%- for _i in (0..4) -%}
        {%- assign _tc_i0   = _i | times: 3 -%}
        {%- assign _tc_i1   = _tc_i0 | plus: 1 -%}
        {%- assign _tc_i2   = _tc_i0 | plus: 2 -%}
        {%- assign _tc_date = _tc_lines[_tc_i0] | strip -%}
        {%- assign _tc_head = _tc_lines[_tc_i1] | strip -%}
        {%- assign _tc_body = _tc_lines[_tc_i2] | strip -%}
        {%- if _tc_date == blank -%}{%- break -%}{%- endif -%}
        {%- assign _tc_card_idx = _tc_card_idx | plus: 1 -%}
        {%- assign _tc_num = _tc_card_idx | prepend: '0' | slice: -2, 2 -%}
        {%- assign _tc_tot = _tc_total  | prepend: '0' | slice: -2, 2 -%}
        <div class="tl-card">
          <span class="tl-eyebrow">{{ _tc_num }} of {{ _tc_tot }}</span>
          <div class="tl-year">{{ _tc_date }}</div>
          {%- if _tc_head != blank -%}<p class="tl-h">{{ _tc_head }}</p>{%- endif -%}
          {%- if _tc_body != blank -%}<p class="tl-p">{{ _tc_body }}</p>{%- endif -%}
        </div>
      {%- endfor -%}

    </div>

    <div class="tl-counter" id="tl-steps-{{ _tc_id }}">
      {%- for _i in (0..4) -%}
        {%- assign _tc_i0    = _i | times: 3 -%}
        {%- assign _tc_check = _tc_lines[_tc_i0] | strip -%}
        {%- if _tc_check == blank -%}{%- break -%}{%- endif -%}
        <div class="tl-step{% if forloop.first %} active{% endif %}" data-i="{{ forloop.index0 }}"></div>
      {%- endfor -%}
    </div>

    <span class="tl-hint" id="tl-hint-{{ _tc_id }}">Scroll to advance</span>

  </div>
</div>

<script>
(function(){
  var eid      = '{{ _tc_id }}';
  var N        = {{ _tc_total }};
  var sentinel = document.getElementById('tl-sentinel-' + eid);
  var track    = document.getElementById('tl-track-' + eid);
  var steps    = sentinel ? sentinel.querySelectorAll('.tl-step') : [];
  var progFill = document.getElementById('tl-pf-'  + eid);
  var hint     = document.getElementById('tl-hint-' + eid);
  var cards    = track ? track.querySelectorAll('.tl-card') : [];
  if (!sentinel || !track || N === 0) return;

  var targetX = 0, animX = 0, raf;
  var lastIdx = -1;

  function cw() { return window.innerWidth; }

  function setH() {
    sentinel.style.height = (window.innerHeight * (N + 0.5)) + 'px';
  }

  function setCardWidths() {
    var w = cw();
    [].forEach.call(cards, function(c){ c.style.width = w + 'px'; });
  }

  function updateActive(idx) {
    if (idx === lastIdx) return;
    lastIdx = idx;
    [].forEach.call(cards, function(c, i){ c.classList.toggle('active', i === idx); });
    steps.forEach(function(s, i){ s.classList.toggle('active', i === idx); });
    if (hint) {
      hint.classList.toggle('last', idx === N - 1);
      hint.textContent = idx === N - 1 ? 'Scroll to continue' : 'Scroll to advance';
    }
  }

  function render() {
    track.style.transform = 'translateX(' + animX + 'px)';
    var w   = cw();
    var idx = Math.max(0, Math.min(N - 1, Math.round(-animX / w)));
    updateActive(idx);
    if (progFill) progFill.style.width = (N > 1 ? (-animX / ((N - 1) * w)) * 100 : 0) + '%';
  }

  function loop() {
    animX += (targetX - animX) * 0.09;
    render();
    if (Math.abs(animX - targetX) > 0.2) raf = requestAnimationFrame(loop);
    else { animX = targetX; render(); }
  }

  function onScroll() {
    var rect = sentinel.getBoundingClientRect();
    if (rect.top > 0 || rect.bottom < window.innerHeight) return;
    var scrolled = -rect.top;
    var total    = sentinel.offsetHeight - window.innerHeight;
    var progress = Math.max(0, Math.min(1, scrolled / total));
    targetX = -progress * (N - 1) * cw();
    cancelAnimationFrame(raf);
    raf = requestAnimationFrame(loop);
  }

  /* Wheel intercept */
  var wheelBuf = 0, wheelTimer;
  window.addEventListener('wheel', function(e) {
    var rect = sentinel.getBoundingClientRect();
    if (rect.top > 0 || rect.bottom < window.innerHeight) return;
    var curIdx = Math.max(0, Math.min(N - 1, Math.round(-targetX / cw())));
    if (curIdx === 0     && e.deltaY < 0) return;
    if (curIdx === N - 1 && e.deltaY > 0) return;
    e.preventDefault();
    wheelBuf += e.deltaY;
    clearTimeout(wheelTimer);
    wheelTimer = setTimeout(function(){ wheelBuf = 0; }, 300);
    if (wheelBuf > 80) {
      wheelBuf = 0;
      var next = Math.min(N - 1, curIdx + 1);
      targetX = -next * cw();
      cancelAnimationFrame(raf); raf = requestAnimationFrame(loop);
      window.scrollTo({ top: sentinel.offsetTop + (sentinel.offsetHeight - window.innerHeight) * (next / (N - 1)), behavior: 'instant' });
    } else if (wheelBuf < -80) {
      wheelBuf = 0;
      var prev = Math.max(0, curIdx - 1);
      targetX = -prev * cw();
      cancelAnimationFrame(raf); raf = requestAnimationFrame(loop);
      window.scrollTo({ top: sentinel.offsetTop + (sentinel.offsetHeight - window.innerHeight) * (prev / (N - 1)), behavior: 'instant' });
    }
  }, { passive: false });

  /* Touch */
  var tY = 0, tDone = false;
  window.addEventListener('touchstart', function(e){ tY = e.touches[0].clientY; tDone = false; }, { passive: true });
  window.addEventListener('touchmove', function(e) {
    var rect = sentinel.getBoundingClientRect();
    if (rect.top > 0 || rect.bottom < window.innerHeight) return;
    var curIdx = Math.max(0, Math.min(N - 1, Math.round(-targetX / cw())));
    var dy = tY - e.touches[0].clientY;
    if (curIdx === 0     && dy < 0) return;
    if (curIdx === N - 1 && dy > 0) return;
    if (Math.abs(dy) > 40 && !tDone) {
      tDone = true;
      e.preventDefault();
      var ni = dy > 0 ? curIdx + 1 : curIdx - 1;
      targetX = -ni * cw();
      cancelAnimationFrame(raf); raf = requestAnimationFrame(loop);
      window.scrollTo({ top: sentinel.offsetTop + (sentinel.offsetHeight - window.innerHeight) * (ni / (N - 1)), behavior: 'instant' });
    }
  }, { passive: false });

  /* Dot clicks */
  steps.forEach(function(s) {
    s.addEventListener('click', function() {
      var i = parseInt(s.dataset.i);
      targetX = -i * cw();
      cancelAnimationFrame(raf); raf = requestAnimationFrame(loop);
      window.scrollTo({ top: sentinel.offsetTop + (sentinel.offsetHeight - window.innerHeight) * (i / (N - 1)), behavior: 'smooth' });
    });
  });

  window.addEventListener('resize', function(){ setCardWidths(); setH(); onScroll(); });

  setH();
  setCardWidths();
  updateActive(0);
  cards[0].classList.add('active');
  onScroll();
})();
</script>
