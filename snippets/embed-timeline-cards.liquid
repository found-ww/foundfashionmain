{% comment %}
  embed-timeline-cards.liquid
  Format: groups of 3 lines (year / headline / body), up to 5 blocks. No blank lines needed.
{% endcomment %}

{%- assign _tc_id    = id | default: article.id -%}
{%- assign _tc_lines = content | newline_to_br | split: '<br />' -%}

{%- assign _tc_total = 0 -%}
{%- for _i in (0..4) -%}
  {%- assign _tc_i0    = _i | times: 3 -%}
  {%- assign _tc_check = _tc_lines[_tc_i0] | strip -%}
  {%- if _tc_check != blank -%}{%- assign _tc_total = _tc_total | plus: 1 -%}{%- endif -%}
{%- endfor -%}

{%- if _tc_total == 0 -%}{%- break -%}{%- endif -%}

<style>
#tc-{{ _tc_id }} {
  box-sizing: border-box;
  display: flex !important;
  flex-direction: column !important;
  height: 500px;
  overflow: hidden !important;
  border-top: .5px solid rgba(0,0,0,.1);
  border-bottom: .5px solid rgba(0,0,0,.1);
  margin: 3.5rem 0;
}
#tc-{{ _tc_id }} * { box-sizing: border-box; }

#tc-{{ _tc_id }} .tl-prog { height: 1px; background: rgba(0,0,0,.07); flex-shrink: 0; position: relative; }
#tc-{{ _tc_id }} .tl-pf   { position: absolute; top: 0; left: 0; height: 100%; width: 0; background: #555; }

#tc-{{ _tc_id }} .tl-card {
  flex-shrink: 0 !important;
  width: clamp(300px, 34vw, 440px) !important;
  height: 100% !important;
  border-right: .5px solid rgba(0,0,0,.07) !important;
  display: flex !important;
  flex-direction: column !important;
  justify-content: flex-end !important;
  gap: 1.1rem !important;
  background: #fff !important;
  position: relative !important;
  overflow: hidden !important;
  margin: 0 !important;
  padding: 2.8rem !important;
}

#tc-{{ _tc_id }} .tl-num {
  position: absolute !important; top: 2rem; right: 2rem;
  font-size: 10px !important; letter-spacing: .18em; text-transform: uppercase;
  color: #ccc; margin: 0 !important; padding: 0 !important; font-style: normal !important;
}

#tc-{{ _tc_id }} .tl-date {
  font-family: 'Cormorant Garamond', Georgia, serif !important;
  font-size: clamp(42px, 5.5vw, 64px) !important;
  font-weight: 300 !important; font-style: italic !important;
  color: #d0d0d0 !important; line-height: 1 !important;
  margin: 0 !important; padding: 0 !important;
  transition: color .4s ease;
}
#tc-{{ _tc_id }} .tl-card:hover .tl-date { color: #aaa !important; }

#tc-{{ _tc_id }} .tl-rule {
  width: 24px !important; height: 1px !important;
  background: #e0e0e0; flex-shrink: 0;
  transition: width .4s cubic-bezier(.16,1,.3,1), background .3s;
  margin: 0 !important; padding: 0 !important;
}
#tc-{{ _tc_id }} .tl-card:hover .tl-rule { width: 48px !important; background: #999; }

#tc-{{ _tc_id }} .tl-h {
  font-family: 'Cormorant Garamond', Georgia, serif !important;
  font-size: clamp(20px, 2.4vw, 26px) !important;
  font-weight: 300 !important; font-style: italic !important;
  color: #1a1a1a !important; line-height: 1.2 !important;
  margin: 0 !important; padding: 0 !important;
  text-transform: none !important; letter-spacing: normal !important;
  transition: transform .45s cubic-bezier(.16,1,.3,1);
}
#tc-{{ _tc_id }} .tl-card:hover .tl-h { transform: translateX(6px); }

#tc-{{ _tc_id }} .tl-p {
  font-size: 13px !important; line-height: 1.72 !important;
  color: #999 !important;
  font-style: normal !important; font-weight: 400 !important;
  margin: 0 !important; padding: 0 !important;
}

#tc-{{ _tc_id }} .tl-card::after {
  content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 1px;
  background: #ccc; transform: scaleX(0); transform-origin: left;
  transition: transform .5s cubic-bezier(.16,1,.3,1);
}
#tc-{{ _tc_id }} .tl-card:hover::after { transform: scaleX(1); }

#tc-{{ _tc_id }} .tl-foot {
  height: 40px; border-top: .5px solid rgba(0,0,0,.07); flex-shrink: 0;
  display: flex !important; align-items: center; gap: 1rem; padding: 0 2rem;
}
#tc-{{ _tc_id }} .tl-dot {
  width: 5px !important; height: 5px !important; border-radius: 50%;
  background: #ddd; cursor: pointer;
  transition: background .2s, transform .2s;
  flex-shrink: 0; padding: 0 !important; margin: 0 !important;
}
#tc-{{ _tc_id }} .tl-dot.active,
#tc-{{ _tc_id }} .tl-dot:hover { background: #555 !important; transform: scale(1.5); }
#tc-{{ _tc_id }} .tl-hint {
  margin-left: auto !important; font-size: 9px !important;
  letter-spacing: .16em; text-transform: uppercase; color: #ccc;
}

@media (max-width: 640px) {
  #tc-{{ _tc_id }} { height: 460px; }
  #tc-{{ _tc_id }} .tl-card { width: 80vw !important; padding: 2.2rem 1.75rem !important; }
  #tc-{{ _tc_id }} .tl-date { font-size: clamp(38px, 11vw, 52px) !important; }
}
</style>

<div id="tc-{{ _tc_id }}">

  <div class="tl-prog"><div class="tl-pf" id="tl-pf-{{ _tc_id }}"></div></div>

  <div class="tl-inner" id="tl-tw-{{ _tc_id }}"
    style="flex:1;overflow:hidden;position:relative;touch-action:pan-y;cursor:grab;">
    <div id="tl-track-{{ _tc_id }}"
      style="display:flex;height:100%;width:max-content;will-change:transform;user-select:none;-webkit-user-select:none;">

      {%- assign _tc_card_idx = 0 -%}
      {%- for _i in (0..4) -%}
        {%- assign _tc_i0   = _i | times: 3 -%}
        {%- assign _tc_i1   = _tc_i0 | plus: 1 -%}
        {%- assign _tc_i2   = _tc_i0 | plus: 2 -%}
        {%- assign _tc_date = _tc_lines[_tc_i0] | strip -%}
        {%- assign _tc_head = _tc_lines[_tc_i1] | strip -%}
        {%- assign _tc_body = _tc_lines[_tc_i2] | strip -%}
        {%- if _tc_date == blank -%}{%- break -%}{%- endif -%}
        {%- assign _tc_card_idx = _tc_card_idx | plus: 1 -%}
        {%- assign _tc_num   = _tc_card_idx | prepend: '0' | slice: -2, 2 -%}
        {%- assign _tc_tot_s = _tc_total    | prepend: '0' | slice: -2, 2 -%}
        <div class="tl-card">
          <span class="tl-num">{{ _tc_num }} / {{ _tc_tot_s }}</span>
          <div class="tl-date">{{ _tc_date }}</div>
          <div class="tl-rule"></div>
          {%- if _tc_head != blank -%}<p class="tl-h">{{ _tc_head }}</p>{%- endif -%}
          {%- if _tc_body != blank -%}<p class="tl-p">{{ _tc_body }}</p>{%- endif -%}
        </div>
      {%- endfor -%}

    </div>
  </div>

  <div class="tl-foot">
    {%- for _i in (0..4) -%}
      {%- if _i < _tc_total -%}
        <div class="tl-dot{% if _i == 0 %} active{% endif %}" data-i="{{ _i }}"></div>
      {%- endif -%}
    {%- endfor -%}
    <span class="tl-hint">Drag to explore</span>
  </div>

</div>

<script>
(function(){
  var root  = document.getElementById('tc-{{ _tc_id }}');
  var tw    = document.getElementById('tl-tw-{{ _tc_id }}');
  var track = document.getElementById('tl-track-{{ _tc_id }}');
  var pf    = document.getElementById('tl-pf-{{ _tc_id }}');
  if (!tw || !track) return;

  var dots  = root.querySelectorAll('.tl-dot');
  var cards = track.querySelectorAll('.tl-card');
  var tx = 0, animTx = 0, raf;
  var dragStartX = 0, dragStartTx = 0, dragging = false;

  function lerp(a,b,n){ return a+(b-a)*n; }
  function maxTx(){ return -(track.scrollWidth - tw.clientWidth); }
  function clamp(v){ return Math.max(maxTx(), Math.min(0,v)); }

  function render(){
    track.style.transform = 'translateX('+animTx+'px)';
    var max = -maxTx();
    pf.style.width = (max > 0 ? Math.min(100, (-animTx/max)*100) : 0)+'%';
    var cw = cards[0] ? cards[0].offsetWidth : 1;
    dots.forEach(function(d,i){ d.classList.toggle('active', i === Math.round(-animTx/cw)); });
  }
  function loop(){
    animTx = lerp(animTx, tx, .1);
    if(Math.abs(animTx - tx) > 0.3){ render(); raf = requestAnimationFrame(loop); }
    else{ animTx = tx; render(); }
  }

  /* ── Pointer Events API — handles mouse + touch uniformly ── */
  tw.addEventListener('pointerdown', function(e){
    dragging = true;
    dragStartX = e.clientX;
    dragStartTx = tx;
    tw.setPointerCapture(e.pointerId);
    tw.style.cursor = 'grabbing';
    cancelAnimationFrame(raf);
    e.preventDefault();
  });

  tw.addEventListener('pointermove', function(e){
    if(!dragging) return;
    tx = clamp(dragStartTx + (e.clientX - dragStartX));
    render();
  });

  tw.addEventListener('pointerup', function(e){
    if(!dragging) return;
    dragging = false;
    tw.style.cursor = 'grab';
    /* snap to nearest card */
    var cw = cards[0] ? cards[0].offsetWidth : 1;
    tx = clamp(-Math.round(-tx / cw) * cw);
    cancelAnimationFrame(raf); raf = requestAnimationFrame(loop);
  });

  tw.addEventListener('pointercancel', function(){
    dragging = false;
    tw.style.cursor = 'grab';
  });

  /* ── Dot clicks ── */
  dots.forEach(function(d){
    d.addEventListener('click', function(){
      tx = clamp(-(cards[0] ? cards[0].offsetWidth * parseInt(d.dataset.i) : 0));
      cancelAnimationFrame(raf); raf = requestAnimationFrame(loop);
    });
  });

  window.addEventListener('resize', function(){ tx = clamp(tx); render(); });
  render();
})();
</script>
