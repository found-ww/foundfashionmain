{% comment %}
  embed-timeline-cards.liquid
  Sticky-scroll timeline. Pins to viewport and advances cards as user scrolls.
  Format: groups of 3 lines (year / headline / body), up to 5 blocks. No blank lines needed.
{% endcomment %}

{%- assign _tc_id    = id | default: article.id -%}
{%- assign _tc_lines = content | newline_to_br | split: '<br />' -%}

{%- assign _tc_total = 0 -%}
{%- for _i in (0..4) -%}
  {%- assign _tc_i0    = _i | times: 3 -%}
  {%- assign _tc_check = _tc_lines[_tc_i0] | strip -%}
  {%- if _tc_check != blank -%}{%- assign _tc_total = _tc_total | plus: 1 -%}{%- endif -%}
{%- endfor -%}

{%- if _tc_total == 0 -%}{%- break -%}{%- endif -%}

<style>
/* ── Outer scroll container — height gives scroll room ── */
.tl-outer-{{ _tc_id }} {
  --n: {{ _tc_total }};
  height: calc((var(--n) - 1) * 55vh + 100vh);
  position: relative;
}

/* ── Sticky panel ── */
.tl-outer-{{ _tc_id }} .tl-sticky {
  position: sticky;
  top: 0;
  height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  overflow: hidden;
  background: #fff;
}

/* ── Top progress bar ── */
.tl-outer-{{ _tc_id }} .tl-bar {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1px;
  background: rgba(0,0,0,.07);
}
.tl-outer-{{ _tc_id }} .tl-bar-fill {
  position: absolute;
  top: 0; left: 0; height: 100%; width: 0;
  background: #222;
  transition: width .05s linear;
}

/* ── Cards container ── */
.tl-outer-{{ _tc_id }} .tl-cards {
  position: relative;
  width: 100%;
  flex: 1;
  display: flex;
  align-items: center;
}

/* ── Single card ── */
.tl-outer-{{ _tc_id }} .tl-card {
  position: absolute !important;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex !important;
  flex-direction: column !important;
  justify-content: center !important;
  padding: 0 0 0 0 !important;
  margin: 0 !important;
  opacity: 0;
  transform: translateY(28px);
  transition: none; /* driven by JS */
  pointer-events: none;
  background: transparent !important;
}
.tl-outer-{{ _tc_id }} .tl-card.active {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}

/* ── Year — huge decorative ── */
.tl-outer-{{ _tc_id }} .tl-year {
  font-family: 'Cormorant Garamond', Georgia, serif !important;
  font-size: clamp(80px, 14vw, 160px) !important;
  font-weight: 300 !important;
  font-style: italic !important;
  color: #ebebeb !important;
  line-height: 1 !important;
  margin: 0 0 .3em 0 !important;
  padding: 0 !important;
  letter-spacing: -.02em;
  user-select: none;
}

/* ── Rule ── */
.tl-outer-{{ _tc_id }} .tl-rule {
  width: 32px !important;
  height: 1px !important;
  background: #ddd;
  margin: 0 0 1.4em 0 !important;
  padding: 0 !important;
  flex-shrink: 0;
  transition: width .5s cubic-bezier(.16,1,.3,1);
}
.tl-outer-{{ _tc_id }} .tl-card.active .tl-rule { width: 56px !important; background: #aaa; }

/* ── Headline ── */
.tl-outer-{{ _tc_id }} .tl-h {
  font-family: 'Cormorant Garamond', Georgia, serif !important;
  font-size: clamp(28px, 4vw, 48px) !important;
  font-weight: 300 !important;
  font-style: italic !important;
  color: #1a1a1a !important;
  line-height: 1.2 !important;
  margin: 0 0 1em 0 !important;
  padding: 0 !important;
  max-width: 16em;
  text-transform: none !important;
  letter-spacing: normal !important;
}

/* ── Body ── */
.tl-outer-{{ _tc_id }} .tl-p {
  font-size: 14px !important;
  line-height: 1.75 !important;
  color: #888 !important;
  font-style: normal !important;
  font-weight: 400 !important;
  margin: 0 !important;
  padding: 0 !important;
  max-width: 44ch;
}

/* ── Bottom row: card count + dots + hint ── */
.tl-outer-{{ _tc_id }} .tl-foot {
  position: absolute;
  bottom: 2.5rem; left: 0; right: 0;
  display: flex !important;
  align-items: center;
  gap: .75rem;
}
.tl-outer-{{ _tc_id }} .tl-num {
  font-size: 10px !important;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: #ccc;
  margin: 0 !important; padding: 0 !important;
  font-style: normal !important;
  min-width: 3.5em;
}
.tl-outer-{{ _tc_id }} .tl-dot {
  width: 4px !important; height: 4px !important;
  border-radius: 50%;
  background: #ddd;
  transition: background .3s, transform .3s;
  padding: 0 !important; margin: 0 !important;
  flex-shrink: 0;
}
.tl-outer-{{ _tc_id }} .tl-dot.active { background: #444 !important; transform: scale(1.5); }
.tl-outer-{{ _tc_id }} .tl-hint {
  margin-left: auto !important;
  font-size: 9px !important;
  letter-spacing: .16em;
  text-transform: uppercase;
  color: #ccc;
}

/* ── Mobile: smaller height per step ── */
@media (max-width: 640px) {
  .tl-outer-{{ _tc_id }} { height: calc((var(--n) - 1) * 70vh + 100vh); }
  .tl-outer-{{ _tc_id }} .tl-h { font-size: clamp(24px, 7vw, 36px) !important; }
  .tl-outer-{{ _tc_id }} .tl-year { font-size: clamp(64px, 18vw, 100px) !important; }
  .tl-outer-{{ _tc_id }} .tl-p { font-size: 13px !important; }
}
</style>

<div class="tl-outer-{{ _tc_id }}" id="tl-outer-{{ _tc_id }}" data-n="{{ _tc_total }}">
  <div class="tl-sticky">

    <div class="tl-bar"><div class="tl-bar-fill" id="tl-bar-{{ _tc_id }}"></div></div>

    <div class="tl-cards" id="tl-cards-{{ _tc_id }}" style="padding: 0 3rem;">

      {%- assign _tc_card_idx = 0 -%}
      {%- for _i in (0..4) -%}
        {%- assign _tc_i0   = _i | times: 3 -%}
        {%- assign _tc_i1   = _tc_i0 | plus: 1 -%}
        {%- assign _tc_i2   = _tc_i0 | plus: 2 -%}
        {%- assign _tc_date = _tc_lines[_tc_i0] | strip -%}
        {%- assign _tc_head = _tc_lines[_tc_i1] | strip -%}
        {%- assign _tc_body = _tc_lines[_tc_i2] | strip -%}
        {%- if _tc_date == blank -%}{%- break -%}{%- endif -%}
        {%- assign _tc_card_idx = _tc_card_idx | plus: 1 -%}
        <div class="tl-card{% if _tc_card_idx == 1 %} active{% endif %}" data-idx="{{ forloop.index0 }}">
          <div class="tl-year">{{ _tc_date }}</div>
          <div class="tl-rule"></div>
          {%- if _tc_head != blank -%}<p class="tl-h">{{ _tc_head }}</p>{%- endif -%}
          {%- if _tc_body != blank -%}<p class="tl-p">{{ _tc_body }}</p>{%- endif -%}
        </div>
      {%- endfor -%}

    </div>

    <div class="tl-foot" style="padding: 0 3rem;" id="tl-foot-{{ _tc_id }}">
      <span class="tl-num" id="tl-num-{{ _tc_id }}">01 / {{ _tc_total | prepend: '0' | slice: -2, 2 }}</span>
      {%- for _i in (0..4) -%}
        {%- if _i < _tc_total -%}
          <div class="tl-dot{% if _i == 0 %} active{% endif %}" data-i="{{ _i }}"></div>
        {%- endif -%}
      {%- endfor -%}
      <span class="tl-hint" id="tl-hint-{{ _tc_id }}">Scroll to continue</span>
    </div>

  </div>
</div>

<script>
(function(){
  var eid   = '{{ _tc_id }}';
  var outer = document.getElementById('tl-outer-' + eid);
  var bar   = document.getElementById('tl-bar-'   + eid);
  var numEl = document.getElementById('tl-num-'   + eid);
  var hint  = document.getElementById('tl-hint-'  + eid);
  var cards = outer.querySelectorAll('.tl-card');
  var dots  = outer.querySelectorAll('.tl-dot');
  var N     = cards.length;
  if (!outer || N === 0) return;

  var shown = -1; /* which card is currently active */

  /* smoothstep easing */
  function ease(t){ return t*t*(3-2*t); }

  function fmt(n){ return (n < 10 ? '0' : '') + n; }

  function goTo(idx, instant) {
    if (idx === shown) return;
    shown = idx;

    cards.forEach(function(c, i) {
      var active = i === idx;
      if (instant) {
        c.style.transition = 'none';
        c.style.opacity    = active ? '1' : '0';
        c.style.transform  = active ? 'translateY(0)' : (i < idx ? 'translateY(-22px)' : 'translateY(22px)');
      } else {
        c.style.transition = 'opacity .55s cubic-bezier(.16,1,.3,1), transform .55s cubic-bezier(.16,1,.3,1)';
        c.style.opacity    = active ? '1' : '0';
        c.style.transform  = active ? 'translateY(0)' : (i < idx ? 'translateY(-22px)' : 'translateY(22px)');
      }
      c.classList.toggle('active', active);
    });

    dots.forEach(function(d, i){ d.classList.toggle('active', i === idx); });

    if (numEl) numEl.textContent = fmt(idx + 1) + ' / ' + fmt(N);
    if (hint)  hint.textContent  = idx < N - 1 ? 'Scroll to continue' : '↓ Continue reading';
    if (bar)   bar.style.width   = ((idx / (N - 1)) * 100) + '%';
  }

  function onScroll() {
    var rect    = outer.getBoundingClientRect();
    var scrolled = -rect.top;                        /* px scrolled past outer top */
    var range    = rect.height - window.innerHeight; /* total scrollable within outer */
    var progress = Math.max(0, Math.min(1, scrolled / range));
    var idx      = Math.min(N - 1, Math.floor(progress * N));
    goTo(idx, false);
  }

  /* init */
  goTo(0, true);
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
})();
</script>
