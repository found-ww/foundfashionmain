{% comment %}
  embed-timeline-cards.liquid
  Parses a multi_line_text_field into a horizontal drag timeline.

  Format — groups of 4 lines, up to 5 blocks:
    Line 1: year / caption
    Line 2: headline
    Line 3: body copy
    Line 4: blank (separator)

  Usage: render 'embed-timeline-cards', content: string, id: string
{% endcomment %}

{%- assign _tc_id    = id | default: article.id -%}
{%- assign _tc_lines = content | split: "\n" -%}

{%- assign _tc_total = 0 -%}
{%- for _i in (0..4) -%}
  {%- assign _tc_i0    = _i | times: 4 -%}
  {%- assign _tc_check = _tc_lines[_tc_i0] | strip | remove: "\r" -%}
  {%- if _tc_check != blank -%}{%- assign _tc_total = _tc_total | plus: 1 -%}{%- endif -%}
{%- endfor -%}

{%- if _tc_total == 0 -%}{%- break -%}{%- endif -%}

<style>
#tc-{{ _tc_id }} {
  display: flex;
  flex-direction: column;
  height: 460px;
  overflow: hidden;
  border: .5px solid rgba(128,111,100,.15);
  border-radius: 4px;
  margin: 3rem 0;
  font-family: 'Jost', -apple-system, sans-serif;
}
#tc-{{ _tc_id }} .tl-prog { height: 1px; background: rgba(128,111,100,.15); flex-shrink: 0; position: relative; }
#tc-{{ _tc_id }} .tl-prog-fill { position: absolute; top: 0; left: 0; height: 100%; width: 0; background: rgb(128,111,100); }
#tc-{{ _tc_id }} .tl-wrap { flex: 1; overflow: hidden; cursor: grab; position: relative; }
#tc-{{ _tc_id }} .tl-wrap:active { cursor: grabbing; }
#tc-{{ _tc_id }} .tl-track { display: flex !important; height: 100%; width: max-content; user-select: none; }
#tc-{{ _tc_id }} .tl-card {
  flex-shrink: 0;
  width: clamp(280px, 32vw, 420px);
  height: 100%;
  border-right: .5px solid rgba(128,111,100,.15);
  padding: 3rem !important;
  display: flex !important;
  flex-direction: column !important;
  justify-content: flex-end !important;
  gap: 1rem !important;
  background: #fff !important;
  transition: background .35s;
  position: relative;
  overflow: hidden;
  margin: 0 !important;
}
#tc-{{ _tc_id }} .tl-card:hover { background: rgb(245,243,239) !important; }
#tc-{{ _tc_id }} .tl-num {
  position: absolute; top: 2.5rem; right: 2.5rem;
  font-size: 9px !important; letter-spacing: .22em; text-transform: uppercase;
  color: rgb(128,111,100); opacity: .35;
  font-family: 'Jost', sans-serif !important;
  margin: 0 !important; padding: 0 !important;
}
#tc-{{ _tc_id }} .tl-date {
  font-family: 'Cormorant Garamond', Georgia, serif !important;
  font-size: clamp(28px, 4vw, 42px) !important;
  font-weight: 300 !important; font-style: italic !important;
  color: rgb(128,111,100) !important;
  line-height: 1 !important;
  transition: letter-spacing .4s cubic-bezier(.16,1,.3,1);
  margin: 0 !important; padding: 0 !important;
}
#tc-{{ _tc_id }} .tl-card:hover .tl-date { letter-spacing: .03em; }
#tc-{{ _tc_id }} .tl-rule {
  width: 28px; height: .5px;
  background: rgba(128,111,100,.2);
  transition: width .4s cubic-bezier(.16,1,.3,1), background .3s;
  flex-shrink: 0;
}
#tc-{{ _tc_id }} .tl-card:hover .tl-rule { width: 50px; background: rgb(128,111,100); }
#tc-{{ _tc_id }} .tl-h {
  font-family: 'Cormorant Garamond', Georgia, serif !important;
  font-size: clamp(18px, 2.2vw, 24px) !important;
  font-weight: 300 !important; font-style: italic !important;
  color: rgb(18,16,14) !important;
  line-height: 1.15 !important;
  transition: transform .45s cubic-bezier(.16,1,.3,1), color .3s;
  margin: 0 !important; padding: 0 !important;
  text-transform: none !important; letter-spacing: normal !important;
}
#tc-{{ _tc_id }} .tl-card:hover .tl-h { transform: translateX(7px); color: rgb(128,111,100) !important; }
#tc-{{ _tc_id }} .tl-p {
  font-size: 12px !important;
  line-height: 1.78 !important;
  color: rgb(148,123,105) !important;
  font-family: 'Jost', sans-serif !important;
  margin: 0 !important; padding: 0 !important;
  font-style: normal !important; font-weight: 400 !important;
}
#tc-{{ _tc_id }} .tl-card::after {
  content: ''; position: absolute;
  bottom: 0; left: 0; right: 0; height: 1px;
  background: rgb(128,111,100);
  transform: scaleX(0); transform-origin: left;
  transition: transform .5s cubic-bezier(.16,1,.3,1);
}
#tc-{{ _tc_id }} .tl-card:hover::after { transform: scaleX(1); }
#tc-{{ _tc_id }} .tl-foot {
  height: 38px; border-top: .5px solid rgba(128,111,100,.15); flex-shrink: 0;
  display: flex; align-items: center; gap: 1.25rem; padding: 0 2.5rem;
}
#tc-{{ _tc_id }} .tl-dot {
  width: 5px; height: 5px; border-radius: 50%;
  background: rgba(128,111,100,.2);
  cursor: pointer; transition: background .2s, transform .2s; flex-shrink: 0;
}
#tc-{{ _tc_id }} .tl-dot.active,
#tc-{{ _tc_id }} .tl-dot:hover { background: rgb(128,111,100); transform: scale(1.5); }
#tc-{{ _tc_id }} .tl-hint {
  margin-left: auto; font-size: 9px; letter-spacing: .18em;
  text-transform: uppercase; color: rgb(128,111,100); opacity: .3;
}
@media screen and (max-width: 640px) {
  #tc-{{ _tc_id }} { height: auto; }
  #tc-{{ _tc_id }} .tl-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; height: 380px; }
  #tc-{{ _tc_id }} .tl-card { width: 84vw; padding: 2.5rem 2rem !important; }
}
</style>

<div id="tc-{{ _tc_id }}">

  <div class="tl-prog"><div class="tl-prog-fill" id="tl-pf-{{ _tc_id }}"></div></div>

  <div class="tl-wrap" id="tl-tw-{{ _tc_id }}">
    <div class="tl-track" id="tl-track-{{ _tc_id }}">

      {%- assign _tc_card_idx = 0 -%}
      {%- for _i in (0..4) -%}
        {%- assign _tc_i0   = _i | times: 4 -%}
        {%- assign _tc_i1   = _tc_i0 | plus: 1 -%}
        {%- assign _tc_i2   = _tc_i0 | plus: 2 -%}
        {%- assign _tc_date = _tc_lines[_tc_i0] | strip | remove: "\r" -%}
        {%- assign _tc_head = _tc_lines[_tc_i1] | strip | remove: "\r" -%}
        {%- assign _tc_body = _tc_lines[_tc_i2] | strip | remove: "\r" -%}
        {%- if _tc_date == blank -%}{%- break -%}{%- endif -%}
        {%- assign _tc_card_idx = _tc_card_idx | plus: 1 -%}
        {%- assign _tc_num   = _tc_card_idx | prepend: '0' | slice: -2, 2 -%}
        {%- assign _tc_tot_s = _tc_total    | prepend: '0' | slice: -2, 2 -%}
        <div class="tl-card">
          <span class="tl-num">{{ _tc_num }} / {{ _tc_tot_s }}</span>
          <div class="tl-date">{{ _tc_date }}</div>
          <div class="tl-rule"></div>
          {%- if _tc_head != blank -%}<p class="tl-h">{{ _tc_head }}</p>{%- endif -%}
          {%- if _tc_body != blank -%}<p class="tl-p">{{ _tc_body }}</p>{%- endif -%}
        </div>
      {%- endfor -%}

    </div>
  </div>

  <div class="tl-foot">
    {%- for _i in (0..4) -%}
      {%- if _i < _tc_total -%}
        <div class="tl-dot{% if _i == 0 %} active{% endif %}" data-i="{{ _i }}"></div>
      {%- endif -%}
    {%- endfor -%}
    <span class="tl-hint">Drag to explore</span>
  </div>

</div>

<script>
(function(){
  var id    = 'tc-{{ _tc_id }}';
  var root  = document.getElementById(id);
  var tw    = document.getElementById('tl-tw-'    + '{{ _tc_id }}');
  var track = document.getElementById('tl-track-' + '{{ _tc_id }}');
  var pf    = document.getElementById('tl-pf-'   + '{{ _tc_id }}');
  if (!tw || !track) return;

  var dots  = root.querySelectorAll('.tl-dot');
  var cards = track.querySelectorAll('.tl-card');
  var isDragging = false, startX = 0, tx = 0, animTx = 0, raf;

  function lerp(a, b, n) { return a + (b - a) * n; }
  function maxTx() { return -(track.scrollWidth - tw.clientWidth); }
  function clamp(v) { return Math.max(maxTx(), Math.min(0, v)); }

  function render() {
    track.style.transform = 'translateX(' + animTx + 'px)';
    var max = -maxTx();
    pf.style.width = (max > 0 ? Math.min(100, (-animTx / max) * 100) : 0) + '%';
    var cw  = cards[0] ? cards[0].offsetWidth : 1;
    var idx = Math.round(-animTx / cw);
    dots.forEach(function(d, i) { d.classList.toggle('active', i === idx); });
  }

  function loop() {
    animTx = lerp(animTx, tx, .1);
    if (Math.abs(animTx - tx) > 0.1) { render(); raf = requestAnimationFrame(loop); }
    else { animTx = tx; render(); }
  }

  tw.addEventListener('mousedown', function(e) {
    isDragging = true; startX = e.pageX; cancelAnimationFrame(raf);
  });
  window.addEventListener('mousemove', function(e) {
    if (!isDragging) return;
    tx = clamp(tx + (e.pageX - startX)); startX = e.pageX; render();
  });
  window.addEventListener('mouseup', function() { isDragging = false; });

  tw.addEventListener('touchstart', function(e) {
    startX = e.touches[0].pageX; cancelAnimationFrame(raf);
  }, { passive: true });
  tw.addEventListener('touchmove', function(e) {
    tx = clamp(tx + (e.touches[0].pageX - startX)); startX = e.touches[0].pageX; render();
  }, { passive: true });

  dots.forEach(function(d) {
    d.addEventListener('click', function() {
      tx = clamp(-(cards[0] ? cards[0].offsetWidth * parseInt(d.dataset.i) : 0));
      cancelAnimationFrame(raf); raf = requestAnimationFrame(loop);
    });
  });

  window.addEventListener('resize', function() { tx = clamp(tx); render(); });
  render();
})();
</script>
