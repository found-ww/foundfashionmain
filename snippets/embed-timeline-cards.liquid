{% comment %}
  embed-timeline-cards.liquid
  Apple-style scroll-lock timeline. Sticky black panel advances cards as user scrolls.
  Format: groups of 3 lines (year / headline / body), up to 5 blocks. No blank lines needed.
{% endcomment %}

{%- assign _tc_id    = id | default: article.id -%}
{%- assign _tc_lines = content | newline_to_br | split: '<br />' -%}

{%- assign _tc_total = 0 -%}
{%- for _i in (0..4) -%}
  {%- assign _tc_i0    = _i | times: 3 -%}
  {%- assign _tc_check = _tc_lines[_tc_i0] | strip -%}
  {%- if _tc_check != blank -%}{%- assign _tc_total = _tc_total | plus: 1 -%}{%- endif -%}
{%- endfor -%}

{%- if _tc_total == 0 -%}{%- break -%}{%- endif -%}

<style>
/* ── Sentinel ── */
#tl-sentinel-{{ _tc_id }} {
  position: relative;
}

/* ── Sticky panel — full viewport, black ── */
#tl-sentinel-{{ _tc_id }} .tl-sticky {
  position: sticky !important;
  top: 0 !important;
  height: 100vh !important;
  background: #000 !important;
  overflow: hidden !important;
  display: flex !important;
  flex-direction: column !important;
}

/* ── Progress bar ── */
#tl-sentinel-{{ _tc_id }} .tl-prog {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1px;
  background: rgba(255,255,255,.08);
  z-index: 10;
}
#tl-sentinel-{{ _tc_id }} .tl-prog-fill {
  position: absolute;
  top: 0; left: 0;
  height: 100%; width: 0;
  background: rgb(128,111,100);
  transition: width .5s cubic-bezier(.16,1,.3,1);
}

/* ── Card track ── */
#tl-sentinel-{{ _tc_id }} .tl-track {
  flex: 1 !important;
  position: relative !important;
}

/* ── Single card — stacked, centred ── */
#tl-sentinel-{{ _tc_id }} .tl-card {
  position: absolute !important;
  inset: 0 !important;
  top: 0 !important; right: 0 !important; bottom: 0 !important; left: 0 !important;
  display: flex !important;
  flex-direction: column !important;
  align-items: center !important;
  justify-content: center !important;
  padding: 6rem 2rem 5rem !important;
  text-align: center !important;
  pointer-events: none !important;
  margin: 0 !important;
  background: transparent !important;
}

/* ── Eyebrow ── */
#tl-sentinel-{{ _tc_id }} .tl-eyebrow {
  display: block !important;
  font-family: 'Jost', -apple-system, sans-serif !important;
  font-size: clamp(11px, 1.1vw, 13px) !important;
  font-weight: 400 !important;
  font-style: normal !important;
  letter-spacing: .12em !important;
  text-transform: uppercase !important;
  color: rgb(128,111,100) !important;
  margin: 0 0 1.5rem 0 !important;
  padding: 0 !important;
  opacity: 0;
  transform: translateY(10px);
  transition: opacity .6s, transform .6s cubic-bezier(.16,1,.3,1);
}

/* ── Year ── */
#tl-sentinel-{{ _tc_id }} .tl-year {
  display: block !important;
  font-family: 'Jost', -apple-system, sans-serif !important;
  font-size: clamp(72px, 13vw, 160px) !important;
  font-weight: 700 !important;
  font-style: normal !important;
  color: #fff !important;
  line-height: .88 !important;
  letter-spacing: -.04em !important;
  margin: 0 0 2.5rem 0 !important;
  padding: 0 !important;
  opacity: 0;
  transform: translateY(16px);
  transition: opacity .65s .08s, transform .65s .08s cubic-bezier(.16,1,.3,1);
}

/* ── Headline ── */
#tl-sentinel-{{ _tc_id }} .tl-h {
  font-family: 'Jost', -apple-system, sans-serif !important;
  font-size: clamp(22px, 3.5vw, 44px) !important;
  font-weight: 600 !important;
  font-style: normal !important;
  color: #f5f5f7 !important;
  line-height: 1.08 !important;
  letter-spacing: -.02em !important;
  text-transform: none !important;
  max-width: 760px;
  margin: 0 0 1.75rem 0 !important;
  padding: 0 !important;
  opacity: 0;
  transform: translateY(16px);
  transition: opacity .65s .18s, transform .65s .18s cubic-bezier(.16,1,.3,1);
}

/* ── Body ── */
#tl-sentinel-{{ _tc_id }} .tl-p {
  font-family: 'Jost', -apple-system, sans-serif !important;
  font-size: clamp(14px, 1.5vw, 17px) !important;
  font-weight: 300 !important;
  font-style: normal !important;
  color: rgba(255,255,255,.45) !important;
  line-height: 1.7 !important;
  max-width: 560px;
  letter-spacing: -.01em !important;
  margin: 0 !important;
  padding: 0 !important;
  opacity: 0;
  transform: translateY(12px);
  transition: opacity .65s .28s, transform .65s .28s cubic-bezier(.16,1,.3,1);
}

/* ── Active: reveal all elements ── */
#tl-sentinel-{{ _tc_id }} .tl-card.active .tl-eyebrow {
  opacity: .7;
  transform: translateY(0);
}
#tl-sentinel-{{ _tc_id }} .tl-card.active .tl-year,
#tl-sentinel-{{ _tc_id }} .tl-card.active .tl-h {
  opacity: 1;
  transform: translateY(0);
}
#tl-sentinel-{{ _tc_id }} .tl-card.active .tl-p {
  opacity: 1;
  transform: translateY(0);
}

/* ── Exiting: fade up and out ── */
#tl-sentinel-{{ _tc_id }} .tl-card.exiting .tl-eyebrow,
#tl-sentinel-{{ _tc_id }} .tl-card.exiting .tl-year,
#tl-sentinel-{{ _tc_id }} .tl-card.exiting .tl-h,
#tl-sentinel-{{ _tc_id }} .tl-card.exiting .tl-p {
  opacity: 0;
  transform: translateY(-14px);
  transition: opacity .4s, transform .4s cubic-bezier(.4,0,1,1);
}

/* ── Dots counter — bottom centre ── */
#tl-sentinel-{{ _tc_id }} .tl-counter {
  position: absolute;
  bottom: 2.5rem;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  gap: 8px;
  z-index: 10;
}
#tl-sentinel-{{ _tc_id }} .tl-step {
  width: 5px; height: 5px;
  border-radius: 50%;
  background: rgba(255,255,255,.2);
  cursor: pointer;
  pointer-events: all;
  transition: background .3s, transform .3s;
  flex-shrink: 0;
}
#tl-sentinel-{{ _tc_id }} .tl-step.active {
  background: #fff;
  transform: scale(1.35);
}

/* ── Scroll hint — bottom right ── */
#tl-sentinel-{{ _tc_id }} .tl-hint {
  position: absolute;
  right: 2.5rem; bottom: 2.5rem;
  z-index: 10;
  font-family: 'Jost', -apple-system, sans-serif !important;
  font-size: 10px !important;
  font-style: normal !important;
  letter-spacing: .16em;
  text-transform: uppercase;
  color: rgba(255,255,255,.15);
  transition: color .4s;
  margin: 0 !important; padding: 0 !important;
}
#tl-sentinel-{{ _tc_id }} .tl-hint.last { color: rgba(255,255,255,.35); }

/* ── Mobile ── */
@media (max-width: 640px) {
  #tl-sentinel-{{ _tc_id }} .tl-year { font-size: clamp(56px, 18vw, 88px) !important; }
  #tl-sentinel-{{ _tc_id }} .tl-hint { display: none; }
  #tl-sentinel-{{ _tc_id }} .tl-card { padding: 5rem 1.5rem 6rem !important; }
}
</style>

<div id="tl-sentinel-{{ _tc_id }}" data-n="{{ _tc_total }}">
  <div class="tl-sticky">

    <div class="tl-prog">
      <div class="tl-prog-fill" id="tl-pf-{{ _tc_id }}"></div>
    </div>

    <div class="tl-track" id="tl-track-{{ _tc_id }}">

      {%- assign _tc_card_idx = 0 -%}
      {%- for _i in (0..4) -%}
        {%- assign _tc_i0   = _i | times: 3 -%}
        {%- assign _tc_i1   = _tc_i0 | plus: 1 -%}
        {%- assign _tc_i2   = _tc_i0 | plus: 2 -%}
        {%- assign _tc_date = _tc_lines[_tc_i0] | strip -%}
        {%- assign _tc_head = _tc_lines[_tc_i1] | strip -%}
        {%- assign _tc_body = _tc_lines[_tc_i2] | strip -%}
        {%- if _tc_date == blank -%}{%- break -%}{%- endif -%}
        {%- assign _tc_card_idx = _tc_card_idx | plus: 1 -%}
        {%- assign _tc_num = _tc_card_idx | prepend: '0' | slice: -2, 2 -%}
        {%- assign _tc_tot = _tc_total  | prepend: '0' | slice: -2, 2 -%}
        <div class="tl-card" data-index="{{ forloop.index0 }}">
          <span class="tl-eyebrow">{{ _tc_num }} of {{ _tc_tot }}</span>
          <div class="tl-year">{{ _tc_date }}</div>
          {%- if _tc_head != blank -%}<p class="tl-h">{{ _tc_head }}</p>{%- endif -%}
          {%- if _tc_body != blank -%}<p class="tl-p">{{ _tc_body }}</p>{%- endif -%}
        </div>
      {%- endfor -%}

    </div>

    <div class="tl-counter" id="tl-steps-{{ _tc_id }}">
      {%- for _i in (0..4) -%}
        {%- assign _tc_i0    = _i | times: 3 -%}
        {%- assign _tc_check = _tc_lines[_tc_i0] | strip -%}
        {%- if _tc_check == blank -%}{%- break -%}{%- endif -%}
        <div class="tl-step{% if forloop.first %} active{% endif %}" data-i="{{ forloop.index0 }}"></div>
      {%- endfor -%}
    </div>

    <span class="tl-hint" id="tl-hint-{{ _tc_id }}">Scroll to advance</span>

  </div>
</div>

<script>
(function(){
  var eid      = '{{ _tc_id }}';
  var N        = {{ _tc_total }};
  var sentinel = document.getElementById('tl-sentinel-' + eid);
  var cards    = sentinel ? sentinel.querySelectorAll('.tl-card') : [];
  var steps    = sentinel ? sentinel.querySelectorAll('.tl-step') : [];
  var progFill = document.getElementById('tl-pf-'  + eid);
  var hint     = document.getElementById('tl-hint-' + eid);
  if (!sentinel || cards.length === 0) return;

  var cur = 0;

  function setH() {
    sentinel.style.height = (window.innerHeight * (N + 0.5)) + 'px';
  }
  setH();
  window.addEventListener('resize', setH);

  function goTo(idx) {
    if (idx === cur) return;
    var prev = cur;
    cur = idx;

    cards[prev].classList.remove('active');
    cards[prev].classList.add('exiting');
    (function(p){ setTimeout(function(){ cards[p].classList.remove('exiting'); }, 400); })(prev);

    cards[cur].classList.add('active');

    if (progFill) progFill.style.width = (N > 1 ? (cur / (N - 1) * 100) : 0) + '%';
    steps.forEach(function(s, i){ s.classList.toggle('active', i === cur); });
    if (hint) {
      hint.classList.toggle('last', cur === N - 1);
      hint.textContent = cur === N - 1 ? 'Scroll to continue' : 'Scroll to advance';
    }
  }

  cards[0].classList.add('active');

  function onScroll() {
    var rect = sentinel.getBoundingClientRect();
    if (rect.top > 0 || rect.bottom < window.innerHeight) return;
    var scrolled = -rect.top;
    var total    = sentinel.offsetHeight - window.innerHeight;
    var idx      = Math.round((scrolled / total) * (N - 1));
    idx = Math.max(0, Math.min(N - 1, idx));
    if (idx !== cur) goTo(idx);
  }
  window.addEventListener('scroll', onScroll, { passive: true });

  /* Wheel intercept — prevent page scroll while inside timeline */
  var wheelBuf = 0, wheelTimer;
  window.addEventListener('wheel', function(e) {
    var rect = sentinel.getBoundingClientRect();
    if (rect.top > 0 || rect.bottom < window.innerHeight) return;
    if (cur === 0     && e.deltaY < 0) return;
    if (cur === N - 1 && e.deltaY > 0) return;
    e.preventDefault();
    wheelBuf += e.deltaY;
    clearTimeout(wheelTimer);
    wheelTimer = setTimeout(function(){ wheelBuf = 0; }, 300);
    if (wheelBuf > 80) {
      wheelBuf = 0;
      var next = cur + 1;
      goTo(next);
      window.scrollTo({ top: sentinel.offsetTop + (sentinel.offsetHeight - window.innerHeight) * (next / (N - 1)), behavior: 'instant' });
    } else if (wheelBuf < -80) {
      wheelBuf = 0;
      var prev2 = cur - 1;
      goTo(prev2);
      window.scrollTo({ top: sentinel.offsetTop + (sentinel.offsetHeight - window.innerHeight) * (prev2 / (N - 1)), behavior: 'instant' });
    }
  }, { passive: false });

  /* Touch */
  var tY = 0, tDone = false;
  window.addEventListener('touchstart', function(e){ tY = e.touches[0].clientY; tDone = false; }, { passive: true });
  window.addEventListener('touchmove', function(e) {
    var rect = sentinel.getBoundingClientRect();
    if (rect.top > 0 || rect.bottom < window.innerHeight) return;
    var dy = tY - e.touches[0].clientY;
    if (cur === 0     && dy < 0) return;
    if (cur === N - 1 && dy > 0) return;
    if (Math.abs(dy) > 40 && !tDone) {
      tDone = true;
      e.preventDefault();
      var ni = dy > 0 ? cur + 1 : cur - 1;
      goTo(ni);
      window.scrollTo({ top: sentinel.offsetTop + (sentinel.offsetHeight - window.innerHeight) * (ni / (N - 1)), behavior: 'instant' });
    }
  }, { passive: false });

  /* Dot clicks */
  steps.forEach(function(s) {
    s.addEventListener('click', function() {
      var i = parseInt(s.dataset.i);
      window.scrollTo({ top: sentinel.offsetTop + (sentinel.offsetHeight - window.innerHeight) * (i / (N - 1)), behavior: 'smooth' });
      setTimeout(function(){ goTo(i); }, 100);
    });
  });

})();
</script>
