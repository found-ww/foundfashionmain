{% comment %}
  embed-timeline-cards.liquid
  Option 2: sticky year left column, flowing events right column.
  Format: groups of 3 lines (year / headline / body), up to 8 blocks. No blank lines needed.
{% endcomment %}

{%- assign _tc_id    = id | default: article.id -%}
{%- assign _tc_lines = content | newline_to_br | split: '<br />' -%}

{%- assign _tc_total = 0 -%}
{%- for _i in (0..7) -%}
  {%- assign _tc_i0    = _i | times: 3 -%}
  {%- assign _tc_check = _tc_lines[_tc_i0] | strip -%}
  {%- if _tc_check != blank -%}{%- assign _tc_total = _tc_total | plus: 1 -%}{%- endif -%}
{%- endfor -%}

{%- if _tc_total == 0 -%}{%- break -%}{%- endif -%}

{%- assign _tc_first_year = _tc_lines[0] | strip -%}

<div class="tl-v-outer" id="tl-v-{{ _tc_id }}">
  <div class="tl-v-grid">

    <div class="tl-v-left">
      <div class="tl-v-year" id="tl-v-year-{{ _tc_id }}">{{ _tc_first_year }}</div>
    </div>

    <div class="tl-v-right">
      {%- for _i in (0..7) -%}
        {%- assign _tc_i0   = _i | times: 3 -%}
        {%- assign _tc_i1   = _tc_i0 | plus: 1 -%}
        {%- assign _tc_i2   = _tc_i0 | plus: 2 -%}
        {%- assign _tc_date = _tc_lines[_tc_i0] | strip -%}
        {%- assign _tc_head = _tc_lines[_tc_i1] | strip -%}
        {%- assign _tc_body = _tc_lines[_tc_i2] | strip -%}
        {%- if _tc_date == blank -%}{%- break -%}{%- endif -%}
        <div class="tl-v-entry" data-tl-year="{{ _tc_date }}">
          {%- if _tc_head != blank -%}<p class="tl-v-h">{{ _tc_head }}</p>{%- endif -%}
          {%- if _tc_body != blank -%}<p class="tl-v-p">{{ _tc_body }}</p>{%- endif -%}
        </div>
      {%- endfor -%}
    </div>

  </div>

  <script>
  (function() {
    var yearEl  = document.getElementById('tl-v-year-{{ _tc_id }}');
    var outer   = document.getElementById('tl-v-{{ _tc_id }}');
    if (!yearEl || !outer) return;

    var entries = outer.querySelectorAll('.tl-v-entry');
    if (!entries.length) return;

    var current = yearEl.textContent.trim();

    function setYear(y) {
      if (y === current) return;
      current = y;
      yearEl.classList.add('tl-v-year--fade');
      setTimeout(function() {
        yearEl.textContent = y;
        yearEl.classList.remove('tl-v-year--fade');
      }, 220);
    }

    var io = new IntersectionObserver(function(obs) {
      obs.forEach(function(e) {
        if (e.isIntersecting) setYear(e.target.dataset.tlYear);
      });
    }, { rootMargin: '-5% 0px -55% 0px', threshold: 0 });

    entries.forEach(function(el) { io.observe(el); });
  })();
  </script>

</div>
