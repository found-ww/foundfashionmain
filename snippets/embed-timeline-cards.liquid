{% comment %}
  embed-timeline-cards.liquid
  Format: groups of 3 lines (year / headline / body), up to 5 blocks. No blank lines needed.
{% endcomment %}

{%- assign _tc_id    = id | default: article.id -%}
{%- assign _tc_lines = content | newline_to_br | split: '<br />' -%}

{%- assign _tc_total = 0 -%}
{%- for _i in (0..4) -%}
  {%- assign _tc_i0    = _i | times: 3 -%}
  {%- assign _tc_check = _tc_lines[_tc_i0] | strip -%}
  {%- if _tc_check != blank -%}{%- assign _tc_total = _tc_total | plus: 1 -%}{%- endif -%}
{%- endfor -%}

{%- if _tc_total == 0 -%}{%- break -%}{%- endif -%}

<style>
#tc-{{ _tc_id }} {
  box-sizing: border-box;
  display: flex !important;
  flex-direction: column !important;
  height: 460px;
  overflow: hidden !important;
  border: .5px solid rgba(0,0,0,.1);
  border-radius: 2px;
  margin: 3rem 0;
}
#tc-{{ _tc_id }} * { box-sizing: border-box; }

/* progress */
#tc-{{ _tc_id }} .tl-prog { height: 1px; background: rgba(0,0,0,.07); flex-shrink: 0; position: relative; }
#tc-{{ _tc_id }} .tl-pf   { position: absolute; top: 0; left: 0; height: 100%; width: 0; background: #888; }

/* card */
#tc-{{ _tc_id }} .tl-card {
  flex-shrink: 0 !important;
  width: clamp(280px, 32vw, 400px) !important;
  height: 100% !important;
  border-right: .5px solid rgba(0,0,0,.07) !important;
  display: flex !important;
  flex-direction: column !important;
  justify-content: flex-end !important;
  gap: .9rem !important;
  background: #fff !important;
  position: relative !important;
  overflow: hidden !important;
  margin: 0 !important;
  padding: 2.5rem !important;
}

/* card number */
#tc-{{ _tc_id }} .tl-num {
  position: absolute !important; top: 2rem; right: 2rem;
  font-size: 9px !important; letter-spacing: .2em; text-transform: uppercase;
  color: #bbb; margin: 0 !important; padding: 0 !important; font-style: normal !important;
  font-family: 'Jost', sans-serif !important;
}

/* year */
#tc-{{ _tc_id }} .tl-date {
  font-family: 'Cormorant Garamond', Georgia, serif !important;
  font-size: clamp(26px, 3.5vw, 40px) !important;
  font-weight: 300 !important; font-style: italic !important;
  color: #bbb !important; line-height: 1 !important;
  margin: 0 !important; padding: 0 !important;
  transition: color .35s;
}
#tc-{{ _tc_id }} .tl-card:hover .tl-date { color: #999 !important; }

/* rule */
#tc-{{ _tc_id }} .tl-rule {
  width: 24px !important; height: 1px !important;
  background: rgba(0,0,0,.1); flex-shrink: 0;
  transition: width .4s cubic-bezier(.16,1,.3,1), background .3s;
  margin: 0 !important; padding: 0 !important;
}
#tc-{{ _tc_id }} .tl-card:hover .tl-rule { width: 44px !important; background: #aaa; }

/* headline */
#tc-{{ _tc_id }} .tl-h {
  font-family: 'Cormorant Garamond', Georgia, serif !important;
  font-size: clamp(17px, 2vw, 22px) !important;
  font-weight: 300 !important; font-style: italic !important;
  color: #2a2a2a !important; line-height: 1.2 !important;
  margin: 0 !important; padding: 0 !important;
  text-transform: none !important; letter-spacing: normal !important;
  transition: transform .45s cubic-bezier(.16,1,.3,1);
}
#tc-{{ _tc_id }} .tl-card:hover .tl-h { transform: translateX(5px); }

/* body */
#tc-{{ _tc_id }} .tl-p {
  font-size: 12px !important; line-height: 1.75 !important;
  color: #aaa !important; font-family: 'Jost', sans-serif !important;
  font-style: normal !important; font-weight: 400 !important;
  margin: 0 !important; padding: 0 !important;
}

/* bottom sweep */
#tc-{{ _tc_id }} .tl-card::after {
  content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 1px;
  background: #ccc; transform: scaleX(0); transform-origin: left;
  transition: transform .5s cubic-bezier(.16,1,.3,1);
}
#tc-{{ _tc_id }} .tl-card:hover::after { transform: scaleX(1); }

/* footer */
#tc-{{ _tc_id }} .tl-foot {
  height: 36px; border-top: .5px solid rgba(0,0,0,.07); flex-shrink: 0;
  display: flex !important; align-items: center; gap: 1rem; padding: 0 2rem;
}
#tc-{{ _tc_id }} .tl-dot {
  width: 5px !important; height: 5px !important; border-radius: 50%;
  background: rgba(0,0,0,.12); cursor: pointer;
  transition: background .2s, transform .2s;
  flex-shrink: 0; padding: 0 !important; margin: 0 !important;
}
#tc-{{ _tc_id }} .tl-dot.active,
#tc-{{ _tc_id }} .tl-dot:hover { background: #666 !important; transform: scale(1.5); }
#tc-{{ _tc_id }} .tl-hint {
  margin-left: auto !important; font-size: 9px !important;
  letter-spacing: .16em; text-transform: uppercase; color: #bbb;
  font-family: 'Jost', sans-serif !important;
}

@media (max-width: 640px) {
  #tc-{{ _tc_id }} { height: 400px; }
  #tc-{{ _tc_id }} .tl-card { width: 82vw !important; padding: 2rem 1.75rem !important; }
}
</style>

<div id="tc-{{ _tc_id }}">

  <div class="tl-prog"><div class="tl-pf" id="tl-pf-{{ _tc_id }}"></div></div>

  <div class="tl-inner" id="tl-tw-{{ _tc_id }}"
    style="flex:1;overflow:hidden;cursor:grab;position:relative;-webkit-user-select:none;user-select:none;">
    <div id="tl-track-{{ _tc_id }}"
      style="display:flex;height:100%;width:max-content;will-change:transform;">

      {%- assign _tc_card_idx = 0 -%}
      {%- for _i in (0..4) -%}
        {%- assign _tc_i0   = _i | times: 3 -%}
        {%- assign _tc_i1   = _tc_i0 | plus: 1 -%}
        {%- assign _tc_i2   = _tc_i0 | plus: 2 -%}
        {%- assign _tc_date = _tc_lines[_tc_i0] | strip -%}
        {%- assign _tc_head = _tc_lines[_tc_i1] | strip -%}
        {%- assign _tc_body = _tc_lines[_tc_i2] | strip -%}
        {%- if _tc_date == blank -%}{%- break -%}{%- endif -%}
        {%- assign _tc_card_idx = _tc_card_idx | plus: 1 -%}
        {%- assign _tc_num   = _tc_card_idx | prepend: '0' | slice: -2, 2 -%}
        {%- assign _tc_tot_s = _tc_total    | prepend: '0' | slice: -2, 2 -%}
        <div class="tl-card">
          <span class="tl-num">{{ _tc_num }} / {{ _tc_tot_s }}</span>
          <div class="tl-date">{{ _tc_date }}</div>
          <div class="tl-rule"></div>
          {%- if _tc_head != blank -%}<p class="tl-h">{{ _tc_head }}</p>{%- endif -%}
          {%- if _tc_body != blank -%}<p class="tl-p">{{ _tc_body }}</p>{%- endif -%}
        </div>
      {%- endfor -%}

    </div>
  </div>

  <div class="tl-foot">
    {%- for _i in (0..4) -%}
      {%- if _i < _tc_total -%}
        <div class="tl-dot{% if _i == 0 %} active{% endif %}" data-i="{{ _i }}"></div>
      {%- endif -%}
    {%- endfor -%}
    <span class="tl-hint">Drag to explore</span>
  </div>

</div>

<script>
(function(){
  var root  = document.getElementById('tc-{{ _tc_id }}');
  var tw    = document.getElementById('tl-tw-{{ _tc_id }}');
  var track = document.getElementById('tl-track-{{ _tc_id }}');
  var pf    = document.getElementById('tl-pf-{{ _tc_id }}');
  if (!tw || !track) return;

  var dots  = root.querySelectorAll('.tl-dot');
  var cards = track.querySelectorAll('.tl-card');
  var isDragging = false, startX = 0, startY = 0, tx = 0, animTx = 0, raf;

  function lerp(a,b,n){ return a+(b-a)*n; }
  function maxTx(){ return -(track.scrollWidth - tw.clientWidth); }
  function clamp(v){ return Math.max(maxTx(), Math.min(0,v)); }

  function render(){
    track.style.transform = 'translateX('+animTx+'px)';
    var max = -maxTx();
    pf.style.width = (max>0 ? Math.min(100,(-animTx/max)*100) : 0)+'%';
    var cw = cards[0] ? cards[0].offsetWidth : 1;
    var idx = Math.round(-animTx/cw);
    dots.forEach(function(d,i){ d.classList.toggle('active', i===idx); });
  }
  function loop(){
    animTx = lerp(animTx,tx,.1);
    if(Math.abs(animTx-tx)>0.3){ render(); raf=requestAnimationFrame(loop); }
    else{ animTx=tx; render(); }
  }

  /* ── Desktop drag ── */
  tw.addEventListener('mousedown', function(e){
    isDragging=true; startX=e.pageX;
    cancelAnimationFrame(raf);
    e.preventDefault();
  });
  window.addEventListener('mousemove', function(e){
    if(!isDragging) return;
    tx=clamp(tx+(e.pageX-startX)); startX=e.pageX; render();
  });
  window.addEventListener('mouseup', function(){ isDragging=false; });
  tw.addEventListener('dragstart', function(e){ e.preventDefault(); });

  /* ── Touch drag — non-passive so we can lock horizontal swipes ── */
  tw.addEventListener('touchstart', function(e){
    startX=e.touches[0].pageX; startY=e.touches[0].pageY;
    cancelAnimationFrame(raf);
  }, { passive: true });

  tw.addEventListener('touchmove', function(e){
    var dx = e.touches[0].pageX - startX;
    var dy = e.touches[0].pageY - startY;
    if(Math.abs(dx) > Math.abs(dy)){
      e.preventDefault(); /* lock page scroll while swiping horizontally */
      tx=clamp(tx+dx); startX=e.touches[0].pageX; startY=e.touches[0].pageY;
      render();
      cancelAnimationFrame(raf); raf=requestAnimationFrame(loop);
    }
  }, { passive: false });

  /* ── Dot clicks ── */
  dots.forEach(function(d){
    d.addEventListener('click', function(){
      tx=clamp(-(cards[0] ? cards[0].offsetWidth*parseInt(d.dataset.i) : 0));
      cancelAnimationFrame(raf); raf=requestAnimationFrame(loop);
    });
  });

  window.addEventListener('resize', function(){ tx=clamp(tx); render(); });
  render();
})();
</script>
