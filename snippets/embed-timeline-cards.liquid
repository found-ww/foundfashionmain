{% comment %}
  embed-timeline-cards.liquid
  Sticky-scroll timeline. Pins to viewport and advances cards as user scrolls.
  Format: groups of 3 lines (year / headline / body), up to 5 blocks. No blank lines needed.
{% endcomment %}

{%- assign _tc_id    = id | default: article.id -%}
{%- assign _tc_lines = content | newline_to_br | split: '<br />' -%}

{%- assign _tc_total = 0 -%}
{%- for _i in (0..4) -%}
  {%- assign _tc_i0    = _i | times: 3 -%}
  {%- assign _tc_check = _tc_lines[_tc_i0] | strip -%}
  {%- if _tc_check != blank -%}{%- assign _tc_total = _tc_total | plus: 1 -%}{%- endif -%}
{%- endfor -%}

{%- if _tc_total == 0 -%}{%- break -%}{%- endif -%}

<style>
/* ── Outer scroll container — height gives scroll room ── */
.tl-outer-{{ _tc_id }} {
  --n: {{ _tc_total }};
  height: calc((var(--n) - 1) * 110vh + 100vh);
  position: relative;
  width: 100vw;
  margin-left: calc(50% - 50vw);
}

/* ── Sticky panel ── */
.tl-outer-{{ _tc_id }} .tl-sticky {
  position: sticky;
  top: 0;
  height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  overflow: hidden;
  background: #fff;
}

/* ── Top progress bar ── */
.tl-outer-{{ _tc_id }} .tl-bar {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1px;
  background: rgba(0,0,0,.07);
}
.tl-outer-{{ _tc_id }} .tl-bar-fill {
  position: absolute;
  top: 0; left: 0; height: 100%; width: 0;
  background: #222;
  transition: width .05s linear;
}

/* ── Cards container ── */
.tl-outer-{{ _tc_id }} .tl-cards {
  flex: 1;
  overflow: hidden;
  position: relative;
}

/* ── Horizontal track — JS sets translateX ── */
.tl-outer-{{ _tc_id }} .tl-track {
  display: flex !important;
  height: 100%;
  will-change: transform;
}

/* ── Single card — width set by JS to match container ── */
.tl-outer-{{ _tc_id }} .tl-card {
  flex-shrink: 0 !important;
  height: 100%;
  display: flex !important;
  flex-direction: column !important;
  justify-content: center !important;
  align-items: center !important;
  text-align: center !important;
  padding: 0 clamp(2rem, 8vw, 10rem) 4rem !important;
  margin: 0 !important;
  background: transparent !important;
}

/* ── Year — bold, modern ── */
.tl-outer-{{ _tc_id }} .tl-year {
  font-family: 'Jost', -apple-system, sans-serif !important;
  font-size: clamp(72px, 12vw, 140px) !important;
  font-weight: 700 !important;
  font-style: normal !important;
  color: #190d04 !important;
  line-height: 1 !important;
  margin: 0 0 .45em 0 !important;
  padding: 0 !important;
  letter-spacing: -.03em !important;
  user-select: none;
}

/* ── Rule ── */
.tl-outer-{{ _tc_id }} .tl-rule {
  width: 32px !important;
  height: 1px !important;
  background: #d0d0d0;
  margin: 0 0 1.6em 0 !important;
  padding: 0 !important;
  flex-shrink: 0;
  transition: width .6s cubic-bezier(.16,1,.3,1);
}
.tl-outer-{{ _tc_id }} .tl-card.active .tl-rule { width: 64px !important; background: #999; }

/* ── Headline ── */
.tl-outer-{{ _tc_id }} .tl-h {
  font-family: 'Jost', -apple-system, sans-serif !important;
  font-size: clamp(13px, 1.1vw, 15px) !important;
  font-weight: 400 !important;
  font-style: normal !important;
  color: #190d04 !important;
  line-height: 1.5 !important;
  margin: 0 0 1.2em 0 !important;
  padding: 0 !important;
  max-width: 40ch;
  text-transform: uppercase !important;
  letter-spacing: .15em !important;
}

/* ── Body ── */
.tl-outer-{{ _tc_id }} .tl-p {
  font-size: 15px !important;
  line-height: 1.78 !important;
  color: #666 !important;
  font-style: normal !important;
  font-weight: 400 !important;
  margin: 0 !important;
  padding: 0 !important;
  max-width: 52ch;
}

/* ── Card counter ── */
.tl-outer-{{ _tc_id }} .tl-num {
  position: absolute;
  bottom: 2rem; left: 3rem;
  font-size: 10px !important;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: #ccc;
  margin: 0 !important; padding: 0 !important;
  font-style: normal !important;
}

/* ── Mobile: smaller height per step ── */
@media (max-width: 640px) {
  .tl-outer-{{ _tc_id }} { height: calc((var(--n) - 1) * 110vh + 100vh); }
  .tl-outer-{{ _tc_id }} .tl-h { font-size: clamp(24px, 7vw, 36px) !important; }
  .tl-outer-{{ _tc_id }} .tl-year { font-size: clamp(56px, 16vw, 100px) !important; }
  .tl-outer-{{ _tc_id }} .tl-p { font-size: 13px !important; }
}
</style>

<div class="tl-outer-{{ _tc_id }}" id="tl-outer-{{ _tc_id }}" data-n="{{ _tc_total }}">
  <div class="tl-sticky">

    <div class="tl-bar"><div class="tl-bar-fill" id="tl-bar-{{ _tc_id }}"></div></div>

    <div class="tl-cards" id="tl-cards-{{ _tc_id }}">
      <div class="tl-track" id="tl-track-{{ _tc_id }}">

        {%- assign _tc_card_idx = 0 -%}
        {%- for _i in (0..4) -%}
          {%- assign _tc_i0   = _i | times: 3 -%}
          {%- assign _tc_i1   = _tc_i0 | plus: 1 -%}
          {%- assign _tc_i2   = _tc_i0 | plus: 2 -%}
          {%- assign _tc_date = _tc_lines[_tc_i0] | strip -%}
          {%- assign _tc_head = _tc_lines[_tc_i1] | strip -%}
          {%- assign _tc_body = _tc_lines[_tc_i2] | strip -%}
          {%- if _tc_date == blank -%}{%- break -%}{%- endif -%}
          {%- assign _tc_card_idx = _tc_card_idx | plus: 1 -%}
          <div class="tl-card">
            <div class="tl-year">{{ _tc_date }}</div>
            <div class="tl-rule"></div>
            {%- if _tc_head != blank -%}<p class="tl-h">{{ _tc_head }}</p>{%- endif -%}
            {%- if _tc_body != blank -%}<p class="tl-p">{{ _tc_body }}</p>{%- endif -%}
          </div>
        {%- endfor -%}

      </div>
    </div>

    <span class="tl-num" id="tl-num-{{ _tc_id }}">01 / {{ _tc_total | prepend: '0' | slice: -2, 2 }}</span>

  </div>
</div>

<script>
(function(){
  var eid   = '{{ _tc_id }}';
  var outer = document.getElementById('tl-outer-' + eid);
  var cardsEl = document.getElementById('tl-cards-' + eid);
  var track = document.getElementById('tl-track-' + eid);
  var bar   = document.getElementById('tl-bar-'   + eid);
  var numEl = document.getElementById('tl-num-'   + eid);
  var cards = track ? track.querySelectorAll('.tl-card') : [];
  var N     = cards.length;
  if (!outer || !track || N === 0) return;

  var targetX = 0, animX = 0, raf;

  function fmt(n){ return (n < 10 ? '0' : '') + n; }

  function cardWidth(){ return cardsEl.clientWidth; }

  function setCardWidths(){
    var w = cardWidth();
    [].forEach.call(cards, function(c){ c.style.width = w + 'px'; });
  }

  function render(){
    track.style.transform = 'translateX(' + animX + 'px)';
    var cw  = cardWidth();
    var idx = Math.min(N - 1, Math.max(0, Math.round(-animX / cw)));
    if (numEl) numEl.textContent = fmt(idx + 1) + ' / ' + fmt(N);
    if (bar)   bar.style.width   = (N > 1 ? (-animX / ((N - 1) * cw)) * 100 : 0) + '%';
  }

  function loop(){
    animX += (targetX - animX) * 0.09;
    render();
    if (Math.abs(animX - targetX) > 0.2) raf = requestAnimationFrame(loop);
    else { animX = targetX; render(); }
  }

  function onScroll(){
    var rect     = outer.getBoundingClientRect();
    var scrolled = -rect.top;
    var range    = rect.height - window.innerHeight;
    var progress = Math.max(0, Math.min(1, scrolled / range));
    targetX = -progress * (N - 1) * cardWidth();
    cancelAnimationFrame(raf);
    raf = requestAnimationFrame(loop);
  }

  setCardWidths();
  render();
  window.addEventListener('scroll', onScroll, { passive: true });
  window.addEventListener('resize', function(){ setCardWidths(); onScroll(); });
  onScroll();
})();
</script>
