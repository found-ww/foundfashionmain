{% comment %}
  embed-timeline-cards.liquid
  Parses a multi_line_text_field into a horizontal drag timeline.

  Format — groups of 4 lines, up to 5 blocks:
    Line 1: caption / year
    Line 2: headline
    Line 3: body copy
    Line 4: blank (separator)
    (blank line 1 of a group = stop rendering further blocks)

  Usage: render 'embed-timeline-cards', content: string, id: string
{% endcomment %}

{%- assign _tc_id    = id | default: article.id -%}
{%- assign _tc_lines = content | split: "\n" -%}

{%- comment -%} Pre-count valid blocks so card numbering (01/03 etc.) is accurate {%- endcomment -%}
{%- assign _tc_total = 0 -%}
{%- for _i in (0..4) -%}
  {%- assign _tc_i0    = _i | times: 4 -%}
  {%- assign _tc_check = _tc_lines[_tc_i0] | strip | remove: "\r" -%}
  {%- if _tc_check != blank -%}{%- assign _tc_total = _tc_total | plus: 1 -%}{%- endif -%}
{%- endfor -%}

{%- if _tc_total == 0 -%}{%- break -%}{%- endif -%}

<style>
.TimelineCards__Block{display:flex;flex-direction:column;height:460px;overflow:hidden;border-top:.5px solid rgba(128,111,100,.15);border-bottom:.5px solid rgba(128,111,100,.15);margin:3rem 0 0;}
.tc-prog{height:1px;background:rgba(128,111,100,.12);flex-shrink:0;position:relative;}
.tc-prog-fill{position:absolute;top:0;left:0;height:100%;width:0;background:rgb(128,111,100);}
.tc-track-wrap{flex:1;overflow:hidden;cursor:grab;position:relative;}
.tc-track-wrap:active{cursor:grabbing;}
.tc-track{display:flex;height:100%;width:max-content;user-select:none;}
.tc-card{flex-shrink:0;width:clamp(280px,32vw,420px);height:100%;border-right:.5px solid rgba(128,111,100,.15);padding:3rem;display:flex;flex-direction:column;justify-content:flex-end;gap:1rem;background:#fff;transition:background .35s;position:relative;overflow:hidden;}
.tc-card:hover{background:rgb(245,243,239);}
.tc-card-num{position:absolute;top:2.5rem;right:2.5rem;font-size:9px;letter-spacing:.22em;text-transform:uppercase;color:rgb(128,111,100);opacity:.35;}
.tc-card-date{font-family:'Cormorant Garamond',Georgia,serif;font-size:clamp(28px,4vw,42px);font-weight:300;font-style:italic;color:rgb(128,111,100);line-height:1;transition:letter-spacing .4s cubic-bezier(.16,1,.3,1);}
.tc-card:hover .tc-card-date{letter-spacing:.03em;}
.tc-card-rule{width:28px;height:.5px;background:rgba(128,111,100,.2);transition:width .4s cubic-bezier(.16,1,.3,1),background .3s;}
.tc-card:hover .tc-card-rule{width:50px;background:rgb(128,111,100);}
.tc-card-tag{font-size:9px;letter-spacing:.2em;text-transform:uppercase;color:rgb(128,111,100);opacity:.5;transition:opacity .3s;}
.tc-card:hover .tc-card-tag{opacity:1;}
.tc-card-h{font-family:'Cormorant Garamond',Georgia,serif;font-size:clamp(18px,2.2vw,24px);font-weight:300;font-style:italic;color:rgb(18,16,14);line-height:1.15;transition:transform .45s cubic-bezier(.16,1,.3,1),color .3s;}
.tc-card:hover .tc-card-h{transform:translateX(7px);color:rgb(128,111,100);}
.tc-card-p{font-size:12px;line-height:1.78;color:rgb(148,123,105);}
.tc-card::after{content:'';position:absolute;bottom:0;left:0;right:0;height:1px;background:rgb(128,111,100);transform:scaleX(0);transform-origin:left;transition:transform .5s cubic-bezier(.16,1,.3,1);}
.tc-card:hover::after{transform:scaleX(1);}
.tc-foot{height:38px;border-top:.5px solid rgba(128,111,100,.15);flex-shrink:0;display:flex;align-items:center;gap:1.25rem;padding:0 2.5rem;}
.tc-foot-dot{width:5px;height:5px;border-radius:50%;background:rgba(128,111,100,.2);cursor:pointer;transition:background .2s,transform .2s;flex-shrink:0;}
.tc-foot-dot.active,.tc-foot-dot:hover{background:rgb(128,111,100);transform:scale(1.5);}
.tc-foot-hint{margin-left:auto;font-size:9px;letter-spacing:.18em;text-transform:uppercase;color:rgb(128,111,100);opacity:.3;}
@media screen and (max-width:640px){.TimelineCards__Block{height:auto;}.tc-track-wrap{overflow-x:auto;-webkit-overflow-scrolling:touch;height:380px;}.tc-card{width:84vw;padding:2.5rem 2rem;}}
</style>

<div class="tc-embed">

  <div class="TimelineCards__Block">

    <div class="tc-prog"><div class="tc-prog-fill" id="tc-pf-{{ _tc_id }}"></div></div>

    <div class="tc-track-wrap" id="tc-tw-{{ _tc_id }}">
      <div class="tc-track" id="tc-track-{{ _tc_id }}">

        {%- assign _tc_card_idx = 0 -%}
        {%- for _i in (0..4) -%}
          {%- assign _tc_i0   = _i | times: 4 -%}
          {%- assign _tc_i1   = _tc_i0 | plus: 1 -%}
          {%- assign _tc_i2   = _tc_i0 | plus: 2 -%}
          {%- assign _tc_date = _tc_lines[_tc_i0] | strip | remove: "\r" -%}
          {%- assign _tc_head = _tc_lines[_tc_i1] | strip | remove: "\r" -%}
          {%- assign _tc_body = _tc_lines[_tc_i2] | strip | remove: "\r" -%}
          {%- if _tc_date == blank -%}{%- break -%}{%- endif -%}
          {%- assign _tc_card_idx = _tc_card_idx | plus: 1 -%}
          {%- assign _tc_num   = _tc_card_idx | prepend: '0' | slice: -2, 2 -%}
          {%- assign _tc_tot_s = _tc_total    | prepend: '0' | slice: -2, 2 -%}
          <div class="tc-card">
            <span class="tc-card-num">{{ _tc_num }} / {{ _tc_tot_s }}</span>
            <div class="tc-card-date">{{ _tc_date }}</div>
            <div class="tc-card-rule"></div>
            {%- if _tc_head != blank -%}<h3 class="tc-card-h">{{ _tc_head }}</h3>{%- endif -%}
            {%- if _tc_body != blank -%}<p class="tc-card-p">{{ _tc_body }}</p>{%- endif -%}
          </div>
        {%- endfor -%}

      </div>
    </div>

    <div class="tc-foot">
      {%- for _i in (0.._tc_total) -%}
        {%- if _i < _tc_total -%}
          <div class="tc-foot-dot{% if _i == 0 %} active{% endif %}" data-i="{{ _i }}"></div>
        {%- endif -%}
      {%- endfor -%}
      <span class="tc-foot-hint">Drag to explore</span>
    </div>

  </div>

</div>

<script>
(function(){
  var tcId  = '{{ _tc_id }}';
  var tw    = document.getElementById('tc-tw-'    + tcId);
  var track = document.getElementById('tc-track-' + tcId);
  var pf    = document.getElementById('tc-pf-'   + tcId);
  if (!tw || !track) return;

  var dots  = tw.closest('.TimelineCards__Block').querySelectorAll('.tc-foot-dot');
  var cards = track.querySelectorAll('.tc-card');
  var isDragging = false, startX = 0, tx = 0, animTx = 0, raf;

  function lerp(a, b, n) { return a + (b - a) * n; }
  function maxTx() { return -(track.scrollWidth - tw.clientWidth); }
  function clamp(v) { return Math.max(maxTx(), Math.min(0, v)); }

  function render() {
    track.style.transform = 'translateX(' + animTx + 'px)';
    var max = -maxTx();
    pf.style.width = (max > 0 ? Math.min(100, (-animTx / max) * 100) : 0) + '%';
    var cw  = cards[0] ? cards[0].offsetWidth : 1;
    var idx = Math.round(-animTx / cw);
    dots.forEach(function(d, i) { d.classList.toggle('active', i === idx); });
  }

  function loop() {
    animTx = lerp(animTx, tx, .1);
    if (Math.abs(animTx - tx) > 0.1) { render(); raf = requestAnimationFrame(loop); }
    else { animTx = tx; render(); }
  }

  tw.addEventListener('mousedown', function(e) {
    isDragging = true; startX = e.pageX; cancelAnimationFrame(raf);
  });
  window.addEventListener('mousemove', function(e) {
    if (!isDragging) return;
    tx = clamp(tx + (e.pageX - startX)); startX = e.pageX; render();
  });
  window.addEventListener('mouseup', function() { isDragging = false; });

  tw.addEventListener('touchstart', function(e) {
    startX = e.touches[0].pageX; cancelAnimationFrame(raf);
  }, { passive: true });
  tw.addEventListener('touchmove', function(e) {
    tx = clamp(tx + (e.touches[0].pageX - startX)); startX = e.touches[0].pageX; render();
  }, { passive: true });

  dots.forEach(function(d) {
    d.addEventListener('click', function() {
      tx = clamp(-(cards[0] ? cards[0].offsetWidth * parseInt(d.dataset.i) : 0));
      cancelAnimationFrame(raf); raf = requestAnimationFrame(loop);
    });
  });

  window.addEventListener('resize', function() { tx = clamp(tx); render(); });
  render();
})();
</script>
